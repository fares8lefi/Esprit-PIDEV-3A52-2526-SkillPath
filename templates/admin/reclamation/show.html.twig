{% extends 'base.html.twig' %}

{% block title %}Manage Reclamation{% endblock %}

{% block body %}
<div class="min-h-screen bg-neutral-900 text-white p-8">
    <div class="max-w-4xl mx-auto">
        <a href="{{ path('app_admin_reclamation_index') }}" class="inline-flex items-center mb-6 text-neutral-400 hover:text-white transition-colors">
            &larr; Back to list
        </a>

        <!-- Reclamation Details -->
        <div class="bg-neutral-800 rounded-3xl border border-neutral-700 shadow-xl overflow-hidden mb-8">
            <div class="px-8 py-6 border-b border-neutral-700 flex justify-between items-center">
                <div>
                    <h1 class="text-2xl font-bold text-white mb-1">{{ reclamation.sujet }}</h1>
                    <p class="text-sm text-neutral-400">By: {{ reclamation.user.username }} ({{ reclamation.user.email }})</p>
                </div>
                
                 {{ form_start(status_form, {'attr': {'class': 'flex items-center space-x-2'}}) }}
                    {{ form_widget(status_form.statut, {'attr': {'class': 'bg-neutral-700 text-white border-none rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm'}}) }}
                    <button class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-1 px-3 rounded text-sm transition-colors">Update Status</button>
                    {{ form_errors(status_form.statut) }}
                {{ form_end(status_form) }}
            </div>
            <div class="px-8 py-6">
                <p class="text-neutral-300 whitespace-pre-line">{{ reclamation.description }}</p>
            </div>
            <div class="px-8 py-4 bg-neutral-900/50 border-t border-neutral-700 flex justify-end">
                <form method="post" action="{{ path('app_admin_reclamation_delete', {'id': reclamation.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
                    <button class="text-red-500 hover:text-red-400 text-sm font-bold">Delete Reclamation</button>
                </form>
            </div>
        </div>

        <!-- Responses -->
        <div class="space-y-6">
            <h2 class="text-xl font-bold text-white">Discussion</h2>
            
            {% for response in reclamation.reponses %}
                <div class="bg-neutral-800 rounded-3xl p-6 border {% if 'ADMIN' in response.user.roles %}border-red-500/50{% else %}border-blue-500/50{% endif %}">
                    <div class="flex justify-between items-start mb-2">
                        <span class="font-bold {% if 'ADMIN' in response.user.roles %}text-red-400{% else %}text-blue-400{% endif %}">
                            {{ response.user.username }} ({{ response.user.email }}) {% if 'ADMIN' in response.user.roles %}(Admin){% endif %}
                        </span>
                    </div>
                    <p class="text-neutral-300 whitespace-pre-line">{{ response.message }}</p>
                </div>
            {% else %}
                <p class="text-neutral-500 italic">No responses yet.</p>
            {% endfor %}

            <!-- Add Response Form -->
            <div class="bg-neutral-800 rounded-3xl border border-neutral-700 shadow-xl p-8 mt-6">
                <h3 class="text-lg font-bold text-white mb-4">Add Official Response</h3>
                {{ form_start(response_form) }}
                    <div class="mb-4">
                        {{ form_widget(response_form.message, {'attr': {'class': 'w-full bg-neutral-900 border-neutral-700 text-white rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 p-4', 'placeholder': 'Type your response here...'}}) }}
                        {{ form_errors(response_form.message) }}
                    </div>
                    <button class="bg-gradient-to-r from-red-600 to-orange-600 hover:from-red-500 hover:to-orange-500 text-white font-bold py-3 px-6 rounded-xl transition-all shadow-lg transform hover:scale-105">Post Response</button>
                {{ form_end(response_form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
