{% extends 'base.html.twig' %}

{% block title %}Admin Reclamations{% endblock %}

{% block body %}
<div class="min-h-screen bg-neutral-900 text-white p-8">
    <div class="max-w-7xl mx-auto">
        <header class="flex justify-between items-center mb-12">
            <div>
                <h1 class="text-4xl font-extrabold bg-gradient-to-r from-red-500 to-orange-500 bg-clip-text text-transparent">Reclamations Management</h1>
                <p class="text-neutral-400 mt-2">Manage user complaints</p>
            </div>
            <a href="{{ path('app_admin_dashboard') }}" class="px-6 py-2 bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 rounded-xl transition-all">Back to Dashboard</a>
        </header>

        <div class="bg-neutral-800 rounded-3xl border border-neutral-700 shadow-xl overflow-hidden">
            <table class="min-w-full divide-y divide-neutral-700">
                <thead class="bg-neutral-900">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-neutral-400 uppercase tracking-wider">Id</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-neutral-400 uppercase tracking-wider">User</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-neutral-400 uppercase tracking-wider">Subject</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-neutral-400 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-neutral-400 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-neutral-700">
                {% for reclamation in reclamations %}
                    <tr>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-neutral-300">{{ reclamation.id }}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-neutral-300">{{ reclamation.user.email }}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">{{ reclamation.sujet }}</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                {% if reclamation.statut == 'Pending' %}bg-yellow-900 text-yellow-200{% elseif reclamation.statut == 'Resolved' %}bg-green-900 text-green-200{% else %}bg-neutral-700 text-neutral-300{% endif %}">
                                {{ reclamation.statut }}
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <a href="{{ path('app_admin_reclamation_show', {'id': reclamation.id}) }}" class="text-indigo-400 hover:text-indigo-300">Manage</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-6 py-4 text-center text-neutral-500">No reclamations found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
