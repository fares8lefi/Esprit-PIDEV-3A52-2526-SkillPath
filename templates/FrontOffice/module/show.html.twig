{% extends 'base.html.twig' %}

{% block title %}{{ module.name }} - {{ module.cours.titre }}{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark pb-20">
    <!-- Navigation Bar -->
    <nav class="glass border-b border-slate-200/30 dark:border-white/5 sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <a href="{{ path('app_home') }}" class="flex items-center gap-3 group">
                    <div class="w-9 h-9 gradient-primary rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/20 group-hover:scale-110 transition-transform">
                        <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-5 h-5 invert brightness-0">
                    </div>
                    <span class="text-lg font-black text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
                </a>
                <div class="flex items-center gap-4">
                    <a href="{{ path('app_front_office_cours_show', {id: module.cours.id}) }}" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors">
                        <span class="hidden md:inline">Retour au cours : </span>{{ module.cours.titre }}
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <!-- Module Header -->
        <div class="glass-card rounded-3xl overflow-hidden mb-8 animate-fade-up">
            <div class="gradient-primary px-8 py-10 relative overflow-hidden">
                <div class="absolute right-0 top-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
                
                <div class="relative z-10">
                    <div class="flex flex-wrap items-center gap-3 mb-4">
                        <span class="badge bg-white/20 backdrop-blur-md text-white border-none uppercase tracking-widest text-[10px]">{{ module.type|default('PARTIE') }}</span>
                        <a href="{{ path('app_front_office_cours_show', {id: module.cours.id}) }}" class="badge bg-white/10 hover:bg-white/30 transition-colors backdrop-blur-md text-white border-none uppercase tracking-widest text-[10px] flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                            {{ module.cours.titre }}
                        </a>
                    </div>
                    <h1 class="text-3xl lg:text-4xl font-black text-white mb-4 tracking-tight">{{ module.name }}</h1>
                    <div class="flex items-center gap-6 text-white/80 text-sm font-medium">
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            <span>Ajouté le {{ module.dateCreation|date('d M Y') }}</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-8 lg:p-10">
                <div class="prose prose-slate dark:prose-invert max-w-none">
                    <h2 class="text-xl font-black text-slate-900 dark:text-white mb-6 flex items-center gap-3">
                        <span class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        </span>
                        Contenu du Module
                    </h2>
                    
                    {% if module.description %}
                        <div class="mb-8 p-6 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-slate-100 dark:border-white/5 italic text-slate-600 dark:text-slate-400">
                            {{ module.description|nl2br }}
                        </div>
                    {% endif %}

                    <div class="text-slate-600 dark:text-slate-400 leading-relaxed whitespace-pre-wrap text-lg">
                        {{ module.contenu|default('Contenu à venir...') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
