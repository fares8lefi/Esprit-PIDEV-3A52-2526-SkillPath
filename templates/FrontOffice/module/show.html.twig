{% extends 'base.html.twig' %}

{% block title %}{{ module.title }} - {{ module.course.title }}{% endblock %}

{% block body %}
<div class="flex h-screen overflow-hidden bg-slate-50 dark:bg-[#05070A] text-slate-800 dark:text-slate-200 transition-colors duration-500">
    {# Sidebar Navigation #}
    <aside class="w-80 h-screen bg-white dark:bg-[#0B0F1A] border-r border-slate-200 dark:border-white/5 flex flex-col z-20 transition-all duration-300 hidden md:flex">
        <div class="p-6 border-b border-slate-200 dark:border-white/5 bg-slate-50/50 dark:bg-black/20">
            <!-- Home & Back Navigation -->
            <div class="flex flex-col gap-4 mb-6">
                <a href="{{ path('app_home') }}" class="flex items-center gap-3 group">
                     <div class="w-10 h-10 rounded-xl bg-white dark:bg-white/5 shadow-sm border border-slate-100 dark:border-white/5 flex items-center justify-center text-slate-400 group-hover:text-primary group-hover:scale-105 transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    </div>
                    <div>
                        <span class="block text-xs font-bold uppercase tracking-widest text-slate-500 group-hover:text-primary transition-colors">Accueil</span>
                        <span class="text-[10px] text-slate-400 font-medium">Retourner au site</span>
                    </div>
                </a>

                <a href="{{ path('front_course_show', {id: module.course.id}) }}" class="flex items-center gap-3 group">
                    <div class="w-10 h-10 rounded-xl bg-white dark:bg-white/5 shadow-sm border border-slate-100 dark:border-white/5 flex items-center justify-center text-slate-400 group-hover:text-primary group-hover:scale-105 transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </div>
                    <div>
                        <span class="block text-xs font-bold uppercase tracking-widest text-slate-500 group-hover:text-primary transition-colors">Retour au Cours</span>
                        <span class="text-[10px] text-slate-400 font-medium">Vue d'ensemble</span>
                    </div>
                </a>
            </div>
            
            <h1 class="text-sm font-bold text-slate-800 dark:text-slate-400 uppercase tracking-widest mb-1">{{ module.course.title }}</h1>
            <div class="w-full bg-slate-200 dark:bg-white/5 h-1.5 rounded-full overflow-hidden mt-3">
                 {% set totalModules = module.course.modules|length %}
                 {% set currentMax = userCourseView.maxModuleReached|default(0) %}
                 {% set progress = totalModules > 0 ? (currentMax / totalModules * 100)|round : 0 %}
                <div class="bg-primary h-full shadow-[0_0_10px_rgba(124,58,237,0.5)] transition-all duration-500" style="width: {{ progress }}%"></div>
            </div>
            <p class="text-[10px] text-slate-500 mt-2 font-bold uppercase tracking-widest">{{ progress }}% Complété</p>
        </div>

        <nav class="flex-grow overflow-y-auto py-6 px-4 custom-scrollbar">
            {# Quizzes Section #}
            {% if module.course.quizzes|length > 0 %}
                <div class="mb-6">
                    <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-2 mb-3 flex items-center gap-2">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                        Évaluations
                    </h3>
                    <div class="space-y-2">
                        {% for quiz in module.course.quizzes %}
                            <a href="{{ path('app_front_office_quiz_take', {id: quiz.id}) }}" 
                               class="flex items-center gap-3 p-3 rounded-xl transition-all group hover:bg-purple-50 dark:hover:bg-purple-500/10 border border-transparent hover:border-purple-200 dark:hover:border-purple-500/20 text-slate-500 hover:text-purple-600 dark:text-slate-400 dark:hover:text-purple-400">
                                <div class="w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs bg-purple-100 dark:bg-purple-500/20 text-purple-600 dark:text-purple-300">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                </div>
                                <div class="flex-grow min-w-0">
                                    <p class="text-xs font-bold truncate">{{ quiz.titre }}</p>
                                    <p class="text-[10px] opacity-60">{{ quiz.questions|length }} Questions • {{ quiz.duree }} min</p>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                    <div class="w-full h-px bg-slate-200 dark:bg-white/5 my-4"></div>
                </div>
            {% endif %}

            <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest px-2 mb-3 flex items-center gap-2">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                Modules du cours
            </h3>
            <div class="space-y-2">
                {% for m in module.course.modules %}
                    {% set isActive = m.id == module.id %}
                    <a href="{{ path('app_front_office_module_show', {id: m.id}) }}" 
                       class="flex items-center gap-4 p-4 rounded-2xl transition-all group {{ isActive ? 'bg-primary/10 border border-primary/20 text-primary dark:text-white' : 'hover:bg-slate-100 dark:hover:bg-white/5 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white' }}">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs {{ isActive ? 'bg-primary text-white shadow-lg shadow-primary/20' : 'bg-slate-100 dark:bg-white/5 group-hover:bg-slate-200 dark:group-hover:bg-white/10' }}">
                            {{ loop.index }}
                        </div>
                        <div class="flex-grow min-w-0">
                            <p class="text-sm font-bold truncate">{{ m.title }}</p>
                            <div class="flex items-center gap-2 mt-0.5">
                                <span class="text-[10px] uppercase opacity-50">{{ m.type }}</span>
                                {% if isActive %}
                                    <span class="text-[9px] text-primary font-bold animate-pulse">• En cours</span>
                                {% endif %}
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </nav>
    </aside>

    {# Main Content #}
    <main class="flex-grow flex flex-col relative bg-slate-50 dark:bg-black h-screen overflow-hidden">
        {# Header #}
        <header class="h-16 flex items-center justify-between px-6 md:px-8 glass border-b border-slate-200 dark:border-white/5 z-10 sticky top-0">
            <div class="flex items-center gap-4 text-sm font-bold text-slate-500">
                <span class="hidden md:inline">{{ module.course.title }}</span>
                <span class="hidden md:inline text-slate-300 dark:text-white/10">•</span>
                <span class="text-slate-900 dark:text-white">{{ module.title }}</span>
            </div>
            <div class="flex gap-3">
                 <a href="{{ path('front_course_show', {id: module.course.id}) }}" class="md:hidden w-10 h-10 rounded-xl glass flex items-center justify-center text-slate-400">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                </a>
            </div>
        </header>

        {# Scrollable Content #}
        <div class="flex-grow overflow-y-auto p-6 md:p-12 mesh-light dark:mesh-dark custom-scrollbar transition-colors duration-500">
            <div class="max-w-4xl mx-auto animate-fade-up pb-20">
                {# Video/Media Container #}
                {% if module.type == 'video' %}
                    <div class="aspect-video bg-black rounded-[2rem] border border-slate-200 dark:border-white/10 shadow-2xl mb-10 overflow-hidden relative group">
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-20 h-20 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center hover:scale-110 transition-transform cursor-pointer">
                                <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>
                        {# Placeholder for actual video player implementation #}
                        <img src="{{ asset('uploads/modules/' ~ module.course.image) }}" class="w-full h-full object-cover opacity-50" onerror="this.src='https://ui-avatars.com/api/?name=Video&background=random'">
                    </div>
                {% endif %}

                {# Title & Meta #}
                <div class="mb-10 flex flex-col md:flex-row md:items-center gap-8">
                    {% if module.image %}
                        <div class="w-24 h-24 md:w-32 md:h-32 rounded-3xl overflow-hidden glass border border-white/10 shadow-xl shrink-0">
                            <img src="{{ asset('uploads/modules/' ~ module.image) }}" class="w-full h-full object-cover">
                        </div>
                    {% endif %}
                    <div>
                        <span class="badge badge-purple glass !bg-primary/10 dark:!bg-primary/20 !text-primary dark:!text-white !backdrop-blur-md mb-4">{{ module.type }}</span>
                        <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-6 leading-tight">{{ module.title }}</h1>
                        <div class="flex items-center gap-4 text-sm text-slate-500 dark:text-slate-400 font-medium">
                            <div class="flex items-center gap-2">
                                <span>{{ module.level|default('Standard') }}</span>
                            </div>
                            <div class="w-1 h-1 rounded-full bg-slate-300 dark:bg-white/20"></div>
                            <span>Ajouté le {{ module.createdAt|date('d M Y') }}</span>
                        </div>
                    </div>
                </div>

                {# Description & Content #}
                <div class="prose prose-lg prose-slate dark:prose-invert max-w-none leading-relaxed mb-16">
                     {% if module.description %}
                        <div class="bg-white dark:bg-white/5 border-l-4 border-primary p-6 rounded-r-xl mb-10 italic text-slate-600 dark:text-slate-300 shadow-sm">
                            {{ module.description|nl2br }}
                        </div>
                    {% endif %}
                    
                    <div class="text-slate-700 dark:text-slate-300">
                        {{ module.content|default('Contenu du module...')|nl2br }}
                    </div>

                    {% if module.document %}
                        {% set fileExt = module.document|split('.')|last|lower %}
                        {% set docUrl  = asset('uploads/modules/' ~ module.document) %}
                        {% set isPdf   = fileExt == 'pdf' %}
                        {% set fileLabel = isPdf ? 'Fichier PDF' : 'Document Word' %}

                        {# ──────────── PROFESSIONAL DOCUMENT READER ──────────── #}
                        <div class="mt-16" id="doc-reader">

                            {# Section pill divider #}
                            <div class="flex items-center gap-4 mb-6">
                                <div class="h-px flex-1 bg-gradient-to-r from-transparent via-slate-200 dark:via-white/10 to-transparent"></div>
                                <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-black uppercase tracking-widest">Ressource du module</span>
                                <div class="h-px flex-1 bg-gradient-to-r from-slate-200 dark:from-white/10 to-transparent"></div>
                            </div>

                            {# Browser-style reader shell #}
                            <div id="reader-shell" class="rounded-3xl overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.22)] border border-slate-200 dark:border-white/5 bg-white dark:bg-[#0d111c] transition-all duration-500">

                                {# ── Chrome toolbar ── #}
                                <div class="flex items-center justify-between px-5 py-3 bg-slate-50 dark:bg-[#0B0F1A] border-b border-slate-200 dark:border-white/5 select-none">

                                    <div class="flex items-center gap-4">
                                        {# Traffic lights #}
                                        <div class="flex items-center gap-1.5">
                                            <div onclick="collapseReader()" title="Réduire" class="w-3 h-3 rounded-full bg-red-400/70 hover:bg-red-500 cursor-pointer transition-colors"></div>
                                            <div class="w-3 h-3 rounded-full bg-amber-400/70 hover:bg-amber-400 cursor-pointer transition-colors"></div>
                                            <div onclick="toggleReaderFullscreen()" title="Plein écran" class="w-3 h-3 rounded-full bg-green-400/70 hover:bg-green-400 cursor-pointer transition-colors"></div>
                                        </div>

                                        <div class="w-px h-5 bg-slate-200 dark:bg-white/10"></div>

                                        {# File chip #}
                                        <div class="flex items-center gap-2.5 px-3 py-1.5 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/5">
                                            <svg class="w-4 h-4 {{ isPdf ? 'text-red-400' : 'text-blue-400' }} shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
                                            <span class="text-xs font-bold text-slate-600 dark:text-slate-300 max-w-[180px] truncate">{{ module.document }}</span>
                                            <span class="text-[10px] font-black px-1.5 py-0.5 rounded-md {{ isPdf ? 'bg-red-100 dark:bg-red-500/20 text-red-500' : 'bg-blue-100 dark:bg-blue-500/20 text-blue-400' }} uppercase tracking-widest">{{ fileExt }}</span>
                                        </div>
                                    </div>

                                    {# Action buttons #}
                                    <div class="flex items-center gap-1">
                                        <button onclick="resizeReader(-150)" title="Réduire hauteur" class="w-8 h-8 rounded-xl flex items-center justify-center text-slate-400 hover:text-primary hover:bg-primary/10 transition-all">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/></svg>
                                        </button>
                                        <button onclick="resizeReader(150)" title="Agrandir hauteur" class="w-8 h-8 rounded-xl flex items-center justify-center text-slate-400 hover:text-primary hover:bg-primary/10 transition-all">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                                        </button>
                                        <div class="w-px h-5 bg-slate-200 dark:bg-white/10 mx-1"></div>
                                        <a href="{{ docUrl }}" download title="Télécharger" class="w-8 h-8 rounded-xl flex items-center justify-center text-slate-400 hover:text-primary hover:bg-primary/10 transition-all">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                                        </a>
                                        <button onclick="toggleReaderFullscreen()" title="Plein écran" class="w-8 h-8 rounded-xl flex items-center justify-center text-slate-400 hover:text-primary hover:bg-primary/10 transition-all">
                                            <svg id="icon-expand" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m4-4l-5 5m11-1v4m0 0h-4m-4-4l5 5"/></svg>
                                            <svg id="icon-compress" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9V4m0 0H4m5 0L3 10m12-1V4m0 0h-5m5 0l6 6M9 15v5m0 0H4m5 0l-6-6m17 6h-5m5 0l-6-6"/></svg>
                                        </button>
                                    </div>
                                </div>

                                {# Progress bar #}
                                <div class="h-0.5 bg-slate-100 dark:bg-white/5">
                                    <div id="reader-progress" class="h-full bg-gradient-to-r from-primary to-violet-400 transition-all duration-1000 ease-out" style="width:60%"></div>
                                </div>

                                {# Iframe area #}
                                <div id="reader-frame-wrap" class="relative bg-white dark:bg-[#07090F] transition-all duration-500" style="height:75vh;">

                                    {# Spinner #}
                                    <div id="reader-loader" class="absolute inset-0 z-20 flex flex-col items-center justify-center gap-5 bg-white dark:bg-[#07090F]">
                                        <div class="relative w-16 h-16">
                                            <div class="absolute inset-0 rounded-full border-4 border-primary/20"></div>
                                            <div class="absolute inset-0 rounded-full border-4 border-transparent border-t-primary animate-spin"></div>
                                            <div class="absolute inset-2 rounded-full border-4 border-transparent border-b-violet-400 animate-spin" style="animation-direction:reverse;animation-duration:.8s"></div>
                                        </div>
                                        <div class="text-center">
                                            <p class="text-sm font-bold text-slate-700 dark:text-white">Ouverture du document</p>
                                            <p class="text-xs text-slate-400 mt-1">{{ fileLabel }} en cours de chargement…</p>
                                        </div>
                                    </div>

                                    {% if isPdf %}
                                        <iframe id="doc-frame"
                                            src="{{ docUrl }}#navpanes=0&scrollbar=1&view=FitH&zoom=page-width"
                                            class="w-full h-full border-none opacity-0 transition-opacity duration-700"
                                            onload="onDocLoaded()" allow="fullscreen autoplay"></iframe>
                                    {% else %}
                                        <iframe id="doc-frame"
                                            src="https://docs.google.com/viewer?url={{ absolute_url(docUrl)|url_encode }}&embedded=true"
                                            class="w-full h-full border-none opacity-0 transition-opacity duration-700"
                                            onload="onDocLoaded()"></iframe>
                                    {% endif %}
                                </div>

                                {# Status bar #}
                                <div class="flex items-center justify-between px-5 py-2 bg-slate-50 dark:bg-[#0B0F1A] border-t border-slate-200 dark:border-white/5 text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                                    <span id="reader-status">Chargement…</span>
                                    <span>{{ isPdf ? 'PDF Reader' : 'Google Docs Viewer' }}</span>
                                </div>
                            </div>
                        </div>

                        <script>
                        (function(){
                            var isFS  = false;
                            var curH  = window.innerHeight * 0.75;

                            window.onDocLoaded = function() {
                                document.getElementById('reader-loader').style.display = 'none';
                                var f = document.getElementById('doc-frame');
                                f.style.opacity = '1';
                                document.getElementById('reader-status').textContent = 'Document prêt ✓';
                                var bar = document.getElementById('reader-progress');
                                bar.style.width = '100%';
                                setTimeout(function(){ bar.style.opacity='0'; }, 1500);
                            };

                            window.resizeReader = function(delta) {
                                var wrap = document.getElementById('reader-frame-wrap');
                                curH = Math.max(320, Math.min(curH + delta, window.innerHeight * 0.95));
                                wrap.style.height = curH + 'px';
                            };

                            window.toggleReaderFullscreen = function() {
                                var shell = document.getElementById('reader-shell');
                                var wrap  = document.getElementById('reader-frame-wrap');
                                isFS = !isFS;
                                if (isFS) {
                                    shell.classList.add('fixed','inset-0','z-[999]','!rounded-none');
                                    wrap.style.height = 'calc(100vh - 68px)';
                                } else {
                                    shell.classList.remove('fixed','inset-0','z-[999]','!rounded-none');
                                    wrap.style.height = curH + 'px';
                                }
                                document.getElementById('icon-expand').classList.toggle('hidden', isFS);
                                document.getElementById('icon-compress').classList.toggle('hidden', !isFS);
                            };

                            window.collapseReader = function() {
                                var wrap = document.getElementById('reader-frame-wrap');
                                var collapsed = wrap.style.height === '0px';
                                wrap.style.height = collapsed ? curH + 'px' : '0px';
                            };

                            document.addEventListener('keydown', function(e){
                                if (e.key === 'Escape' && isFS) window.toggleReaderFullscreen();
                            });
                        })();
                        </script>
                    {% endif %}


                {# Navigation Footer #}
                <div class="flex justify-between items-center pt-10 border-t border-slate-200 dark:border-white/5">
                    {% set prevModule = null %}
                    {% set nextModule = null %}
                    {% set found = false %}
                    {% for m in module.course.modules %}
                        {% if m.id == module.id %}
                            {% set found = true %}
                        {% elseif not found %}
                            {% set prevModule = m %}
                        {% elseif found and nextModule is null %}
                            {% set nextModule = m %}
                        {% endif %}
                    {% endfor %}

                    {# Previous Button #}
                    <div>
                        {% if prevModule %}
                            <a href="{{ path('app_front_office_module_show', {'id': prevModule.id}) }}" class="flex items-center gap-3 group text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">
                                <div class="w-12 h-12 rounded-2xl glass border border-slate-200 dark:border-white/5 flex items-center justify-center group-hover:bg-slate-100 dark:group-hover:bg-white/10 transition-all">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                                </div>
                                <div class="hidden sm:block">
                                    <p class="text-[10px] uppercase font-bold tracking-widest opacity-50">Précédent</p>
                                    <p class="font-bold text-sm">{{ prevModule.title }}</p>
                                </div>
                            </a>
                        {% endif %}
                    </div>

                    {# Next / Finish Button #}
                    <div>
                        {% if nextModule %}
                             <a href="{{ path('app_front_office_module_show', {'id': nextModule.id}) }}" class="flex items-center gap-3 group text-right text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">
                                <div class="hidden sm:block">
                                    <p class="text-[10px] uppercase font-bold tracking-widest opacity-50">Suivant</p>
                                    <p class="font-bold text-sm">{{ nextModule.title }}</p>
                                </div>
                                <div class="w-12 h-12 rounded-2xl glass border border-slate-200 dark:border-white/5 flex items-center justify-center group-hover:bg-slate-100 dark:group-hover:bg-white/10 transition-all">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </div>
                            </a>
                        {% else %}
                            <button onclick="openCompletionModal()" class="btn-primary !py-3 !px-8 flex items-center gap-2 shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:scale-105 transition-all">
                                <span>Terminer le cours</span>
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            </button>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

{# Completion Modal #}
<div id="completionModal" class="fixed inset-0 z-50 hidden">
    {# Backdrop #}
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity opacity-0" id="modalBackdrop" onclick="closeCompletionModal()"></div>
    
    {# Modal Content #}
    <div class="absolute inset-0 flex items-center justify-center p-4">
        <div class="bg-[#0B0F1A] border border-white/10 rounded-[2.5rem] w-full max-w-lg p-8 transform scale-95 opacity-0 transition-all duration-300 shadow-2xl shadow-primary/20 relative" id="modalContent">
            
            <div class="absolute -top-20 left-1/2 -translate-x-1/2">
                <div class="w-40 h-40 bg-primary/20 rounded-full blur-3xl animate-pulse"></div>
            </div>

            <div class="text-center relative z-10">
                <div class="w-20 h-20 rounded-full gradient-primary mx-auto flex items-center justify-center shadow-lg shadow-primary/40 mb-6">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                
                <h2 class="text-3xl font-black text-white mb-2">Félicitations !</h2>
                <p class="text-slate-400 font-medium mb-8">Vous avez terminé le cours <span class="text-white font-bold">{{ module.course.title }}</span> avec succès.</p>

                <div class="grid grid-cols-2 gap-4 mb-8">
                    <div class="glass p-4 rounded-2xl border border-white/5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Modules</p>
                        <p class="text-2xl font-black text-white">{{ module.course.modules|length }}</p>
                    </div>
                    <div class="glass p-4 rounded-2xl border border-white/5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">XP Gagné</p>
                        <p class="text-2xl font-black text-primary">+500</p>
                    </div>
                </div>

                <div class="space-y-3">
                    <a href="{{ path('front_course_index') }}" class="btn-primary w-full justify-center !py-4 shadow-lg shadow-primary/20">
                        Retour à la Bibliothèque
                    </a>
                    <button onclick="closeCompletionModal()" class="w-full py-4 text-sm font-bold text-slate-400 hover:text-white transition-colors">
                        Rester sur cette page
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

{# FLOATING CHATBOT WIDGET #}
<div id="ai-chat-widget" class="fixed bottom-6 right-6 z-[100] flex flex-col items-end">
    {# Chat Window #}
    <div id="ai-chat-window" class="hidden w-[380px] h-[550px] bg-white rounded-3xl shadow-2xl flex flex-col overflow-hidden border border-gray-100 mb-4 animate-fade-in-up origin-bottom-right">
        {# Chat Header #}
        <div class="h-16 px-6 bg-[#1E88E5] flex items-center justify-between shadow-lg">
            <div class="flex items-center gap-3 text-white">
                <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center backdrop-blur-md">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <div>
                    <h2 class="font-bold text-sm">Assistant SkillPath</h2>
                    <p class="text-[10px] text-white/70">En ligne • IA</p>
                </div>
            </div>
            <button id="close-chat" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        {# Chat Messages #}
        <div id="chat-messages" class="flex-grow p-6 space-y-4 overflow-y-auto custom-scrollbar scroll-smooth bg-gray-50/50">
            <div class="flex flex-col items-center justify-center h-full text-center text-gray-400 opacity-40 px-10" id="empty-state">
                <p class="text-xs font-medium">Une question sur ce module ? Je suis là !</p>
            </div>
        </div>

        {# Chat Input Area #}
        <div class="p-4 bg-white border-t border-gray-100">
            <form id="tutor-form">
                <div class="flex gap-2 overflow-x-auto pb-3 mb-3 no-scrollbar">
                        <span class="mode-chip whitespace-nowrap px-3 py-1.5 rounded-full text-[10px] font-bold uppercase bg-[#1E88E5] text-white cursor-pointer" data-value="expliquer">💡 Expliquer</span>
                        <span class="mode-chip whitespace-nowrap px-3 py-1.5 rounded-full text-[10px] font-bold uppercase bg-gray-100 text-gray-500 cursor-pointer" data-value="resumer">📝 Résumer</span>
                        <span class="mode-chip whitespace-nowrap px-3 py-1.5 rounded-full text-[10px] font-bold uppercase bg-gray-100 text-gray-500 cursor-pointer" data-value="quiz">❓ Quiz</span>
                </div>
                
                <select id="mode" class="hidden"><option value="expliquer" selected>expliquer</option></select>
                <textarea id="context" class="hidden">{{ module.title }} : {{ module.content|striptags|slice(0, 1000) }}</textarea>

                <div class="relative flex items-center">
                    <input type="text" id="question" class="w-full bg-gray-50 border-gray-100 rounded-2xl py-3.5 pl-4 pr-12 text-sm text-gray-800 focus:ring-2 focus:ring-blue-200" placeholder="Une question ?" autocomplete="off">
                    <button type="submit" id="submit-btn" class="absolute right-1.5 p-2 bg-[#1E88E5] text-white rounded-xl shadow-lg">
                        <svg id="btn-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# Toggle Button #}
    <button id="toggle-chat" class="w-16 h-16 bg-[#1E88E5] text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 transition-all">
        <svg id="toggle-open-icon" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
    </button>
</div>

<style>
    @keyframes fade-in-up { from { opacity: 0; transform: translateY(20px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .animate-fade-in-up { animation: fade-in-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const chatWindow = document.getElementById('ai-chat-window');
        const toggleBtn = document.getElementById('toggle-chat');
        const closeBtn = document.getElementById('close-chat');
        const form = document.getElementById('tutor-form');
        const chatMessages = document.getElementById('chat-messages');
        const questionInput = document.getElementById('question');
        const contextInput = document.getElementById('context');
        const modeSelect = document.getElementById('mode');

        const toggleChat = () => chatWindow.classList.toggle('hidden');
        if(toggleBtn) toggleBtn.addEventListener('click', toggleChat);
        if(closeBtn) closeBtn.addEventListener('click', toggleChat);

        // Mode chips logic
        const modeChips = document.querySelectorAll('.mode-chip');
        modeChips.forEach(chip => {
            chip.addEventListener('click', () => {
                modeSelect.value = chip.dataset.value;
                modeChips.forEach(c => {
                    c.classList.remove('bg-[#1E88E5]', 'text-white');
                    c.classList.add('bg-gray-100', 'text-gray-500');
                });
                chip.classList.remove('bg-gray-100', 'text-gray-500');
                chip.classList.add('bg-[#1E88E5]', 'text-white');
            });
        });

        function addMessage(text, isUser = false) {
            document.getElementById('empty-state')?.remove();
            const div = document.createElement('div');
            div.className = `flex ${isUser ? 'justify-end' : 'justify-start'} animate-fade-in-up items-end gap-2`;
            const content = `<div class="${isUser ? 'bg-[#1E88E5] text-white' : 'bg-white border text-gray-800'} p-3.5 rounded-2xl max-w-[85%] text-xs leading-relaxed overflow-hidden break-words"><div class="prose prose-sm prose-p:my-1 prose-ul:my-1 prose-li:my-0">${text}</div></div>`;
            div.innerHTML = content;
            chatMessages.appendChild(div);
            // Wait for DOM to update then scroll
            setTimeout(() => {
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }, 50);
        }

        if(form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const question = questionInput.value.trim();
                if (!question) return;

                addMessage(question, true);
                questionInput.value = '';

                try {
                    const response = await fetch('/api/huggingface-chat', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ question, context: contextInput.value, mode: modeSelect.value })
                    });
                    const data = await response.json();
                    
                    // Basic markdown parsing for bold and line breaks
                    let formattedAnswer = (data.answer || "Erreur de réponse.")
                        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                        .replace(/\n/g, '<br>');
                        
                    addMessage(formattedAnswer);
                } catch (error) {
                    addMessage("Erreur de connexion.");
                }
            });
        }
    });
</script>

<script>
    function openCompletionModal() {
        const modal = document.getElementById('completionModal');
        const backdrop = document.getElementById('modalBackdrop');
        const content = document.getElementById('modalContent');
        
        modal.classList.remove('hidden');
        void modal.offsetWidth;
        
        backdrop.classList.remove('opacity-0');
        content.classList.remove('scale-95', 'opacity-0');
        content.classList.add('scale-100', 'opacity-100');

        // Appeler la route de complétion en arrière-plan
        fetch('{{ path('front_course_complete', {id: module.course.id}) }}', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).then(response => response.json())
          .then(data => console.log('Cours complété:', data))
          .catch(err => console.error('Erreur complétion:', err));
    }

    function closeCompletionModal() {
        const modal = document.getElementById('completionModal');
        const backdrop = document.getElementById('modalBackdrop');
        const content = document.getElementById('modalContent');
        
        backdrop.classList.add('opacity-0');
        content.classList.add('scale-95', 'opacity-0');
        content.classList.remove('scale-100', 'opacity-100');
        
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }

    // Heartbeat for Time Tracking
    (function() {
        const heartbeatInterval = 60000; // 1 minute
        const heartbeatUrl = "{{ path('app_front_office_module_heartbeat', {id: module.id}) }}";

        function sendHeartbeat() {
            fetch(heartbeatUrl, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.status === 'success') {
                    console.log('Engagement tracked: ' + data.time + ' mins');
                }
            })
            .catch(error => console.error('Heartbeat error:', error));
        }

        // Send first heartbeat after 1 minute
        setInterval(sendHeartbeat, heartbeatInterval);
    })();
</script>

<style>
    .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(124,58,237,0.1); border-radius: 2px; }
    .custom-scrollbar:hover::-webkit-scrollbar-thumb { background: rgba(124,58,237,0.3); }
</style>
{% endblock %}
