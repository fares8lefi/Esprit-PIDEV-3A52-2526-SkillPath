{% extends 'base.html.twig' %}

{% block title %}SkillPath - Propulsez votre carrière{% endblock %}

{% block stylesheets %}
<style>
    @keyframes gradient-shift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }
    .hero-gradient-bg {
        background: linear-gradient(135deg, rgba(124,58,237,0.06), rgba(6,182,212,0.04), rgba(245,158,11,0.03));
    }
    .dark .hero-gradient-bg {
        background: linear-gradient(135deg, rgba(124,58,237,0.08), rgba(6,182,212,0.04), rgba(245,158,11,0.02));
    }
</style>
{% endblock %}

{% block body %}
<div class="relative min-h-screen mesh-light dark:mesh-dark overflow-hidden">

    <!-- Navigation -->
    <nav class="glass sticky top-0 z-[100] px-6 lg:px-12 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3 group cursor-pointer">
                <div class="w-10 h-10 gradient-primary rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/20 group-hover:scale-110 transition-transform">
                    <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-7 h-7 object-contain">
                </div>
                <span class="text-2xl font-black tracking-tight text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
            </div>

            <div class="hidden md:flex items-center gap-8">
                <a href="{{ path('app_event_index') }}" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Événements</a>
                <a href="#catalogue" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Catalogue</a>
                <a href="#catalogue" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Courses</a>
                <a href="#stats" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">About</a>
            </div>

            <div class="flex items-center gap-4">
                {% if app.user %}
                    <div class="flex items-center gap-4 pl-4 border-l border-slate-200/50 dark:border-white/5">
                        <div class="text-right hidden sm:block">
                            <p class="text-xs font-bold text-slate-900 dark:text-white">{{ app.user.username }}</p>
                            <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Compte {{ app.user.role }}</p>
                        </div>
                        <a href="{{ path('app_event_my_events') }}" class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 transition-all" title="Mes Événements">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                        </a>
                        <a href="{{ path('app_user_profile') }}" class="w-10 h-10 rounded-xl gradient-primary flex items-center justify-center text-white font-bold text-sm shadow-md shadow-purple-500/15 hover:scale-105 transition-transform">
                            {{ app.user.username|first|upper }}
                        </a>
                        <a href="{{ path('app_logout') }}" class="p-2 text-slate-400 hover:text-red-400 transition-colors" title="Déconnexion">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                        </a>
                    </div>
                {% else %}
                    <a href="{{ path('app_user_login') }}" class="text-sm font-semibold text-slate-600 dark:text-slate-300 hover:text-primary px-4 py-2 transition-colors">Login</a>
                    <a href="{{ path('app_user_register') }}" class="btn-primary text-sm !py-3 !px-6">Register</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-12 pt-20 pb-28">
        <div class="flex flex-col lg:flex-row items-center gap-16">
            <div class="flex-1 text-center lg:text-left animate-fade-up">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/8 dark:bg-primary/15 border border-primary/15 dark:border-primary/20 mb-8">
                    <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                    <span class="text-[11px] font-bold text-primary dark:text-primary-light uppercase tracking-widest">Plateforme 2026</span>
                </div>
                <h1 class="text-5xl lg:text-[5.5rem] font-[900] text-slate-900 dark:text-white mb-8 leading-[1.05] tracking-tight">
                    Master your <br>
                    <span class="gradient-text">Future.</span>
                </h1>
                <p class="text-lg text-slate-500 dark:text-slate-400 max-w-xl mb-12 font-medium leading-relaxed">
                    Access world-class curricula designed by industry architects to optimize your career and dominate tomorrow's technologies.
                </p>
                <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
                    <a href="#catalogue" class="btn-primary w-full sm:w-auto text-center flex items-center justify-center gap-2 !py-4 !px-8">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        Start Adventure
                    </a>
                    <a href="#catalogue" class="btn-secondary w-full sm:w-auto text-center flex items-center justify-center gap-2 !py-4 !px-8 group">
                        Browse Courses
                        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                </div>
            </div>

            <!-- Bento Hero Illustration -->
            <div class="flex-1 relative hidden lg:block animate-fade-up delay-200">
                <div class="grid grid-cols-2 gap-4">
                    <!-- Card 1: Course Preview -->
                    <div class="glass-card p-6 rounded-3xl col-span-2">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-12 h-12 rounded-xl gradient-primary flex items-center justify-center text-white font-black shadow-lg shadow-purple-500/20">JS</div>
                            <div>
                                <p class="text-sm font-bold text-slate-900 dark:text-white">JavaScript Expert</p>
                                <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Cours Masterclass</p>
                            </div>
                            <span class="badge badge-green ml-auto">Nouveau</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-bar-fill" style="width: 75%"></div>
                        </div>
                        <p class="text-right text-[10px] font-bold text-slate-400 mt-2">75% Complété</p>
                    </div>

                    <!-- Card 2: Stats -->
                    <div class="glass-card p-6 rounded-3xl animate-float">
                        <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mb-3">
                            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                        </div>
                        <p class="text-2xl font-black text-slate-900 dark:text-white">92%</p>
                        <p class="text-xs font-semibold text-slate-400">Taux de réussite</p>
                    </div>

                    <!-- Card 3: Achievement -->
                    <div class="glass-card p-6 rounded-3xl" style="animation-delay: 3s">
                        <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center mb-3">
                            <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                        </div>
                        <p class="text-2xl font-black text-slate-900 dark:text-white">12</p>
                        <p class="text-xs font-semibold text-slate-400">Badges obtenus</p>
                    </div>
                </div>
                <!-- Decorative blurs -->
                <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl -z-10 animate-pulse"></div>
                <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-accent/10 rounded-full blur-3xl -z-10"></div>
            </div>
        </div>
    </section>

    <!-- Trusted By -->
    <section class="border-y border-slate-200/30 dark:border-white/5 bg-slate-50/30 dark:bg-white/[0.02] py-10">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-[0.3em] mb-8">Trusted by Leading Innovators</p>
            <div class="flex flex-wrap justify-center gap-12 lg:gap-20 opacity-30 dark:opacity-20 grayscale hover:grayscale-0 hover:opacity-60 transition-all duration-500">
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Google</span>
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Netflix</span>
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Adobe</span>
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Spotify</span>
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Vercel</span>
            </div>
        </div>
    </section>

    <!-- Help & Reclamation CTA -->
    {% if app.user %}
    <section class="max-w-7xl mx-auto px-6 lg:px-12 py-16 animate-fade-up">
        <div class="gradient-primary rounded-3xl p-10 lg:p-12 shadow-2xl shadow-purple-500/15 relative overflow-hidden">
            <div class="absolute right-0 top-0 w-64 h-64 bg-white/5 rounded-full blur-3xl"></div>
            <div class="absolute left-0 bottom-0 w-48 h-48 bg-black/5 rounded-full blur-2xl"></div>
            
            <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                        </div>
                        <span class="text-[10px] font-bold text-white/70 uppercase tracking-widest">Support available 24/7</span>
                    </div>
                    <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Need Assistance?</h2>
                    <p class="text-white/80 font-medium text-sm max-w-lg">Our elite team is here for you. Initiate a request and receive a swift response.</p>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="{{ path('app_reclamation_new') }}" class="px-6 py-3.5 bg-white text-primary font-bold rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-95 transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        New Request
                    </a>
                    <a href="{{ path('app_reclamation_index') }}" class="px-6 py-3.5 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-xl border border-white/15 hover:bg-white/20 transition-all flex items-center gap-2 text-sm">
                        My Requests
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>
    {% endif %}

    <!-- Catalogue Section -->
    <section id="catalogue" class="max-w-7xl mx-auto px-6 lg:px-12 py-24">
        <div class="text-center mb-16 animate-fade-up">
            <span class="badge badge-purple mb-4">Curriculum</span>
            <h2 class="text-4xl lg:text-5xl font-black text-slate-900 dark:text-white mb-5 tracking-tight">Explore our Premium <span class="gradient-text">Masterclass</span></h2>
            <p class="text-slate-500 dark:text-slate-400 font-medium max-w-2xl mx-auto leading-relaxed">Discover structured learning paths designed to master the most elite skills in the tech ecosystem.</p>
        </div>

        {% if not app.user %}
            <!-- CTA for non-logged users -->
            <div class="max-w-3xl mx-auto rounded-3xl overflow-hidden relative shadow-2xl mb-16">
                <div class="gradient-primary p-12 lg:p-16 text-center relative">
                    <div class="absolute inset-0 bg-[url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22 width=%2232%22 height=%2232%22 fill=%22none%22 stroke=%22rgba(255,255,255,0.05)%22><path d=%22M0 .5H31.5V32%22/></svg>')] opacity-50"></div>
                    <div class="relative z-10">
                        <div class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
                            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                        </div>
                        <h3 class="text-3xl font-black text-white mb-4">Ready to Unleash Your Potential?</h3>
                        <p class="text-white/70 mb-8 max-w-md mx-auto font-medium">Log in to access your master curriculum and begin your elite training.</p>
                        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                            <a href="{{ path('app_user_login') }}" class="w-full sm:w-auto px-8 py-4 bg-white text-primary font-bold rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-95 transition-all">
                                Launch Login
                            </a>
                            <a href="{{ path('app_user_register') }}" class="w-full sm:w-auto px-8 py-4 bg-white/10 text-white font-bold rounded-xl border border-white/15 hover:bg-white/20 transition-all">
                                Join Now
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% elseif courses is empty %}
            <div class="py-20 text-center">
                <div class="w-16 h-16 bg-primary/8 rounded-2xl flex items-center justify-center mx-auto mb-5">
                    <svg class="w-8 h-8 text-primary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                </div>
                <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">Curriculum Pending</h3>
                <p class="text-slate-500 font-medium text-sm">Check back soon for fresh core architectural releases.</p>
            </div>
        {% else %}
        <div class="space-y-20">
            {% for course in courses %}
                <div class="relative animate-fade-up" style="animation-delay: {{ loop.index * 100 }}ms">
                        <!-- Module Header -->
                        <div class="flex flex-col md:flex-row items-center gap-8 mb-10">
                            <div class="w-24 h-24 rounded-2xl glass-card !hover:transform-none flex items-center justify-center p-4 group">
                                {% if course.image %}
                                    <img src="{{ asset('uploads/modules/' ~ course.image) }}" alt="{{ course.title }}" class="w-full h-full object-contain">
                                {% else %}
                                    <div class="w-full h-full rounded-xl gradient-primary flex items-center justify-center text-2xl font-black text-white">
                                        {{ course.title|first }}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="flex-1 text-center md:text-left">
                                <span class="badge badge-purple mb-2">Level {{ course.level }}</span>
                                <h3 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">{{ course.title }}</h3>
                                <p class="text-slate-500 dark:text-slate-400 font-medium max-w-2xl leading-relaxed text-sm">{{ course.description }}</p>
                            </div>
                            <div class="hidden lg:block">
                                <span class="text-5xl font-black text-slate-100 dark:text-slate-800/50 tracking-tighter">{{ loop.index|format('%02d') }}</span>
                            </div>
                        </div>

                        <!-- Courses Bento Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 ml-0 md:ml-8">
                            {% for module in course.modules %}
                                <a href="{{ path('app_front_office_module_show', {'id': module.id}) }}" class="block group">
                                    <div class="glass-card p-7 rounded-2xl group relative overflow-hidden h-full hover:bg-white dark:hover:bg-white/5 transition-colors">
                                        <!-- Type glow -->
                                        <div class="absolute top-0 right-0 w-24 h-24 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500
                                            {% if module.type == 'video' %}bg-primary/10{% elseif module.type == 'quiz' %}bg-accent/10{% else %}bg-mint/10{% endif %}">
                                        </div>

                                        <div class="relative z-10">
                                            <div class="flex items-center justify-between mb-5">
                                                {% set typeIcon = {
                                                    'video': '<svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
                                                    'quiz': '<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>',
                                                    'texte': '<svg class="w-5 h-5 text-mint" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>'
                                                } %}
                                                <div class="w-10 h-10 rounded-xl {% if module.type == 'video' %}bg-primary/8{% elseif module.type == 'quiz' %}bg-accent/8{% else %}bg-mint/8{% endif %} flex items-center justify-center">
                                                    {{ typeIcon[module.type]|default('<svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>')|raw }}
                                                </div>
                                                <span class="badge {% if module.type == 'video' %}badge-purple{% elseif module.type == 'quiz' %}badge-cyan{% else %}badge-green{% endif %}">{{ module.type|default('Text')|capitalize }}</span>
                                            </div>
                                            <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-2 group-hover:text-primary dark:group-hover:text-primary-light transition-colors">{{ module.title }}</h4>

                                            <p class="text-slate-500 dark:text-slate-400 text-sm font-medium leading-relaxed mb-5 line-clamp-2">{{ module.description }}</p>
                                            
                                            <div class="pt-5 border-t border-slate-100/50 dark:border-white/5 flex items-center justify-between">
                                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Duration: 45 min</span>
                                                <div class="w-9 h-9 rounded-xl bg-primary/8 dark:bg-primary/15 flex items-center justify-center text-primary dark:text-primary-light hover:gradient-primary hover:text-white transition-all hover:shadow-lg hover:shadow-purple-500/20">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            {% else %}
                                <div class="col-span-full py-12 text-center glass-card rounded-2xl border-2 border-dashed border-slate-200/50 dark:border-white/5">
                                    <div class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center mx-auto mb-3">
                                        <svg class="w-6 h-6 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                                    </div>
                                    <p class="text-slate-400 font-semibold text-sm">No learning units found for this path.</p>
                                </div>
                            {% endfor %}
                        </div>

                        <!-- Background glow -->
                        {% if loop.index is odd %}
