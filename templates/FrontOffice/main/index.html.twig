{% extends 'base.html.twig' %}

{% block title %}SkillPath - Propulsez votre carrière{% endblock %}

{% block stylesheets %}
<style>
    @keyframes gradient-shift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }
    .hero-gradient-bg {
        background: linear-gradient(135deg, rgba(124,58,237,0.06), rgba(6,182,212,0.04), rgba(245,158,11,0.03));
    }
    .dark .hero-gradient-bg {
        background: linear-gradient(135deg, rgba(124,58,237,0.08), rgba(6,182,212,0.04), rgba(245,158,11,0.02));
    }
</style>
{% endblock %}

{% block body %}
<div class="relative min-h-screen mesh-light dark:mesh-dark overflow-hidden">

    <!-- Navigation -->
    <nav class="glass sticky top-0 z-[100] px-6 lg:px-12 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3 group cursor-pointer">
                <div class="w-10 h-10 gradient-primary rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/20 group-hover:scale-110 transition-transform">
                    <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-7 h-7 object-contain">
                </div>
                <span class="text-2xl font-black tracking-tight text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
            </div>

            <div class="hidden md:flex items-center gap-8">
                <a href="{{ path('app_event_index') }}" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Événements</a>
                <a href="{{ path('front_course_index') }}" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Catalogue</a>
                {% if app.user %}
                    <a href="{{ path('front_course_my_courses') }}" class="text-sm font-semibold text-primary font-bold">Mes Cours</a>
                    <a href="{{ path('app_recommendations') }}" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Recommandations</a>
                {% endif %}
            </div>

            <div class="flex items-center gap-4">
                {% if app.user %}
                    <div class="flex items-center gap-4 pl-4 border-l border-slate-200/50 dark:border-white/5">
                        
                        <!-- Notifications -->
                        <div class="relative">
                            <button onclick="fetchNotifications()" class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center text-slate-400 hover:text-primary transition-all relative">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                                <span id="notification-count" class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-black rounded-full flex items-center justify-center border-2 border-white dark:border-slate-900 hidden">0</span>
                            </button>

                            <!-- Dropdown -->
                            <div id="notification-dropdown" class="absolute right-0 mt-3 w-80 glass dark:bg-slate-900/90 rounded-2xl shadow-2xl border border-white/10 overflow-hidden hidden z-[110] animate-scale-in">
                                <div class="p-4 border-b border-slate-50 dark:border-white/5 bg-slate-50/50 dark:bg-white/5">
                                    <h3 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">Notifications</h3>
                                </div>
                                <div id="notification-list" class="max-h-96 overflow-y-auto custom-scrollbar">
                                    <!-- Dynamic content -->
                                </div>
                                <div class="p-3 text-center border-t border-slate-50 dark:border-white/5">
                                    <button class="text-[10px] font-bold text-slate-400 hover:text-primary transition-colors uppercase tracking-widest">Tout marquer comme lu</button>
                                </div>
                            </div>
                        </div>

                        <div class="text-right hidden sm:block">
                            <p class="text-xs font-bold text-slate-900 dark:text-white">{{ app.user.username }}</p>
                            <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Compte {{ app.user.role }}</p>
                        </div>
                        <a href="{{ path('app_event_my_events') }}" class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 transition-all" title="Mes Événements">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                        </a>
                        <a href="{{ path('app_user_profile') }}" class="w-10 h-10 rounded-xl gradient-primary flex items-center justify-center text-white font-bold text-sm shadow-md shadow-purple-500/15 hover:scale-105 transition-transform">
                            {{ app.user.username|first|upper }}
                        </a>
                        <a href="{{ path('app_logout') }}" class="p-2 text-slate-400 hover:text-red-400 transition-colors" title="Déconnexion">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                        </a>
                    </div>
                {% else %}
                    <a href="{{ path('app_user_login') }}" class="text-sm font-semibold text-slate-600 dark:text-slate-300 hover:text-primary px-4 py-2 transition-colors">Login</a>
                    <a href="{{ path('app_user_register') }}" class="btn-primary text-sm !py-3 !px-6">Register</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-12 pt-20 pb-28">
        <div class="flex flex-col lg:flex-row items-center gap-16">
            <div class="flex-1 text-center lg:text-left animate-fade-up">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/8 dark:bg-primary/15 border border-primary/15 dark:border-primary/20 mb-8">
                    <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                    <span class="text-[11px] font-bold text-primary dark:text-primary-light uppercase tracking-widest">Plateforme 2026</span>
                </div>
                <h1 class="text-5xl lg:text-[5.5rem] font-[900] text-slate-900 dark:text-white mb-8 leading-[1.05] tracking-tight">
                    Master your <br>
                    <span class="gradient-text">Future.</span>
                </h1>
                <p class="text-lg text-slate-500 dark:text-slate-400 max-w-xl mb-12 font-medium leading-relaxed">
                    Access world-class curricula designed by industry architects to optimize your career and dominate tomorrow's technologies.
                </p>
                <div class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
                    <a href="{{ path('front_course_index') }}" class="btn-primary w-full sm:w-auto text-center flex items-center justify-center gap-2 !py-4 !px-8">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        Start Adventure
                    </a>
                    <a href="{{ path('front_course_index') }}" class="btn-secondary w-full sm:w-auto text-center flex items-center justify-center gap-2 !py-4 !px-8 group">
                        Browse Courses
                        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                </div>
            </div>

            <!-- Bento Hero Illustration -->
            <div class="flex-1 relative hidden lg:block animate-fade-up delay-200">
                <div class="grid grid-cols-2 gap-4">
                    <!-- Card 1: Course Preview -->
                    <div class="glass-card p-6 rounded-3xl col-span-2">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-12 h-12 rounded-xl gradient-primary flex items-center justify-center text-white font-black shadow-lg shadow-purple-500/20">JS</div>
                            <div>
                                <p class="text-sm font-bold text-slate-900 dark:text-white">JavaScript Expert</p>
                                <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Cours Masterclass</p>
                            </div>
                            <span class="badge badge-green ml-auto">Nouveau</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-bar-fill" style="width: {{ userStats.progression }}%"></div>
                        </div>
                        <p class="text-right text-[10px] font-bold text-slate-400 mt-2">{{ userStats.progression }}% Complété</p>
                    </div>

                    <!-- Card 2: Stats -->
                    <div class="glass-card p-6 rounded-3xl animate-float">
                        <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mb-3">
                            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                        </div>
                        <p class="text-2xl font-black text-slate-900 dark:text-white">92%</p>
                        <p class="text-xs font-semibold text-slate-400">Taux de réussite</p>
                    </div>

                    <!-- Card 3: Achievement -->
                    <div class="glass-card p-6 rounded-3xl" style="animation-delay: 3s">
                        <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center mb-3">
                            <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                        </div>
                        <p class="text-2xl font-black text-slate-900 dark:text-white">{{ userStats.certifs }}</p>
                        <p class="text-xs font-semibold text-slate-400">Certificats obtenus</p>
                    </div>
                </div>
                <!-- Decorative blurs -->
                <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl -z-10 animate-pulse"></div>
                <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-accent/10 rounded-full blur-3xl -z-10"></div>
            </div>
        </div>
    </section>

    <!-- Trusted By -->
    <section class="border-y border-slate-200/30 dark:border-white/5 bg-slate-50/30 dark:bg-white/[0.02] py-10">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <p class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-[0.3em] mb-8">Trusted by Leading Innovators</p>
            <div class="flex flex-wrap justify-center gap-12 lg:gap-20 opacity-30 dark:opacity-20 grayscale hover:grayscale-0 hover:opacity-60 transition-all duration-500">
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Google</span>
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Netflix</span>
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Adobe</span>
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Spotify</span>
                <span class="text-xl font-black text-slate-700 dark:text-slate-300">Vercel</span>
            </div>
        </div>
    </section>

    <!-- Help & Reclamation CTA -->
    {% if app.user %}
    <section class="max-w-7xl mx-auto px-6 lg:px-12 py-16 animate-fade-up">
        <div class="gradient-primary rounded-3xl p-10 lg:p-12 shadow-2xl shadow-purple-500/15 relative overflow-hidden">
            <div class="absolute right-0 top-0 w-64 h-64 bg-white/5 rounded-full blur-3xl"></div>
            <div class="absolute left-0 bottom-0 w-48 h-48 bg-black/5 rounded-full blur-2xl"></div>
            
            <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                        </div>
                        <span class="text-[10px] font-bold text-white/70 uppercase tracking-widest">Support available 24/7</span>
                    </div>
                    <h2 class="text-3xl font-black text-white mb-2 tracking-tight">Need Assistance?</h2>
                    <p class="text-white/80 font-medium text-sm max-w-lg">Our elite team is here for you. Initiate a request and receive a swift response.</p>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="{{ path('app_reclamation_new') }}" class="px-6 py-3.5 bg-white text-primary font-bold rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-95 transition-all flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        New Request
                    </a>
                    <a href="{{ path('app_reclamation_index') }}" class="px-6 py-3.5 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-xl border border-white/15 hover:bg-white/20 transition-all flex items-center gap-2 text-sm">
                        My Requests
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>
    {% endif %}

    {% if app.user and recommendedCourses is not empty %}
    <!-- AI Recommendation Spotlight Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-12 py-20 animate-fade-up">
        <div class="flex items-center gap-3 mb-10">
            <div class="w-10 h-10 rounded-xl gradient-primary flex items-center justify-center text-white shadow-lg shadow-primary/20">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div>
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-primary block leading-none mb-1">Intelligence Artificielle &middot; Consensus de 3 Mod&egrave;les</span>
                <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Le Meilleur Cours Recommand&eacute; pour <span class="gradient-text">Vous</span></h2>
            </div>
        </div>

        {% for course in recommendedCourses %}
        <div class="group relative bg-[#0d1117] rounded-[2.5rem] border border-white/10 overflow-hidden hover:border-primary/50 transition-all duration-500 shadow-2xl shadow-primary/5">
            <div class="absolute -top-20 -left-20 w-80 h-80 bg-primary/10 rounded-full blur-[100px] group-hover:bg-primary/20 transition-all duration-700 pointer-events-none"></div>
            <div class="absolute -bottom-20 -right-20 w-80 h-80 bg-accent/5 rounded-full blur-[100px] pointer-events-none"></div>

            <div class="relative flex flex-col md:flex-row items-stretch z-10">
                <div class="w-full md:w-80 lg:w-96 shrink-0 relative overflow-hidden" style="min-height:260px">
                    {% if course.image %}
                        <img src="{{ asset('uploads/modules/' ~ course.image) }}" class="w-full h-full object-cover absolute inset-0 group-hover:scale-105 transition-transform duration-700">
                    {% else %}
                        <div class="w-full h-full gradient-primary flex items-center justify-center text-white text-7xl font-black absolute inset-0">{{ course.title|first }}</div>
                    {% endif %}
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[#0d1117] hidden md:block"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] to-transparent md:hidden"></div>
                    <div class="absolute top-5 left-5">
                        <div class="flex items-center gap-2 px-3 py-2 rounded-full bg-black/70 backdrop-blur-md border border-primary/40 shadow-lg shadow-primary/20">
                            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                            <span class="text-[10px] font-black text-primary uppercase tracking-widest">IA Pick</span>
                        </div>
                    </div>
                    <div class="absolute top-5 right-5">
                        <span class="px-3 py-1.5 rounded-full bg-black/60 backdrop-blur-md border border-white/10 text-[10px] font-black text-slate-300 uppercase tracking-widest">{{ course.category|default('Cours') }}</span>
                    </div>
                </div>

                <div class="flex-1 p-8 md:p-10 lg:p-14 flex flex-col justify-between">
                    <div>
                        <div class="flex flex-wrap items-center gap-3 mb-5">
                            <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest border border-white/10 px-3 py-1 rounded-full">{{ course.level }}</span>
                            <span class="text-[10px] font-black text-slate-500 uppercase tracking-widest">{{ course.modules|length }} Modules</span>
                            <span class="text-[10px] font-black text-primary uppercase tracking-widest">{{ course.price|default('0.00') }} DT</span>
                        </div>
                        <h3 class="text-3xl lg:text-4xl font-black text-white mb-4 group-hover:text-primary transition-colors leading-tight">{{ course.title }}</h3>
                        <p class="text-slate-400 text-base font-medium leading-relaxed mb-8 max-w-2xl">{{ course.description }}</p>

                    </div>
                    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pt-6 border-t border-white/5">
                        <a href="{{ path('front_course_show', {id: course.id}) }}" class="btn-primary flex items-center gap-2 !px-8 !py-4">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            D&eacute;couvrir ce cours
                        </a>
                        <a href="{{ path('front_course_index') }}" class="text-sm font-bold text-slate-500 hover:text-white transition-colors flex items-center gap-2">
                            Voir tout le catalogue
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </section>
    {% endif %}

    <!-- Catalogue Section -->
    <section id="catalogue" class="max-w-7xl mx-auto px-6 lg:px-12 py-24 scroll-mt-24">
        <div class="text-center mb-16 animate-fade-up">
            <span class="badge badge-purple mb-4">Curriculum</span>
            <h2 class="text-4xl lg:text-5xl font-black text-slate-900 dark:text-white mb-5 tracking-tight">Explore our Premium <span class="gradient-text">Masterclass</span></h2>
            <p class="text-slate-500 dark:text-slate-400 font-medium max-w-2xl mx-auto leading-relaxed">Discover structured learning paths designed to master the most elite skills in the tech ecosystem.</p>
        </div>

        {# Filters & Search #}
        <form method="GET" action="{{ path('app_home') }}#catalogue" class="mb-12 flex flex-col md:flex-row gap-6 items-end animate-fade-up delay-100">
            <div class="flex-grow w-full">
                <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Search Course</label>
                <div class="relative group">
                    <input type="text" name="search" value="{{ currentSearch }}" placeholder="What do you want to learn today?" 
                           class="form-input !bg-white/5 !border-white/10 dark:!border-white/10 focus:!border-primary !text-slate-900 dark:!text-white w-full h-14 pl-12 glass transition-all">
                    <svg class="w-5 h-5 absolute left-4 top-4.5 text-slate-500 group-focus-within:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
            </div>
            <div class="w-full md:w-64">
                <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Level</label>
                <select name="level" onchange="this.form.submit()" class="form-input !bg-white/5 !border-white/10 dark:!border-white/10 focus:!border-primary !text-slate-900 dark:!text-white h-14 glass">
                    <option value="" class="bg-white dark:bg-slate-900">All Levels</option>
                    {% for lvl in ['Débutant', 'Intermédiaire', 'Avancé'] %}
                        <option value="{{ lvl }}" {{ currentLevel == lvl ? 'selected' : '' }} class="bg-white dark:bg-slate-900">{{ lvl }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="w-full md:w-64">
                <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Category</label>
                <select name="category" onchange="this.form.submit()" class="form-input !bg-white/5 !border-white/10 dark:!border-white/10 focus:!border-primary !text-slate-900 dark:!text-white h-14 glass">
                    <option value="" class="bg-white dark:bg-slate-900">All Categories</option>
                    {% for cat in categoriesCount %}
                        <option value="{{ cat.name }}" {{ currentCategory == cat.name ? 'selected' : '' }} class="bg-white dark:bg-slate-900">{{ cat.name }} ({{ cat.count }})</option>
                    {% endfor %}
                </select>
            </div>
        </form>

        {# Course Grid #}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 animate-fade-up delay-200">
            {% for course in courses %}
                <div class="group relative bg-white dark:bg-[#121622] rounded-[2.5rem] border border-slate-200/50 dark:border-white/5 overflow-hidden hover:border-primary/30 transition-all duration-500 flex flex-col shadow-xl shadow-slate-200/20 dark:shadow-none">
                    {# Glass decoration #}
                    <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/10 blur-[80px] rounded-full group-hover:bg-primary/20 transition-all"></div>
                    
                    <div class="flex flex-col md:flex-row h-full">
                        {# Course Image #}
                        <div class="w-full md:w-56 h-56 md:h-auto overflow-hidden relative">
                            {% if course.image %}
                                <img src="{{ asset('uploads/modules/' ~ course.image) }}" alt="{{ course.title }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            {% else %}
                                <div class="w-full h-full gradient-primary opacity-20 flex items-center justify-center text-white">
                                    {{ course.title|first }}
                                </div>
                            {% endif %}
                            <div class="absolute top-4 left-4">
                                <span class="badge badge-purple glass !bg-primary/20 !text-primary-light !backdrop-blur-md">{{ course.category|default('General') }}</span>
                            </div>
                        </div>

                        {# Course Info #}
                        <div class="flex-grow p-8 flex flex-col justify-between">
                            <div>
                                <div class="flex justify-between items-start mb-4">
                                    <div class="flex items-center gap-1 text-secondary">
                                        {% for i in 1..5 %}
                                            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                        {% endfor %}
                                    </div>
                                    <span class="text-xs font-black text-slate-500 uppercase tracking-widest">{{ course.level }}</span>
                                </div>

                                <h2 class="text-2xl font-black mb-3 text-slate-900 dark:text-white group-hover:text-primary transition-colors">
                                    <a href="{{ path('front_course_show', {id: course.id}) }}">{{ course.title }}</a>
                                </h2>
                                <p class="text-slate-500 dark:text-slate-400 text-sm line-clamp-2 mb-6 font-medium">{{ course.description }}</p>

                                {# Module Count & Quick Meta #}
                                <div class="flex items-center gap-6 text-[10px] font-black uppercase tracking-widest text-slate-400">
                                    <div class="flex items-center gap-2">
                                        <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
                                        <span>{{ course.modules|length }} Chapters</span>
                                    </div>
                                        <div class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-400">
                                            {% if course.id in certifiedCourseIds|default([]) %}
                                                <svg class="w-4 h-4 text-success/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                                <span class="text-success">Certifié</span>
                                            {% else %}
                                                <svg class="w-4 h-4 text-red-500/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                                                <span class="text-red-500">Pas encore certifié</span>
                                            {% endif %}
                                        </div>
                                    <div class="flex items-center gap-2">
                                        <span class="text-primary font-black">{{ course.price|default('0.00') }} DT</span>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-8 flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <img src="https://ui-avatars.com/api/?name=Skill+Path&background=7C3AED&color=fff" class="w-9 h-9 rounded-xl border border-slate-200 dark:border-white/10">
                                    <div>
                                        <p class="text-xs font-bold text-slate-900 dark:text-white">SkillPath Experts</p>
                                        <p class="text-[9px] text-slate-500 font-bold uppercase tracking-widest">Instructors</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    {% if app.user %}
                                        {% set isEnrolled = false %}
                                        {% for userCourse in app.user.courses %}
                                            {% if userCourse.id == course.id %}
                                                {% set isEnrolled = true %}
                                            {% endif %}
                                        {% endfor %}

                                        {% if isEnrolled %}
                                            <a href="{{ path('front_course_show', {id: course.id}) }}" class="btn-primary !px-5 !py-2.5 !text-xs flex items-center gap-2">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                Resume
                                            </a>
                                        {% else %}
                                            <form action="{{ path('front_course_enroll', {id: course.id}) }}" method="POST">
                                                <button type="submit" class="btn-primary !px-5 !py-2.5 !text-xs flex items-center gap-2 shadow-lg shadow-primary/20">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
                                                    Enroll Now
                                                </button>
                                            </form>
                                        {% endif %}
                                    {% else %}
                                        <a href="{{ path('app_user_login') }}" class="btn-primary !px-5 !py-2.5 !text-xs">Enroll Now</a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Nested Modules UX Section #}
                    <div class="border-t border-slate-100 dark:border-white/5 bg-slate-50/50 dark:bg-black/20 overflow-hidden">
                        <button onclick="toggleModules('modules-{{ course.id }}', this)" class="w-full px-8 py-4 flex items-center justify-between text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-primary transition-colors group/btn">
                            <span>Show Course Content</span>
                            <svg class="w-4 h-4 transform transition-transform group-hover/btn:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div id="modules-{{ course.id }}" class="hidden max-h-[300px] overflow-y-auto px-8 pb-8 space-y-3">
                            {% for module in course.modules %}
                                <div class="flex items-center justify-between p-4 bg-white dark:bg-white/5 border border-slate-100 dark:border-white/5 rounded-2xl hover:bg-slate-50 dark:hover:bg-white/10 transition-colors shadow-sm dark:shadow-none">
                                    <div class="flex items-center gap-4">
                                        <div class="w-8 h-8 rounded-xl bg-primary/10 flex items-center justify-center text-primary font-black text-[10px]">
                                            {{ loop.index|format('%02d') }}
                                        </div>
                                        <div>
                                            <p class="text-xs font-bold text-slate-900 dark:text-white">{{ module.title }}</p>
                                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">{{ module.type }}</p>
                                        </div>
                                    </div>
                                    <svg class="w-4 h-4 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                                </div>
                            {% else %}
                                <p class="text-center text-slate-400 font-bold uppercase tracking-widest text-[10px] py-4">No modules added yet.</p>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-span-full py-24 text-center glass rounded-[2.5rem] border-2 border-dashed border-slate-200/50 dark:border-white/10">
                    <h3 class="text-2xl font-black text-slate-900 dark:text-white mb-4">No courses matched your criteria</h3>
                    <p class="text-slate-500 font-medium mb-8">Try adjusting your filters or search keywords.</p>
                    <a href="{{ path('app_home') }}#catalogue" class="btn-secondary !px-8 !py-4">Reset All Filters</a>
                </div>
            {% endfor %}
        </div>
    </section>


    <!-- Footer -->
    <footer class="border-t border-slate-200/30 dark:border-white/5 pt-16 pb-8">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-16">
                <div>
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-8 h-8 gradient-primary rounded-lg flex items-center justify-center shadow-lg shadow-purple-500/15">
                            <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-5 h-5 object-contain">
                        </div>
                        <span class="text-lg font-black tracking-tight text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
                    </div>
                    <p class="text-slate-500 dark:text-slate-400 text-sm font-medium leading-relaxed mb-5">
                        Transformer l'éducation par la technologie pour tout le monde, partout.
                    </p>
                    <div class="flex gap-3">
                        <a href="#" class="w-9 h-9 rounded-xl bg-slate-100/60 dark:bg-white/5 flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white transition-all"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg></a>
                        <a href="#" class="w-9 h-9 rounded-xl bg-slate-100/60 dark:bg-white/5 flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white transition-all"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
                    </div>
                </div>

                <div>
                    <h5 class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-widest mb-5">Plateforme</h5>
                    <ul class="space-y-3">
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Tous les cours</a></li>
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Abonnements</a></li>
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Parrainage</a></li>
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">IA Guidance</a></li>
                    </ul>
                </div>

                <div>
                    <h5 class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-widest mb-5">Société</h5>
                    <ul class="space-y-3">
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Notre équipe</a></li>
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Carrières</a></li>
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Blog</a></li>
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Contact</a></li>
                    </ul>
                </div>

                <div>
                    <h5 class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-widest mb-5">Support</h5>
                    <ul class="space-y-3">
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">FAQ</a></li>
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Centre d'aide</a></li>
                        <li><a href="#" class="text-slate-500 dark:text-slate-400 text-sm font-medium hover:text-primary dark:hover:text-primary-light transition-colors">Sécurité</a></li>
                    </ul>
                </div>
            </div>

            <div class="flex flex-col md:flex-row justify-between items-center gap-5 pt-8 border-t border-slate-200/30 dark:border-white/5">
                <p class="text-xs font-semibold text-slate-400">© 2026 SkillPath Inc. Tous droits réservés.</p>
                <div class="flex gap-6">
                    <a href="#" class="text-xs font-semibold text-slate-400 hover:text-primary transition-colors">Confidentialité</a>
                    <a href="#" class="text-xs font-semibold text-slate-400 hover:text-primary transition-colors">Conditions</a>
                </div>
            </div>
        </div>
    </footer>

</div>

<script>
    function toggleModules(id, btn) {
        const el = document.getElementById(id);
        const svg = btn.querySelector('svg');
        if (el.classList.contains('hidden')) {
            el.classList.remove('hidden');
            el.classList.add('animate-fade-in');
            svg.style.transform = 'rotate(180deg)';
        } else {
            el.classList.add('hidden');
            svg.style.transform = 'rotate(0deg)';
        }
    }
</script>

<style>
    .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .badge {
        @apply px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border transition-all;
    }
    .badge-purple {
        @apply bg-primary/10 text-primary border-primary/20;
    }
</style>
{% endblock %}
