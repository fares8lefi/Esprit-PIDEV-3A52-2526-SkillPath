{% extends 'base.html.twig' %}

{% block title %}Nouvelle Réclamation{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark flex items-center justify-center p-6">
    <div class="max-w-2xl w-full">
        <!-- Back Link -->
        <a href="{{ path('app_reclamation_index') }}" class="inline-flex items-center gap-2 text-xs font-bold text-slate-400 hover:text-primary transition-colors mb-8 animate-fade-up">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Retour aux réclamations
        </a>


        <div class="glass-card p-10 lg:p-14 rounded-3xl shadow-2xl animate-fade-up relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
            
            <div class="relative z-10">
                <div class="mb-10">
                    <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-4 tracking-tight">Nouvelle <span class="gradient-text">Réclamation</span></h1>
                    <p class="text-slate-500 dark:text-slate-400 font-medium">Décrivez votre problème en détail pour que notre équipe puisse vous aider efficacement.</p>
                </div>

                {# Global Form Errors #}
                {% if not form.vars.valid %}
                    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-8 rounded-xl animate-fade-up">
                        <div class="flex items-center mb-2">
                            <svg class="w-5 h-5 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <span class="font-bold text-red-700">Erreur de validation</span>
                        </div>
                        {{ form_errors(form) }}
                        {% for child in form.children %}
                            {% for error in child.vars.errors %}
                                <p class="text-red-600 text-xs font-medium ml-7">• {{ error.message }}</p>
                            {% endfor %}
                        {% endfor %}
                    </div>
                {% endif %}

                {{ form_start(form, {'attr': {
                    'class': 'space-y-8', 
                    'enctype': 'multipart/form-data',
                    'data-controller': 'voice-recognition'
                }}) }}
                    <div class="space-y-3">
                        {{ form_label(form.sujet, 'Sujet ou Titre', {'label_attr': {'class': 'text-xs font-bold uppercase tracking-widest text-slate-400 ml-1'}}) }}
                        {{ form_widget(form.sujet, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Problème d\'accès au cours...'}}) }}
                        {{ form_errors(form.sujet, {'attr': {'class': 'text-red-500 text-sm font-bold mt-2 ml-1'}}) }}
                    </div>

                    <div class="space-y-3">
                        <div class="flex items-center justify-between">
                            {{ form_label(form.description, 'Description détaillée', {'label_attr': {'class': 'text-xs font-bold uppercase tracking-widest text-slate-400 ml-1'}}) }}
                            
                            <!-- Language & Mic UI -->
                            <div class="flex items-center gap-1.5 p-1 bg-slate-100 dark:bg-white/5 rounded-xl border border-slate-200 dark:border-white/10">
                                <div class="flex items-center px-1 gap-1">
                                    <button type="button" data-action="click->voice-recognition#setLanguage" data-lang="fr-FR" class="w-6 h-6 flex items-center justify-center text-[10px] font-bold rounded-lg transition-all bg-primary text-white">FR</button>
                                    <button type="button" data-action="click->voice-recognition#setLanguage" data-lang="en-US" class="w-6 h-6 flex items-center justify-center text-[10px] font-bold rounded-lg transition-all text-slate-400 hover:text-primary">EN</button>
                                    <button type="button" data-action="click->voice-recognition#setLanguage" data-lang="ar-SA" class="w-6 h-6 flex items-center justify-center text-[10px] font-bold rounded-lg transition-all text-slate-400 hover:text-primary">AR</button>
                                </div>
                                <div class="w-px h-4 bg-slate-200 dark:bg-white/10"></div>
                                <button 
                                    data-voice-recognition-target="trigger"
                                    data-action="click->voice-recognition#toggle"
                                    type="button" 
                                    class="w-8 h-8 flex items-center justify-center rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-all"
                                    title="Activer le micro"
                                >
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path></svg>
                                </button>
                            </div>
                        </div>
                        {{ form_widget(form.description, {'attr': {
                            'class': 'form-input min-h-[150px] ' ~ (form.description.vars.errors|length > 0 ? 'border-red-500 ring-2 ring-red-500/20' : ''), 
                            'placeholder': 'Expliquez ce qui s\'est passé...',
                            'data-voice-recognition-target': 'input'
                        }}) }}
                        
                        {% for error in form.description.vars.errors %}
                            <div class="flex items-center gap-2 mt-2 text-red-500 animate-fade-up">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                <span class="text-xs font-bold uppercase tracking-wide">{{ error.message }}</span>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="space-y-3">
                        {{ form_label(form.pieceJointe, 'Pièce jointe (Image ou Document)', {'label_attr': {'class': 'text-xs font-bold uppercase tracking-widest text-slate-400 ml-1'}}) }}
                        {{ form_widget(form.pieceJointe, {'attr': {'class': 'form-input bg-transparent border-dashed border-2'}}) }}
                        {{ form_errors(form.pieceJointe, {'attr': {'class': 'text-red-500 text-sm font-bold mt-2 ml-1'}}) }}
                    </div>
                    
                    <button type="submit" class="btn-primary w-full !py-5 !text-lg mt-6">
                        Envoyer ma demande
                    </button>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{{ include('_chatbot.html.twig') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
