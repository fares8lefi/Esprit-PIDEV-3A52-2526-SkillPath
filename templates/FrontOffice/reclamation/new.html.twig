{% extends 'base.html.twig' %}

{% block title %}Nouvelle Réclamation{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark flex items-center justify-center p-6">
    <div class="max-w-2xl w-full">
        <!-- Back Link -->
        <a href="{{ path('app_reclamation_index') }}" class="inline-flex items-center gap-2 text-xs font-bold text-slate-400 hover:text-primary transition-colors mb-8 animate-fade-up">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Retour aux réclamations
        </a>

        <div class="glass-card p-10 lg:p-14 rounded-3xl shadow-2xl animate-fade-up relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
            
            <div class="relative z-10">
                <div class="mb-10">
                    <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-4 tracking-tight">Nouvelle <span class="gradient-text">Réclamation</span></h1>
                    <p class="text-slate-500 dark:text-slate-400 font-medium">Décrivez votre problème en détail pour que notre équipe puisse vous aider efficacement.</p>
                </div>

                {{ form_start(form, {'attr': {'class': 'space-y-8'}}) }}
                    <div class="space-y-3">
                        {{ form_label(form.sujet, 'Sujet ou Titre', {'label_attr': {'class': 'text-xs font-bold uppercase tracking-widest text-slate-400 ml-1'}}) }}
                        {{ form_widget(form.sujet, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Problème d\'accès au cours...'}}) }}
                        {{ form_errors(form.sujet, {'attr': {'class': 'text-red-500 text-sm font-bold mt-2 ml-1'}}) }}
                    </div>

                    <div class="space-y-3">
                        {{ form_label(form.description, 'Description détaillée', {'label_attr': {'class': 'text-xs font-bold uppercase tracking-widest text-slate-400 ml-1'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-input min-h-[150px]', 'placeholder': 'Expliquez ce qui s\'est passé...'}}) }}
                        {{ form_errors(form.description, {'attr': {'class': 'text-red-500 text-sm font-bold mt-2 ml-1'}}) }}
                    </div>
                    
                    <button type="submit" class="btn-primary w-full !py-5 !text-lg mt-6">
                        Envoyer ma demande
                    </button>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
