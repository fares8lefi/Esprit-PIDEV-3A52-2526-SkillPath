{% extends 'base.html.twig' %}

{% block title %}Mes Réclamations{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark py-12">
    <div class="max-w-4xl mx-auto px-6">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10 animate-fade-up">
            <div>
                <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-xs font-bold text-slate-400 hover:text-primary transition-colors mb-3">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                    Retour à l'accueil
                </a>
                <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Mes <span class="gradient-text">Réclamations</span></h1>
            </div>
            
            <div class="flex flex-col sm:flex-row items-center gap-3">
                <form method="get" class="flex items-center gap-3 bg-white/50 dark:bg-white/5 px-4 py-2.5 rounded-2xl border border-slate-200 dark:border-white/10 w-full sm:w-64 focus-within:ring-2 focus-within:ring-primary/20 transition-all group backdrop-blur-sm">
                    <input type="text" name="search" value="{{ search }}" placeholder="Rechercher..." class="bg-transparent border-none focus:outline-none text-sm w-full text-slate-900 dark:text-white placeholder-slate-400 font-medium">
                    <button type="submit" class="text-slate-400 hover:text-primary">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </button>
                </form>

                <a href="{{ path('app_reclamation_new') }}" class="btn-primary !py-3 !px-6 text-sm flex items-center gap-2 w-full sm:w-fit justify-center">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Nouvelle demande
                </a>
            </div>
        </div>

        <!-- Sorting Info -->
        {% if search or reclamations|length > 0 %}
            <div class="flex items-center justify-between mb-6 animate-fade-up">
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">
                    {{ search ? 'Résultats pour "' ~ search ~ '"' : 'Toutes vos demandes' }} 
                    <span class="ml-2 text-primary">({{ reclamations|length }})</span>
                </p>
                <div class="flex gap-4">
                    <a href="{{ path('app_reclamation_index', {sort: 'statut', direction: direction == 'desc' ? 'asc' : 'desc', search: search}) }}" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-colors flex items-center gap-1">
                        Statut
                        {% if sort == 'statut' %}<svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ direction == 'desc' ? 'M19 9l-7 7-7-7' : 'M5 15l7-7 7 7' }}"/></svg>{% endif %}
                    </a>
                    <a href="{{ path('app_reclamation_index', {sort: 'id', direction: direction == 'desc' ? 'asc' : 'desc', search: search}) }}" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-primary transition-colors flex items-center gap-1">
                        Date
                        {% if sort == 'id' %}<svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ direction == 'desc' ? 'M19 9l-7 7-7-7' : 'M5 15l7-7 7 7' }}"/></svg>{% endif %}
                    </a>
                </div>
            </div>
        {% endif %}

        <!-- Reclamation Cards -->
        <div class="space-y-4">
            {% for reclamation in reclamations %}
                <div onclick="window.location.href='{{ path('app_reclamation_show', {'id': reclamation.id}) }}'" class="glass-card p-6 rounded-2xl flex flex-col md:flex-row md:items-center gap-4 group cursor-pointer animate-fade-up {% if reclamation.statut == 'Urgent' %}border-l-4 border-red-500 bg-red-50/30 dark:bg-red-900/10{% endif %}" style="animation-delay: {{ loop.index * 80 }}ms">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <h3 class="text-base font-bold text-slate-900 dark:text-white group-hover:text-primary dark:group-hover:text-primary-light transition-colors">{{ reclamation.sujet }}</h3>
                            {% if reclamation.statut|lower == 'pending' or reclamation.statut|lower == 'en attente' %}
                                <a href="{{ path('app_reclamation_edit', {'id': reclamation.id}) }}" 
                                   class="text-[10px] font-black uppercase tracking-widest text-primary hover:underline z-10" 
                                   onclick="event.stopPropagation();">Modifier</a>
                                <span class="badge badge-amber">En attente</span>
                            {% if reclamation.statut == 'Urgent' %}
                                <span class="badge badge-red animate-pulse italic">Urgent ⚡</span>
                            {% elseif reclamation.statut|lower == 'pending' or reclamation.statut|lower == 'en attente' %}
                                <span class="badge badge-amber">En attente</span>
                            {% elseif reclamation.statut|lower == 'resolved' or reclamation.statut|lower == 'résolu' %}
                                <span class="badge badge-green">Résolu</span>
                            {% else %}
                                <span class="badge badge-purple">{{ reclamation.statut|capitalize }}</span>
                            {% endif %}
                        </div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 font-medium line-clamp-1">{{ reclamation.description }}</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">
                            {{ reclamation.reponses|length }} réponse{{ reclamation.reponses|length > 1 ? 's' : '' }}
                        </span>
                        <svg class="w-4 h-4 text-slate-300 dark:text-slate-600 group-hover:text-primary group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </div>
                </div>
            {% else %}
                <div class="glass-card py-20 rounded-2xl text-center animate-fade-up">
                    <div class="w-16 h-16 rounded-2xl bg-primary/8 flex items-center justify-center mx-auto mb-5">
                        <svg class="w-8 h-8 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Aucune réclamation</h3>
                    <p class="text-slate-500 font-medium text-sm mb-6">Vous n'avez soumis aucune réclamation pour le moment.</p>
                    <a href="{{ path('app_reclamation_new') }}" class="btn-primary !py-3 !px-6 text-sm inline-flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Créer votre première réclamation
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

{{ include('_chatbot.html.twig') }}
{% endblock %}
