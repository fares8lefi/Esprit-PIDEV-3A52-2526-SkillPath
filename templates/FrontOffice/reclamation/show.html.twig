{% extends 'base.html.twig' %}

{% block title %}Réclamation{% endblock %}

{% block stylesheets %}
<style>
    .mesh-background {
        background-color: #ffffff;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 136, 229, 0.08) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(67, 160, 71, 0.08) 0px, transparent 50%),
            radial-gradient(at 50% 50%, rgba(251, 192, 45, 0.03) 0px, transparent 50%);
    }
    .dark .mesh-background {
        background-color: #020617;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 136, 229, 0.04) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(67, 160, 71, 0.04) 0px, transparent 50%),
            radial-gradient(at 50% 50%, rgba(251, 192, 45, 0.01) 0px, transparent 50%);
    }
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.5);
    }
    .dark .glass-card {
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .vibrant-shimmer {
        background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
    }
    /* Chat Bubble Styles */
    .chat-bubble-user {
        background: rgba(30, 136, 229, 0.1);
        border-radius: 1.5rem 1.5rem 0 1.5rem;
        border: 1px solid rgba(30, 136, 229, 0.2);
    }
    .dark .chat-bubble-user {
        background: rgba(30, 136, 229, 0.15);
        border: 1px solid rgba(30, 136, 229, 0.1);
        color: #e2e8f0;
    }
    .chat-bubble-admin {
        background: rgba(255, 255, 255, 0.8);
        border-radius: 1.5rem 1.5rem 1.5rem 0;
        border: 1px solid rgba(0, 0, 0, 0.05);
    }
    .dark .chat-bubble-admin {
        background: rgba(30, 41, 59, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.05);
        color: #e2e8f0;
    }
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen mesh-background p-6 lg:p-12">
    <div class="max-w-4xl mx-auto">
        <!-- Back Link -->
        <a href="{{ path('app_reclamation_index') }}" class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-widest text-slate-400 hover:text-blue-600 mb-8 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Retour
        </a>

        <!-- Original Reclamation -->
        <div class="glass-card p-8 lg:p-10 rounded-[2.5rem] shadow-xl mb-8 border-l-4 border-blue-500 animate-in fade-in slide-in-from-bottom-4 duration-700">
            <div class="flex justify-between items-start mb-6">
                <div>
                    <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-2">{{ reclamation.sujet }}</h1>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Ticket #{{ reclamation.id }}</p>
                </div>
                <span class="px-4 py-2 rounded-xl text-xs font-black uppercase tracking-wider
                    {% if reclamation.statut == 'Pending' %}
                        bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400 border border-yellow-200 dark:border-yellow-800/50
                    {% elseif reclamation.statut == 'Resolved' %}
                        bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 border border-green-200 dark:border-green-800/50
                    {% else %}
                        bg-slate-100 text-slate-700 dark:bg-slate-800/50 dark:text-slate-400 border border-slate-200 dark:border-slate-700
                    {% endif %}">
                    {{ reclamation.statut }}
                </span>
            </div>
            <div class="prose dark:prose-invert max-w-none">
                <p class="text-slate-600 dark:text-slate-300 font-medium leading-relaxed whitespace-pre-line text-lg">{{ reclamation.description }}</p>
            </div>
        </div>

        <!-- Conversation Stream -->
        <div class="space-y-8 mb-12 relative">
            <div class="absolute left-6 lg:left-8 top-0 bottom-0 w-[2px] bg-slate-200 dark:bg-slate-800 z-0"></div>
            
            {% for response in reclamation.reponses %}
                <div class="relative z-10 pl-16 lg:pl-20 animate-in fade-in slide-in-from-bottom-2 duration-500" style="animation-delay: {{ loop.index0 * 100 }}ms">
                    <!-- Avatar -->
                    <div class="absolute left-0 top-0 w-12 h-12 lg:w-16 lg:h-16 rounded-2xl flex items-center justify-center shadow-lg border-2 border-white dark:border-slate-900
                        {% if 'ADMIN' in response.user.roles %}
                            bg-gradient-to-br from-red-500 to-orange-500 text-white
                        {% else %}
                            bg-gradient-to-br from-blue-500 to-cyan-500 text-white
                        {% endif %}">
                        <span class="font-black text-lg">{{ response.user.username|first|upper }}</span>
                    </div>

                    <!-- Message Bubble -->
                    <div class="p-6 lg:p-8 shadow-md 
                        {% if 'ADMIN' in response.user.roles %}
                            chat-bubble-admin
                        {% else %}
                            chat-bubble-user ml-auto text-right
                        {% endif %}">
                        <div class="flex items-center gap-2 mb-2 {% if 'ADMIN' not in response.user.roles %}justify-end{% endif %}">
                            <span class="text-xs font-black uppercase tracking-widest 
                                {% if 'ADMIN' in response.user.roles %}text-red-500{% else %}text-blue-500{% endif %}">
                                {{ response.user.username }} {% if 'ADMIN' in response.user.roles %}(Support){% endif %}
                            </span>
                        </div>
                        <p class="font-medium leading-relaxed whitespace-pre-line {% if 'ADMIN' not in response.user.roles %}text-slate-700 dark:text-slate-200{% else %}text-slate-600 dark:text-slate-300{% endif %}">{{ response.message }}</p>
                    </div>
                </div>
            {% else %}
                <div class="pl-16 lg:pl-20">
                    <p class="text-slate-400 italic font-medium">Aucune réponse pour le moment.</p>
                </div>
            {% endfor %}
        </div>

        <!-- Response Form -->
        {% if reclamation.statut != 'Resolved' %}
            <div class="glass-card p-8 rounded-[2rem] shadow-xl relative z-20">
                <h3 class="text-lg font-black text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                    Ajouter une réponse
                </h3>
                {{ form_start(response_form) }}
                    <div class="mb-4">
                        {{ form_widget(response_form.message, {'attr': {'class': 'w-full bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl py-4 px-6 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/5 transition-all outline-none text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600 font-medium min-h-[100px]', 'placeholder': 'Votre message...'}}) }}
                        {{ form_errors(response_form.message) }}
                    </div>
                    <div class="flex justify-end">
                        <button class="bg-blue-600 hover:bg-blue-700 text-white font-black py-3 px-8 rounded-xl shadow-lg hover:shadow-blue-500/30 transition-all transform active:scale-95 flex items-center gap-2">
                            <span>Envoyer</span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9-2-9-18-9 18 9-2zm0 0v-8"/></svg>
                        </button>
                    </div>
                {{ form_end(response_form) }}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
