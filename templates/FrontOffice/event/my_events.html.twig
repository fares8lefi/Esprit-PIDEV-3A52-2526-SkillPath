{% extends 'base.html.twig' %}

{% block title %}Mes Événements - SkillPath{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-12">
    <div class="max-w-5xl mx-auto">
        <h1 class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-8">
            Mes <span class="gradient-text">Événements</span>
        </h1>

        <!-- Tabs -->
        <div class="flex gap-4 mb-8 border-b border-slate-200 dark:border-slate-800" x-data="{ tab: 'joined' }">
            <button @click="tab = 'joined'" :class="{ 'border-primary text-primary': tab === 'joined', 'border-transparent text-slate-500 hover:text-slate-700': tab !== 'joined' }" class="px-6 py-3 font-bold border-b-2 transition-colors">
                Inscriptions
                <span class="ml-2 px-2 py-0.5 bg-primary/10 text-primary text-xs rounded-full">{{ joinedEvents|length }}</span>
            </button>
            <button @click="tab = 'favorites'" :class="{ 'border-primary text-primary': tab === 'favorites', 'border-transparent text-slate-500 hover:text-slate-700': tab !== 'favorites' }" class="px-6 py-3 font-bold border-b-2 transition-colors">
                Favoris
                <span class="ml-2 px-2 py-0.5 bg-red-500/10 text-red-500 text-xs rounded-full">{{ favoriteEvents|length }}</span>
            </button>
        </div>

        <div x-data="{ tab: 'joined' }"> <!-- Re-declaring for server-side logic if alpine not used, or just structural separation -->
             <!-- Joined Events Section -->
            <div id="joined-section" class="space-y-6 mb-12">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-3">
                    <span class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    </span>
                    Mes Inscriptions
                </h2>

                {% if joinedEvents|length > 0 %}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        {% for event in joinedEvents %}
                            <div class="glass-card p-6 flex items-start gap-4 group hover:border-primary/30 transition-colors">
                                <div class="w-24 h-24 rounded-2xl overflow-hidden flex-shrink-0 bg-slate-100">
                                    {% if event.image %}
                                        <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-full h-full object-cover">
                                    {% endif %}
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex justify-between items-start mb-2">
                                        <span class="text-xs font-bold text-primary uppercase tracking-wider">{{ event.eventDate|date('d F Y') }}</span>
                                        <span class="badge badge-green">Inscrit</span>
                                    </div>
                                    <h3 class="font-bold text-slate-900 dark:text-white text-lg truncate mb-1">
                                        <a href="{{ path('app_event_show', {id: event.id}) }}" class="hover:text-primary transition-colors">{{ event.title }}</a>
                                    </h3>
                                    <p class="text-sm text-slate-500 mb-4">{{ event.startTime|date('H:i') }} - {{ event.location ? event.location.name : 'En ligne' }}</p>
                                    
                                    <div class="flex items-center gap-3 mt-4">
                                        <a href="{{ path('app_event_qrcode', {id: event.id}) }}" class="text-xs font-bold text-primary hover:text-primary-dark flex items-center gap-1 bg-primary/5 px-3 py-2 rounded-lg hover:bg-primary/10 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 12v1m0 0v3m0-3h2m-2 0h-2m-2 0v-3m0 0h-2m2 0h2M5 12a1 1 0 001 1h2a1 1 0 001-1V9a1 1 0 00-1-1H6a1 1 0 00-1 1v3zM5 12h.01M5 12v1m0 0v3m0-3h2M5 12h2M5 12H3m2 0v-1m0 1h.01M5 21v-3m0 0h2m-2 0h-2m2 0v-1m0 1h.01M12 4a1 1 0 011 1v2a1 1 0 01-1 1H9a1 1 0 01-1-1V5a1 1 0 011-1h3zM12 4h.01M12 4v3m0 0h.01M12 4h-2m2 0v-2m0 2h.01M21 12a1 1 0 011 1v2a1 1 0 01-1 1h-3a1 1 0 01-1-1v-2a1 1 0 011-1h3zM21 12h.01M21 12v3m0 0h.01M21 12h-2m2 0v-2m0 2h.01M5 5v2m0-2h2m0 2H5m0-2H3m2 0V3m0 2H5"/></svg>
                                            Billet QR
                                        </a>
                                        <form action="{{ path('app_event_join', {id: event.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir vous désinscrire ?');">
                                            <button type="submit" class="text-xs font-bold text-red-500 hover:text-red-600 flex items-center gap-1 px-3 py-2 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/10 transition-colors">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                                Se désinscrire
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-12 glass-card rounded-[2rem] border-dashed border-2 border-slate-200">
                        <p class="text-slate-500">Vous n'êtes inscrit à aucun événement.</p>
                        <a href="{{ path('app_event_index') }}" class="btn-primary mt-4 inline-flex">Parcourir les événements</a>
                    </div>
                {% endif %}
            </div>

            <!-- Favorite Events Section -->
            <div id="favorites-section" class="space-y-6">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-3">
                    <span class="w-8 h-8 rounded-lg bg-red-500/10 text-red-500 flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    </span>
                    Mes Favoris
                </h2>

                {% if favoriteEvents|length > 0 %}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        {% for event in favoriteEvents %}
                            <div class="glass-card p-6 flex items-start gap-4 group hover:border-red-500/30 transition-colors">
                                <div class="w-24 h-24 rounded-2xl overflow-hidden flex-shrink-0 bg-slate-100">
                                    {% if event.image %}
                                        <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-full h-full object-cover">
                                    {% endif %}
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex justify-between items-start mb-2">
                                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">{{ event.eventDate|date('d F Y') }}</span>
                                    </div>
                                    <h3 class="font-bold text-slate-900 dark:text-white text-lg truncate mb-1">
                                        <a href="{{ path('app_event_show', {id: event.id}) }}" class="hover:text-primary transition-colors">{{ event.title }}</a>
                                    </h3>
                                    
                                    <div class="flex items-center gap-4 mt-4">
                                        <a href="{{ path('app_event_show', {id: event.id}) }}" class="text-xs font-bold text-primary hover:underline">Voir détails</a>
                                        <form action="{{ path('app_event_favorite', {id: event.id}) }}" method="post">
                                            <button type="submit" class="text-xs font-bold text-slate-400 hover:text-red-500 transition-colors flex items-center gap-1">
                                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                                                Retirer
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                 {% else %}
                    <div class="text-center py-12 glass-card rounded-[2rem] border-dashed border-2 border-slate-200">
                        <p class="text-slate-500">Vous n'avez aucun événement en favori.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
