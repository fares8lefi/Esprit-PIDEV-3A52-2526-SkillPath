{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} - SkillPath{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    /* Ensure Leaflet tiles are not hidden by other elements and map has height */
    #event-map { z-index: 10 !important; }
    .glass-card { overflow: visible !important; }
</style>
{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <a href="{{ path('app_event_index') }}" class="inline-flex items-center gap-2 text-slate-500 hover:text-primary transition-colors mb-8 font-medium">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Retour aux événements
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
            <!-- Hero Image -->
            <div class="relative h-96 rounded-[2.5rem] overflow-hidden shadow-2xl">
                {% if event.image %}
                    <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-full h-full object-cover">
                {% else %}
                    <div class="w-full h-full bg-slate-100 dark:bg-white/5 flex items-center justify-center">
                        <svg class="w-20 h-20 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                {% endif %}
                
                <!-- Quick Actions Overlay -->
                {% if app.user %}
                    <div class="absolute top-6 right-6 flex gap-3">
                         <form action="{{ path('app_event_favorite', {id: event.id}) }}" method="post">
                            <button type="submit" class="p-4 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md rounded-full shadow-xl hover:bg-slate-50 dark:hover:bg-white/10 transition-all group" title="Ajouter aux favoris">
                                <svg class="w-6 h-6 transition-colors {{ app.user.favoriteEvents.contains(event) ? 'text-red-500 fill-red-500' : 'text-slate-400 group-hover:text-red-500' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>

            <!-- Content -->
            <div>
                <div class="flex flex-wrap items-center gap-4 mb-6">
                    <span class="px-4 py-2 bg-primary/10 text-primary rounded-xl font-bold text-sm uppercase tracking-wider">
                         Conférence
                    </span>
                    {% if event.location %}
                    <span class="flex items-center gap-2 text-slate-500 font-medium">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span id="event-location" data-original="{{ event.location.name }}">{{ event.location.name }}</span>
                    </span>
                    {% endif %}

                    <!-- AI Translation Buttons -->
                    <div class="ml-auto flex items-center gap-2">
                        <span class="text-xs text-slate-500 font-medium">🤖 Traduire :</span>
                        <button id="btn-translate-en" onclick="translateEvent('en')" class="flex items-center gap-1 px-3 py-1.5 text-xs font-bold rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-primary hover:text-white transition-all duration-200">
                            🇺🇸 English
                        </button>
                        <button id="btn-translate-ar" onclick="translateEvent('ar')" class="flex items-center gap-1 px-3 py-1.5 text-xs font-bold rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-primary hover:text-white transition-all duration-200">
                            🇸🇦 العربية
                        </button>
                        <button id="btn-translate-reset" onclick="resetTranslation()" class="hidden flex items-center gap-1 px-3 py-1.5 text-xs font-bold rounded-xl bg-red-100 text-red-600 hover:bg-red-200 transition-all duration-200">
                            ↩ Original
                        </button>
                    </div>
                </div>

                <h1 id="event-title" data-original="{{ event.title }}" class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white mb-4 leading-tight">
                    {{ event.title }}
                </h1>

                <div class="flex items-center gap-2 mb-6">
                    <div class="flex">
                        {% set rating = event.averageRating|default(0) %}
                        {% for i in 1..5 %}
                            <svg class="w-6 h-6 {{ i <= rating ? 'text-yellow-400 fill-yellow-400' : 'text-slate-200 dark:text-slate-700' }}" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                        {% endfor %}
                    </div>
                    <span class="text-xl font-bold text-slate-700 dark:text-slate-300">{{ event.averageRating|default(0)|number_format(1) }}</span>
                    <span class="text-slate-500">({{ event.ratings|length|default(0) }} avis)</span>
                </div>

                <!-- Flash Messages -->
                {% for message in app.flashes('success') %}
                    <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 px-6 py-4 rounded-2xl flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                        <span class="font-medium">{{ message }}</span>
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                     <div class="mb-6 bg-red-500/10 border border-red-500/20 text-red-600 dark:text-red-400 px-6 py-4 rounded-2xl flex items-center gap-3">
                        <span class="font-medium">{{ message }}</span>
                    </div>
                {% endfor %}

                <div id="event-description" data-original="{{ event.description|e('html_attr') }}" class="prose prose-lg prose-slate dark:prose-invert max-w-none transition-opacity duration-300">
                    {{ event.description|nl2br }}
                </div>

                <div class="mt-12">
                    <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">Évaluer cet événement</h3>
                    {% if app.user %}
                        <form action="{{ path('app_event_rate', {id: event.id}) }}" method="post" class="bg-slate-50 dark:bg-slate-800/50 rounded-2xl p-6 border border-slate-100 dark:border-white/5">
                            <div class="flex flex-col sm:flex-row items-center gap-6">
                                <div class="flex-1 w-full">
                                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-3">Votre note (sur 5)</label>
                                    <div class="flex items-center gap-2 flex-row-reverse justify-end rating-stars">
                                        {% for i in 5..1 %}
                                            <input type="radio" name="rating" id="star{{ i }}" value="{{ i }}" class="peer hidden" required>
                                            <label for="star{{ i }}" class="cursor-pointer text-slate-300 peer-checked:text-yellow-400 hover:text-yellow-400 transition-colors">
                                                <svg class="w-10 h-10 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                            </label>
                                        {% endfor %}
                                        <style>
                                            .rating-stars label:hover ~ label { color: #facc15 !important; }
                                        </style>
                                    </div>
                                </div>
                                <button type="submit" class="btn-primary w-full sm:w-auto px-8 py-3 shadow-lg shadow-primary/30">Soumettre</button>
                            </div>
                        </form>
                    {% else %}
                        <div class="bg-blue-50/50 dark:bg-blue-900/10 border border-blue-100 dark:border-blue-800/30 rounded-2xl p-6 text-center">
                            <p class="text-blue-800 dark:text-blue-300 mb-4">Vous devez être connecté pour laisser une évaluation.</p>
                            <a href="{{ path('app_user_login') }}" class="btn-primary inline-flex">Se connecter</a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
            <!-- Event Details Card -->
            <div class="glass-card rounded-[2rem] p-8 shadow-xl">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Détails pratiques</h3>
                
                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-blue-500/10 text-blue-500 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                        <div>
                            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Date</span>
                            <span class="block text-lg font-bold text-slate-900 dark:text-white">{{ event.eventDate|date('d F Y') }}</span>
                            <span class="text-sm font-medium text-primary">{{ event.eventDate|ago }}</span>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-amber-500/10 text-amber-500 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Horaire</span>
                            <span class="text-lg font-bold text-slate-900 dark:text-white">{{ event.startTime|date('H:i') }} - {{ event.endTime|date('H:i') }}</span>
                        </div>
                    </div>

                    {% if event.location %}
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <div>
                            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Lieu</span>
                            <span class="block text-lg font-bold text-slate-900 dark:text-white">{{ event.location.name }}</span>
                            <span class="text-sm text-slate-500">{{ event.location.building }} - Salle {{ event.location.roomNumber }}</span>
                        </div>
                    </div>

                    {# Leaflet Map (FREE) #}
                    {% if event.location and event.location.latitude is not null and event.location.longitude is not null %}
                    <div class="mt-4">
                        <label class="block text-xs font-black uppercase tracking-wider text-slate-400 mb-3">Localisation</label>
                        <div id="event-map" style="height: 220px;" class="w-full rounded-2xl overflow-hidden border border-slate-100 dark:border-white/10 shadow-lg bg-slate-50 dark:bg-slate-900/50"></div>
                    </div>
                    {% endif %}
                    {% endif %}
                </div>

                <div class="mt-8 pt-8 border-t border-slate-100 dark:border-white/5">
                    {% if app.user %}
                        {% if app.user.joinedEvents.contains(event) %}
                            <form action="{{ path('app_event_join', {id: event.id}) }}" method="post">
                                <button type="submit" class="w-full btn-secondary flex items-center justify-center gap-2 group">
                                    <span class="group-hover:hidden">Déjà inscrit</span>
                                    <span class="hidden group-hover:inline text-red-500">Se désinscrire</span>
                                </button>
                            </form>
                        {% else %}
                             <form action="{{ path('app_event_join', {id: event.id}) }}" method="post">
                                <button type="submit" class="w-full btn-primary flex items-center justify-center gap-2 shadow-xl shadow-primary/20">
                                    S'inscrire maintenant
                                </button>
                            </form>
                        {% endif %}
                    {% else %}
                        <a href="{{ path('app_user_login') }}" class="w-full btn-primary flex items-center justify-center gap-2 shadow-xl shadow-primary/20">
                            Connectez-vous pour participer
                        </a>
                    {% endif %}
                </div>
            </div>
            
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
const translateUrlBase = "{{ path('app_event_translate', {id: event.id, lang: 'en'}) }}".replace('/en', '/{lang}');

async function translateEvent(lang) {
    const btns = ['btn-translate-en','btn-translate-ar'];
    btns.forEach(id => { document.getElementById(id).disabled = true; document.getElementById(id).textContent = '...⏳'; });

    const url = translateUrlBase.replace('{lang}', lang);

    try {
        const resp = await fetch(url);
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();

        const dir = lang === 'ar' ? 'rtl' : 'ltr';
        fadeTo('#event-title', data.title, dir);
        fadeHtmlTo('#event-description', (data.description || '').replace(/\n/g, '<br>'), dir);
        const locEl = document.getElementById('event-location');
        if (locEl && data.location) fadeTo('#event-location', data.location, dir);

        document.getElementById('btn-translate-reset').classList.remove('hidden');
    } catch(e) {
        alert('Erreur de traduction : ' + e.message);
    } finally {
        document.getElementById('btn-translate-en').disabled = false;
        document.getElementById('btn-translate-en').innerHTML = '🇺🇸 English';
        document.getElementById('btn-translate-ar').disabled = false;
        document.getElementById('btn-translate-ar').innerHTML = '🇸🇦 العربية';
    }
}

function resetTranslation() {
    const titleEl = document.getElementById('event-title');
    const descEl  = document.getElementById('event-description');
    const locEl   = document.getElementById('event-location');
    fadeTo('#event-title', titleEl.dataset.original, 'ltr');
    fadeHtmlTo('#event-description', descEl.dataset.original.replace(/\n/g, '<br>'), 'ltr');
    if (locEl) fadeTo('#event-location', locEl.dataset.original, 'ltr');
    document.getElementById('btn-translate-reset').classList.add('hidden');
}

function fadeTo(sel, text, dir) {
    const el = document.querySelector(sel);
    el.style.transition = 'opacity 0.3s';
    el.style.opacity = 0;
    setTimeout(() => { el.textContent = text; el.dir = dir; el.style.opacity = 1; }, 300);
}

function fadeHtmlTo(sel, html, dir) {
    const el = document.querySelector(sel);
    el.style.transition = 'opacity 0.3s';
    el.style.opacity = 0;
    setTimeout(() => { el.innerHTML = html; el.dir = dir; el.style.opacity = 1; }, 300);
}
</script>

{% if event.location and event.location.latitude is not null and event.location.longitude is not null %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const eventLat = {{ event.location.latitude }};
    const eventLng = {{ event.location.longitude }};
    const mapEl = document.getElementById('event-map');
    
    if (mapEl) {
        const map = L.map('event-map', { 
            zoomControl: true,
            scrollWheelZoom: false 
        }).setView([eventLat, eventLng], 15);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 19,
        }).addTo(map);

        L.marker([eventLat, eventLng])
            .addTo(map)
            .bindPopup('<strong>{{ event.location.name|e('js') }}</strong><br>{{ event.location.building|default('')|e('js') }}')
            .openPopup();
            
        setTimeout(() => map.invalidateSize(), 500);
    }
});
</script>
{% endif %}
{% endblock %}
