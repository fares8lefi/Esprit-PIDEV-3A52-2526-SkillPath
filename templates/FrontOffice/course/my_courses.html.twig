{% extends 'base.html.twig' %}

{% block title %}Mes Cours - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen mesh-dark text-white pt-24 pb-12">
    <div class="container mx-auto px-6">
        {# Header #}
        <div class="mb-12 animate-fade-up">
            <h1 class="text-5xl font-extrabold mb-4 gradient-text">Mes Formations</h1>
            <p class="text-slate-400 text-lg max-w-2xl">Retrouvez tous les cours auxquels vous êtes inscrit et continuez votre apprentissage.</p>
        </div>

        {# Course Grid #}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 animate-fade-up delay-200">
            {% for course in courses %}
                <div class="group relative bg-[#121622] rounded-3xl border border-white/5 overflow-hidden hover:border-primary/30 transition-all duration-500 flex flex-col">
                    {# Glass decoration #}
                    <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/10 blur-[80px] rounded-full group-hover:bg-primary/20 transition-all"></div>
                    
                    <div class="flex flex-col md:flex-row h-full">
                        {# Course Image #}
                        <div class="w-full md:w-56 h-56 md:h-auto overflow-hidden relative">
                            {% if course.image %}
                                <img src="{{ asset('uploads/modules/' ~ course.image) }}" alt="{{ course.title }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            {% else %}
                                <div class="w-full h-full gradient-primary opacity-20 flex items-center justify-center">
                                    <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                                </div>
                            {% endif %}
                            <div class="absolute top-4 left-4">
                                <span class="badge badge-purple glass !bg-primary/20 !text-white !backdrop-blur-md">{{ course.category|default('General') }}</span>
                            </div>
                        </div>

                        {# Course Info #}
                        <div class="flex-grow p-8 flex flex-col justify-between">
                            <div>
                                <div class="flex justify-between items-start mb-4">
                                    <div class="flex items-center gap-1 text-secondary">
                                        {% for i in 1..5 %}
                                            <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                        {% endfor %}
                                    </div>
                                    <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">{{ course.level }}</span>
                                </div>

                                <h2 class="text-2xl font-bold mb-3 group-hover:text-primary transition-colors">
                                    <a href="{{ path('front_course_show', {id: course.id}) }}">{{ course.title }}</a>
                                </h2>
                                <p class="text-slate-400 text-sm line-clamp-2 mb-6">{{ course.description }}</p>

                                {# Progress Bar Simulation #}
                                <div class="mb-6">
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-[10px] font-black uppercase text-slate-500">Progression</span>
                                        <span class="text-[10px] font-black text-primary">35%</span>
                                    </div>
                                    <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                                        <div class="h-full bg-primary w-[35%] shadow-[0_0_10px_rgba(124,58,237,0.5)]"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">{{ course.modules|length }} Chapitres</span>
                                <a href="{{ path('front_course_show', {id: course.id}) }}" class="btn-primary !px-6 !py-3 !text-sm flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    Continuer
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-span-full py-24 text-center glass rounded-3xl border border-white/10">
                    <h3 class="text-2xl font-bold mb-4">Vous n'êtes inscrit à aucun cours</h3>
                    <p class="text-slate-400 mb-8">Parcourez notre catalogue pour commencer votre aventure.</p>
                    <a href="{{ path('front_course_index') }}" class="btn-primary">Voir le Catalogue</a>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

<style>
    .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .mesh-dark {
        background: radial-gradient(circle at 0% 0%, #0B0F1A 0%, #05070A 100%);
    }
</style>
{% endblock %}
