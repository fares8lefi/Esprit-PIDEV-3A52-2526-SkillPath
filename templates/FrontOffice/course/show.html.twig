{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} - Learning Mode{% endblock %}

{% block body %}
<div class="min-h-screen bg-[#05070A] text-slate-200 overflow-x-hidden">
    {# Floating Background Decorations #}
    <div class="fixed top-0 left-0 w-full h-full -z-10 overflow-hidden pointer-events-none">
        <div class="absolute top-[10%] left-[-10%] w-[40rem] h-[40rem] bg-primary/10 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute bottom-[10%] right-[-10%] w-[35rem] h-[35rem] bg-accent/5 rounded-full blur-[110px]"></div>
    </div>

    {# Top Navigation #}
    <nav class="h-20 flex items-center justify-between px-8 md:px-12 glass border-b border-white/5 sticky top-0 z-[100]">
        <div class="flex items-center gap-6">
            <a href="{{ path('app_home') }}#catalogue" class="w-10 h-10 rounded-xl glass border border-white/10 flex items-center justify-center text-slate-400 hover:text-white hover:scale-110 transition-all group">
                <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
            <div class="flex flex-col">
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">Formation Premium</span>
                <span class="text-sm font-bold text-white">{{ course.title }}</span>
            </div>
        </div>

        <div class="flex items-center gap-4">
            {% if isEnrolled %}
                {% if isCompleted %}
                    <a href="{{ path('front_course_certificate_download', {id: course.id}) }}" class="hidden md:flex items-center gap-2 px-6 py-2 rounded-2xl bg-[#F59E0B]/10 text-[#F59E0B] border border-[#F59E0B]/20 hover:bg-[#F59E0B]/20 transition-all font-bold text-xs uppercase group shadow-[0_0_15px_rgba(245,158,11,0.3)] hover:shadow-[0_0_25px_rgba(245,158,11,0.5)] cursor-pointer">
                        <svg class="w-4 h-4 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path></svg>
                        Télécharger Certificat
                    </a>
                {% else %}
                    <div class="hidden md:flex items-center gap-4 px-6 py-2 rounded-2xl bg-white/5 border border-white/5">
                        <span class="text-xs font-bold text-slate-400 uppercase">Ma Progression</span>
                        <div class="w-32 h-1.5 bg-white/10 rounded-full overflow-hidden">
                            <div class="h-full bg-primary w-1/3 shadow-[0_0_10px_rgba(124,58,237,0.5)]"></div>
                        </div>
                    </div>
                {% endif %}
            {% else %}
                <form action="{{ path('front_course_enroll', {id: course.id}) }}" method="POST">
                    <button type="submit" class="btn-primary !py-2.5 !px-6 !text-xs flex items-center gap-2 group shadow-xl">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        S'inscrire Maintenant
                    </button>
                </form>
            {% endif %}

            {% if app.user %}
                <div class="relative">
                    <button onclick="fetchNotifications()" class="w-10 h-10 rounded-xl glass border border-white/10 flex items-center justify-center text-slate-400 hover:text-white transition-all relative">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                        <span id="notification-count" class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-black rounded-full flex items-center justify-center border-2 border-slate-900 hidden">0</span>
                    </button>

                    <!-- Dropdown -->
                    <div id="notification-dropdown" class="absolute right-0 mt-3 w-80 glass dark:bg-slate-900/95 rounded-2xl shadow-2xl border border-white/10 overflow-hidden hidden z-[110] animate-scale-in">
                        <div class="p-4 border-b border-white/5 bg-white/5">
                            <h3 class="text-sm font-black text-white uppercase tracking-wider">Notifications</h3>
                        </div>
                        <div id="notification-list" class="max-h-96 overflow-y-auto custom-scrollbar">
                            <!-- Dynamic content -->
                        </div>
                        <div class="p-3 text-center border-t border-white/5">
                            <button class="text-[10px] font-bold text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">Tout marquer comme lu</button>
                        </div>
                    </div>
                </div>
            {% endif %}

            <a href="{{ path('front_course_my_courses') }}" class="w-10 h-10 rounded-xl glass border border-white/10 flex items-center justify-center text-slate-400 hover:text-white transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </a>
        </div>
    </nav>

    {# Hero Overview Section #}
    <header class="relative px-8 md:px-12 py-20 pb-32">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-16 items-center">
            {# Course Visual #}
            <div class="relative group shrink-0">
                <div class="absolute inset-0 bg-primary/20 blur-3xl rounded-[3rem] animate-pulse group-hover:bg-primary/40 transition-all"></div>
                <div class="relative w-64 h-64 md:w-80 md:h-80 rounded-[3rem] overflow-hidden glass border-2 border-white/10 shadow-2xl">
                    {% if course.image %}
                        <img src="{{ asset('uploads/modules/' ~ course.image) }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                    {% else %}
                        <div class="w-full h-full gradient-primary flex items-center justify-center text-6xl font-black text-white">
                            {{ course.title|first }}
                        </div>
                    {% endif %}
                </div>
                {# Stats badges floating #}
                <div class="absolute -right-6 -bottom-6 glass p-4 rounded-2xl border border-white/10 animate-float shadow-xl">
                    {% set visible_modules = course.modules|filter(m => m.scheduledAt is null or m.scheduledAt <= date()) %}
                    <p class="text-[10px] font-black uppercase text-slate-500 mb-1">Modules</p>
                    <p class="text-xl font-black text-white">{{ visible_modules|length }} Units</p>
                </div>
            </div>

            {# Course Copy #}
            <div class="flex-1 animate-fade-up">
                <div class="flex items-center gap-4 mb-6">
                    <span class="badge badge-purple glass !bg-primary/20 !text-primary-light !border-primary/20">{{ course.category|default('Masterclass') }}</span>
                    <span class="text-xs font-black uppercase tracking-[0.2em] text-slate-500">{{ course.level }}</span>
                </div>
                <h1 class="text-6xl md:text-7xl font-black mb-8 leading-[1.1] tracking-tight">
                    Dominez <br>
                    <span class="gradient-text">{{ course.title }}.</span>
                </h1>
                <p class="text-xl text-slate-400 font-medium max-w-2xl leading-relaxed mb-10">
                    {{ course.description }}
                </p>
                
                <div class="flex flex-wrap gap-8 items-center border-t border-white/5 pt-10 text-white">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center text-secondary">
                             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <div>
                            <p class="text-sm font-bold {% if not isCertified %}text-red-500{% endif %}">
                                {{ isCertified ? 'Certifié' : 'Pas encore certifié' }}
                            </p>
                            <p class="text-[10px] uppercase text-slate-500 font-bold">Industry Standard</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center text-accent">
                             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div>
                            <p class="text-sm font-bold">~{{ course.duration|default('120') }} Min</p>
                            <p class="text-[10px] uppercase text-slate-500 font-bold">Auto-formation</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center text-primary">
                             <span class="text-xl font-black">DT</span>
                        </div>
                        <div>
                            <p class="text-sm font-bold">{{ course.price|default('0.00') }}</p>
                            <p class="text-[10px] uppercase text-slate-500 font-bold">Investissement</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    {# Modules Bento Grid #}
    <main class="relative bg-black/40 backdrop-blur-3xl py-24 px-8 md:px-12">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row items-end justify-between mb-16 gap-6">
                <div class="animate-fade-up">
                    <span class="text-primary font-black uppercase tracking-[0.3em] text-[10px] mb-2 block">Curriculum Architectural</span>
                    <h2 class="text-4xl md:text-5xl font-black text-white">Plan d'Apprentissage</h2>
                </div>
                <p class="text-slate-400 max-w-sm text-sm font-medium leading-relaxed">
                    Un parcours structuré en étapes progressives pour une maîtrise totale des concepts.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {% set visible_modules = course.modules|filter(m => m.scheduledAt is null or m.scheduledAt <= date()) %}
                {% for module in visible_modules %}
                    {% if isEnrolled %}
                        <a href="{{ path('app_front_office_module_show', {id: module.id}) }}" class="group block relative animate-fade-up" style="animation-delay: {{ loop.index * 100 }}ms">
                    {% else %}
                        <div class="group relative animate-fade-up cursor-not-allowed" style="animation-delay: {{ loop.index * 100 }}ms">
                    {% endif %}
                        <div class="h-full glass border border-white/5 rounded-[2.5rem] p-10 flex flex-col justify-between overflow-hidden relative transition-all duration-500 hover:border-primary/40 hover:-translate-y-2 hover:shadow-2xl hover:shadow-primary/10">
                            {# Kinetic backgrounds #}
                            <div class="absolute -top-20 -right-20 w-40 h-40 bg-primary/5 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            
                            <div class="relative z-10 text-white">
                                <div class="flex justify-between items-start mb-12">
                                    <div class="w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center text-primary group-hover:gradient-primary group-hover:text-white transition-all shadow-xl group-hover:scale-110 duration-500 overflow-hidden">
                                        {% if module.image %}
                                            <img src="{{ asset('uploads/modules/' ~ module.image) }}" class="w-full h-full object-cover">
                                        {% elseif module.type == 'video' %}
                                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path></svg>
                                        {% elseif module.type == 'quiz' %}
                                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
                                        {% else %}
                                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                        {% endif %}
                                    </div>
                                    <span class="text-5xl font-black text-white/5 select-none transition-colors group-hover:text-primary/10">{{ loop.index|format('%02d') }}</span>
                                </div>

                                <h3 class="text-2xl font-bold mb-4 text-white group-hover:text-primary transition-all">{{ module.title }}</h3>
                                <p class="text-slate-500 text-sm leading-relaxed mb-10 line-clamp-3 font-medium">
                                    {{ module.description }}
                                </p>
                            </div>

                            <div class="flex items-center justify-between relative z-10 pt-8 border-t border-white/5">
                                <div class="flex items-center gap-3">
                                    <span class="badge glass !bg-white/5 !text-slate-400 !border-white/5">{{ module.type|capitalize|default('Text') }}</span>
                                    <span class="text-[10px] font-black text-slate-600 uppercase tracking-widest">{{ module.level|default('MIXED') }}</span>
                                </div>
                                
                                {% if not isEnrolled %}
                                    <div class="w-12 h-12 rounded-full glass flex items-center justify-center text-slate-500 border border-white/5">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                    </div>
                                {% else %}
                                    <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:gradient-primary group-hover:text-white transition-all transform group-hover:rotate-45 duration-500 shadow-lg shadow-primary/20">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% if isEnrolled %}
                        </a>
                    {% else %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </main>

    {# Secondary CTA Section #}
    {% if not isEnrolled %}
        <section class="max-w-4xl mx-auto px-8 py-24 text-center">
            <div class="gradient-primary p-12 md:p-16 rounded-[3rem] shadow-2xl relative overflow-hidden group text-white">
                <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity"></div>
                <h3 class="text-3xl md:text-4xl font-black text-white mb-6 animate-fade-up">Prêt à élever vos compétences ?</h3>
                <p class="text-white/80 font-medium text-lg mb-10 max-w-xl mx-auto">Rejoignez des milliers d'autres étudiants et commencez votre transformation aujourd'hui.</p>
                <form action="{{ path('front_course_enroll', {id: course.id}) }}" method="POST">
                    <button type="submit" class="px-12 py-5 bg-white text-primary font-black rounded-2xl shadow-xl hover:scale-105 active:scale-95 transition-all text-lg">
                        S'inscrire à ce cours
                    </button>
                </form>
            </div>
        </section>
    {% endif %}

    {# Footer Metadata #}
    <footer class="py-12 border-t border-white/5 text-center px-8">
        <a href="{{ path('app_home') }}#catalogue" class="text-xs font-bold text-slate-500 hover:text-white transition-colors flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 15l-3-3m0 0l3-3m-3 3h8M3 12a9 9 0 1118 0 9 9 0 01-18 0z"></path></svg>
            Retour au Catalogue SkillPath
        </a>
    </footer>
</div>

<style>
    .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
</style>
{% endblock %}
