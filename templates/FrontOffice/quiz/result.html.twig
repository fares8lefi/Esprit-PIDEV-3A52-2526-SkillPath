{% extends 'base.html.twig' %}

{% block title %}Résultat du Quiz - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark py-10 px-4">
    <div class="max-w-3xl mx-auto">
        <!-- Score Card -->
        <div class="glass-card rounded-3xl overflow-hidden mb-8 animate-scale-in">
            {% set percentage = totalPoints > 0 ? (score / totalPoints * 100)|round : 0 %}
            {% set passed = percentage >= 50 %}

            <div class="{% if passed %}bg-gradient-to-br from-emerald-500 to-teal-600{% else %}bg-gradient-to-br from-red-500 to-rose-600{% endif %} px-8 py-10 text-center relative overflow-hidden">
                <div class="absolute top-0 left-0 w-32 h-32 bg-white/10 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
                <div class="absolute bottom-0 right-0 w-24 h-24 bg-white/10 rounded-full translate-x-1/3 translate-y-1/3"></div>
                
                <div class="relative z-10">
                    <div class="w-20 h-20 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center mx-auto mb-5 animate-float">
                        {% if passed %}
                            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {% else %}
                            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.5 0L4.268 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                        {% endif %}
                    </div>

                    <h1 class="text-3xl font-black text-white mb-2">
                        {% if passed %}Bravo ! 🎉{% else %}Continuez ! 💪{% endif %}
                    </h1>
                    <p class="text-white/80 text-sm font-medium">
                        {% if passed %}Vous avez réussi le quiz avec succès{% else %}Ne vous découragez pas, essayez encore{% endif %}
                    </p>
                </div>
            </div>

            <div class="p-8">
                <!-- Score Circle -->
                <div class="text-center mb-6">
                    <div class="relative inline-flex items-center justify-center w-32 h-32">
                        <svg class="w-32 h-32 -rotate-90" viewBox="0 0 128 128">
                            <circle cx="64" cy="64" r="56" fill="none" stroke="currentColor" stroke-width="8" class="text-slate-100 dark:text-white/5"/>
                            <circle cx="64" cy="64" r="56" fill="none" stroke-width="8" stroke-linecap="round"
                                    class="{% if passed %}text-emerald-500{% else %}text-red-500{% endif %}"
                                    stroke-dasharray="{{ 2 * 3.14159 * 56 }}"
                                    stroke-dashoffset="{{ 2 * 3.14159 * 56 * (1 - percentage / 100) }}"
                                    style="transition: stroke-dashoffset 1.5s cubic-bezier(0.22, 1, 0.36, 1)"/>
                        </svg>
                        <div class="absolute">
                            <span class="text-2xl font-black text-slate-900 dark:text-white">{{ percentage }}%</span>
                        </div>
                    </div>
                    <p class="text-lg font-bold text-slate-900 dark:text-white mt-2">{{ score }} <span class="text-slate-400">/ {{ totalPoints }}</span></p>
                    <p class="text-xs text-slate-400 mt-1">{{ quiz.titre }}</p>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="{{ path('app_front_office_quiz_take', {'id': quiz.id}) }}" class="btn-primary flex-1 text-center text-sm !py-3 inline-flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                        Réessayer
                    </a>
                    {% if passed and resultatId %}
                    <a href="{{ path('app_quiz_certificat', {'id': resultatId}) }}" class="bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white rounded-xl flex-1 text-center text-sm font-bold !py-3 inline-flex items-center justify-center gap-2 shadow-lg shadow-emerald-500/20 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        Télécharger Certificat
                    </a>
                    {% endif %}
                    <a href="{{ path('app_front_office_quiz_index') }}" class="btn-secondary flex-1 text-center text-sm !py-3 inline-flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                        Tous les Quiz
                    </a>
                </div>
            </div>
        </div>

        <!-- Answer Review Section -->
        {% if userAnswers|length > 0 %}
        <h2 class="text-xl font-black text-slate-900 dark:text-white mb-6 animate-fade-up">📋 Revue des Réponses</h2>

        {% for question in quiz.questions %}
            {% set userAnswer = userAnswers[question.id] ?? null %}
            {% set isCorrect = userAnswer == question.bonneReponse %}
            
            <div class="glass-card rounded-2xl p-6 mb-4 animate-fade-up {{ isCorrect ? 'border-l-4 border-l-emerald-500' : 'border-l-4 border-l-red-500' }}">
                <div class="flex items-start gap-4 mb-4">
                    <span class="w-10 h-10 rounded-xl {{ isCorrect ? 'bg-emerald-500' : 'bg-red-500' }} flex items-center justify-center text-white text-sm font-black flex-shrink-0">
                        {% if isCorrect %}✓{% else %}✗{% endif %}
                    </span>
                    <div class="flex-1">
                        <h3 class="text-sm font-bold text-slate-900 dark:text-white">{{ question.enonce }}</h3>
                        <div class="flex items-center gap-2 mt-1">
                            <span class="badge badge-amber">{{ question.points }} pts</span>
                            {% if isCorrect %}
                                <span class="badge badge-green">Correct</span>
                            {% else %}
                                <span class="badge badge-red">Incorrect</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 ml-14">
                    {% set choices = {'A': question.choixA, 'B': question.choixB, 'C': question.choixC, 'D': question.choixD} %}
                    {% for letter, text in choices %}
                        {% if text %}
                        {% set isUserChoice = userAnswer == letter %}
                        {% set isCorrectChoice = question.bonneReponse == letter %}
                        <div class="flex items-center gap-2 p-2.5 rounded-xl text-sm
                            {% if isCorrectChoice %}bg-emerald-500/10 border border-emerald-500/30
                            {% elseif isUserChoice %}bg-red-500/10 border border-red-500/30
                            {% else %}bg-slate-50/50 dark:bg-white/[0.02] border border-transparent{% endif %}">
                            <span class="w-6 h-6 rounded-md flex items-center justify-center text-xs font-black flex-shrink-0
                                {% if isCorrectChoice %}bg-emerald-500 text-white
                                {% elseif isUserChoice %}bg-red-500 text-white
                                {% else %}bg-slate-200/60 dark:bg-white/10 text-slate-400{% endif %}">{{ letter }}</span>
                            <span class="{% if isCorrectChoice %}font-bold text-emerald-700 dark:text-emerald-400{% elseif isUserChoice %}font-bold text-red-600 dark:text-red-400{% else %}text-slate-500 dark:text-slate-400{% endif %}">{{ text }}</span>
                            {% if isCorrectChoice %}
                                <svg class="w-3.5 h-3.5 text-emerald-500 ml-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                            {% endif %}
                            {% if isUserChoice and not isCorrectChoice %}
                                <svg class="w-3.5 h-3.5 text-red-500 ml-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                            {% endif %}
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
        {% endif %}
    </div>
</div>
    </div>
</div>

<!-- Fun Fact Dialog -->
<div id="funFactDialog" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-slate-900/50 backdrop-blur-sm opacity-0 transition-opacity duration-300">
    <div class="glass-card p-8 rounded-3xl max-w-md w-full mx-4 transform scale-90 transition-transform duration-300" id="funFactContent">
        <div class="text-center">
            <div class="w-16 h-16 bg-amber-100 dark:bg-amber-900/30 rounded-full flex items-center justify-center mx-auto mb-6 animate-bounce-slow">
                <span class="text-3xl">💡</span>
            </div>
            <h3 class="text-xl font-black text-slate-900 dark:text-white mb-4">Le saviez-vous ?</h3>
            <p class="text-slate-600 dark:text-slate-300 font-medium leading-relaxed mb-8">
                {{ funFact }}
            </p>
            <button onclick="closeFunFact()" class="btn-primary w-full py-3 rounded-xl font-bold">
                Continuer
            </button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Show dialog with a slight delay for better UX
        setTimeout(() => {
            const dialog = document.getElementById('funFactDialog');
            const content = document.getElementById('funFactContent');
            
            dialog.classList.remove('hidden');
            // Trigger reflow
            void dialog.offsetWidth;
            
            dialog.classList.remove('opacity-0');
            content.classList.remove('scale-90');
            content.classList.add('scale-100');
        }, 800);
    });

    function closeFunFact() {
        const dialog = document.getElementById('funFactDialog');
        const content = document.getElementById('funFactContent');
        
        dialog.classList.add('opacity-0');
        content.classList.remove('scale-100');
        content.classList.add('scale-90');
        
        setTimeout(() => {
            dialog.classList.add('hidden');
        }, 300);
    }
</script>
{% endblock %}
