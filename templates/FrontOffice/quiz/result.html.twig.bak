{% extends 'base.html.twig' %}

{% block title %}Quiz Result{% endblock %}

{% block body %}
    <div class="container mx-auto p-4 max-w-2xl text-center">
        <div class="bg-gray-800 rounded-lg shadow-lg p-8 border border-gray-700">
            <div class="mb-6">
                 {% if totalPoints > 0 and (score / totalPoints) >= 0.5 %}
                    <div class="w-20 h-20 bg-green-900/50 text-green-400 rounded-full flex items-center justify-center mx-auto mb-4 border border-green-700">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <h1 class="text-3xl font-bold text-white mb-2">Good Job!</h1>
                    <p class="text-gray-300">You have successfully completed the quiz.</p>
                {% elseif totalPoints > 0 %}
                    <div class="w-20 h-20 bg-red-900/50 text-red-400 rounded-full flex items-center justify-center mx-auto mb-4 border border-red-700">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </div>
                    <h1 class="text-3xl font-bold text-white mb-2">Keep Trying!</h1>
                    <p class="text-gray-300">Don't give up, try again to improve your score.</p>
                {% else %}
                    <h1 class="text-3xl font-bold text-white mb-2">Completed</h1>
                    <p class="text-gray-300">Quiz completed. Score: {{ score }}</p>
                {% endif %}
            </div>

            <div class="bg-gray-700 rounded-lg p-6 mb-8 border border-gray-600">
                <p class="text-sm text-gray-400 uppercase tracking-wide mb-1">Your Score</p>
                <div class="text-4xl font-extrabold text-blue-400">
                    {{ score }} <span class="text-2xl text-gray-500 font-medium">/ {{ totalPoints }}</span>
                </div>
            </div>

            <div class="flex justify-center space-x-4">
                <a href="{{ path('app_front_office_quiz_index') }}" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-2 px-6 rounded transition duration-300 border border-gray-500">
                    Back to Quizzes
                </a>
                <a href="{{ path('app_front_office_quiz_take', {'id': quiz.id}) }}" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded transition duration-300">
                    Retake Quiz
                </a>
            </div>
        </div>
    </div>
{% endblock %}
