{% extends 'base.html.twig' %}

{% block title %}{{ quiz.titre }} - SkillPath Quiz{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark">
    <!-- Navigation Bar -->
    <nav class="glass border-b border-slate-200/30 dark:border-white/5 sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <a href="{{ path('app_home') }}" class="flex items-center gap-3 group">
                    <div class="w-9 h-9 gradient-primary rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/20 group-hover:scale-110 transition-transform">
                        <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-5 h-5 invert brightness-0">
                    </div>
                    <span class="text-lg font-black text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
                </a>
                <div class="flex items-center gap-4">
                    <a href="{{ path('app_front_office_quiz_index') }}" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors">← Retour aux Quiz</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <!-- Quiz Header -->
        <div class="glass-card rounded-2xl overflow-hidden mb-8 animate-fade-up">
            <div class="gradient-primary px-8 py-6">
                <div class="flex items-start justify-between">
                    <div>
                        <span class="badge bg-white/15 text-white backdrop-blur-sm mb-3 inline-flex">📝 Quiz</span>
                        <h1 class="text-2xl font-black text-white mb-2">{{ quiz.titre }}</h1>
                        <p class="text-white/70 text-sm">{{ quiz.description }}</p>
                    </div>
                </div>
            </div>
            <div class="px-8 py-4 flex items-center gap-6">
                <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="font-semibold">{{ quiz.duree }} min</span>
                </div>
                <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                    <span class="font-semibold">{{ quiz.noteMax }} pts max</span>
                </div>
                <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="font-semibold">{{ quiz.questions|length }} questions</span>
                </div>
            </div>
        </div>

        <!-- Progress Bar & Timer Container -->
        <div class="grid grid-cols-1 {% if quiz.duree > 0 %}md:grid-cols-3{% endif %} gap-6 mb-8">
            <div class="{% if quiz.duree > 0 %}md:col-span-2{% endif %} glass-card rounded-2xl px-6 py-4 animate-fade-up delay-100">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-black uppercase tracking-[0.15em] text-slate-400 dark:text-slate-500">Progression</span>
                    <span class="text-xs font-bold text-primary dark:text-primary-light" id="progressText">0 / {{ quiz.questions|length }}</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-bar-fill" id="progressBar" style="width: 0%"></div>
                </div>
            </div>
            
            {% if quiz.duree > 0 %}
            <!-- Advanced Feature: Real-time Anti-Cheat Timer -->
            <div class="glass-card rounded-2xl px-6 py-4 animate-fade-up delay-200 flex flex-col justify-center items-center relative overflow-hidden group border-2 border-transparent transition-colors" id="timerBox">
                <div class="absolute inset-0 bg-primary/5 dark:bg-primary/10 transition-colors group-hover:bg-primary/10" id="timerBg"></div>
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-1 z-10" id="timerLabel">Temps Restant</span>
                <div class="flex items-center gap-3 z-10" id="timerContainer">
                    <svg id="timerIcon" class="w-6 h-6 text-primary animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="text-3xl font-black text-slate-900 dark:text-white tracking-widest font-mono" id="countdownTimer">--:--</span>
                </div>
            </div>
            {% endif %}
        </div>

        <!-- Quiz Form -->
        <form method="post" action="{{ path('app_front_office_quiz_take', {'id': quiz.id}) }}" id="quizForm">
            {% for question in quiz.questions %}
                <div class="glass-card rounded-2xl p-6 mb-4 question-card" style="display: none;" data-index="{{ loop.index }}" data-id="{{ question.id }}" data-points="{{ question.points }}" data-correct="{{ question.bonneReponse|e('html_attr') }}">
                    <div class="flex items-start gap-4 mb-4">
                        <span class="w-10 h-10 rounded-xl gradient-primary flex items-center justify-center text-white text-sm font-black flex-shrink-0 shadow-lg shadow-purple-500/15 question-counter">{{ loop.index }}</span>
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-2">
                                <span class="badge badge-purple px-2 py-0.5 !text-[10px]"><span class="animate-pulse mr-1 border border-white/40 w-1.5 h-1.5 rounded-full inline-block bg-white"></span> IA Active</span>
                                <span class="badge badge-amber !text-[10px]">{{ question.points }} pts - Difficulté Estimée</span>
                            </div>
                            <h3 class="text-base font-bold text-slate-900 dark:text-white leading-relaxed">{{ question.enonce }}</h3>
                        </div>
                    </div>
                    
                    <div class="space-y-2 ml-14">
                        {% set choices = [
                            {'letter': 'A', 'text': question.choixA},
                            {'letter': 'B', 'text': question.choixB},
                            {'letter': 'C', 'text': question.choixC},
                            {'letter': 'D', 'text': question.choixD}
                        ] %}
                        {% for choice in choices %}
                            {% if choice.text %}
                            <label class="flex items-center gap-3 p-3.5 rounded-xl cursor-pointer border-2 border-transparent hover:border-primary/20 hover:bg-primary/[0.03] dark:hover:bg-primary/[0.05] transition-all group quiz-option" data-question="{{ question.id }}" data-letter="{{ choice.letter }}">
                                <input type="radio" name="question_{{ question.id }}" value="{{ choice.letter }}" class="hidden quiz-radio">
                                <span class="w-8 h-8 rounded-lg border-2 border-slate-200 dark:border-slate-600 flex items-center justify-center text-xs font-black text-slate-400 dark:text-slate-500 group-hover:border-primary group-hover:text-primary transition-all option-letter">{{ choice.letter }}</span>
                                <span class="text-sm font-medium text-slate-700 dark:text-slate-300 group-hover:text-slate-900 dark:group-hover:text-white transition-colors option-text">{{ choice.text }}</span>
                            </label>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}

            <!-- Dynamic Adaptive Controls -->
            <div class="text-center py-8">
                <button type="button" id="btnNextAi" class="btn-primary text-base !py-4 !px-10 inline-flex items-center gap-3 shadow-lg shadow-purple-500/30 w-full md:w-auto" style="display: none;">
                    <div>
                        <span class="block text-sm font-black">Valider & Analyser</span>
                        <span class="block text-[10px] text-white/70 uppercase tracking-widest mt-0.5">Laver l'algorithme...</span>
                    </div>
                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </button>

                <button type="submit" id="btnSubmitForm" class="btn-primary text-base !bg-green-500 !border-green-500 hover:!bg-green-600 !py-4 !px-10 inline-flex items-center gap-3 w-full md:w-auto mt-4" style="display: none;">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Soumettre mes Réponses au Système
                </button>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // --- True AI Adaptive Engine ---
    const allCards = document.querySelectorAll('.question-card');
    const btnNext = document.getElementById('btnNextAi');
    const btnSubmit = document.getElementById('btnSubmitForm');
    const progressBar = document.getElementById('progressBar');
    const progressText = document.getElementById('progressText');
    const quizForm = document.getElementById('quizForm');
    
    let questionsPool = [];
    allCards.forEach(card => {
        questionsPool.push({
            el: card,
            id: card.dataset.id,
            points: parseInt(card.dataset.points, 10) || 1,
            correct: card.dataset.correct,
            asked: false
        });
    });

    // Start slightly easier than average
    const totalPoints = questionsPool.reduce((sum, q) => sum + q.points, 0);
    let targetDifficulty = questionsPool.length > 0 ? Math.max(1, Math.floor(totalPoints / questionsPool.length) - 1) : 1;
    
    let currentQuestion = null;
    let questionStartTime = 0;
    let askedCount = 0;
    const totalQuestions = questionsPool.length;

    function showNextQuestion() {
        // Hide actual if exists
        if (currentQuestion) {
            currentQuestion.el.style.display = 'none';
        }
        btnNext.style.display = 'none';

        // Find unasked questions
        const available = questionsPool.filter(q => !q.asked);
        
        if (available.length === 0) {
            // End of quiz
            btnSubmit.style.display = 'inline-flex';
            if (progressBar) progressBar.style.width = '100%';
            if (progressText) progressText.textContent = `${totalQuestions} / ${totalQuestions}`;
            return;
        }

        // AI Core: Find question closest to target difficulty
        available.sort((a, b) => {
            const diffA = Math.abs(a.points - targetDifficulty);
            const diffB = Math.abs(b.points - targetDifficulty);
            return diffA - diffB; // Closest first
        });

        // Pick the best match (or random among ties)
        currentQuestion = available[0];
        currentQuestion.asked = true;
        askedCount++;

        // Update UI
        currentQuestion.el.style.display = 'block';
        currentQuestion.el.classList.add('animate-fade-up');
        
        // Update Counter
        const counter = currentQuestion.el.querySelector('.question-counter');
        if (counter) counter.textContent = askedCount;

        if (progressBar) progressBar.style.width = ((askedCount - 1) / totalQuestions * 100) + '%';
        if (progressText) progressText.textContent = `${askedCount - 1} / ${totalQuestions}`;

        questionStartTime = Date.now();
    }

    // Option Click UI Logic
    const options = document.querySelectorAll('.quiz-option');
    options.forEach(option => {
        option.addEventListener('click', function() {
            const radio = this.querySelector('.quiz-radio');
            radio.checked = true;

            const questionId = this.dataset.question;
            const siblings = document.querySelectorAll(`[data-question="${questionId}"]`);
            siblings.forEach(sib => {
                sib.classList.remove('bg-purple-600', 'border-purple-600', 'shadow-md', 'scale-[1.01]');
                sib.classList.add('border-transparent');
                
                const textSpan = sib.querySelector('.option-text');
                if (textSpan) {
                    textSpan.classList.remove('text-white');
                    textSpan.classList.add('text-slate-700', 'dark:text-slate-300');
                }
                
                const letter = sib.querySelector('.option-letter');
                if (letter) {
                    letter.classList.remove('bg-white', 'text-purple-600', 'border-white');
                    letter.classList.add('border-slate-200', 'dark:border-slate-600', 'text-slate-400');
                }
            });

            this.classList.remove('border-transparent');
            this.classList.add('bg-purple-600', 'border-purple-600', 'shadow-md', 'scale-[1.01]');
            
            const textSpan = this.querySelector('.option-text');
            if (textSpan) {
                textSpan.classList.remove('text-slate-700', 'dark:text-slate-300');
                textSpan.classList.add('text-white');
            }

            const letter = this.querySelector('.option-letter');
            if (letter) {
                letter.classList.remove('border-slate-200', 'dark:border-slate-600', 'text-slate-400');
                letter.classList.add('bg-white', 'text-purple-600', 'border-white');
            }

            // Show NEXT button
            btnNext.style.display = 'inline-flex';
        });
    });

    // AI Next Analysis
    btnNext.addEventListener('click', function() {
        if (!currentQuestion) return;

        // Find Selected Value
        const radioName = `question_${currentQuestion.id}`;
        const checkedRadio = document.querySelector(`input[name="${radioName}"]:checked`);
        
        if (!checkedRadio) return; // Should not happen since button is hidden

        const userAnswer = checkedRadio.value;
        const timeTaken = (Date.now() - questionStartTime) / 1000;
        const isCorrect = (userAnswer === currentQuestion.correct);

        // AI Decision Matrix (Calculated Adjustment)
        let diffAdjust = 0;
        
        if (isCorrect) {
            if (timeTaken < 15) diffAdjust = 2; // Fast & Correct -> Significantly Harder
            else if (timeTaken < 30) diffAdjust = 1; // Normal & Correct -> Harder
            else diffAdjust = 0; // Slow & Correct -> Stable
        } else {
            if (timeTaken < 10) diffAdjust = -1; // Fast & Wrong (Guessing) -> Easier
            else diffAdjust = -2; // Slow & Wrong -> Significantly Easier
        }

        targetDifficulty = Math.max(1, targetDifficulty + diffAdjust);
        
        // Minor visual feedback of calculation on button
        const originalText = btnNext.innerHTML;
        btnNext.innerHTML = `<svg class="w-5 h-5 animate-spin mx-auto text-purple-600" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>`;
        setTimeout(() => {
            btnNext.innerHTML = originalText;
            showNextQuestion();
        }, 600); // Simulate AI processing delay for UX
    });

    // Advanced Anti-Cheat Timer
    {% if quiz.duree > 0 %}
    (function() {
        const storageKey = 'quiz_timer_{{ quiz.id }}';
        const durationSec = {{ quiz.duree }} * 60;
        let endTimeStr = localStorage.getItem(storageKey);
        let endTime = parseInt(endTimeStr, 10);
        
        const now = Date.now();
        if (!endTime || isNaN(endTime) || endTime < (now - 3600000)) { 
            endTime = now + (durationSec * 1000);
            localStorage.setItem(storageKey, endTime);
        }
        
        const timerDisplay = document.getElementById('countdownTimer');
        const timerIcon = document.getElementById('timerIcon');
        const timerBox = document.getElementById('timerBox');
        if (!timerDisplay) return;

        let timerInterval = setInterval(() => {
            const currentNow = Date.now();
            let timeLeft = Math.floor((endTime - currentNow) / 1000);
            
            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                localStorage.removeItem(storageKey);
                alert("⏰ Temps écoulé (Mode IA) ! Soumission...");
                quizForm.submit();
                return;
            }
            
            const m = Math.floor(timeLeft / 60);
            const s = timeLeft % 60;
            timerDisplay.textContent = m.toString().padStart(2, '0') + ':' + s.toString().padStart(2, '0');
            
            if (timeLeft <= 60 && timerBox) { 
                timerDisplay.classList.add('text-red-500');
                if(timerIcon) timerIcon.classList.add('text-red-500', 'animate-bounce');
                timerBox.classList.add('border-red-500/50');
            }
        }, 1000);
        
        quizForm.addEventListener('submit', () => localStorage.removeItem(storageKey));
    })();
    {% endif %}

    // Start Engine
    showNextQuestion();
});
</script>
{% endblock %}
