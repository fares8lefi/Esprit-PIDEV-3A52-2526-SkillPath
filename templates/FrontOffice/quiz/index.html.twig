{% extends 'base.html.twig' %}

{% block title %}Available Quizzes{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 py-8">
        <h1 class="text-4xl font-bold text-center mb-10">Available Quizzes</h1>

        {% if fun_fact %}
            <!-- API Integration: Fun Fact Banner -->
            <div class="mb-8 bg-blue-900/30 border-l-4 border-blue-500 p-6 rounded-r-lg shadow-lg backdrop-blur-sm">
                <div class="flex items-center gap-4">
                    <div class="bg-blue-500 p-3 rounded-full flex-shrink-0">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-blue-400 font-bold mb-1 uppercase tracking-wider text-sm">Le saviez-vous ? (Culture G)</h3>
                        <p class="text-white italic text-lg leading-relaxed">"{{ fun_fact }}"</p>
                    </div>
                </div>
            </div>
        {% endif %}

        <!-- Search and Sort Form -->
        <div class="mb-8 bg-gray-800 p-4 rounded-lg shadow-md border border-gray-700">
            <form method="get" action="{{ path('app_front_office_quiz_index') }}" class="flex flex-col md:flex-row gap-4 items-center justify-between">
                <div class="w-full md:w-1/2">
                    <input type="text" name="search" value="{{ current_search }}" placeholder="Rechercher..." 
                           class="w-full bg-gray-700 text-white border border-gray-600 rounded px-4 py-2 focus:outline-none focus:border-blue-500 placeholder-gray-400">
                </div>
                <div class="flex gap-4 w-full md:w-auto">
                    <select name="sort" onchange="this.form.submit()" class="bg-gray-700 text-white border border-gray-600 rounded px-4 py-2 focus:outline-none focus:border-blue-500 cursor-pointer">
                        <option value="" disabled {% if not current_sort %}selected{% endif %}>Trier par durée</option>
                        <option value="duree_asc" {% if current_sort == 'duree_asc' %}selected{% endif %}>Durée (Courte)</option>
                        <option value="duree_desc" {% if current_sort == 'duree_desc' %}selected{% endif %}>Durée (Longue)</option>
                    </select>
                </div>
            </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for quiz in quizzes %}
                <div class="bg-gray-800 rounded-lg shadow-md p-6 hover:shadow-lg transition duration-300 border border-gray-700">
                    <h2 class="text-xl font-bold mb-2 text-white">{{ quiz.titre }}</h2>
                    <p class="text-gray-300 mb-4 line-clamp-3">{{ quiz.description }}</p>
                    <div class="flex justify-between items-center text-sm text-gray-400 mb-4">
                        <span><i class="fas fa-clock mr-1"></i> {{ quiz.duree }} min</span>
                        <span><i class="fas fa-star mr-1"></i> {{ quiz.noteMax }} pts</span>
                    </div>
                    <a href="{{ path('app_front_office_quiz_take', {'id': quiz.id}) }}" class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded transition duration-300">
                        Start Quiz
                    </a>
                </div>
            {% else %}
                <div class="col-span-full text-center text-gray-400">
                    No quizzes available at the moment.
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
