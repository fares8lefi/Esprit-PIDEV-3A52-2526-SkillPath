{% extends 'base.html.twig' %}

{% block title %}Available Quizzes{% endblock %}

{% block body %}
    <div class="container mx-auto p-4">
        <h1 class="text-3xl font-bold text-center mb-8">Available Quizzes</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for quiz in quizzes %}
                <div class="bg-gray-800 rounded-lg shadow-md p-6 hover:shadow-lg transition duration-300 border border-gray-700">
                    <h2 class="text-xl font-bold mb-2 text-white">{{ quiz.titre }}</h2>
                    <p class="text-gray-300 mb-4 line-clamp-3">{{ quiz.description }}</p>
                    <div class="flex justify-between items-center text-sm text-gray-400 mb-4">
                        <span><i class="fas fa-clock mr-1"></i> {{ quiz.duree }} min</span>
                        <span><i class="fas fa-star mr-1"></i> {{ quiz.noteMax }} pts</span>
                    </div>
                    <a href="{{ path('app_front_office_quiz_take', {'id': quiz.id}) }}" class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded transition duration-300">
                        Start Quiz
                    </a>
                </div>
            {% else %}
                <div class="col-span-full text-center text-gray-400">
                    No quizzes available at the moment.
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
