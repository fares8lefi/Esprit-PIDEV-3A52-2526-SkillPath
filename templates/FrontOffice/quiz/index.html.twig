{% extends 'base.html.twig' %}

{% block title %}Quiz Disponibles - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark">
    <!-- Navigation Bar -->
    <nav class="glass border-b border-slate-200/30 dark:border-white/5 sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <a href="{{ path('app_home') }}" class="flex items-center gap-3 group">
                    <div class="w-9 h-9 gradient-primary rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/20 group-hover:scale-110 transition-transform">
                        <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-5 h-5 invert brightness-0">
                    </div>
                    <span class="text-lg font-black text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
                </a>
                <div class="flex items-center gap-4">
                    <a href="{{ path('app_home') }}" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors">Accueil</a>
                    <span class="text-slate-300 dark:text-slate-600">|</span>
                    <span class="text-sm font-bold text-primary dark:text-primary-light">Quiz</span>
                    <span class="text-slate-300 dark:text-slate-600">|</span>
                    <a href="{{ path('app_front_office_quiz_history') }}" class="text-sm font-semibold text-slate-500 dark:text-slate-400 hover:text-primary transition-colors">Mes Résultats</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <!-- Header -->
        <div class="text-center mb-10 animate-fade-up">
            <span class="badge badge-purple mb-4 inline-flex">🎯 Évaluation</span>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-3">Quiz <span class="gradient-text">Disponibles</span></h1>
            <p class="text-lg text-slate-500 dark:text-slate-400 max-w-xl mx-auto">Testez vos connaissances et évaluez votre progression</p>
        </div>

        {% if fun_fact %}
        <!-- Fun Fact Banner -->
        <div class="glass-card rounded-2xl p-6 mb-8 animate-fade-up delay-100">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl gradient-primary flex items-center justify-center flex-shrink-0 shadow-lg shadow-purple-500/20">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <div>
                    <h3 class="text-[10px] font-black uppercase tracking-[0.15em] text-primary dark:text-primary-light mb-1">💡 Le saviez-vous ?</h3>
                    <p class="text-sm text-slate-700 dark:text-slate-300 italic leading-relaxed">"{{ fun_fact }}"</p>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- Search & Sort -->
        <div class="glass-card rounded-2xl p-5 mb-8 animate-fade-up delay-200">
            <form method="get" action="{{ path('app_front_office_quiz_index') }}" class="flex flex-col sm:flex-row gap-4 items-center">
                <div class="flex-1 w-full">
                    <div class="flex items-center gap-3 bg-slate-100/60 dark:bg-white/5 px-4 py-3 rounded-xl focus-within:ring-2 focus-within:ring-primary/20 focus-within:bg-white dark:focus-within:bg-white/8 transition-all">
                        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        <input type="text" name="search" value="{{ current_search }}" placeholder="Rechercher un quiz..." class="bg-transparent border-none focus:outline-none text-sm w-full text-slate-900 dark:text-white placeholder-slate-400 font-medium">
                    </div>
                </div>
                <select name="tri" onchange="this.form.submit()" class="form-input !w-auto !py-3 min-w-[180px] cursor-pointer text-sm">
                    <option value="" disabled {% if not current_sort %}selected{% endif %}>Trier par...</option>
                    <option value="duree_asc" {% if current_sort == 'duree_asc' %}selected{% endif %}>Durée ↑ (Courte)</option>
                    <option value="duree_desc" {% if current_sort == 'duree_desc' %}selected{% endif %}>Durée ↓ (Longue)</option>
                    <option value="titre_asc" {% if current_sort == 'titre_asc' %}selected{% endif %}>Titre A-Z</option>
                    <option value="titre_desc" {% if current_sort == 'titre_desc' %}selected{% endif %}>Titre Z-A</option>
                </select>
            </form>
        </div>

        <!-- Quiz Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for quiz in quizzes %}
                <div class="glass-card rounded-2xl overflow-hidden animate-fade-up delay-{{ loop.index0 * 100 }}">
                    <!-- Card Header -->
                    <div class="h-2 gradient-primary"></div>
                    <div class="p-6">
                        <div class="flex items-start justify-between mb-3">
                            <h2 class="text-lg font-black text-slate-900 dark:text-white">{{ quiz.titre }}</h2>
                            <span class="badge badge-purple flex-shrink-0 ml-2">{{ quiz.questions|length }} Q</span>
                        </div>
                        {% if quiz.course %}
                            <span class="badge badge-green text-[10px] mb-2 inline-flex">📚 {{ quiz.course.title }}</span>
                        {% endif %}
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-5 line-clamp-3 leading-relaxed">{{ quiz.description }}</p>
                        
                        <!-- Stats -->
                        <div class="flex items-center gap-4 mb-5 text-sm">
                            <div class="flex items-center gap-1.5 text-slate-400 dark:text-slate-500">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                <span class="font-semibold">{{ quiz.duree }} min</span>
                            </div>
                            <div class="flex items-center gap-1.5 text-slate-400 dark:text-slate-500">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                                <span class="font-semibold">{{ quiz.noteMax }} pts</span>
                            </div>
                        </div>

                        <!-- CTA Buttons -->
                        <div class="flex flex-col gap-2">
                            <a href="{{ path('app_front_office_quiz_take', {'id': quiz.id}) }}" class="btn-primary w-full text-center text-[13px] !py-3 inline-flex items-center justify-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                Mode Classique
                            </a>
                            <a href="{{ path('app_front_office_quiz_adaptive', {'id': quiz.id}) }}" class="btn-secondary w-full text-center text-[13px] !py-3 inline-flex items-center justify-center gap-2 !bg-purple-500/10 !text-purple-600 dark:!text-purple-400 !border !border-purple-500/30 hover:!bg-purple-500/20 shadow-[0_0_15px_rgba(168,85,247,0.15)] group relative overflow-hidden">
                                <span class="absolute inset-0 bg-gradient-to-r from-purple-500/0 via-purple-500/10 to-purple-500/0 -translate-x-[100%] group-hover:translate-x-[100%] transition-transform duration-700"></span>
                                <svg class="w-4 h-4 animate-pulse relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                <span class="relative z-10 font-black">Mode IA Adaptatif ✨</span>
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-span-full">
                    <div class="glass-card rounded-2xl p-12 text-center">
                        <div class="w-20 h-20 rounded-2xl bg-slate-100 dark:bg-white/5 flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                        </div>
                        <p class="text-lg font-bold text-slate-400 dark:text-slate-500">Aucun quiz disponible pour le moment</p>
                        <p class="text-sm text-slate-400 dark:text-slate-600 mt-1">Revenez bientôt !</p>
                    </div>
                </div>
            {% endfor %}
        </div>

        <!-- Pagination -->
        <div class="mt-12 flex justify-center">
            {{ knp_pagination_render(quizzes, '@KnpPaginator/Pagination/tailwindcss_pagination.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
