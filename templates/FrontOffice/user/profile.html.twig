{% extends 'base.html.twig' %}

{% block title %}Mon Profil Premium - SkillPath{% endblock %}

{% block stylesheets %}
<style>
    .mesh-background {
        background-color: #ffffff;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 136, 229, 0.08) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(67, 160, 71, 0.08) 0px, transparent 50%),
            radial-gradient(at 50% 50%, rgba(251, 192, 45, 0.03) 0px, transparent 50%);
    }
    .dark .mesh-background {
        background-color: #020617;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 136, 229, 0.04) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(67, 160, 71, 0.04) 0px, transparent 50%),
            radial-gradient(at 50% 50%, rgba(251, 192, 45, 0.01) 0px, transparent 50%);
    }
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.5);
    }
    .dark .glass-card {
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .profile-glow {
        position: relative;
    }
    .profile-glow::after {
        content: '';
        position: absolute;
        inset: -2px;
        background: linear-gradient(135deg, #1E88E5, #43A047);
        z-index: -1;
        border-radius: 2.5rem;
        opacity: 0.3;
        filter: blur(10px);
    }
    .vibrant-shimmer {
        background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
    }
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen mesh-background pb-20">
    <!-- Premium Header -->
    <nav class="sticky top-0 z-[100] px-6 lg:px-12 py-4 bg-white/50 dark:bg-slate-950/50 backdrop-blur-md border-b border-white/20 dark:border-slate-800/50">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="{{ path('app_home') }}" class="flex items-center gap-3 group transition-transform hover:scale-105">
                <div class="w-10 h-10 vibrant-shimmer rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20">
                    <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-6 h-6 invert brightness-0">
                </div>
                <span class="text-2xl font-black tracking-tight text-slate-900 dark:text-white">SkillPath</span>
            </a>

            <div class="flex items-center gap-6">
                <a href="{{ path('app_home') }}" class="text-xs font-black uppercase tracking-widest text-slate-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Accueil</a>
                <div class="h-8 w-[1px] bg-slate-200 dark:bg-slate-800"></div>
                <a href="{{ path('app_logout') }}" class="text-xs font-black uppercase tracking-widest text-red-500 hover:text-red-600 transition-colors">Déconnexion</a>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 lg:px-12 pt-16">
        <!-- Dashboard Header -->
        <div class="mb-16 animate-in fade-in slide-in-from-left-8 duration-700">
            <h1 class="text-5xl font-black text-slate-900 dark:text-white mb-4 tracking-tight">Mon <span class="text-transparent bg-clip-text vibrant-shimmer">Espace Personnel</span></h1>
            <p class="text-slate-500 dark:text-slate-400 font-medium text-lg">Gérez votre profil et suivez votre évolution sur la plateforme.</p>
        </div>

        {% for message in app.flashes('success') %}
            <div class="max-w-3xl bg-green-50 text-green-600 px-6 py-4 rounded-3xl mb-8 font-bold border border-green-100 flex items-center gap-4 animate-in slide-in-from-top-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="max-w-3xl bg-red-50 text-red-600 px-6 py-4 rounded-3xl mb-8 font-bold border border-red-100 flex items-center gap-4 animate-in slide-in-from-top-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                {{ message }}
            </div>
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <!-- Profile Sidebar -->
            <div class="lg:col-span-1 space-y-8 animate-in fade-in zoom-in duration-1000">
                <div class="glass-card p-10 rounded-[3rem] text-center profile-glow overflow-hidden relative">
                    <div class="absolute top-0 left-0 w-full h-24 vibrant-shimmer opacity-10"></div>
                    
                    <div class="relative z-10">
                        <div class="w-32 h-32 rounded-[2.5rem] vibrant-shimmer p-1 shadow-2xl mx-auto mb-6 transform hover:rotate-6 transition-transform">
                            <div class="w-full h-full rounded-[2.2rem] bg-white dark:bg-slate-900 flex items-center justify-center text-4xl font-black text-slate-900 dark:text-white">
                                {{ user.username|first|upper }}
                            </div>
                        </div>
                        <h3 class="text-2xl font-black text-slate-900 dark:text-white mb-1">{{ user.username }}</h3>
                        <p class="text-slate-500 dark:text-slate-400 font-medium mb-8">{{ user.email }}</p>

                        <div class="grid grid-cols-2 gap-4">
                            <div class="bg-blue-50/50 dark:bg-blue-900/10 p-4 rounded-2xl border border-blue-50 dark:border-blue-900/30">
                                <p class="text-[10px] font-black uppercase tracking-widest text-blue-600 dark:text-blue-400 mb-1">Rangement</p>
                                <p class="text-xl font-black text-slate-900 dark:text-white">#42</p>
                            </div>
                            <div class="bg-green-50/50 dark:bg-green-900/10 p-4 rounded-2xl border border-green-50 dark:border-green-900/30">
                                <p class="text-[10px] font-black uppercase tracking-widest text-green-600 dark:text-green-400 mb-1">Badge</p>
                                <p class="text-xl font-black text-slate-900 dark:text-white">Starter</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="glass-card p-8 rounded-[2.5rem] border-white/50">
                    <h4 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-6 px-2">Statistiques de formation</h4>
                    <div class="space-y-6">
                        <div class="space-y-2">
                            <div class="flex justify-between text-xs font-black text-slate-600 dark:text-slate-400 uppercase">
                                <span>Progression globale</span>
                                <span>65%</span>
                            </div>
                            <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
                                <div class="h-full vibrant-shimmer w-2/3 rounded-full"></div>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <div class="flex justify-between text-xs font-black text-slate-600 dark:text-slate-400 uppercase">
                                <span>Modules complétés</span>
                                <span>4/12</span>
                            </div>
                            <div class="w-full h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                                <div class="h-full bg-slate-300 w-1/3 rounded-full"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Settings Form -->
            <div class="lg:col-span-2 animate-in fade-in slide-in-from-right-8 duration-1000">
                <div class="glass-card p-10 lg:p-14 rounded-[3.5rem] shadow-2xl relative overflow-hidden">
                    <form action="{{ path('app_user_profile') }}" method="POST" class="space-y-10">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-2">
                                <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-1">Nom d'utilisateur</label>
                                <input type="text" name="username" value="{{ user.username }}" required
                                       class="w-full bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl py-4 px-6 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/5 transition-all outline-none font-bold text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600"
                                       placeholder="ex: Jean_Duplication">
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-1">Adresse Email</label>
                                <input type="email" name="email" value="{{ user.email }}" required
                                       class="w-full bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl py-4 px-6 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/5 transition-all outline-none font-bold text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600"
                                       placeholder="ex: jean@skillpath.net">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-1">Changer le mot de passe (si nécessaire)</label>
                            <input type="password" name="new_password" 
                                   class="w-full bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl py-4 px-6 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/5 transition-all outline-none dark:text-white placeholder-slate-400 dark:placeholder-slate-600"
                                   placeholder="8 caractères minimum — Laissez vide pour ne pas changer">
                        </div>

                        <div class="bg-slate-900 rounded-3xl p-8 relative overflow-hidden group">
                            <div class="absolute inset-0 vibrant-shimmer opacity-0 group-hover:opacity-5 transition-opacity"></div>
                            <div class="relative z-10">
                                <label class="flex items-center gap-2 text-xs font-black uppercase tracking-[0.2em] text-blue-400 mb-4">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                                    Vérification de sécurité
                                </label>
                                <input type="password" name="current_password" required
                                       class="w-full bg-white/10 border border-white/10 rounded-2xl py-4 px-6 focus:bg-white/20 focus:outline-none focus:border-white/20 transition-all outline-none text-white placeholder-slate-500"
                                       placeholder="Saisissez votre mot de passe actuel pour valider les changements">
                            </div>
                        </div>

                        <button type="submit" class="w-full vibrant-shimmer text-white font-black py-5 rounded-2xl shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all text-lg tracking-tight">
                            Enregistrer les modifications
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
