{% extends 'base.html.twig' %}

{% block title %}Mon Profil - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex flex-col">
    <!-- Header/Navbar -->
    <header class="bg-white shadow-sm border-b border-gray-200 py-4 px-8 flex justify-between items-center sticky top-0 z-50">
        <div class="flex items-center">
            <img src="{{ asset('images/logo.png') }}" alt="Logo" class="h-10 w-auto mr-3">
            <span class="text-2xl font-bold text-skill-blue">SkillPath</span>
        </div>
        <div class="flex items-center space-x-6">
            <a href="{{ path('app_user_login') }}" class="text-sm font-bold text-gray-500 hover:text-skill-blue transition-colors">Accueil</a>
            <div class="h-8 w-8 rounded-full bg-gradient-to-br from-skill-blue to-skill-green flex items-center justify-center text-white text-xs font-bold shadow-md">
                {{ user.username|first|upper }}
            </div>
            <a href="{{ path('app_logout') }}" class="text-xs font-bold text-red-500 hover:text-red-700 uppercase tracking-wider">Déconnexion</a>
        </div>
    </header>

    <main class="flex-1 p-8">
        <div class="max-w-4xl mx-auto">
            <div class="mb-8">
                <h1 class="text-3xl font-extrabold text-gray-900 border-b-4 border-skill-blue inline-block pb-2">Paramètres du Profil</h1>
                <p class="text-gray-500 mt-4 leading-relaxed italic">
                    Gérez vos informations personnelles et sécurisez votre compte.
                </p>
            </div>

            {% for message in app.flashes('success') %}
                <div class="bg-green-100 border border-green-200 text-green-700 px-6 py-4 rounded-2xl mb-8 flex items-center shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3 text-green-500" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="font-bold">{{ message }}</span>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="bg-red-100 border border-red-200 text-red-700 px-6 py-4 rounded-2xl mb-8 flex items-center shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3 text-red-500" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    <span class="font-bold">{{ message }}</span>
                </div>
            {% endfor %}

            <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100 flex flex-col md:flex-row">
                <!-- Sidebar Decor -->
                <div class="md:w-1/3 bg-gradient-to-b from-skill-blue to-skill-green p-10 text-white flex flex-col justify-between">
                    <div>
                        <div class="w-24 h-24 rounded-3xl bg-white/20 backdrop-blur-md p-1 mb-6 shadow-xl border border-white/30 mx-auto md:mx-0">
                            <div class="w-full h-full rounded-2xl bg-white flex items-center justify-center text-skill-blue text-4xl font-black">
                                {{ user.username|first|upper }}
                            </div>
                        </div>
                        <h3 class="text-xl font-bold mb-1 text-center md:text-left">{{ user.username }}</h3>
                        <p class="text-white/70 text-sm text-center md:text-left">{{ user.email }}</p>
                        <div class="mt-8 space-y-4 hidden md:block">
                            <div class="flex items-center text-sm font-medium text-white/90">
                                <span class="w-2 h-2 rounded-full bg-skill-yellow mr-3"></span>
                                Membre depuis {{ "now"|date("Y") }}
                            </div>
                            
                        </div>
                    </div>
                </div>

                <!-- Form Area -->
                <div class="md:w-2/3 p-10 md:p-12">
                    <form action="{{ path('app_user_profile') }}" method="POST" class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div>
                                <label for="username" class="block text-sm font-black text-gray-700 mb-3 uppercase tracking-wider">Nom d'utilisateur</label>
                                <input type="text" id="username" name="username" value="{{ user.username }}" required
                                    class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-4 focus:bg-white focus:border-skill-blue focus:outline-none transition-all font-medium text-gray-900 shadow-sm"
                                    placeholder="ex: phares_lefi">
                            </div>
                            <div>
                                <label for="email" class="block text-sm font-black text-gray-700 mb-3 uppercase tracking-wider">Adresse Email</label>
                                <input type="email" id="email" name="email" value="{{ user.email }}" required
                                    class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-4 focus:bg-white focus:border-skill-blue focus:outline-none transition-all font-medium text-gray-900 shadow-sm"
                                    placeholder="ex: contact@skillpath.tn">
                            </div>
                        </div>

                        <div class="space-y-8 pt-6 border-t border-gray-100">
                            <div>
                                <label for="new_password" class="block text-sm font-black text-gray-700 mb-3 uppercase tracking-wider">Nouveau Mot de Passe (optionnel)</label>
                                <input type="password" id="new_password" name="new_password"
                                    class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-4 focus:bg-white focus:border-skill-blue focus:outline-none transition-all placeholder-gray-300 shadow-sm"
                                    placeholder="Laissez vide pour conserver l'actuel">
                            </div>

                            <div class="bg-skill-blue/5 p-8 rounded-3xl border-2 border-skill-blue/10">
                                <label for="current_password" class="block text-sm font-black text-skill-blue mb-3 uppercase tracking-wider flex items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                                    </svg>
                                    Vérification de sécurité
                                </label>
                                <input type="password" id="current_password" name="current_password" required
                                    class="w-full bg-white border-2 border-skill-blue/20 rounded-2xl px-5 py-4 focus:border-skill-blue focus:outline-none transition-all shadow-md focus:ring-4 focus:ring-skill-blue/10"
                                    placeholder="Entrez votre mot de passe actuel pour valider">
                                <p class="text-[10px] text-gray-400 mt-3 font-bold uppercase tracking-tighter">Votre mot de passe est nécessaire pour toute modification</p>
                            </div>
                        </div>

                        <div class="pt-6">
                            <button type="submit" class="w-full bg-gradient-to-r from-skill-blue to-skill-green text-white font-black py-5 rounded-3xl shadow-xl shadow-skill-blue/30 transform transition-all active:scale-[0.98] hover:shadow-2xl hover:-translate-y-1 text-lg">
                                Enregistrer les modifications
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-white border-t border-gray-200 py-6 px-8 text-center text-gray-400 text-xs">
        &copy; {{ "now"|date("Y") }} SkillPath — Tous droits réservés.
    </footer>
</div>
{% endblock %}
