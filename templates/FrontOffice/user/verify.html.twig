{% extends 'base.html.twig' %}

{% block title %}Vérification du compte - SkillPath{% endblock %}

{% block stylesheets %}
<style>
    /* Autofill Fix */
    input:-webkit-autofill,
    input:-webkit-autofill:hover, 
    input:-webkit-autofill:focus, 
    input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px white inset !important;
        -webkit-text-fill-color: #0f172a !important;
        transition: background-color 5000s ease-in-out 0s;
    }
    .dark input:-webkit-autofill,
    .dark input:-webkit-autofill:hover, 
    .dark input:-webkit-autofill:focus, 
    .dark input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px #0B0F1A inset !important;
        -webkit-text-fill-color: white !important;
        transition: background-color 5000s ease-in-out 0s;
    }
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark flex items-center justify-center p-6 relative overflow-hidden">
    <!-- Abstract shapes -->
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/8 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-accent/8 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s"></div>
    
    <div class="max-w-md w-full relative z-10 animate-fade-up">
        <div class="glass-card p-10 lg:p-12 rounded-3xl shadow-2xl relative overflow-hidden text-center">
            <div class="absolute top-0 left-0 w-full h-2 gradient-primary"></div>
            
            <div class="mb-10">
                <div class="w-16 h-16 gradient-primary rounded-2xl flex items-center justify-center shadow-lg shadow-purple-500/20 mx-auto mb-6 transform hover:rotate-12 transition-transform">
                    <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-10 h-10 invert brightness-0">
                </div>
                <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Vérification</h2>
                <p class="text-slate-500 dark:text-slate-400 font-medium text-sm">
                    Un code sécurisé a été envoyé à<br>
                    <span class="text-primary dark:text-primary-light font-black">{{ email }}</span>
                </p>
            </div>

            {# Messages Flash #}
            {% for message in app.flashes('success') %}
                <div class="bg-mint/8 text-mint px-4 py-3 rounded-xl mb-6 text-xs font-bold border border-mint/15 animate-pulse">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('warning') %}
                <div class="bg-secondary/8 text-secondary px-4 py-3 rounded-xl mb-6 text-xs font-bold border border-secondary/15">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="bg-coral/8 text-coral px-4 py-3 rounded-xl mb-6 text-xs font-bold border border-coral/15">
                    {{ message }}
                </div>
            {% endfor %}

            <form action="{{ path('app_user_verify') }}" method="POST" class="space-y-6">
                <input type="hidden" name="email" value="{{ email }}">
                
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 ml-1">Code de sécurité</label>
                    <input type="text" name="code" required maxlength="6" autofocus
                           class="form-input text-center !text-3xl !font-black !tracking-[0.4em] !py-5"
                           placeholder="000000">
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">6 chiffres requis</p>
                </div>

                <button type="submit" class="btn-primary w-full !py-4">
                    Confirmer l'identité
                </button>
            </form>

            <form method="POST" action="{{ path('app_user_resend_verification') }}" class="mt-10 pt-8 border-t border-slate-100/50 dark:border-white/5">
                <input type="hidden" name="email" value="{{ email }}">
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400">
                    Code non reçu ?
                    <button type="submit" class="text-primary dark:text-primary-light font-black hover:underline ml-1">
                        Renvoyer
                    </button>
                </p>
            </form>

            <div class="mt-8 flex items-center justify-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-300 dark:text-slate-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                Vérification Sécurisée
            </div>
        </div>
    </div>
</div>
{% endblock %}
