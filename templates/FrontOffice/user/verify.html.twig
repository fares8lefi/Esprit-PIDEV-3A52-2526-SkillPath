{% extends 'base.html.twig' %}

{% block title %}Vérification du compte - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-skill-blue via-skill-green to-skill-yellow/30 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl max-w-md w-full p-10">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center mb-4">
                <img src="{{ asset('images/logo.png') }}" alt="SkillPath Logo" class="h-16 w-auto">
            </div>
            <h2 class="text-3xl font-extrabold text-skill-blue mb-2">Vérification du compte</h2>
            <p class="text-gray-500 text-sm">
                Un code de vérification a été envoyé à<br>
                <strong class="text-skill-blue">{{ email }}</strong>
            </p>
            
        </div>

        {# Messages Flash #}
        {% for message in app.flashes('success') %}
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl mb-4" role="alert">
                <span class="block sm:inline">{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="bg-yellow-100 border border-yellow-400 text-yellow-700 px-4 py-3 rounded-xl mb-4 text-sm" role="alert">
                <span class="block sm:inline">{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl mb-4" role="alert">
                <span class="block sm:inline">{{ message }}</span>
            </div>
        {% endfor %}

        {# Formulaire de vérification simplifié #}
        <form id="verifyForm" method="POST" action="{{ path('app_user_verify') }}" class="space-y-6">
            <input type="hidden" name="email" value="{{ email }}">
            
            <div>
                <label class="block font-bold text-gray-700 mb-2 text-center">Code de vérification</label>
                <input 
                    type="text" 
                    name="code" 
                    id="codeInput"
                    placeholder="000000" 
                    maxlength="6"
                    required
                    autofocus
                    class="w-full text-center text-3xl tracking-widest font-bold border-2 border-gray-200 rounded-xl px-4 py-4 focus:border-skill-blue focus:outline-none transition-colors"
                >
                <p class="text-xs text-gray-400 mt-2 text-center">Entrez le code à 6 chiffres reçu par email</p>
            </div>

            <button 
                type="submit" 
                id="submitBtn"
                class="w-full bg-gradient-to-r from-skill-blue to-skill-green text-white font-bold py-3 rounded-xl shadow-lg shadow-skill-blue/30 transform transition-transform active:scale-95"
            >
                Vérifier le compte
            </button>
        </form>

        <form method="POST" action="{{ path('app_user_resend_verification') }}" class="mt-6">
            <input type="hidden" name="email" value="{{ email }}">
            <p class="text-center text-sm text-gray-500">
                Code non reçu ?
                <button type="submit" class="text-skill-blue font-bold hover:underline ml-1">
                    Renvoyer le code
                </button>
            </p>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-100">
            <div class="flex items-center justify-center space-x-2 text-xs text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <span>Vérification sécurisée</span>
            </div>
        </div>
    </div>
</div>

<script>
// Assurez-vous que le formulaire se soumet correctement
document.getElementById('verifyForm').addEventListener('submit', function(e) {
    var code = document.getElementById('codeInput').value;
    console.log('Submitting code:', code);
    // Ne pas empêcher la soumission - laisser le formulaire se soumettre normalement
});
</script>
{% endblock %}
