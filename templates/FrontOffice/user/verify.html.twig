{% extends 'base.html.twig' %}

{% block title %}Vérification du compte - SkillPath Premium{% endblock %}

{% block stylesheets %}
<style>
    .mesh-background {
        background-color: #ffffff;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 136, 229, 0.1) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(67, 160, 71, 0.1) 0px, transparent 50%),
            radial-gradient(at 50% 50%, rgba(251, 192, 45, 0.05) 0px, transparent 50%),
            radial-gradient(at 100% 100%, rgba(30, 136, 229, 0.1) 0px, transparent 50%);
    }
    .dark .mesh-background {
        background-color: #020617;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 136, 229, 0.05) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(67, 160, 71, 0.05) 0px, transparent 50%),
            radial-gradient(at 50% 50%, rgba(251, 192, 45, 0.02) 0px, transparent 50%),
            radial-gradient(at 100% 100%, rgba(30, 136, 229, 0.05) 0px, transparent 50%);
    }
    .glass-login {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.4);
    }
    .dark .glass-login {
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .vibrant-shimmer {
        background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
        box-shadow: 0 10px 40px rgba(30, 136, 229, 0.3);
    }
    /* Autofill Fix */
    input:-webkit-autofill,
    input:-webkit-autofill:hover, 
    input:-webkit-autofill:focus, 
    input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px white inset !important;
        -webkit-text-fill-color: #0f172a !important;
        transition: background-color 5000s ease-in-out 0s;
    }
    .dark input:-webkit-autofill,
    .dark input:-webkit-autofill:hover, 
    .dark input:-webkit-autofill:focus, 
    .dark input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px #020617 inset !important;
        -webkit-text-fill-color: white !important;
        transition: background-color 5000s ease-in-out 0s;
    }
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen mesh-background flex items-center justify-center p-6 relative overflow-hidden">
    <!-- Abstract shapes -->
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-400/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-green-400/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s"></div>
    
    <div class="max-w-md w-full relative z-10 animate-in fade-in zoom-in duration-700">
        <div class="glass-login p-10 lg:p-12 rounded-[3.5rem] shadow-2xl relative overflow-hidden text-center">
            <div class="absolute top-0 left-0 w-full h-2 vibrant-shimmer"></div>
            
            <div class="mb-10">
                <div class="w-16 h-16 vibrant-shimmer rounded-2xl flex items-center justify-center shadow-lg mx-auto mb-6 transform hover:rotate-12 transition-transform">
                    <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-10 h-10 invert brightness-0">
                </div>
                <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Vérification</h2>
                <p class="text-slate-500 dark:text-slate-400 font-medium text-sm">
                    Un code sécurisé a été envoyé à<br>
                    <span class="text-blue-600 dark:text-blue-400 font-black">{{ email }}</span>
                </p>
            </div>

            {# Messages Flash #}
            {% for message in app.flashes('success') %}
                <div class="bg-green-50 text-green-600 px-4 py-3 rounded-2xl mb-6 text-xs font-bold border border-green-100 animate-pulse">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('warning') %}
                <div class="bg-yellow-50 text-yellow-600 px-4 py-3 rounded-2xl mb-6 text-xs font-bold border border-yellow-100">
                    {{ message }}
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="bg-red-50 text-red-600 px-4 py-3 rounded-2xl mb-6 text-xs font-bold border border-red-100">
                    {{ message }}
                </div>
            {% endfor %}

            <form action="{{ path('app_user_verify') }}" method="POST" class="space-y-6">
                <input type="hidden" name="email" value="{{ email }}">
                
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 ml-1">Code de sécurité</label>
                    <input type="text" name="code" required maxlength="6" autofocus
                           class="w-full bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl py-5 px-6 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/5 transition-all outline-none text-center text-3xl font-black tracking-[0.4em] text-slate-900 dark:text-white placeholder-slate-200 dark:placeholder-slate-800"
                           placeholder="000000">
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">6 chiffres requis</p>
                </div>

                <button type="submit" class="w-full vibrant-shimmer text-white font-black py-4 rounded-2xl transform active:scale-95 transition-all shadow-xl">
                    Confirmer l'identité
                </button>
            </form>

            <form method="POST" action="{{ path('app_user_resend_verification') }}" class="mt-10 pt-8 border-t border-slate-50 dark:border-slate-800">
                <input type="hidden" name="email" value="{{ email }}">
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400">
                    Code non reçu ?
                    <button type="submit" class="text-blue-600 dark:text-blue-400 font-black hover:underline ml-1">
                        Renvoyer
                    </button>
                </p>
            </form>

            <div class="mt-8 flex items-center justify-center gap-2 text-[10px] font-black uppercase tracking-widest text-slate-300">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                Vérification Sécurisée
            </div>
        </div>
    </div>
</div>
{% endblock %}
