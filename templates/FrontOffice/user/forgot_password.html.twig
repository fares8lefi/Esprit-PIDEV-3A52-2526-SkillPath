{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-skill-blue via-skill-green to-skill-yellow/30 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl flex flex-col md:flex-row max-w-4xl w-full overflow-hidden">
        
        <!-- Left Side: Visual -->
        <div class="hidden md:flex md:w-1/2 bg-blue-50/50 p-10 flex flex-col justify-center items-center text-center border-r border-gray-100">
            <div class="w-48 h-48 mb-8 flex items-center justify-center bg-white rounded-3xl shadow-inner border border-gray-50">
                <img src="{{ asset('images/logo.png') }}" alt="SkillPath Logo" class="h-32 w-auto">
            </div>
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Besoin d'aide ?</h2>
            <p class="text-gray-500 text-sm leading-relaxed max-w-xs">
                Ne vous inquiétez pas, cela arrive à tout le monde. Entrez votre email et nous vous enverrons un code pour récupérer l'accès à votre compte.
            </p>
        </div>

        <!-- Right Side: Form -->
        <div class="w-full md:w-1/2 p-10">
            <div class="mb-8">
                <a href="{{ path('app_user_login') }}" class="text-skill-blue text-xs font-bold flex items-center hover:underline mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                    </svg>
                    Retour à la connexion
                </a>
                <h2 class="text-3xl font-extrabold text-skill-blue mb-2">Mot de passe oublié</h2>
                <p class="text-gray-400 text-sm">Entrez votre adresse email pour recevoir un code.</p>
            </div>

            {% for message in app.flashes('error') %}
                <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-6 text-sm">
                    {{ message }}
                </div>
            {% endfor %}

            <form action="{{ path('app_user_forgot_password') }}" method="POST" class="space-y-6">
                <div>
                    <label for="email" class="block font-bold text-gray-700 mb-2 text-sm">Adresse Email</label>
                    <div class="relative">
                        <input type="email" id="email" name="email" required
                               class="w-full border-2 border-gray-100 rounded-xl px-4 py-3 focus:border-skill-blue focus:outline-none transition-colors pr-10 text-sm"
                               placeholder="votre.email@exemple.com">
                        <span class="absolute right-3 top-3.5 text-gray-300">
                             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </span>
                    </div>
                </div>

                <button type="submit" 
                        class="w-full bg-gradient-to-r from-skill-blue to-skill-green text-white font-bold py-3.5 rounded-xl shadow-lg shadow-skill-blue/30 transform transition-transform active:scale-95 text-sm">
                    Envoyer le code de réinitialisation
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
