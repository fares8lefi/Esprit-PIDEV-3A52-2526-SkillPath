{% extends 'base.html.twig' %}

{% block title %}Connexion - SkillPath Premium{% endblock %}

{% block stylesheets %}
<style>
    .mesh-background {
        background-color: #ffffff;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 136, 229, 0.1) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(67, 160, 71, 0.1) 0px, transparent 50%),
            radial-gradient(at 50% 50%, rgba(251, 192, 45, 0.05) 0px, transparent 50%),
            radial-gradient(at 100% 100%, rgba(30, 136, 229, 0.1) 0px, transparent 50%);
    }
    .dark .mesh-background {
        background-color: #020617;
        background-image: 
            radial-gradient(at 0% 0%, rgba(30, 136, 229, 0.05) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(67, 160, 71, 0.05) 0px, transparent 50%),
            radial-gradient(at 50% 50%, rgba(251, 192, 45, 0.02) 0px, transparent 50%),
            radial-gradient(at 100% 100%, rgba(30, 136, 229, 0.05) 0px, transparent 50%);
    }
    .glass-login {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.4);
    }
    .dark .glass-login {
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .float-slow {
        animation: float 8s ease-in-out infinite;
    }
    @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0); }
        50% { transform: translateY(-20px) rotate(2deg); }
    }
    .vibrant-shimmer {
        background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
        box-shadow: 0 10px 40px rgba(30, 136, 229, 0.3);
    }
    /* Autofill Fix */
    input:-webkit-autofill,
    input:-webkit-autofill:hover, 
    input:-webkit-autofill:focus, 
    input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px white inset !important;
        -webkit-text-fill-color: #0f172a !important;
        transition: background-color 5000s ease-in-out 0s;
    }
    .dark input:-webkit-autofill,
    .dark input:-webkit-autofill:hover, 
    .dark input:-webkit-autofill:focus, 
    .dark input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px #020617 inset !important;
        -webkit-text-fill-color: white !important;
        transition: background-color 5000s ease-in-out 0s;
    }
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen mesh-background flex items-center justify-center p-6 relative overflow-hidden">
    <!-- Abstract shapes -->
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-blue-400/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-green-400/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s"></div>
    
    <div class="max-w-6xl w-full flex flex-col lg:flex-row items-center gap-12 relative z-10 animate-in fade-in zoom-in duration-700">
        
        <!-- Creative Branding Side -->
        <div class="flex-1 hidden lg:flex flex-col text-left">
            <div class="flex items-center gap-4 mb-20 group cursor-pointer">
                <div class="w-14 h-14 vibrant-shimmer rounded-2xl flex items-center justify-center transform group-hover:rotate-12 transition-transform">
                    <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-8 h-8 invert brightness-0">
                </div>
                <div>
                    <span class="text-3xl font-black tracking-tighter text-slate-900 dark:text-white">SkillPath</span>
                    <span class="block text-[10px] font-black uppercase tracking-[0.3em] text-blue-600 dark:text-blue-400">Elevate your future</span>
                </div>
            </div>

            <h1 class="text-6xl font-black text-slate-900 dark:text-white leading-tight mb-8">
                Prêt pour votre <br>
                <span class="text-transparent bg-clip-text vibrant-shimmer">prochaine étape ?</span>
            </h1>
            
            <p class="text-lg text-slate-500 dark:text-slate-400 font-medium max-w-md leading-relaxed mb-12">
                Accédez à votre espace personnel pour continuer votre apprentissage et suivre vos progrès.
            </p>

            <div class="flex gap-6 mt-8">
                <div class="glass-login p-6 rounded-3xl flex-1 border border-blue-100 dark:border-blue-900/30 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center text-blue-600 dark:text-blue-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <span class="text-sm font-black text-slate-900 dark:text-white">+500 Cours Premium</span>
                </div>
                <div class="glass-login p-6 rounded-3xl flex-1 border border-green-100 dark:border-green-900/30 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-green-50 dark:bg-green-900/20 flex items-center justify-center text-green-600 dark:text-green-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    </div>
                    <span class="text-sm font-black text-slate-900 dark:text-white">Certificats Reconnus</span>
                </div>
            </div>
        </div>

        <!-- Glass Login Card -->
        <div class="w-full max-w-md">
            <div class="glass-login p-10 lg:p-12 rounded-[3.5rem] shadow-2xl relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-2xl"></div>
                
                <div class="relative z-10">
                    <div class="mb-10 text-center lg:text-left">
                        <h2 class="text-4xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Bon retour !</h2>
                        <p class="text-slate-500 dark:text-slate-400 font-medium">Content de vous revoir parmi nous.</p>
                    </div>

                    {% for message in app.flashes('success') %}
                        <div class="bg-green-50 text-green-600 px-6 py-4 rounded-2xl mb-6 text-sm font-bold border border-green-100 flex items-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {{ message }}
                        </div>
                    {% endfor %}

                    {% if error %}
                        <div class="bg-red-50 text-red-600 px-6 py-4 rounded-2xl mb-6 text-sm font-bold border border-red-100 flex items-center gap-3">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form action="{{ path('app_user_login') }}" method="POST" class="space-y-6">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        
                        <div class="space-y-2">
                            <label class="text-xs font-black uppercase tracking-widest text-slate-400 ml-1">Votre Email</label>
                            <div class="relative group">
                                <input type="email" name="_username" value="{{ last_username }}" placeholder="ex: jean.dupont@email.com" required
                                       class="w-full bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl py-4 px-6 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/5 transition-all outline-none dark:text-white placeholder-slate-300 dark:placeholder-slate-600">
                                <span class="absolute right-5 top-4 text-slate-300 group-focus-within:text-blue-500 transition-colors">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206"/></svg>
                                </span>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <div class="flex items-center justify-between ml-1">
                                <label class="text-xs font-black uppercase tracking-widest text-slate-400">Mot de Passe</label>
                                <a href="{{ path('app_user_forgot_password') }}" class="text-[10px] font-black uppercase tracking-widest text-blue-600 dark:text-blue-400 hover:text-blue-700">Oublié ?</a>
                            </div>
                            <div class="relative group">
                                <input type="password" name="_password" placeholder="Entrez vos 8 caractères..." required
                                       class="w-full bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl py-4 px-6 focus:outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/5 transition-all outline-none dark:text-white placeholder-slate-300 dark:placeholder-slate-600">
                                <span class="absolute right-5 top-4 text-slate-300 group-focus-within:text-blue-500 transition-colors">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                                </span>
                            </div>
                        </div>

                        <div class="flex items-center gap-2 px-1">
                            <input type="checkbox" id="remember_me" name="_remember_me" class="w-4 h-4 rounded border-slate-300 dark:border-slate-700 text-blue-600 focus:ring-blue-500 bg-white/50 dark:bg-slate-900/50">
                            <label for="remember_me" class="text-xs font-bold text-slate-500 dark:text-slate-400 cursor-pointer">Rester connecté</label>
                        </div>

                        <button type="submit" class="w-full vibrant-shimmer text-white font-black py-4 rounded-2xl transform active:scale-95 transition-all shadow-xl">
                            Se connecter
                        </button>
                    </form>

                    <div class="mt-10 pt-10 border-t border-slate-100 dark:border-slate-800 flex flex-col gap-6">
                        <p class="text-center text-sm font-medium text-slate-500 dark:text-slate-400">
                            Pas encore de compte ? 
                            <a href="{{ path('app_user_register') }}" class="text-blue-600 dark:text-blue-400 font-black hover:underline ml-1">Créer un profil</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
