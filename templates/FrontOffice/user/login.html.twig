{% extends 'base.html.twig' %}

{% block title %}Connexion - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-skill-blue via-skill-green to-skill-yellow/30 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl flex flex-col md:flex-row max-w-5xl w-full overflow-hidden min-h-[600px]">
        
        <!-- Left Side: Welcome Info -->
        <div class="md:w-1/2 bg-blue-50/50 p-10 flex flex-col justify-center items-center text-center border-r border-gray-100">
            <div class="mb-8">
                <div class="flex items-center justify-center mb-10">
                    <img src="{{ asset('images/logo.png') }}" alt="SkillPath Logo" class="h-16 w-auto">
                    <span class="text-3xl font-bold text-skill-blue ml-2">SkillPath</span>
                </div>
                
                <div class="w-48 h-48 mx-auto mb-8 flex items-center justify-center bg-white rounded-3xl shadow-inner border border-gray-50">
                    <img src="{{ asset('images/logo.png') }}" alt="SkillPath Logo Large" class="h-32 w-auto">
                </div>
            </div>

            <h1 class="text-3xl font-extrabold text-gray-800 mb-4">Bienvenue sur SkillPath</h1>
            <p class="text-gray-500 mb-10 leading-relaxed max-w-xs">
                Votre plateforme d'apprentissage pour progresser dans votre carrière et maîtriser de nouvelles compétences.
            </p>

            <div class="space-y-6 text-left w-full max-w-xs">
                <div class="flex items-start space-x-4">
                    <div class="bg-skill-blue/20 p-2 rounded-full">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-skill-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-800">Cours de Qualité</h4>
                        <p class="text-xs text-gray-400">500+ cours créés par des experts</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4">
                    <div class="bg-skill-blue/20 p-2 rounded-full">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-skill-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-800">Certifications</h4>
                        <p class="text-xs text-gray-400">Obtenir des certificats reconnus</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4">
                    <div class="bg-skill-blue/20 p-2 rounded-full">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-skill-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-800">Communauté</h4>
                        <p class="text-xs text-gray-400">100K+ apprenants actifs</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Login Form -->
        <div class="md:w-1/2 p-10 flex flex-col justify-center">
            <h2 class="text-3xl font-extrabold text-skill-blue mb-2">Connexion</h2>
            <p class="text-gray-400 mb-8 text-sm">Connectez-vous à votre compte SkillPath</p>

            {% for message in app.flashes('success') %}
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl relative mb-4" role="alert">
                    <span class="block sm:inline">{{ message }}</span>
                </div>
            {% endfor %}

            {% if error %}
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl relative mb-4" role="alert">
                    <span class="block sm:inline">{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            <form action="{{ path('app_user_login') }}" method="POST" class="space-y-6 text-sm">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <div>
                    <label class="block font-bold text-gray-700 mb-2">Adresse Email</label>
                    <div class="relative">
                    <input type="email" name="_username" value="{{ last_username }}" placeholder="votre.email@exemple.com" required
                               class="w-full border-2 border-gray-100 rounded-xl px-4 py-3 focus:border-skill-blue focus:outline-none transition-colors pr-10">
                        <span class="absolute right-3 top-3.5 text-gray-300">
                             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div>
                    <label class="block font-bold text-gray-700 mb-2">Mot de Passe</label>
                    <div class="relative">
                        <input type="password" name="_password" placeholder="••••••••" required
                               class="w-full border-2 border-gray-100 rounded-xl px-4 py-3 focus:border-skill-blue focus:outline-none transition-colors pr-10">
                        <span class="absolute right-3 top-3.5 text-gray-300">
                             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div class="flex items-center justify-between text-xs">
                    <label class="flex items-center text-gray-500 cursor-pointer">
                        <input type="checkbox" class="mr-2 rounded border-gray-300 accent-skill-blue"> Se souvenir de moi
                    </label>
                    <a href="#" class="text-skill-blue font-bold hover:underline">Mot de passe oublié ?</a>
                </div>

                <button type="submit" 
                        class="w-full bg-gradient-to-r from-skill-blue to-skill-green text-white font-bold py-3 rounded-xl shadow-lg shadow-skill-blue/30 transform transition-transform active:scale-95">
                    Connexion
                </button>

                <div class="relative flex items-center justify-center py-4">
                    <div class="border-t border-gray-100 w-full"></div>
                    <span class="absolute bg-white px-4 text-xs text-gray-300 uppercase tracking-widest">Ou continuer avec</span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <button class="flex items-center justify-center space-x-2 border-2 border-gray-100 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-xs font-bold text-gray-700">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="w-5 h-5" alt="Google">
                        <span>Google</span>
                    </button>
                    <button class="flex items-center justify-center space-x-2 border-2 border-gray-100 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-xs font-bold text-gray-700">
                        <img src="https://www.svgrepo.com/show/475654/github-color.svg" class="w-5 h-5" alt="GitHub">
                        <span>GitHub</span>
                    </button>
                </div>

                <p class="text-center text-gray-400 text-xs mt-6">
                    Pas encore de compte ? <br>
                    <a href="{{ path('app_user_register') }}" class="text-skill-blue font-extrabold hover:underline">Créer un compte gratuitement</a>
                </p>

                <div class="flex items-center justify-center text-[10px] text-gray-300 space-x-1 mt-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    <span>Connexion sécurisée avec SSL</span>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
