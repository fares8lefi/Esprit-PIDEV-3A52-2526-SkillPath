{% extends 'base.html.twig' %}

{% block title %}Inscription - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-skill-blue via-skill-green to-skill-yellow/30 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl flex flex-col md:flex-row max-w-5xl w-full overflow-hidden min-h-[600px]">
        
        <!-- Left Side: Welcome Info (Same as Login) -->
        <div class="md:w-1/2 bg-blue-50/50 p-10 flex flex-col justify-center items-center text-center border-r border-gray-100">
            <div class="mb-8">
                <div class="flex items-center justify-center mb-10">
                    <img src="{{ asset('images/logo.png') }}" alt="SkillPath Logo" class="h-16 w-auto">
                    <span class="text-3xl font-bold text-skill-blue ml-2">SkillPath</span>
                </div>
                
                <div class="w-48 h-48 mx-auto mb-8 flex items-center justify-center bg-white rounded-3xl shadow-inner border border-gray-50">
                    <img src="{{ asset('images/logo.png') }}" alt="SkillPath Logo Large" class="h-32 w-auto">
                </div>
            </div>

            <h1 class="text-3xl font-extrabold text-gray-800 mb-4">Rejoignez SkillPath</h1>
            <p class="text-gray-500 mb-10 leading-relaxed max-w-xs">
                Commencez votre voyage d'apprentissage aujourd'hui et débloquez de nouvelles opportunités.
            </p>

            <div class="space-y-6 text-left w-full max-w-xs">
                <div class="flex items-start space-x-4">
                    <div class="bg-skill-green/20 p-2 rounded-full">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-skill-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-800">Accès Immédiat</h4>
                        <p class="text-xs text-gray-400">Plus de 500 cours disponibles</p>
                    </div>
                </div>
                <div class="flex items-start space-x-4">
                    <div class="bg-skill-green/20 p-2 rounded-full">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-skill-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-800">Gratuit pour débuter</h4>
                        <p class="text-xs text-gray-400">Inscrivez-vous sans frais</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Sign Up Form -->
        <div class="md:w-1/2 p-10 flex flex-col justify-center">
            <h2 class="text-3xl font-extrabold text-skill-blue mb-2">Inscription</h2>
            <p class="text-gray-400 mb-8 text-sm">Créez votre compte SkillPath gratuitement</p>

            <form action="{{ path('app_user_register') }}" method="POST" class="space-y-4 text-sm">
                <div>
                    <label class="block font-bold text-gray-700 mb-1">Nom d'utilisateur</label>
                    <div class="relative">
                        <input type="text" name="username" placeholder="votre_pseudo" required
                               class="w-full border-2 border-gray-100 rounded-xl px-4 py-3 focus:border-skill-blue focus:outline-none transition-colors pr-10">
                        <span class="absolute right-3 top-3.5 text-gray-300">
                             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div>
                    <label class="block font-bold text-gray-700 mb-1">Adresse Email</label>
                    <div class="relative">
                        <input type="email" name="email" placeholder="votre.email@exemple.com" required
                               class="w-full border-2 border-gray-100 rounded-xl px-4 py-3 focus:border-skill-blue focus:outline-none transition-colors pr-10">
                        <span class="absolute right-3 top-3.5 text-gray-300">
                             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div>
                    <label class="block font-bold text-gray-700 mb-1">Mot de Passe</label>
                    <div class="relative">
                        <input type="password" name="password" placeholder="••••••••" required
                               class="w-full border-2 border-gray-100 rounded-xl px-4 py-3 focus:border-skill-blue focus:outline-none transition-colors pr-10">
                        <span class="absolute right-3 top-3.5 text-gray-300">
                             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </span>
                    </div>
                </div>

                <div class="flex items-center text-[10px] text-gray-400 py-2">
                    <input type="checkbox" required class="mr-2 rounded border-gray-300 accent-skill-blue">
                    <span>J'accepte les <a href="#" class="text-skill-blue font-bold hover:underline">Conditions d'Utilisation</a> et la <a href="#" class="text-skill-blue font-bold hover:underline">Politique de Confidentialité</a>.</span>
                </div>

                <button type="submit" 
                        class="w-full bg-gradient-to-r from-skill-blue to-skill-green text-white font-bold py-3 rounded-xl shadow-lg shadow-skill-blue/30 transform transition-transform active:scale-95 mt-4">
                    Créer mon compte
                </button>

                <div class="relative flex items-center justify-center py-4">
                    <div class="border-t border-gray-100 w-full"></div>
                    <span class="absolute bg-white px-4 text-xs text-gray-300 uppercase tracking-widest">Ou s'inscrire avec</span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <button type="button" class="flex items-center justify-center space-x-2 border-2 border-gray-100 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-xs font-bold text-gray-700">
                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="w-5 h-5" alt="Google">
                        <span>Google</span>
                    </button>
                    <button type="button" class="flex items-center justify-center space-x-2 border-2 border-gray-100 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-xs font-bold text-gray-700">
                        <img src="https://www.svgrepo.com/show/475654/github-color.svg" class="w-5 h-5" alt="GitHub">
                        <span>GitHub</span>
                    </button>
                </div>

                <p class="text-center text-gray-400 text-xs mt-6">
                    Déjà un compte ? <br>
                    <a href="{{ path('app_user_login') }}" class="text-skill-blue font-extrabold hover:underline">Se connecter maintenant</a>
                </p>
            </form>
        </div>
    </div>
</div>
{% endblock %}
