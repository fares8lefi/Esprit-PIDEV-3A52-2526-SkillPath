{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe - SkillPath{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-skill-blue via-skill-green to-skill-yellow/30 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl flex flex-col md:flex-row max-w-4xl w-full overflow-hidden">
        
        <!-- Left Side: Instructions -->
        <div class="hidden md:flex md:w-1/2 bg-blue-50/50 p-10 flex flex-col justify-center border-r border-gray-100">
            <h2 class="text-2xl font-bold text-skill-blue mb-6">Étape finale</h2>
            <div class="space-y-6">
                <div class="flex items-start">
                    <div class="w-8 h-8 rounded-full bg-skill-blue text-white flex items-center justify-center font-bold mr-4 shrink-0 shadow-lg shadow-skill-blue/20">1</div>
                    <div>
                        <p class="font-bold text-gray-800 text-sm">Vérifiez vos emails</p>
                        <p class="text-xs text-gray-500">Nous avons envoyé un code à 6 chiffres.</p>
                    </div>
                </div>
                <div class="flex items-start">
                    <div class="w-8 h-8 rounded-full bg-skill-green text-white flex items-center justify-center font-bold mr-4 shrink-0 shadow-lg shadow-skill-green/20">2</div>
                    <div>
                        <p class="font-bold text-gray-800 text-sm">Changez votre mot de passe</p>
                        <p class="text-xs text-gray-500">Choisissez un mot de passe fort et unique.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Form -->
        <div class="w-full md:w-1/2 p-10">
            <div class="mb-8">
                <h2 class="text-3xl font-extrabold text-skill-blue mb-2">Réinitialisation</h2>
                <p class="text-gray-400 text-sm">Veuillez entrer le code et votre nouveau mot de passe.</p>
            </div>

            {% for message in app.flashes('error') %}
                <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-6 text-sm">
                    {{ message }}
                </div>
            {% endfor %}

            <form action="{{ path('app_user_reset_password') }}" method="POST" class="space-y-6">
                <input type="hidden" name="email" value="{{ email }}">
                
                <div>
                    <label for="code" class="block font-bold text-gray-700 mb-2 text-sm text-center">Code de vérification</label>
                    <input type="text" id="code" name="code" required maxlength="6"
                           class="w-full border-2 border-gray-100 rounded-xl px-4 py-4 focus:border-skill-blue focus:outline-none transition-all text-center text-2xl font-black tracking-widest text-skill-blue placeholder-gray-200"
                           placeholder="000000">
                </div>

                <div>
                    <label for="password" class="block font-bold text-gray-700 mb-2 text-sm">Nouveau mot de passe</label>
                    <div class="relative">
                        <input type="password" id="password" name="password" required
                               class="w-full border-2 border-gray-100 rounded-xl px-4 py-3 focus:border-skill-blue focus:outline-none transition-colors pr-10 text-sm"
                               placeholder="••••••••">
                        <span class="absolute right-3 top-3.5 text-gray-300">
                             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </span>
                    </div>
                </div>

                <button type="submit" 
                        class="w-full bg-gradient-to-r from-skill-blue to-skill-green text-white font-bold py-3.5 rounded-xl shadow-lg shadow-skill-blue/30 transform transition-transform active:scale-95 text-sm">
                    Mettre à jour le mot de passe
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
