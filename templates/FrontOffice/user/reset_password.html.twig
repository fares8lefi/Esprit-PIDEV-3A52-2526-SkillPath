{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe - SkillPath{% endblock %}

{% block stylesheets %}
<style>
    /* Autofill Fix */
    input:-webkit-autofill,
    input:-webkit-autofill:hover, 
    input:-webkit-autofill:focus, 
    input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px white inset !important;
        -webkit-text-fill-color: #0f172a !important;
        transition: background-color 5000s ease-in-out 0s;
    }
    .dark input:-webkit-autofill,
    .dark input:-webkit-autofill:hover, 
    .dark input:-webkit-autofill:focus, 
    .dark input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px #0B0F1A inset !important;
        -webkit-text-fill-color: white !important;
        transition: background-color 5000s ease-in-out 0s;
    }
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark flex items-center justify-center p-6 relative overflow-hidden">
    <!-- Abstract shapes -->
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary/8 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-accent/8 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s"></div>
    
    <div class="max-w-4xl w-full relative z-10 animate-fade-up">
        <div class="glass-card p-10 lg:p-14 rounded-3xl shadow-2xl relative overflow-hidden flex flex-col md:flex-row gap-12 items-center">
            
            <!-- Left Side -->
            <div class="md:w-1/2 text-center md:text-left">
                <div class="flex items-center gap-3 mb-10 group justify-center md:justify-start">
                    <div class="w-10 h-10 gradient-primary rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/20">
                        <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-6 h-6 invert brightness-0">
                    </div>
                    <span class="text-xl font-black tracking-tight text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
                </div>
                
                <h2 class="text-4xl font-black text-slate-900 dark:text-white mb-6 leading-tight">Dernière <br><span class="gradient-text">étape !</span></h2>
                <p class="text-slate-500 dark:text-slate-400 font-medium leading-relaxed mb-8">
                    Saisissez le code reçu par e-mail et choisissez un nouveau mot de passe robuste pour sécuriser votre accès.
                </p>
                
                <div class="space-y-4 hidden md:block">
                    <div class="flex items-center gap-3 text-sm font-bold text-slate-600 dark:text-slate-400">
                        <div class="w-2 h-2 rounded-full bg-primary"></div>
                        Code à 6 chiffres
                    </div>
                    <div class="flex items-center gap-3 text-sm font-bold text-slate-600 dark:text-slate-400">
                        <div class="w-2 h-2 rounded-full bg-mint"></div>
                        8 caractères min.
                    </div>
                </div>
            </div>

            <!-- Right Side -->
            <div class="md:w-1/2 w-full">
                {% for message in app.flashes('error') %}
                    <div class="bg-coral/8 text-coral px-5 py-4 rounded-xl mb-6 text-sm font-bold border border-coral/15 flex items-center gap-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                        {{ message }}
                    </div>
                {% endfor %}

                <form action="{{ path('app_user_reset_password') }}" method="POST" class="space-y-6">
                    <input type="hidden" name="email" value="{{ email }}">
                    
                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-widest text-slate-400 ml-1 text-center block">Code de vérification</label>
                        <input type="text" name="code" required maxlength="6"
                               class="form-input text-center !text-3xl !font-black !tracking-[0.3em] !text-primary dark:!text-primary-light !py-4"
                               placeholder="000000">
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-widest text-slate-400 ml-1">Nouveau mot de passe</label>
                        <div class="relative group">
                            <input type="password" name="password" placeholder="••••••••" required
                                   class="form-input pr-12">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 dark:text-slate-600 group-focus-within:text-primary transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                            </span>
                        </div>
                    </div>

                    <button type="submit" class="btn-primary w-full !py-4">
                        Réinitialiser l'accès
                    </button>
                    
                    <a href="{{ path('app_user_login') }}" class="block text-center text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 hover:text-primary transition-colors">
                        Annuler et retourner
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
