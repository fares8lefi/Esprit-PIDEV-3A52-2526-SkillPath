{# ===== FLOATING CHATBOT WIDGET ===== #}
<div data-controller="chatbot" id="chatbot-widget">
    {# Floating Toggle Button #}
    <button id="chat-toggle-btn"
            onclick="document.getElementById('chat-panel').classList.toggle('hidden'); document.getElementById('chat-panel').classList.add('chat-open'); document.getElementById('chat-toggle-btn').classList.toggle('hidden');"
            class="fixed bottom-6 right-6 z-50 w-16 h-16 bg-gradient-to-tr from-indigo-600 via-purple-600 to-indigo-500 rounded-2xl shadow-[0_20px_50px_rgba(79,70,229,0.3)] flex items-center justify-center text-white hover:scale-110 active:scale-95 transition-all duration-300 cursor-pointer group">
        <span class="chat-bubble-ring"></span>
        <svg class="w-8 h-8 transition-transform group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
        </svg>
    </button>

    {# Chat Panel #}
    <div id="chat-panel"
         class="hidden fixed bottom-6 right-6 z-50 w-80 md:w-96 bg-white dark:bg-[#0F172A] rounded-[2.5rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.2)] border border-slate-200 dark:border-white/5 overflow-hidden flex flex-col"
         style="height: 600px;">
        
        {# Header #}
        <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-5 flex items-center justify-between flex-shrink-0">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center backdrop-blur-md border border-white/20 shadow-inner">
                    <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-white font-black text-sm tracking-tight">SkillPath Intelligence</h2>
                    <div class="flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                        <p class="text-white/70 text-[10px] font-bold uppercase tracking-wider">Assistant Actif</p>
                    </div>
                </div>
            </div>
            <button onclick="document.getElementById('chat-panel').classList.add('hidden'); document.getElementById('chat-toggle-btn').classList.remove('hidden');"
                    class="w-8 h-8 rounded-xl bg-black/10 hover:bg-black/20 text-white flex items-center justify-center transition-all cursor-pointer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        {# Messages #}
        <div class="flex-1 overflow-y-auto p-6 space-y-6 bg-slate-50/50 dark:bg-[#0B0F1A]/50 custom-scrollbar"
             data-chatbot-target="messages">
            
            <div class="flex items-start gap-3 msg-fade">
                <div class="w-8 h-8 bg-gradient-to-tr from-indigo-600 to-purple-600 rounded-xl flex items-center justify-center text-white flex-shrink-0 shadow-lg shadow-purple-500/20">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-white/5 rounded-2xl rounded-tl-none p-4 max-w-[85%] shadow-sm">
                    <p class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed">Hello! 👋 Je suis l'assistant IA de SkillPath. Comment puis-je vous aider aujourd'hui ?</p>
                </div>
            </div>

            <div class="flex items-start gap-3" data-chatbot-target="typingIndicator" style="display: none;">
                <div class="w-8 h-8 bg-gradient-to-tr from-indigo-600 to-purple-600 rounded-xl flex items-center justify-center text-white flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-white/5 rounded-2xl rounded-tl-none px-4 py-3 shadow-sm">
                    <div class="flex gap-1.5 items-center">
                        <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full dot1"></span>
                        <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full dot2"></span>
                        <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full dot3"></span>
                    </div>
                </div>
            </div>
        </div>

        {# Input #}
        <div class="border-t border-slate-100 dark:border-white/5 bg-white dark:bg-[#0F172A] px-5 py-5 flex-shrink-0">
            <form class="flex items-center gap-3" data-action="submit->chatbot#sendMessage" data-turbo="false">
                <input type="text"
                       class="flex-1 px-5 py-3 bg-slate-100 dark:bg-white/5 border-0 rounded-2xl text-sm text-slate-800 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white dark:focus:bg-slate-800 transition-all shadow-inner"
                       data-chatbot-target="input"
                       placeholder="Écrivez votre message..."
                       autocomplete="off">
                <button type="submit"
                        class="w-11 h-11 bg-gradient-to-tr from-indigo-600 to-purple-600 text-white rounded-2xl flex items-center justify-center hover:shadow-lg hover:shadow-indigo-500/25 hover:-translate-y-0.5 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed group"
                        data-chatbot-target="sendButton">
                    <svg class="w-5 h-5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes fadeOutDown {
        from { opacity: 1; transform: translateY(0) scale(1); }
        to { opacity: 0; transform: translateY(20px) scale(0.95); }
    }
    @keyframes bounce-dot {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1); }
    }
    @keyframes pulse-ring {
        0% { transform: scale(0.8); opacity: 1; }
        100% { transform: scale(2); opacity: 0; }
    }
    .chat-open { animation: fadeInUp 0.3s ease-out forwards; }
    .chat-close { animation: fadeOutDown 0.2s ease-in forwards; }
    .dot1 { animation: bounce-dot 1.4s infinite ease-in-out -0.32s; }
    .dot2 { animation: bounce-dot 1.4s infinite ease-in-out -0.16s; }
    .dot3 { animation: bounce-dot 1.4s infinite ease-in-out 0s; }
    .msg-fade { animation: fadeInUp 0.25s ease-out; }
    .chat-bubble-ring {
        position: absolute; inset: -4px; border-radius: 50%;
        border: 3px solid rgba(139, 92, 246, 0.4);
        animation: pulse-ring 2s ease-out infinite;
    }
</style>
