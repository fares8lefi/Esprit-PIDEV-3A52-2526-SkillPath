<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SkillPath - Apprendre autrement{% endblock %}</title>

    <link rel="icon" href="{{ asset('images/logo.png') }}">

    <!-- Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Tailwind CSS v4 -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
             if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark')
            } else {
                document.documentElement.classList.remove('dark')
            }
        });

        function toggleTheme() {
            const html = document.documentElement;
            html.style.transition = 'background-color 0.5s ease, color 0.5s ease';
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
            // Dispatch event for components that need to react (like charts)
            window.dispatchEvent(new Event('themeChanged'));
        }
    </script>

    <style type="text/tailwindcss">
        @theme {
            /* 2026 Dopamine Color Palette */
            --color-primary: #7C3AED;
            --color-primary-light: #A78BFA;
            --color-primary-dark: #5B21B6;
            --color-secondary: #F59E0B;
            --color-secondary-light: #FCD34D;
            --color-accent: #06B6D4;
            --color-accent-light: #67E8F9;
            --color-lavender: #C4B5FD;
            --color-coral: #FB7185;
            --color-mint: #34D399;
            --color-peach: #FDBA74;

            /* Brand Colors for backwards compatibility */
            --color-brand-blue: #1E88E5;
            --color-brand-blue-light: #E3F2FD;
            --color-brand-blue-dark: #1565C0;
            --color-brand-green: #43A047;
            --color-brand-green-light: #E8F5E9;
            --color-brand-green-dark: #2E7D32;
            --color-brand-yellow: #FBC02D;
            --color-brand-yellow-light: #FFFDE7;
            --color-brand-yellow-dark: #F9A825;
            --color-brand-gray: #F8F9FB;
            --color-brand-dark: #1A1D1F;
            --color-brand-muted: #6F767E;

            /* Semantic */
            --color-success: #10B981;
            --color-warning: #F59E0B;
            --color-danger: #EF4444;
            --color-info: #3B82F6;

            --shadow-soft: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
            --shadow-gleam: 0 0 40px -5px rgba(30, 136, 229, 0.15);
        }

        @layer base {
            body {
                @apply font-sans antialiased overflow-x-hidden;
            }
        }

        @layer components {
            .btn-primary {
                background: linear-gradient(135deg, #7C3AED, #6D28D9);
                color: white;
                font-weight: 700;
                padding: 0.875rem 2rem;
                border-radius: 1rem;
                box-shadow: 0 4px 14px rgba(124,58,237,0.3);
                transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
                @apply active:scale-95;
            }
            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(124,58,237,0.4);
            }
            .card {
                @apply bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-white/5 shadow-soft hover:shadow-lg transition-all duration-300;
            }
        }
    </style>

        <style>
            /* ============================================================
               SKILLPATH DESIGN SYSTEM 2026
               Trends: Bento Grid, Dark Mode 2.0, Dopamine Colors,
                       Micro-delights, Glassmorphism 2.0, Kinetic UI
            ============================================================ */

            /* -- Mesh Gradients (Background) -- */
            .mesh-light {
                background-color: #FAFAFA;
                background-image:
                    radial-gradient(at 0% 0%, rgba(124,58,237,0.07) 0px, transparent 50%),
                    radial-gradient(at 80% 0%, rgba(6,182,212,0.05) 0px, transparent 50%),
                    radial-gradient(at 50% 100%, rgba(245,158,11,0.04) 0px, transparent 50%);
            }
            .mesh-dark {
                background-color: #0B0F1A;
                background-image:
                    radial-gradient(at 0% 0%, rgba(124,58,237,0.08) 0px, transparent 50%),
                    radial-gradient(at 80% 0%, rgba(6,182,212,0.05) 0px, transparent 50%),
                    radial-gradient(at 100% 100%, rgba(245,158,11,0.03) 0px, transparent 50%);
            }

            /* -- Glass Cards (Glassmorphism 2.0) -- */
            .glass {
                background: rgba(255,255,255,0.65);
                backdrop-filter: blur(16px) saturate(180%);
                -webkit-backdrop-filter: blur(16px) saturate(180%);
                border: 1px solid rgba(255,255,255,0.4);
            }
            .dark .glass {
                background: rgba(15,23,42,0.6);
                backdrop-filter: blur(16px) saturate(180%);
                -webkit-backdrop-filter: blur(16px) saturate(180%);
                border: 1px solid rgba(255,255,255,0.06);
            }

            .glass-card {
                background: rgba(255,255,255,0.7);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border: 1px solid rgba(0,0,0,0.04);
                transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
            }
            .dark .glass-card {
                background: rgba(30,41,59,0.5);
                border: 1px solid rgba(255,255,255,0.05);
            }
            .glass-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 24px 48px -12px rgba(124,58,237,0.12);
                border-color: rgba(124,58,237,0.3);
            }
            .dark .glass-card:hover {
                box-shadow: 0 24px 48px -12px rgba(124,58,237,0.2);
                border-color: rgba(124,58,237,0.4);
            }

            /* -- Gradients -- */
            .gradient-primary {
                background: linear-gradient(135deg, #7C3AED 0%, #06B6D4 100%);
            }
            .gradient-warm {
                background: linear-gradient(135deg, #F59E0B 0%, #FB7185 100%);
            }
            .gradient-dopamine {
                background: linear-gradient(135deg, #7C3AED 0%, #F59E0B 50%, #06B6D4 100%);
            }
            .gradient-text {
                background: linear-gradient(135deg, #7C3AED 0%, #06B6D4 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            /* -- Sidebar -- */
            .sidebar-item {
                transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
                position: relative;
            }
            .sidebar-active {
                background: rgba(124,58,237,0.08);
                color: #7C3AED;
            }
            .dark .sidebar-active {
                background: rgba(124,58,237,0.15);
                color: #A78BFA;
            }
            .sidebar-active::before {
                content: '';
                position: absolute;
                right: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 3px;
                height: 60%;
                background: #7C3AED;
                border-radius: 3px 0 0 3px;
            }

            /* -- Bento Grid -- */
            .bento-grid {
                display: grid;
                gap: 1rem;
                grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            }

            /* -- Buttons (Secondary) -- */
            .btn-secondary {
                background: transparent;
                color: #7C3AED;
                font-weight: 700;
                padding: 0.875rem 2rem;
                border-radius: 1rem;
                border: 2px solid rgba(124,58,237,0.2);
                transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            }
            .dark .btn-secondary {
                color: #A78BFA;
                border-color: rgba(167,139,250,0.2);
            }
            .btn-secondary:hover {
                background: rgba(124,58,237,0.06);
                border-color: rgba(124,58,237,0.4);
                transform: translateY(-2px);
            }

            /* -- Tags / Badges -- */
            .badge {
                display: inline-flex;
                align-items: center;
                gap: 0.375rem;
                padding: 0.25rem 0.75rem;
                border-radius: 9999px;
                font-size: 0.7rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }
            .badge-purple { background: rgba(124,58,237,0.1); color: #7C3AED; }
            .badge-cyan { background: rgba(6,182,212,0.1); color: #06B6D4; }
            .badge-amber { background: rgba(245,158,11,0.1); color: #D97706; }
            .badge-green { background: rgba(16,185,129,0.1); color: #059669; }
            .badge-red { background: rgba(239,68,68,0.1); color: #DC2626; }
            .dark .badge-purple { background: rgba(124,58,237,0.2); color: #A78BFA; }
            .dark .badge-cyan { background: rgba(6,182,212,0.15); color: #67E8F9; }
            .dark .badge-amber { background: rgba(245,158,11,0.15); color: #FCD34D; }
            .dark .badge-green { background: rgba(16,185,129,0.15); color: #34D399; }
            .dark .badge-red { background: rgba(239,68,68,0.15); color: #FCA5A5; }

            /* -- Animations (Micro-delights) -- */
            @keyframes fadeInUp {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }
            @keyframes fadeIn {
                from { opacity: 0; }
                to { opacity: 1; }
            }
            @keyframes scaleIn {
                from { opacity: 0; transform: scale(0.9); }
                to { opacity: 1; transform: scale(1); }
            }
            @keyframes slideInLeft {
                from { opacity: 0; transform: translateX(-20px); }
                to { opacity: 1; transform: translateX(0); }
            }
            @keyframes float {
                0%, 100% { transform: translateY(0px); }
                50% { transform: translateY(-12px); }
            }
            @keyframes shimmer {
                0% { background-position: -200% 0; }
                100% { background-position: 200% 0; }
            }
            @keyframes pulse-glow {
                0%, 100% { box-shadow: 0 0 0 0 rgba(124,58,237,0.3); }
                50% { box-shadow: 0 0 20px 4px rgba(124,58,237,0.15); }
            }

            .animate-fade-up { animation: fadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both; }
            .animate-fade-in { animation: fadeIn 0.5s ease both; }
            .animate-scale-in { animation: scaleIn 0.4s cubic-bezier(0.22, 1, 0.36, 1) both; }
            .animate-slide-left { animation: slideInLeft 0.5s cubic-bezier(0.22, 1, 0.36, 1) both; }
            .animate-float { animation: float 6s ease-in-out infinite; }
            .animate-pulse-glow { animation: pulse-glow 3s ease-in-out infinite; }

            .delay-100 { animation-delay: 100ms; }
            .delay-200 { animation-delay: 200ms; }
            .delay-300 { animation-delay: 300ms; }
            .delay-400 { animation-delay: 400ms; }
            .delay-500 { animation-delay: 500ms; }

            /* -- Form Styles (Dark Mode 2.0) -- */
            .form-input {
                width: 100%;
                padding: 0.875rem 1.25rem;
                border-radius: 1rem;
                border: 2px solid transparent;
                background: rgba(0,0,0,0.03);
                transition: all 0.3s ease;
                font-weight: 500;
                color: #1E293B;
            }
            .dark .form-input {
                background: rgba(255,255,255,0.04);
                color: #F1F5F9;
            }
            .form-input:focus {
                outline: none;
                border-color: #7C3AED;
                background: white;
                box-shadow: 0 0 0 4px rgba(124,58,237,0.08);
            }
            .dark .form-input:focus {
                background: rgba(124,58,237,0.06);
                box-shadow: 0 0 0 4px rgba(124,58,237,0.15);
            }
            .form-input::placeholder {
                color: #94A3B8;
            }
            .dark .form-input::placeholder {
                color: #475569;
            }

            /* -- Scrollbar (Premium Minimal) -- */
            .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
            .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
            .custom-scrollbar::-webkit-scrollbar-thumb { 
                background: rgba(124, 58, 237, 0.1); 
                border-radius: 20px;
                transition: background 0.3s;
            }
            .custom-scrollbar:hover::-webkit-scrollbar-thumb {
                background: rgba(124, 58, 237, 0.3);
            }
            .dark .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(167, 139, 250, 0.1); }
            .dark .custom-scrollbar:hover::-webkit-scrollbar-thumb { background: rgba(167, 139, 250, 0.2); }

            /* -- Chat bubbles -- */
            .chat-user {
                background: rgba(124,58,237,0.08);
                border-radius: 1.25rem 1.25rem 0.25rem 1.25rem;
                border: 1px solid rgba(124,58,237,0.12);
            }
            .dark .chat-user {
                background: rgba(124,58,237,0.12);
                border-color: rgba(124,58,237,0.15);
            }
            .chat-admin {
                background: rgba(6,182,212,0.06);
                border-radius: 1.25rem 1.25rem 1.25rem 0.25rem;
                border: 1px solid rgba(6,182,212,0.1);
            }
            .dark .chat-admin {
                background: rgba(6,182,212,0.1);
                border-color: rgba(6,182,212,0.12);
            }

            /* -- Kinetic hover -- */
            .hover-lift {
                transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
            }
            .hover-lift:hover {
                transform: translateY(-4px);
            }
        </style>

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        <script>
            async function fetchNotifications() {
                const dropdown = document.getElementById('notification-dropdown');
                const list = document.getElementById('notification-list');
                
                dropdown.classList.toggle('hidden');
                if (dropdown.classList.contains('hidden')) return;

                list.innerHTML = '<div class="p-4 text-center text-xs text-slate-500 italic">Chargement...</div>';

                try {
                    const response = await fetch('/notifications/list');
                    const data = await response.json();
                    
                    if (data.notifications.length === 0) {
                        list.innerHTML = '<div class="p-4 text-center text-xs text-slate-500">Aucune notification</div>';
                        return;
                    }

                    list.innerHTML = data.notifications.map(n => `
                        <div class="p-4 border-b border-slate-50 dark:border-white/5 hover:bg-slate-50 dark:hover:bg-white/5 transition-colors ${n.isRead ? 'opacity-60' : ''}">
                            <div class="flex justify-between items-start mb-1">
                                <h4 class="text-xs font-bold ${n.isRead ? '' : 'text-primary'}">${n.title}</h4>
                                <span class="text-[10px] text-slate-400">${n.createdAt}</span>
                            </div>
                            <p class="text-[11px] text-slate-500 dark:text-slate-400 line-clamp-2 mb-2">${n.message}</p>
                            ${n.link ? `<a href="${n.link}" onclick="markAsRead(${n.id})" class="text-[10px] font-bold text-primary hover:underline">Voir le cours</a>` : ''}
                        </div>
                    `).join('');
                } catch (e) {
                    list.innerHTML = '<div class="p-4 text-center text-xs text-red-500">Erreur de chargement</div>';
                }
            }

            async function markAsRead(id) {
                await fetch('/notifications/mark-as-read/' + id, { method: 'POST' });
                refreshUnreadCount();
            }

            async function refreshUnreadCount() {
                try {
                    const response = await fetch('/notifications/unread-count');
                    const data = await response.json();
                    const badge = document.getElementById('notification-count');
                    if (data.count > 0) {
                        badge.textContent = data.count > 9 ? '9+' : data.count;
                        badge.classList.remove('hidden');
                    } else {
                        badge.classList.add('hidden');
                    }
                } catch (e) {}
            }

            document.addEventListener('DOMContentLoaded', refreshUnreadCount);
            // Auto refresh every 30 seconds
            setInterval(refreshUnreadCount, 30000);
        </script>
    </head>

<body class="bg-[#FAFAFA] dark:bg-[#0B0F1A] text-slate-800 dark:text-slate-200 transition-colors duration-500">
    <!-- Theme Toggle (Micro-delight) -->
    <button onclick="toggleTheme()" class="fixed bottom-6 left-6 z-[999] w-14 h-14 flex items-center justify-center gradient-primary shadow-2xl shadow-purple-500/25 rounded-2xl hover:scale-110 active:scale-90 transition-all text-white group" title="Toggle theme">
        <svg class="w-5 h-5 block dark:hidden transition-transform group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        <svg class="w-5 h-5 hidden dark:block transition-transform group-hover:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.243 17.657l.707.707M6.343 6.343l.707-.707M14.5 12a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
    </button>

    {% block body %}{% endblock %}
</body>
</html>
