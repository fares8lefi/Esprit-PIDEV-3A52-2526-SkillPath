{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} - SkillPath{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <a href="{{ path('app_event_index') }}" class="inline-flex items-center gap-2 text-slate-500 hover:text-primary transition-colors mb-8 font-medium">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Retour aux événements
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
            <!-- Hero Image -->
            <div class="relative h-96 rounded-[2.5rem] overflow-hidden shadow-2xl">
                {% if event.image %}
                    <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-full h-full object-cover">
                {% else %}
                    <div class="w-full h-full bg-slate-100 dark:bg-white/5 flex items-center justify-center">
                        <svg class="w-20 h-20 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                {% endif %}
                
                <!-- Quick Actions Overlay -->
                {% if app.user %}
                    <div class="absolute top-6 right-6 flex gap-3">
                         <form action="{{ path('app_event_favorite', {id: event.id}) }}" method="post">
                            <button type="submit" class="p-4 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md rounded-full shadow-xl hover:bg-slate-50 dark:hover:bg-white/10 transition-all group" title="Ajouter aux favoris">
                                <svg class="w-6 h-6 transition-colors {{ app.user.favoriteEvents.contains(event) ? 'text-red-500 fill-red-500' : 'text-slate-400 group-hover:text-red-500' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>

            <!-- Content -->
            <div>
                <div class="flex flex-wrap items-center gap-4 mb-6">
                    <span class="px-4 py-2 bg-primary/10 text-primary rounded-xl font-bold text-sm uppercase tracking-wider">
                         Conférence
                    </span>
                    {% if event.location %}
                    <span class="flex items-center gap-2 text-slate-500 font-medium">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {{ event.location.name }}
                    </span>
                    {% endif %}
                </div>

                <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white mb-6 leading-tight">
                    {{ event.title }}
                </h1>

                <!-- Flash Messages -->
                {% for message in app.flashes('success') %}
                    <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 px-6 py-4 rounded-2xl flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                        <span class="font-medium">{{ message }}</span>
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                     <div class="mb-6 bg-red-500/10 border border-red-500/20 text-red-600 dark:text-red-400 px-6 py-4 rounded-2xl flex items-center gap-3">
                        <span class="font-medium">{{ message }}</span>
                    </div>
                {% endfor %}

                <div class="prose prose-lg prose-slate dark:prose-invert max-w-none">
                    {{ event.description|nl2br }}
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
            <!-- Event Details Card -->
            <div class="glass-card rounded-[2rem] p-8 shadow-xl">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Détails pratiques</h3>
                
                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-blue-500/10 text-blue-500 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                        <div>
                            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Date</span>
                            <span class="text-lg font-bold text-slate-900 dark:text-white">{{ event.eventDate|date('d F Y') }}</span>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-amber-500/10 text-amber-500 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Horaire</span>
                            <span class="text-lg font-bold text-slate-900 dark:text-white">{{ event.startTime|date('H:i') }} - {{ event.endTime|date('H:i') }}</span>
                        </div>
                    </div>

                    {% if event.location %}
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <div>
                            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Lieu</span>
                            <span class="block text-lg font-bold text-slate-900 dark:text-white">{{ event.location.name }}</span>
                            <span class="text-sm text-slate-500">{{ event.location.building }} - Salle {{ event.location.roomNumber }}</span>
                        </div>
                    </div>
                    {% endif %}
                </div>

                <div class="mt-8 pt-8 border-t border-slate-100 dark:border-white/5">
                    {% if app.user %}
                        {% if app.user.joinedEvents.contains(event) %}
                            <form action="{{ path('app_event_join', {id: event.id}) }}" method="post">
                                <button type="submit" class="w-full btn-secondary flex items-center justify-center gap-2 group">
                                    <span class="group-hover:hidden">Déjà inscrit</span>
                                    <span class="hidden group-hover:inline text-red-500">Se désinscrire</span>
                                </button>
                            </form>
                        {% else %}
                             <form action="{{ path('app_event_join', {id: event.id}) }}" method="post">
                                <button type="submit" class="w-full btn-primary flex items-center justify-center gap-2 shadow-xl shadow-primary/20">
                                    S'inscrire maintenant
                                </button>
                            </form>
                        {% endif %}
                    {% else %}
                        <a href="{{ path('app_login') }}" class="w-full btn-primary flex items-center justify-center gap-2 shadow-xl shadow-primary/20">
                            Connectez-vous pour participer
                        </a>
                    {% endif %}
                </div>
            </div>
            
        </div>
    </div>
</div>
{% endblock %}
