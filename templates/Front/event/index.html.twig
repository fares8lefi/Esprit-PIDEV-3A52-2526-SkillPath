{% extends 'base.html.twig' %}

{% block title %}Événements - SkillPath{% endblock %}

{% block body %}
<!-- Hero Section -->
<div class="relative py-20 bg-gradient-to-b from-primary/5 to-transparent dark:from-primary/10">
    <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-6">
            Découvrez nos <span class="gradient-text">Événements</span>
        </h1>
        <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
            Participez à des conférences, ateliers et rencontres exclusives pour booster votre carrière.
        </p>
    </div>
</div>

<!-- Events Grid -->
<div class="container mx-auto px-4 pb-20">
    {% if events|length > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for event in events %}
                <div class="group glass-card rounded-[2rem] overflow-hidden hover:shadow-2xl hover:shadow-primary/10 transition-all duration-300 hover:-translate-y-2">
                    <!-- Image -->
                    <div class="relative h-64 overflow-hidden">
                        {% if event.image %}
                            <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700">
                        {% else %}
                            <div class="w-full h-full bg-slate-100 dark:bg-white/5 flex items-center justify-center">
                                <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            </div>
                        {% endif %}
                        
                        <!-- Date Badge -->
                        <div class="absolute top-4 left-4 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md px-4 py-2 rounded-2xl shadow-lg">
                            <div class="text-center leading-none">
                                <span class="block text-xs font-bold text-slate-400 uppercase">{{ event.eventDate|date('M') }}</span>
                                <span class="block text-2xl font-black text-slate-900 dark:text-white">{{ event.eventDate|date('d') }}</span>
                            </div>
                        </div>

                        <!-- Favorite Button (if logged in) -->
                        {% if app.user %}
                            <form action="{{ path('app_event_favorite', {id: event.id}) }}" method="post" class="absolute top-4 right-4">
                                <button type="submit" class="p-3 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md rounded-full shadow-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors group/love">
                                    <svg class="w-5 h-5 transition-colors {{ app.user.favoriteEvents.contains(event) ? 'text-red-500 fill-red-500' : 'text-slate-400 group-hover/love:text-red-500' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                                </button>
                            </form>
                        {% endif %}
                    </div>

                    <!-- Content -->
                    <div class="p-8">
                        <div class="flex items-center gap-2 mb-4 text-xs font-bold uppercase tracking-wider text-primary">
                            {% if event.location %}
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                <span>{{ event.location.name }}</span>
                            {% else %}
                                <span>En ligne</span>
                            {% endif %}
                        </div>

                        <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-3 line-clamp-1">
                            <a href="{{ path('app_event_show', {id: event.id}) }}" class="hover:text-primary transition-colors">{{ event.title }}</a>
                        </h3>
                        
                        <p class="text-slate-500 dark:text-slate-400 line-clamp-2 mb-6">
                            {{ event.description }}
                        </p>

                        <div class="flex items-center justify-between border-t border-slate-100 dark:border-white/5 pt-6">
                            <div class="flex items-center gap-2 text-sm font-medium text-slate-600 dark:text-slate-400">
                                <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                {{ event.startTime|date('H:i') }} - {{ event.endTime|date('H:i') }}
                            </div>
                            
                            <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn-secondary text-sm py-2">
                                Voir détails
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-20">
            <div class="w-24 h-24 bg-slate-50 dark:bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">Aucun événement prévu</h3>
            <p class="text-slate-500 dark:text-slate-400">Revenez plus tard pour découvrir nos prochains événements.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
