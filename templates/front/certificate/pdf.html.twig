<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Certificat de Réussite</title>
    <style>
        @page { margin: 0; }
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
            margin: 0;
            padding: 0;
        }
        .certificate-container {
            width: 100%;
            height: 100%;
            padding: 50px;
            box-sizing: border-box;
            background-color: #f1f5f9;
        }
        .border-outer {
            border: 10px solid #2563eb;
            padding: 20px;
            height: calc(100% - 40px);
            background-color: white;
            position: relative;
        }
        .border-inner {
            border: 2px solid #e2e8f0;
            padding: 60px;
            height: calc(100% - 120px);
            text-align: center;
        }
        .logo {
            font-size: 32px;
            font-weight: bold;
            color: #2563eb;
            margin-bottom: 40px;
        }
        .title {
            font-size: 48px;
            font-weight: 900;
            color: #0f172a;
            margin-bottom: 20px;
            text-transform: uppercase;
        }
        .subtitle {
            font-size: 20px;
            color: #64748b;
            margin-bottom: 50px;
        }
        .student-name {
            font-size: 36px;
            font-weight: bold;
            color: #2563eb;
            margin-bottom: 20px;
            border-bottom: 2px solid #e2e8f0;
            display: inline-block;
            padding-bottom: 10px;
            min-width: 400px;
        }
        .cours-info {
            font-size: 18px;
            margin-bottom: 60px;
            line-height: 1.6;
        }
        .cours-name {
            font-weight: bold;
            color: #0f172a;
        }
        .footer {
            margin-top: 80px;
            width: 100%;
        }
        .signature-box {
            border-top: 1px solid #94a3b8;
            width: 200px;
            padding-top: 10px;
            font-size: 14px;
            color: #64748b;
        }
        .certificate-id {
            position: absolute;
            bottom: 30px;
            right: 30px;
            font-size: 10px;
            color: #94a3b8;
            font-family: monospace;
        }
        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            font-size: 120px;
            font-weight: bold;
            color: rgba(37, 99, 235, 0.03);
            z-index: 0;
            pointer-events: none;
        }
    </style>
</head>
<body>
    <div class="certificate-container">
        <div class="border-outer">
            <div class="watermark">SKILLPATH</div>
            <div class="border-inner">
                <div class="logo">SkillPath.</div>
                
                <div class="title">Certificat de Réussite</div>
                <div class="subtitle">Ce document certifie que</div>
                
                <div class="student-name">{{ studentName }}</div>
                
                <div class="cours-info">
                    a complété avec succès le cours complet :<br>
                    <span class="cours-name">{{ coursName }}</span><br>
                    le {{ completionDate|date('d F Y') }}
                </div>
                
                <div class="footer">
                    <div style="float: left; text-align: center;">
                        <div style="font-family: 'Courier', serif; font-size: 24px; color: #1e293b; margin-bottom: 5px;">Yazid Khedhiri</div>
                        <div class="signature-box">Directeur Pédagogique</div>
                    </div>
                    <div style="float: right; text-align: center;">
                        <img src="{{ sealPath }}" style="width: 120px; height: 120px; margin-top: -60px;">
                        <div class="signature-box">Sceau de l'Académie</div>
                    </div>
                    <div style="clear: both;"></div>
                </div>

                <div class="certificate-id">ID Certificat : {{ certificateNumber }}</div>
            </div>
        </div>
    </div>
</body>
</html>
