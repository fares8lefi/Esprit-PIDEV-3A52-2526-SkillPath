{% extends 'base.html.twig' %}

{% block title %}{{ cours.name }} - SkillPathOff{% endblock %}

{% block body %}
    <div class="bg-gray-50 min-h-screen font-sans pb-20">
        
        {# Decorative Header #}
        <div class="bg-brand-blue-dark pt-20 pb-40 px-4 relative overflow-hidden">
             <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
             <div class="absolute inset-0 bg-gradient-to-br from-brand-blue/20 to-transparent"></div>
             
             <div class="container mx-auto max-w-5xl relative z-10">
                <div class="flex items-center justify-between mb-8">
                    <a href="{{ path('front_cours_index') }}" class="inline-flex items-center text-white/70 hover:text-white transition-colors font-medium text-sm group">
                        <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center mr-3 group-hover:bg-white/20 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                        </div>
                        Retour à la liste des cours
                    </a>
                    {% if app.user %}
                        <a href="{{ path('front_notifications_index') }}" class="relative inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/20 text-white hover:bg-white hover:text-brand-dark transition">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                            </svg>
                            {% if unreadCount is defined and unreadCount > 0 %}
                                <span class="absolute -top-1 -right-1 inline-flex items-center justify-center px-1.5 py-0.5 rounded-full bg-red-500 text-white text-[10px] font-bold">
                                    {{ unreadCount > 9 ? '9+' : unreadCount }}
                                </span>
                            {% endif %}
                        </a>
                    {% endif %}
                </div>

                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
                    <div class="max-w-3xl">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white bg-brand-blue rounded-lg shadow-lg shadow-brand-blue/30">
                                {{ cours.level }}
                            </span>
                            <span class="text-white/60 text-sm flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                Mis à jour le {{ cours.createdAt|date('d M Y') }}
                            </span>
                        </div>
                        <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-2">{{ cours.name }}</h1>
                    </div>
                </div>
             </div>
        </div>

        <div class="container mx-auto max-w-5xl px-4 -mt-32 relative z-20">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                
                {# Left Side: Main Content #}
                <div class="lg:col-span-2 space-y-8">
                    {# Image & Content Card #}
                    <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/50 overflow-hidden border border-gray-100">
                        <div class="h-80 w-full relative">
                             {% if cours.image %}
                                <img src="{{ asset('uploads/modules/' ~ cours.image) }}" alt="{{ cours.name }}" class="w-full h-full object-cover">
                                <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
                            {% else %}
                                <div class="w-full h-full bg-brand-gray flex items-center justify-center text-gray-300">
                                    <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                </div>
                            {% endif %}
                        </div>

                        <div class="px-8 pb-12">
                            <h2 class="text-2xl font-bold text-brand-dark mb-6">À propos de ce cours</h2>
                            <div class="prose prose-lg prose-slate max-w-none text-brand-dark/70 font-normal leading-relaxed">
                                <p>{{ cours.description|nl2br }}</p>
                            </div>
                        </div>
                    </div>

                    {# Programme Section #}
                    <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/50 p-8 border border-gray-100">
                        <div class="flex items-center justify-between mb-8">
                            <h2 class="text-2xl font-bold text-brand-dark flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl bg-brand-blue/10 flex items-center justify-center text-brand-blue">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                </div>
                                Programme complet 
                                <span class="text-brand-muted text-lg font-normal ml-2">({{ cours.modules|length }} chapitres)</span>
                            </h2>
                        </div>
                        
                        <div class="space-y-4">
                            {% for module in cours.modules %}
                                {% set isFuture = module.scheduledAt > now %}
                                <div class="relative">
                                    {% if isFuture %}
                                        <div class="bg-gray-50/50 p-5 rounded-2xl border border-dashed border-gray-200 flex items-center justify-between opacity-60">
                                            <div class="flex items-center gap-5">
                                                <div class="w-12 h-12 rounded-2xl bg-gray-200 flex items-center justify-center text-gray-400 font-bold text-lg">
                                                    {{ loop.index }}
                                                </div>
                                                <div>
                                                    <h3 class="font-bold text-gray-500">{{ module.name }}</h3>
                                                    <div class="flex items-center gap-3 mt-1">
                                                        <span class="px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded text-[10px] font-bold uppercase">Prochainement</span>
                                                        <span class="text-[10px] text-gray-400 font-medium">Disponible le {{ module.scheduledAt|date('d/m/Y') }}</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-300">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                            </div>
                                        </div>
                                    {% else %}
                                        <a href="{{ path('front_cours_module_show', {coursId: cours.id, moduleId: module.id}) }}" class="block">
                                            <div class="bg-gray-50/50 p-5 rounded-2xl border border-gray-100 flex items-center justify-between hover:bg-white hover:shadow-lg hover:shadow-brand-blue/5 hover:border-brand-blue/30 transition-all group cursor-pointer">
                                                <div class="flex items-center gap-5">
                                                    <div class="w-12 h-12 rounded-2xl bg-white shadow-sm flex items-center justify-center text-brand-blue font-bold text-lg group-hover:bg-brand-blue group-hover:text-white transition-all transform group-hover:rotate-6">
                                                        {{ loop.index }}
                                                    </div>
                                                    <div>
                                                        <h3 class="font-bold text-brand-dark group-hover:text-brand-blue transition-colors">{{ module.name }}</h3>
                                                        <div class="flex items-center gap-3 text-[10px] text-brand-muted mt-1 uppercase tracking-widest font-bold">
                                                            <span class="bg-white border border-gray-100 px-2 py-0.5 rounded-lg">{{ module.type }}</span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <button class="w-10 h-10 rounded-full bg-white shadow-sm flex items-center justify-center text-brand-blue opacity-0 group-hover:opacity-100 transition-all hover:scale-110">
                                                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
                                                </button>
                                            </div>
                                        </a>
                                    {% endif %}
                                </div>
                            {% else %}
                                <div class="text-center py-12 text-brand-muted italic bg-white rounded-2xl border border-dashed border-gray-200">
                                    Aucun module disponible pour ce cours.
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# Right Side: Cours Info #}
                <div class="lg:col-span-1">
                    <div class="sticky top-8 space-y-6">
                                    <li class="flex items-start gap-3 text-sm text-brand-dark/70">
                                    <svg class="w-5 h-5 text-brand-green mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                    Certificat de réussite
                                </li>
                            </ul>

                            {% if app.user %}
                                <div class="mt-8 pt-8 border-t border-gray-100">
                                    <div class="flex items-center justify-between mb-2">
                                        <span class="text-sm font-bold text-brand-dark">Votre progression</span>
                                        <span class="text-sm font-bold text-brand-blue">{{ progression|round }}%</span>
                                    </div>
                                    <div class="w-full h-3 bg-gray-100 rounded-full overflow-hidden mb-6">
                                        <div class="h-full bg-brand-blue transition-all duration-1000" style="width: {{ progression }}%"></div>
                                    </div>

                                    {% if progression == 100 %}
                                        <a href="{{ path('front_cours_certificate_download', {coursId: cours.id}) }}" class="w-full flex items-center justify-center gap-2 py-4 px-6 bg-brand-green text-white rounded-2xl font-bold shadow-lg shadow-brand-green/30 hover:shadow-xl hover:shadow-brand-green/40 transition-all hover:-translate-y-1">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                            Télécharger mon certificat
                                        </a>
                                    {% else %}
                                        <button class="w-full py-4 px-6 bg-brand-blue text-white rounded-2xl font-bold shadow-lg shadow-brand-blue/30 hover:shadow-xl hover:shadow-brand-blue/40 transition-all hover:-translate-y-1">
                                            Continuer le cours
                                        </button>
                                    {% endif %}
                                </div>
                            {% else %}
                                <div class="mt-8 pt-8 border-t border-gray-100">
                                    <a href="{{ path('app_user_login') }}" class="w-full flex items-center justify-center gap-2 py-4 px-6 bg-brand-blue text-white rounded-2xl font-bold shadow-lg shadow-brand-blue/30 hover:shadow-xl hover:shadow-brand-blue/40 transition-all hover:-translate-y-1">
                                        Se connecter pour commencer
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# FLOATING CHATBOT WIDGET #}
        <div id="ai-chat-widget" class="fixed bottom-6 right-6 z-[100] flex flex-col items-end">
            
            {# Chat Window (Hidden by default) #}
            <div id="ai-chat-window" class="hidden w-[380px] h-[550px] bg-white rounded-3xl shadow-2xl flex flex-col overflow-hidden border border-gray-100 mb-4 animate-fade-in-up origin-bottom-right">
                
                {# Chat Header #}
                <div class="h-16 px-6 bg-brand-blue flex items-center justify-between shadow-lg">
                    <div class="flex items-center gap-3 text-white">
                        <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center backdrop-blur-md">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <div>
                            <h2 class="font-bold text-sm">Assistant SkillPath</h2>
                            <p class="text-[10px] text-white/70">En ligne • Intelligence Artificielle</p>
                        </div>
                    </div>
                    <button id="close-chat" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>

                {# Chat Messages #}
                <div id="chat-messages" class="flex-grow p-6 space-y-4 overflow-y-auto custom-scrollbar scroll-smooth bg-gray-50/50">
                    <div class="flex flex-col items-center justify-center h-full text-center text-brand-muted opacity-40 px-10" id="empty-state">
                        <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mb-4 shadow-sm">
                            <svg class="w-8 h-8 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                        </div>
                        <p class="text-xs font-medium">Posez une question sur ce cours, je connais tout le programme !</p>
                    </div>
                </div>

                {# Chat Input Area #}
                <div class="p-4 bg-white border-t border-gray-100">
                    <form id="tutor-form">
                        <div class="flex gap-2 overflow-x-auto pb-3 mb-3 no-scrollbar">
                             <span class="mode-chip whitespace-nowrap px-3 py-1.5 rounded-full text-[10px] font-bold uppercase bg-brand-blue text-white cursor-pointer shadow-md shadow-brand-blue/20 transition-all hover:scale-105" data-value="expliquer">💡 Expliquer</span>
                             <span class="mode-chip whitespace-nowrap px-3 py-1.5 rounded-full text-[10px] font-bold uppercase bg-gray-100 text-brand-muted hover:bg-white hover:text-brand-blue cursor-pointer transition-all border border-transparent hover:border-brand-blue/30" data-value="resumer">📝 Résumer</span>
                             <span class="mode-chip whitespace-nowrap px-3 py-1.5 rounded-full text-[10px] font-bold uppercase bg-gray-100 text-brand-muted hover:bg-white hover:text-brand-blue cursor-pointer transition-all border border-transparent hover:border-brand-blue/30" data-value="quiz">❓ Quiz</span>
                        </div>
                        
                        <select id="mode" class="hidden"><option value="expliquer" selected>expliquer</option></select>
                        <textarea id="context" class="hidden">{{ cours.description }}</textarea>

                        <div class="relative flex items-center">
                            <input type="text" id="question" class="w-full bg-gray-50 border-gray-100 rounded-2xl py-3.5 pl-4 pr-12 text-sm text-brand-dark focus:ring-2 focus:ring-brand-blue/20 focus:border-brand-blue/30 focus:bg-white transition-all placeholder-gray-400" placeholder="Une question ?" autocomplete="off">
                            <button type="submit" id="submit-btn" class="absolute right-1.5 p-2 bg-brand-blue text-white rounded-xl shadow-lg shadow-brand-blue/30 hover:shdaow-brand-blue/40 transition-all disabled:opacity-50">
                                <svg id="btn-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                                <svg id="btn-loader" class="hidden animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            {# Toggle Button #}
            <button id="toggle-chat" class="w-16 h-16 bg-brand-blue text-white rounded-full shadow-2xl shadow-brand-blue/40 flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-300 transform group relative">
                <div class="absolute -top-1 -right-1 flex h-4 w-4">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-4 w-4 bg-green-500 border-2 border-white"></span>
                </div>
                <svg id="toggle-open-icon" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                <svg id="toggle-close-icon" class="hidden w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <style>
            .custom-scrollbar::-webkit-scrollbar { width: 5px; }
            .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
            .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 20px; }
            .no-scrollbar::-webkit-scrollbar { display: none; }
            @keyframes fade-in-up { from { opacity: 0; transform: translateY(20px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }
            .animate-fade-in-up { animation: fade-in-up 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
            .shadow-soft { box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05); }
        </style>

        <script>
            document.addEventListener('turbo:load', () => {
                const chatWindow = document.getElementById('ai-chat-window');
                const toggleBtn = document.getElementById('toggle-chat');
                const closeBtn = document.getElementById('close-chat');
                const openIcon = document.getElementById('toggle-open-icon');
                const closeIcon = document.getElementById('toggle-close-icon');

                // Toggle logic
                const toggleChat = () => {
                    const isHidden = chatWindow.classList.contains('hidden');
                    if (isHidden) {
                        chatWindow.classList.remove('hidden');
                        openIcon.classList.add('hidden');
                        closeIcon.classList.remove('hidden');
                        toggleBtn.classList.add('rotate-90');
                        setTimeout(() => chatWindow.scrollTop = chatWindow.scrollHeight, 100);
                    } else {
                        chatWindow.classList.add('hidden');
                        openIcon.classList.remove('hidden');
                        closeIcon.classList.add('hidden');
                        toggleBtn.classList.remove('rotate-90');
                    }
                };

                toggleBtn.addEventListener('click', toggleChat);
                closeBtn.addEventListener('click', toggleChat);

                // Chat Logic (same as before but adapted for widget)
                const form = document.getElementById('tutor-form');
                const chatMessages = document.getElementById('chat-messages');
                const emptyState = document.getElementById('empty-state');
                const questionInput = document.getElementById('question');
                const contextInput = document.getElementById('context');
                const modeSelect = document.getElementById('mode');
                const submitBtn = document.getElementById('submit-btn');
                const btnIcon = document.getElementById('btn-icon');
                const btnLoader = document.getElementById('btn-loader');
                const modeChips = document.querySelectorAll('.mode-chip');

                modeChips.forEach(chip => {
                    chip.addEventListener('click', () => {
                        modeChips.forEach(c => {
                            c.classList.remove('bg-brand-blue', 'text-white', 'shadow-md', 'shadow-brand-blue/20');
                            c.classList.add('bg-gray-100', 'text-brand-muted');
                        });
                        chip.classList.remove('bg-gray-100', 'text-brand-muted');
                        chip.classList.add('bg-brand-blue', 'text-white', 'shadow-md', 'shadow-brand-blue/20');
                        modeSelect.value = chip.dataset.value;
                    });
                });

                function addMessage(text, isUser = false) {
                    if(emptyState) emptyState.classList.add('hidden');

                    const div = document.createElement('div');
                    div.className = `flex ${isUser ? 'justify-end' : 'justify-start'} animate-fade-in-up items-end gap-2`;
                    
                    const avatar = !isUser ? 
                        `<div class="w-8 h-8 rounded-xl bg-brand-blue flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold shadow-sm mb-1">IA</div>` : '';
                    
                    const bubbleClass = isUser 
                        ? 'bg-brand-blue text-white rounded-2xl rounded-br-none shadow-md' 
                        : 'bg-white text-brand-dark rounded-2xl rounded-bl-none shadow-soft border border-gray-100';

                    const content = `
                        <div class="${bubbleClass} p-3.5 max-w-[85%] text-xs leading-relaxed">
                            <p class="whitespace-pre-wrap">${text}</p>
                        </div>
                    `;

                    div.innerHTML = isUser ? content : avatar + content;
                    chatMessages.appendChild(div);
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }

                function addLoader() {
                    const div = document.createElement('div');
                    div.id = 'chat-loader';
                    div.className = 'flex justify-start animate-fade-in-up items-end gap-2';
                    div.innerHTML = `
                        <div class="w-8 h-8 rounded-xl bg-brand-blue flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold shadow-sm mb-1">IA</div>
                        <div class="bg-white p-4 rounded-2xl rounded-bl-none shadow-soft border border-gray-100">
                            <div class="flex space-x-1">
                                <div class="w-1 h-1 bg-brand-blue rounded-full animate-bounce"></div>
                                <div class="w-1 h-1 bg-brand-blue rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
                                <div class="w-1 h-1 bg-brand-blue rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                            </div>
                        </div>
                    `;
                    chatMessages.appendChild(div);
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }

                function removeLoader() {
                    const loader = document.getElementById('chat-loader');
                    if (loader) loader.remove();
                }

                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const question = questionInput.value.trim();
                    const context = contextInput.value.trim();
                    const mode = modeSelect.value;
                    if (!question) return;

                    questionInput.disabled = true;
                    submitBtn.disabled = true;
                    btnIcon.classList.add('hidden');
                    btnLoader.classList.remove('hidden');

                    addMessage(question, true);
                    addLoader();
                    questionInput.value = '';

                    try {
                        const response = await fetch('/api/tutor', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ question, context, mode })
                        });
                        if (!response.ok) throw new Error(`HTTP ${response.status}`);
                        const data = await response.json();
                        removeLoader();
                        addMessage(data.answer || "Désolé, je rencontre un problème.");
                    } catch (error) {
                        removeLoader();
                        addMessage("Erreur de connexion network.");
                    } finally {
                        questionInput.disabled = false;
                        submitBtn.disabled = false;
                        btnIcon.classList.remove('hidden');
                        btnLoader.classList.add('hidden');
                        questionInput.focus();
                    }
                });
            });
        </script>
    </div>
{% endblock %}
