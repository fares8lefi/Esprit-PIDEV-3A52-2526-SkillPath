{% extends 'base.html.twig' %}

{% block title %}Nos Cours - SkillPath{% endblock %}

{% block body %}
    {# Header / Breadcrumb Section #}
    <div class="bg-brand-dark py-12 relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-5"></div>
        <div class="container mx-auto px-6 relative z-10">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-4xl font-bold text-white mb-2">Liste des Cours</h1>
                    <div class="flex items-center text-sm text-gray-400">
                        <a href="#" class="hover:text-white transition-colors">Accueil</a>
                        <span class="mx-2">•</span>
                        <span class="text-white">Cours</span>
                    </div>
                </div>
                {% if app.user %}
                    <a href="{{ path('front_notifications_index') }}" class="relative inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/10 border border-white/20 text-white hover:bg-white hover:text-brand-dark transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                        </svg>
                        {% if unreadCount is defined and unreadCount > 0 %}
                            <span class="absolute -top-1 -right-1 inline-flex items-center justify-center px-1.5 py-0.5 rounded-full bg-red-500 text-white text-[10px] font-bold">
                                {{ unreadCount > 9 ? '9+' : unreadCount }}
                            </span>
                        {% endif %}
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

    {# Main Content #}
    <section class="container mx-auto px-6 py-12">
        <form id="filter-form" method="GET" action="{{ path('front_cours_index') }}">
            <div class="flex flex-col lg:flex-row gap-8">
                
                {# Left Column: Cours List #}
                <div class="w-full lg:w-3/4">
                    {# Toolbar #}
                    <div class="flex flex-col md:flex-row items-center justify-between mb-8 gap-4">
                        <p class="text-brand-muted font-medium">Affichage de <span class="text-brand-dark font-bold">{{ cours|length }}</span> résultats</p>
                        <div class="flex items-center gap-4 flex-wrap">
                            {# View Toggle Buttons #}
                            <div class="flex items-center gap-2">
                                <button type="button" class="p-2.5 rounded-lg bg-gray-100 text-brand-muted hover:bg-gray-200 transition-colors" title="Grille">
                                     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                                </button>
                                <button type="button" class="p-2.5 rounded-lg bg-brand-blue text-white shadow-md" title="Liste">
                                     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                                </button>
                            </div>

                            {# Date Sorting Group #}
                            <div class="flex items-center gap-1 bg-gray-100 rounded-lg p-1">
                                <button type="button" onclick="setSortAndSubmit('date_desc')" 
                                        class="px-3 py-1.5 text-xs font-semibold rounded transition-all {{ currentSort == 'date_desc' ? 'bg-white text-brand-blue shadow-sm' : 'text-gray-600 hover:text-brand-blue' }}">
                                    Plus récent
                                </button>
                                <button type="button" onclick="setSortAndSubmit('date_asc')" 
                                        class="px-3 py-1.5 text-xs font-semibold rounded transition-all {{ currentSort == 'date_asc' ? 'bg-white text-brand-blue shadow-sm' : 'text-gray-600 hover:text-brand-blue' }}">
                                    Plus ancien
                                </button>
                            </div>

                            {# Title Sorting Group #}
                            <div class="flex items-center gap-1 bg-gray-100 rounded-lg p-1">
                                <button type="button" onclick="setSortAndSubmit('title_asc')" 
                                        class="px-3 py-1.5 text-xs font-semibold rounded transition-all {{ currentSort == 'title_asc' ? 'bg-white text-brand-blue shadow-sm' : 'text-gray-600 hover:text-brand-blue' }}">
                                    A-Z
                                </button>
                                <button type="button" onclick="setSortAndSubmit('title_desc')" 
                                        class="px-3 py-1.5 text-xs font-semibold rounded transition-all {{ currentSort == 'title_desc' ? 'bg-white text-brand-blue shadow-sm' : 'text-gray-600 hover:text-brand-blue' }}">
                                    Z-A
                                </button>
                            </div>

                            <input type="hidden" name="sort" id="sortInput" value="{{ currentSort }}">
                        </div>
                    </div>

                    {# Cours Stack #}
                    <div class="space-y-6">
                        {% if cours is empty %}
                            <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
                               <p class="text-gray-500 italic">Aucun cours ne correspond à vos critères de recherche.</p>
                               <a href="{{ path('front_cours_index') }}" class="text-brand-blue font-bold mt-4 inline-block hover:underline">Réinitialiser les filtres</a>
                            </div>
                        {% else %}
                            {% for cours in cours %}
                                <div class="bg-white rounded-2xl p-4 shadow-soft hover:shadow-lg transition-all duration-300 border border-gray-100 flex flex-col md:flex-row gap-6 group animate-fade-in-up">
                                    {# Image Section #}
                                    <div class="w-full md:w-72 h-48 md:h-auto flex-shrink-0 relative overflow-hidden rounded-xl">
                                        {% if cours.image %}
                                            <img src="{{ asset('uploads/modules/' ~ cours.image) }}" alt="{{ cours.name }}" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500">
                                        {% else %}
                                            <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-300">
                                                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                            </div>
                                        {% endif %}
                                        <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm px-2 py-1 rounded shadow-sm text-xs font-bold text-gray-700">
                                            Gratuit
                                        </div>
                                    </div>

                                    {# Content Section #}
                                    <div class="flex-grow flex flex-col justify-between py-1">
                                        <div>
                                            <div class="flex justify-between items-start mb-2">
                                                <div class="flex items-center gap-2">
                                                    <span class="px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wide bg-brand-blue/10 text-brand-blue">
                                                        {{ cours.categorie|default('Général') }}
                                                    </span>
                                                    <div class="flex items-center text-xs text-brand-yellow font-bold">
                                                        <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                        <span class="ml-1 text-gray-600">4.5</span>
                                                    </div>
                                                </div>
                                                <button type="button" class="text-gray-300 hover:text-red-500 transition-colors"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg></button>
                                            </div>

                                            <h2 class="text-xl font-bold text-brand-dark mb-2 hover:text-brand-blue transition-colors cursor-pointer">
                                                <a href="{{ path('front_cours_show', {id: cours.id}) }}">{{ cours.name }}</a>
                                            </h2>
                                            <p class="text-sm text-gray-500 line-clamp-2 mb-4">
                                                {{ cours.description }}
                                            </p>

                                            <div class="flex items-center gap-4 text-xs text-gray-500 mb-4">
                                                <div class="flex items-center gap-1">
                                                    <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                    <span>{{ cours.modules|length }} modules</span>
                                                </div>
                                                
                                                {# Calendar Schedule Icon #}
                                                {% set futureModules = [] %}
                                                {% for m in cours.modules %}
                                                    {% if m.scheduledAt > now %}
                                                        {% set futureModules = futureModules|merge([m]) %}
                                                    {% endif %}
                                                {% endfor %}

                                                {% if futureModules|length > 0 %}
                                                    <div class="flex items-center gap-1 relative group/tooltip cursor-help">
                                                        <svg class="w-4 h-4 text-brand-blue animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                                        <span class="text-brand-blue font-bold">Agenda</span>
                                                        
                                                        {# Tooltip content #}
                                                        <div class="absolute bottom-full left-0 mb-2 hidden group-hover/tooltip:block bg-gray-900 text-white text-[10px] p-3 rounded-xl shadow-2xl z-50 w-64 border border-gray-700 backdrop-blur-sm bg-opacity-95">
                                                            <p class="font-bold border-b border-gray-700 pb-1 mb-2 text-brand-blue tracking-wider uppercase">Prochainement :</p>
                                                            <ul class="space-y-1.5">
                                                                {% for fm in futureModules|slice(0, 3) %}
                                                                    <li class="flex justify-between items-center gap-2">
                                                                        <span class="truncate">{{ fm.name }}</span>
                                                                        <span class="text-brand-yellow font-medium shrink-0">{{ fm.scheduledAt|date('d/m/Y') }}</span>
                                                                    </li>
                                                                {% endfor %}
                                                                {% if futureModules|length > 3 %}
                                                                    <li class="text-gray-400 italic pt-1 text-center">+ {{ futureModules|length - 3 }} autres chapitres</li>
                                                                {% endif %}
                                                            </ul>
                                                            <div class="absolute top-full left-4 border-8 border-transparent border-t-gray-900"></div>
                                                        </div>
                                                    </div>
                                                {% endif %}

                                                <div class="flex items-center gap-1">
                                                    <svg class="w-4 h-4 text-brand-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                                    <span>{{ cours.level }}</span>
                                                </div>
                                                <div class="flex items-center gap-1">
                                                     <svg class="w-4 h-4 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                    <span>Certifié</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="flex items-center justify-between pt-4 border-t border-gray-100 mt-auto">
                                            <div class="flex items-center gap-2">
                                                <img src="https://ui-avatars.com/api/?name=Skill+Path&background=random" alt="Author" class="w-8 h-8 rounded-full border border-white shadow-sm">
                                                <span class="text-sm font-medium text-brand-dark">SkillPath Team</span>
                                            </div>
                                            <a href="{{ path('front_cours_show', {id: cours.id}) }}" class="bg-gray-800 hover:bg-black text-white text-sm font-semibold py-2 px-5 rounded-lg transition-colors shadow-lg shadow-gray-200">
                                                View more
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

                {# Right Column: Sidebar Filters #}
                <div class="w-full lg:w-1/4 space-y-8">
                    
                    {# Search Widget #}
                    <div class="bg-white p-6 rounded-2xl shadow-soft border border-gray-100">
                        <h3 class="font-bold text-brand-dark mb-4">Rechercher</h3>
                        <div class="relative group">
                            <input type="text" name="search" value="{{ currentSearch }}" placeholder="Mots-clés..." class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:ring-brand-blue focus:border-brand-blue transition-all">
                            <svg class="w-4 h-4 text-gray-400 absolute left-3 top-3 group-focus-within:text-brand-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            <button type="submit" class="hidden"></button> {# Hidden submit for Enter key #}
                        </div>
                    </div>

                    {# Categories Widget #}
                    <div class="bg-white p-6 rounded-2xl shadow-soft border border-gray-100">
                        <h3 class="font-bold text-brand-dark mb-4">Catégories</h3>
                        <div class="space-y-3">
                            {% for cat in categoriesCount %}
                                <label class="flex items-center space-x-3 cursor-pointer group">
                                    <input type="radio" name="category" value="{{ cat.name }}" class="form-radio h-4 w-4 text-brand-blue border-gray-300 focus:ring-brand-blue" {{ currentCategory == cat.name ? 'checked' : '' }}>
                                    <span class="text-gray-600 text-sm group-hover:text-brand-blue transition-colors">{{ cat.name }}</span>
                                    <span class="ml-auto text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{{ cat.count }}</span>
                                </label>
                            {% else %}
                                <p class="text-xs text-brand-muted italic">Aucune catégorie répertoriée.</p>
                            {% endfor %}
                        </div>
                    </div>
                    
                    {# Level Widget #}
                    <div class="bg-white p-6 rounded-2xl shadow-soft border border-gray-100">
                        <h3 class="font-bold text-brand-dark mb-4">Niveau</h3>
                        <div class="space-y-3">
                            <label class="flex items-center space-x-3 cursor-pointer group">
                                <input type="radio" name="level" value="" class="form-radio h-4 w-4 text-brand-blue border-gray-300 focus:ring-brand-blue" {{ not currentLevel ? 'checked' : '' }}>
                                <span class="text-gray-600 text-sm group-hover:text-brand-blue transition-colors">Tous les niveaux</span>
                            </label>
                            {% for lvl in ['Débutant', 'Intermédiaire', 'Avancé'] %}
                                <label class="flex items-center space-x-3 cursor-pointer group">
                                    <input type="radio" name="level" value="{{ lvl }}" class="form-radio h-4 w-4 text-brand-blue border-gray-300 focus:ring-brand-blue" {{ currentLevel == lvl ? 'checked' : '' }}>
                                    <span class="text-gray-600 text-sm group-hover:text-brand-blue transition-colors">{{ lvl }}</span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="pt-4">
                         <a href="{{ path('front_cours_index') }}" class="w-full py-3 px-4 bg-gray-100 text-brand-muted text-center rounded-xl text-sm font-bold hover:bg-gray-200 transition-colors block">
                            Réinitialiser
                        </a>
                    </div>

                    {# Banner Widget #}
                    <div class="relative rounded-2xl overflow-hidden h-64 shadow-lg group">
                        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                        <div class="absolute inset-0 bg-blue-900/80 flex flex-col items-center justify-center text-center p-6">
                            <h4 class="text-white font-bold text-xl mb-2">Devenez Instructeur</h4>
                            <p class="text-blue-100 text-sm mb-4">Partagez vos connaissances et inspirez les autres.</p>
                            <button type="button" class="bg-white text-brand-blue px-4 py-2 rounded-lg text-sm font-bold hover:bg-blue-50 transition-colors">Rejoindre</button>
                        </div>
                    </div>

                </div>
            </div>
        </form>
    </section>

    <script>
        function setSortAndSubmit(sortValue) {
            document.getElementById('sortInput').value = sortValue;
            document.getElementById('filter-form').submit();
        }

        document.addEventListener('DOMContentLoaded', function() {
            const filterForm = document.getElementById('filter-form');
            const inputs = filterForm.querySelectorAll('input[type="radio"]');
            
            inputs.forEach(input => {
                input.addEventListener('change', () => {
                    filterForm.submit();
                });
            });

            // For search input, we use Enter key (default) or debouncing if requested
            // But user said "auto-submit when filter changes", usually refers to list/radio
        });
    </script>

    <style>
        .animate-fade-in-up {
            animation: fadeInUp 0.5s ease-out forwards;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
{% endblock %}


