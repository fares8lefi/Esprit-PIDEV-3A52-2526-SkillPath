{% extends 'base.html.twig' %}

{% block title %}Nos Cours - SkillPath{% endblock %}

{% block body %}
    {# Header / Breadcrumb Section #}
    <div class="bg-brand-dark py-12 relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-5"></div>
        <div class="container mx-auto px-6 relative z-10">
            <h1 class="text-4xl font-bold text-white mb-2">Liste des Cours</h1>
            <div class="flex items-center text-sm text-gray-400">
                <a href="#" class="hover:text-white transition-colors">Accueil</a>
                <span class="mx-2">•</span>
                <span class="text-white">Cours</span>
            </div>
        </div>
    </div>

    {# Main Content #}
    <section class="container mx-auto px-6 py-12">
        <div class="flex flex-col lg:flex-row gap-8">
            
            {# Left Column: Course List #}
            <div class="w-full lg:w-3/4">
                {# Toolbar #}
                <div class="flex flex-col md:flex-row items-center justify-between mb-8">
                    <p class="text-brand-muted font-medium mb-4 md:mb-0">Affichage de <span class="text-brand-dark font-bold">{{ courses|length }}</span> résultats</p>
                    <div class="flex items-center gap-3">
                        <button class="p-2.5 rounded-lg bg-gray-100 text-brand-muted hover:bg-gray-200 transition-colors" title="Grille">
                             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                        </button>
                        <button class="p-2.5 rounded-lg bg-brand-blue text-white shadow-md" title="Liste">
                             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                        </button>
                        <select class="form-select bg-gray-50 border-gray-200 text-gray-600 text-sm rounded-lg focus:ring-brand-blue focus:border-brand-blue block p-2.5">
                            <option>Trier par popularité</option>
                            <option>Plus récent</option>
                            <option>Prix croissant</option>
                        </select>
                    </div>
                </div>

                {# Courses Stack #}
                <div class="space-y-6">
                    {% if courses is empty %}
                        <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-gray-100">
                           <p class="text-gray-500">Aucun cours trouvé.</p>
                        </div>
                    {% else %}
                        {% for course in courses %}
                            <div class="bg-white rounded-2xl p-4 shadow-soft hover:shadow-lg transition-all duration-300 border border-gray-100 flex flex-col md:flex-row gap-6 group">
                                {# Image Section #}
                                <div class="w-full md:w-72 h-48 md:h-auto flex-shrink-0 relative overflow-hidden rounded-xl">
                                    {% if course.image %}
                                        <img src="{{ asset('uploads/modules/' ~ course.image) }}" alt="{{ course.name }}" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500">
                                    {% else %}
                                        <div class="w-full h-full bg-gray-100 flex items-center justify-center text-gray-300">
                                            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        </div>
                                    {% endif %}
                                    <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm px-2 py-1 rounded shadow-sm text-xs font-bold text-gray-700">
                                        Gratuit
                                    </div>
                                </div>

                                {# Content Section #}
                                <div class="flex-grow flex flex-col justify-between py-1">
                                    <div>
                                        <div class="flex justify-between items-start mb-2">
                                            <div class="flex items-center gap-2">
                                                <span class="px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wide bg-brand-blue/10 text-brand-blue">
                                                    Développement
                                                </span>
                                                <div class="flex items-center text-xs text-brand-yellow font-bold">
                                                    <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                    <span class="ml-1 text-gray-600">4.5</span>
                                                </div>
                                            </div>
                                            <button class="text-gray-300 hover:text-red-500 transition-colors"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg></button>
                                        </div>

                                        <h2 class="text-xl font-bold text-brand-dark mb-2 hover:text-brand-blue transition-colors cursor-pointer">
                                            <a href="{{ path('front_courses_show', {id: course.id}) }}">{{ course.name }}</a>
                                        </h2>
                                        <p class="text-sm text-gray-500 line-clamp-2 mb-4">
                                            {{ course.description }}
                                        </p>

                                        <div class="flex items-center gap-4 text-xs text-gray-500 mb-4">
                                            <div class="flex items-center gap-1">
                                                <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                <span>12h 30m</span>
                                            </div>
                                            <div class="flex items-center gap-1">
                                                <svg class="w-4 h-4 text-brand-yellow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                                <span>{{ course.level }}</span>
                                            </div>
                                            <div class="flex items-center gap-1">
                                                 <svg class="w-4 h-4 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                <span>Certifié</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="flex items-center justify-between pt-4 border-t border-gray-100 mt-auto">
                                        <div class="flex items-center gap-2">
                                            <img src="https://ui-avatars.com/api/?name=Skill+Path&background=random" alt="Author" class="w-8 h-8 rounded-full border border-white shadow-sm">
                                            <span class="text-sm font-medium text-brand-dark">SkillPath Team</span>
                                        </div>
                                        <a href="{{ path('front_courses_show', {id: course.id}) }}" class="bg-gray-800 hover:bg-black text-white text-sm font-semibold py-2 px-5 rounded-lg transition-colors shadow-lg shadow-gray-200">
                                            View more
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

            {# Right Column: Sidebar Filters #}
            <div class="w-full lg:w-1/4 space-y-8">
                
                {# Search Widget #}
                <div class="bg-white p-6 rounded-2xl shadow-soft border border-gray-100">
                    <h3 class="font-bold text-brand-dark mb-4">Rechercher</h3>
                    <div class="relative">
                        <input type="text" placeholder="Mots-clés..." class="w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:ring-brand-blue focus:border-brand-blue">
                        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                </div>

                {# Categories Widget #}
                <div class="bg-white p-6 rounded-2xl shadow-soft border border-gray-100">
                    <h3 class="font-bold text-brand-dark mb-4">Catégories</h3>
                    <div class="space-y-3">
                        <label class="flex items-center space-x-3 cursor-pointer group">
                            <input type="checkbox" class="form-checkbox h-4 w-4 text-brand-blue rounded border-gray-300 focus:ring-brand-blue" checked>
                            <span class="text-gray-600 text-sm group-hover:text-brand-blue transition-colors">Développement</span>
                            <span class="ml-auto text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">12</span>
                        </label>
                        <label class="flex items-center space-x-3 cursor-pointer group">
                            <input type="checkbox" class="form-checkbox h-4 w-4 text-brand-blue rounded border-gray-300 focus:ring-brand-blue">
                            <span class="text-gray-600 text-sm group-hover:text-brand-blue transition-colors">Design</span>
                            <span class="ml-auto text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">8</span>
                        </label>
                        <label class="flex items-center space-x-3 cursor-pointer group">
                            <input type="checkbox" class="form-checkbox h-4 w-4 text-brand-blue rounded border-gray-300 focus:ring-brand-blue">
                            <span class="text-gray-600 text-sm group-hover:text-brand-blue transition-colors">Marketing</span>
                            <span class="ml-auto text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">5</span>
                        </label>
                    </div>
                </div>
                
                {# Level Widget #}
                <div class="bg-white p-6 rounded-2xl shadow-soft border border-gray-100">
                    <h3 class="font-bold text-brand-dark mb-4">Niveau</h3>
                    <div class="space-y-3">
                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="radio" name="level" class="form-radio h-4 w-4 text-brand-blue border-gray-300 focus:ring-brand-blue">
                            <span class="text-gray-600 text-sm">Tous les niveaux</span>
                        </label>
                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="radio" name="level" class="form-radio h-4 w-4 text-brand-blue border-gray-300 focus:ring-brand-blue">
                            <span class="text-gray-600 text-sm">Débutant</span>
                        </label>
                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="radio" name="level" class="form-radio h-4 w-4 text-brand-blue border-gray-300 focus:ring-brand-blue">
                            <span class="text-gray-600 text-sm">Intermédiaire</span>
                        </label>
                        <label class="flex items-center space-x-3 cursor-pointer">
                            <input type="radio" name="level" class="form-radio h-4 w-4 text-brand-blue border-gray-300 focus:ring-brand-blue">
                            <span class="text-gray-600 text-sm">Avancé</span>
                        </label>
                    </div>
                </div>

                {# Banner Widget #}
                <div class="relative rounded-2xl overflow-hidden h-64 shadow-lg group">
                    <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                    <div class="absolute inset-0 bg-blue-900/80 flex flex-col items-center justify-center text-center p-6">
                        <h4 class="text-white font-bold text-xl mb-2">Devenez Instructeur</h4>
                        <p class="text-blue-100 text-sm mb-4">Partagez vos connaissances et inspirez les autres.</p>
                        <button class="bg-white text-brand-blue px-4 py-2 rounded-lg text-sm font-bold hover:bg-blue-50 transition-colors">Rejoindre</button>
                    </div>
                </div>

            </div>
        </div>
    </section>
{% endblock %}


