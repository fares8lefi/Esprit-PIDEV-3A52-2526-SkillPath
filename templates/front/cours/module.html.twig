{% extends 'base.html.twig' %}

{% block title %}{{ module.name }} - {{ course.name }} - SkillPath{% endblock %}

{% block body %}
    <div class="bg-gray-50 min-h-screen font-sans">
        
        {# Header #}
        <div class="bg-brand-blue-dark pt-16 pb-12 px-4">
            <div class="container mx-auto max-w-4xl">
                <a href="{{ path('front_courses_show', {id: course.id}) }}" class="inline-flex items-center text-white/70 hover:text-white transition-colors font-medium text-sm mb-6 group">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Retour au cours
                </a>
                
                <div class="flex items-center gap-3 mb-3">
                    <span class="px-3 py-1 text-xs font-bold uppercase text-white bg-brand-blue rounded-lg">
                        {{ module.type|default('TEXTE') }}
                    </span>
                    <span class="text-white/60 text-sm">
                        Module {{ moduleNumber }} / {{ totalModules }}
                    </span>
                </div>
                
                <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{{ module.name }}</h1>
                <p class="text-white/70 text-sm">{{ course.name }}</p>
            </div>
        </div>

        {# Main Content #}
        <div class="container mx-auto max-w-4xl px-4 py-12">
            
            {# Module Content Card #}
            <div class="bg-white rounded-3xl shadow-xl p-8 md:p-12 mb-8">
                <div class="prose prose-lg max-w-none">
                    {% if module.description %}
                        <div class="mb-8 pb-8 border-b border-gray-200">
                            <h2 class="text-xl font-bold text-gray-900 mb-4">Description</h2>
                            <p class="text-gray-600 leading-relaxed">{{ module.description }}</p>
                        </div>
                    {% endif %}

                    {% if module.contenu %}
                        <div>
                            <h2 class="text-xl font-bold text-gray-900 mb-4">Contenu du module</h2>
                            <div class="text-gray-700 leading-relaxed whitespace-pre-wrap">{{ module.contenu }}</div>
                        </div>
                    {% else %}
                        <div class="text-center py-12 text-gray-400">
                            <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            <p class="italic">Le contenu de ce module sera bientôt disponible.</p>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Completion & Navigation #}
            <div class="flex flex-col md:flex-row items-center justify-between gap-6 pt-8 border-t border-gray-100">
                <div>
                    {% if app.user %}
                        <form action="{{ path('front_courses_module_complete', {id: module.id}) }}" method="POST">
                            {% if isCompleted %}
                                <button type="button" disabled class="flex items-center gap-2 px-6 py-3 bg-brand-green/10 text-brand-green rounded-xl font-bold cursor-default">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                    Module terminé
                                </button>
                            {% else %}
                                <button type="submit" class="flex items-center gap-2 px-6 py-3 bg-brand-blue text-white rounded-xl font-bold shadow-lg shadow-brand-blue/30 hover:shadow-xl transition-all hover:-translate-y-1">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    Marquer comme terminé
                                </button>
                            {% endif %}
                        </form>
                    {% endif %}
                </div>

                <div class="flex items-center gap-4">
                    {% if previousModule %}
                        <a href="{{ path('front_courses_module_show', {courseId: course.id, moduleId: previousModule.id}) }}" 
                           class="flex items-center gap-2 px-6 py-3 bg-white text-gray-700 rounded-xl font-semibold shadow-md hover:shadow-lg transition-all hover:-translate-x-1">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                            <span>Précédent</span>
                        </a>
                    {% endif %}

                    {% if nextModule %}
                        <a href="{{ path('front_courses_module_show', {courseId: course.id, moduleId: nextModule.id}) }}" 
                           class="flex items-center gap-2 px-6 py-3 bg-brand-blue/10 text-brand-blue rounded-xl font-semibold hover:bg-brand-blue hover:text-white transition-all">
                            <span>Suivant</span>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                    {% else %}
                        <a href="{{ path('front_courses_show', {id: course.id}) }}" 
                           class="flex items-center gap-2 px-6 py-3 bg-brand-green text-white rounded-xl font-semibold shadow-lg shadow-brand-green/30 hover:shadow-xl transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            <span>Retour au cours</span>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
