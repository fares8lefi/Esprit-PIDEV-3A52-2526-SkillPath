{% extends 'base.html.twig' %}

{% block title %}Mes notifications - SkillPath{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gray-50">
        <div class="max-w-5xl mx-auto px-6 py-10">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-brand-dark mb-1">Mes notifications</h1>
                    <p class="text-sm text-brand-muted">Consultez vos alertes pour les nouveaux cours et modules.</p>
                </div>

                <a href="{{ path('front_cours_index') }}" class="inline-flex items-center text-sm text-brand-blue hover:underline">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Retour aux cours
                </a>
            </div>

            {% set unread = notifications|filter(n => not n.isRead) %}
            {% set read = notifications|filter(n => n.isRead) %}

            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2 text-sm text-brand-muted">
                    <span class="inline-flex items-center px-3 py-1 rounded-full bg-white border border-gray-200 text-xs font-semibold">
                        Non lues : <span class="ml-1 text-brand-blue">{{ unread|length }}</span>
                    </span>
                    <span class="inline-flex items-center px-3 py-1 rounded-full bg-white border border-gray-200 text-xs font-semibold">
                        Lues : <span class="ml-1 text-brand-muted">{{ read|length }}</span>
                    </span>
                </div>

                {% if unread|length > 0 %}
                    <form action="{{ path('front_notifications_mark_all_read') }}" method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('mark_all_notifications') }}">
                        <button type="submit" class="text-xs font-semibold px-3 py-2 rounded-lg bg-brand-blue text-white hover:bg-brand-blue-dark transition">
                            Tout marquer comme lu
                        </button>
                    </form>
                {% endif %}
            </div>

            {% if notifications is empty %}
                <div class="bg-white border border-dashed border-gray-200 rounded-2xl p-10 text-center text-brand-muted">
                    <p class="font-medium">Vous n'avez encore aucune notification.</p>
                </div>
            {% else %}
                <div class="space-y-4">
                    {% for notification in notifications %}
                        <div class="bg-white rounded-2xl border {{ not notification.isRead ? 'border-brand-blue/40 shadow-md shadow-brand-blue/5' : 'border-gray-100' }} p-4 flex items-start justify-between">
                            <div class="flex items-start gap-3">
                                <div class="mt-1">
                                    {% if not notification.isRead %}
                                        <span class="w-2 h-2 rounded-full bg-brand-blue inline-block"></span>
                                    {% else %}
                                        <span class="w-2 h-2 rounded-full bg-gray-300 inline-block"></span>
                                    {% endif %}
                                </div>
                                <div>
                                    <p class="text-sm text-brand-dark">{{ notification.message }}</p>
                                    <p class="text-xs text-brand-muted mt-1">
                                        {{ notification.createdAt|date('d/m/Y H:i') }}
                                        {% if not notification.isRead %}
                                            • Non lue
                                        {% else %}
                                            • Lue
                                        {% endif %}
                                    </p>
                                </div>
                            </div>

                            {% if not notification.isRead %}
                                <form action="{{ path('front_notifications_mark_read', {id: notification.id}) }}" method="POST">
                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_notification' ~ notification.id) }}">
                                    <button type="submit" class="text-xs font-semibold text-brand-blue hover:text-brand-blue-dark">
                                        Marquer comme lue
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

