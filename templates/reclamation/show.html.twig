{% extends 'base.html.twig' %}

{% block title %}{{ reclamation.sujet }}{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark py-12">
    <div class="max-w-3xl mx-auto px-6">
        <!-- Back -->
        <a href="{{ path('app_reclamation_index') }}" class="inline-flex items-center gap-2 text-xs font-bold text-slate-400 hover:text-primary transition-colors mb-6 animate-fade-up">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Mes réclamations
        </a>

        <!-- Subject Card -->
        <div class="glass-card p-7 rounded-2xl mb-8 animate-fade-up">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h1 class="text-xl font-black text-slate-900 dark:text-white tracking-tight mb-2">{{ reclamation.sujet }}</h1>
                    <p class="text-sm text-slate-600 dark:text-slate-300 font-medium leading-relaxed">{{ reclamation.description }}</p>
                </div>
                {% if reclamation.statut == 'pending' %}
                    <span class="badge badge-amber flex-shrink-0">En attente</span>
                {% elseif reclamation.statut == 'resolved' %}
                    <span class="badge badge-green flex-shrink-0">Résolu</span>
                {% else %}
                    <span class="badge badge-purple flex-shrink-0">{{ reclamation.statut }}</span>
                {% endif %}
            </div>
        </div>

        <!-- Responses -->
        <div class="space-y-4 mb-8">
            {% for response in reclamation.reponses %}
                <div class="{% if 'ADMIN' in response.user.roles %}chat-admin{% else %}chat-user{% endif %} p-5 animate-fade-up" style="animation-delay: {{ loop.index * 80 }}ms">
                    <div class="flex items-center gap-2 mb-2">
                        <div class="w-7 h-7 rounded-lg {% if 'ADMIN' in response.user.roles %}bg-accent/15 text-accent{% else %}gradient-primary text-white{% endif %} flex items-center justify-center text-[10px] font-bold">
                            {{ response.user.username|first|upper }}
                        </div>
                        <span class="text-xs font-bold {% if 'ADMIN' in response.user.roles %}text-accent{% else %}text-primary dark:text-primary-light{% endif %}">
                            {{ response.user.username }}
                            {% if 'ADMIN' in response.user.roles %}<span class="text-[9px] opacity-50 ml-1">Support</span>{% endif %}
                        </span>
                    </div>
                    <p class="text-slate-700 dark:text-slate-300 font-medium whitespace-pre-line pl-9 text-sm leading-relaxed">{{ response.message }}</p>
                </div>
            {% else %}
                <div class="glass-card py-12 rounded-2xl text-center animate-fade-up">
                    <div class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center mx-auto mb-3">
                        <svg class="w-6 h-6 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                    </div>
                    <p class="text-slate-400 font-medium text-sm">Pas encore de réponse.</p>
                    <p class="text-slate-400 font-medium text-xs mt-1">Notre équipe reviendra vers vous bientôt.</p>
                </div>
            {% endfor %}
        </div>

        <!-- Reply Form -->
        <div class="glass-card p-7 rounded-2xl border-2 border-primary/8 dark:border-primary/15 animate-fade-up">
            <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-4">Ajouter un message</h3>
            {{ form_start(form) }}
                <div class="mb-4">
                    {{ form_widget(form.message, {'attr': {'class': 'form-input min-h-[100px] resize-none text-sm', 'placeholder': 'Écrivez votre message...'}}) }}
                    {{ form_errors(form.message) }}
                </div>
                <div class="flex justify-end">
                    <button class="btn-primary !py-2.5 !px-6 text-sm flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                        Envoyer
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
