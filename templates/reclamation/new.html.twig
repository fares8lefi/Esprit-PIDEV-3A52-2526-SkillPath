{% extends 'base.html.twig' %}

{% block title %}Nouvelle Réclamation{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark py-12">
    <div class="max-w-2xl mx-auto px-6">
        <!-- Back -->
        <a href="{{ path('app_reclamation_index') }}" class="inline-flex items-center gap-2 text-xs font-bold text-slate-400 hover:text-primary transition-colors mb-6 animate-fade-up">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Mes réclamations
        </a>

        <div class="glass-card p-8 lg:p-10 rounded-2xl animate-fade-up">
            <div class="text-center mb-8">
                <div class="w-14 h-14 rounded-2xl gradient-primary flex items-center justify-center mx-auto mb-4 shadow-lg shadow-purple-500/15">
                    <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                </div>
                <h1 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight mb-1">Nouvelle réclamation</h1>
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Décrivez votre problème et notre équipe vous répondra rapidement.</p>
            </div>

            {{ form_start(form) }}
                <div class="space-y-5">
                    <div>
                        <label class="text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-2 block">Sujet</label>
                        {{ form_widget(form.sujet, {'attr': {'class': 'form-input text-sm', 'placeholder': 'Ex: Problème avec mon compte'}}) }}
                        {{ form_errors(form.sujet) }}
                    </div>
                    <div>
                        <label class="text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-2 block">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-input min-h-[140px] resize-none text-sm', 'placeholder': 'Décrivez votre problème en détail...'}}) }}
                        {{ form_errors(form.description) }}
                    </div>
                </div>
                
                <div class="mt-8 flex flex-col sm:flex-row items-center gap-4">
                    <button class="btn-primary w-full sm:w-auto !py-3.5 !px-8 text-sm flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                        Envoyer la réclamation
                    </button>
                    <a href="{{ path('app_reclamation_index') }}" class="text-sm font-semibold text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
