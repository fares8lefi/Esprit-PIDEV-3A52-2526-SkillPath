{% extends 'base.html.twig' %}

{% block title %}My Reclamations{% endblock %}

{% block body %}
<div class="min-h-screen mesh-light dark:mesh-dark p-6 lg:p-12">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-end md:items-center gap-6 mb-12 animate-fade-up">
            <div>
                <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Mes <span class="gradient-text">Réclamations</span></h1>
                <p class="text-slate-500 dark:text-slate-400 font-medium">Consultez l'historique et le statut de vos demandes de support.</p>
            </div>
            <a href="{{ path('app_reclamation_new') }}" class="btn-primary !py-4 !px-8 flex items-center gap-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Nouvelle Demande
            </a>
        </div>

        <!-- Grid of Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for reclamation in reclamations %}
                <a href="{{ path('app_reclamation_show', {'id': reclamation.id}) }}" class="glass-card p-6 rounded-3xl hover:shadow-2xl hover:-translate-y-1 transition-all group relative overflow-hidden animate-fade-up" style="animation-delay: {{ loop.index * 80 }}ms">
                    <!-- Hover Effect -->
                    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-accent/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    
                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-4">
                            {% if reclamation.statut == 'Pending' %}
                                <span class="badge badge-amber">En attente</span>
                            {% elseif reclamation.statut == 'Resolved' %}
                                <span class="badge badge-green">Résolu</span>
                            {% else %}
                                <span class="badge badge-purple">{{ reclamation.statut }}</span>
                            {% endif %}
                            <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500">#{{ reclamation.id }}</span>
                        </div>

                        <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2 line-clamp-1 group-hover:text-primary dark:group-hover:text-primary-light transition-colors">{{ reclamation.sujet }}</h3>
                        <p class="text-slate-500 dark:text-slate-400 text-sm font-medium line-clamp-3 mb-6">{{ reclamation.description }}</p>

                        <div class="flex items-center justify-between border-t border-slate-100/50 dark:border-white/5 pt-4">
                            <span class="text-xs font-bold text-slate-400">Voir les détails</span>
                            <div class="w-8 h-8 rounded-full bg-primary/8 dark:bg-primary/15 flex items-center justify-center text-primary dark:text-primary-light group-hover:gradient-primary group-hover:text-white transition-all">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                            </div>
                        </div>
                    </div>
                </a>
            {% else %}
                <div class="col-span-full py-20 text-center animate-fade-up">
                    <div class="w-16 h-16 bg-primary/8 rounded-2xl flex items-center justify-center mx-auto mb-5">
                        <svg class="w-8 h-8 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                    </div>
                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">Aucune réclamation</h3>
                    <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-sm mx-auto font-medium">Vous n'avez pas encore soumis de demande. Besoin d'aide ? Créez votre première réclamation.</p>
                    <a href="{{ path('app_reclamation_new') }}" class="text-primary dark:text-primary-light font-black hover:underline uppercase tracking-wider text-xs">Créer une demande</a>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
