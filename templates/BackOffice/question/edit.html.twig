{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Modifier le Vecteur - {{ question.quiz.titre }}{% endblock %}

{% block content %}
    <!-- Breadcrumb -->
    <div class="mb-12 animate-fade-up">
        <a href="{{ path('app_back_office_quiz_show', {'id': question.quiz.id}) }}" class="flex items-center gap-2 text-slate-400 hover:text-primary transition-colors mb-4 group">
            <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            <span class="text-xs font-bold uppercase tracking-widest">Retour au Panneau d'Évaluation</span>
        </a>
        <h1 class="text-2xl font-black text-slate-900 dark:text-white mb-2">Ajuster le <span class="gradient-text">Vecteur de Données</span></h1>
        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-8 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
            Contexte de l'Actif:  
            {% if question.quiz is defined and question.quiz is not null %}
                <span class="text-amber-500">{{ question.quiz.titre }}</span>
            {% else %}
                <span class="text-red-500 italic">Vecteur Orphelin (Quiz Manquant)</span>
            {% endif %}
        </p>

        <div class="glass-card rounded-[2rem] p-10 border border-white/5 shadow-2xl shadow-purple-500/5">
            {{ form_start(form, {'attr': {'class': 'space-y-8'}}) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="md:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Énoncé du Vecteur (Question)</label>
                    {{ form_widget(form.enonce) }}
                    <div class="mt-1 text-red-500 text-[10px] font-bold">{{ form_errors(form.enonce) }}</div>
                </div>
                
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Valeur de Rendement (Points)</label>
                    <div class="relative">
                        {{ form_widget(form.points) }}
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <span class="text-slate-400 text-xs font-bold">PTS</span>
                        </div>
                    </div>
                    <div class="mt-1 text-red-500 text-[10px] font-bold">{{ form_errors(form.points) }}</div>
                </div>

                <div class="md:col-span-2 space-y-4">
                    <div class="flex items-center justify-between border-b border-slate-200/50 dark:border-white/5 pb-2">
                        <label class="text-xs font-bold uppercase tracking-widest text-slate-500">Configuration des Réponses</label>
                        <span class="text-[10px] text-primary font-black bg-primary/10 px-2 py-1 rounded">CHOIX MULTIPLES</span>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="p-4 rounded-xl bg-slate-50 dark:bg-white/2 border border-slate-200/50 dark:border-white/5">
                            <span class="text-[10px] font-black text-slate-400 mb-2 block">OPTION A</span>
                            {{ form_widget(form.choixA) }}
                            <div class="mt-1 text-red-500 text-[10px] font-bold">{{ form_errors(form.choixA) }}</div>
                        </div>
                        <div class="p-4 rounded-xl bg-slate-50 dark:bg-white/2 border border-slate-200/50 dark:border-white/5">
                            <span class="text-[10px] font-black text-slate-400 mb-2 block">OPTION B</span>
                            {{ form_widget(form.choixB) }}
                            <div class="mt-1 text-red-500 text-[10px] font-bold">{{ form_errors(form.choixB) }}</div>
                        </div>
                        <div class="p-4 rounded-xl bg-slate-50 dark:bg-white/2 border border-slate-200/50 dark:border-white/5">
                            <span class="text-[10px] font-black text-slate-400 mb-2 block">OPTION C</span>
                            {{ form_widget(form.choixC) }}
                            <div class="mt-1 text-red-500 text-[10px] font-bold">{{ form_errors(form.choixC) }}</div>
                        </div>
                        <div class="p-4 rounded-xl bg-slate-50 dark:bg-white/2 border border-slate-200/50 dark:border-white/5">
                            <span class="text-[10px] font-black text-slate-400 mb-2 block">OPTION D</span>
                            {{ form_widget(form.choixD) }}
                            <div class="mt-1 text-red-500 text-[10px] font-bold">{{ form_errors(form.choixD) }}</div>
                        </div>
                        <div class="md:col-span-2 p-4 rounded-xl bg-slate-50 dark:bg-white/2 border border-slate-200/50 dark:border-white/5 border-l-4 !border-l-green-500">
                             <div class="flex justify-between items-center mb-2">
                                <span class="text-[10px] font-black text-green-600 dark:text-green-400 block">SOLUTION CIBLE (BONNE RÉPONSE)</span>
                                <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                             </div>
                            {{ form_widget(form.bonneReponse) }}
                            <div class="mt-1 text-red-500 text-[10px] font-bold">{{ form_errors(form.bonneReponse) }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-end gap-4 pt-8 border-t border-slate-200/50 dark:border-white/5">
                <a href="{{ path('app_back_office_quiz_show', {'id': question.quiz.id}) }}" class="btn-secondary !text-sm !py-3 !px-6">Abandonner les Changements</a>
                <button type="submit" class="btn-primary !text-sm !py-3 !px-8">Recalibrer le Vecteur</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
