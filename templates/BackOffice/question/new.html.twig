{% extends 'base.html.twig' %}

{% block title %}New Question{% endblock %}

{% block body %}
    <div class="container mx-auto p-4">
        <h1 class="text-2xl font-bold mb-4">Add new Question to {{ quiz.titre }}</h1>

        {{ form_start(form, {'attr': {'class': 'max-w-lg'}}) }}
            {% for field in form %}
                {% if field.vars.name != '_token' %}
                    <div class="mb-4">
                        {{ form_label(field, null, {'label_attr': {'class': 'block text-white text-sm font-bold mb-2'}}) }}
                        {{ form_widget(field, {'attr': {'class': 'shadow appearance-none border border-gray-600 rounded w-full py-2 px-3 text-white bg-gray-800 leading-tight focus:outline-none focus:shadow-outline'}}) }}
                        {{ form_errors(field) }}
                    </div>
                {% endif %}
            {% endfor %}

            <button class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">Save</button>
            <a href="{{ path('app_back_office_quiz_show', {'id': quiz.id}) }}" class="inline-block align-baseline font-bold text-sm text-blue-500 hover:text-blue-800 ml-4">Back to Quiz</a>
        {{ form_end(form) }}
    </div>
{% endblock %}
