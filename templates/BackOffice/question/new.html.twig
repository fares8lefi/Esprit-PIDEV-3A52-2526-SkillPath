{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Nouvelle Question - SkillPath{% endblock %}

{% block content %}
    <!-- Breadcrumb -->
    <nav class="mb-6">
        <ol class="flex items-center gap-2 text-sm">
            <li><a href="{{ path('app_back_office_quiz_index') }}" class="text-slate-400 dark:text-slate-500 hover:text-primary transition-colors font-medium">Quiz</a></li>
            <li class="text-slate-300 dark:text-slate-600">/</li>
            <li><a href="{{ path('app_back_office_quiz_show', {'id': quiz.id}) }}" class="text-slate-400 dark:text-slate-500 hover:text-primary transition-colors font-medium">{{ quiz.titre }}</a></li>
            <li class="text-slate-300 dark:text-slate-600">/</li>
            <li class="text-slate-700 dark:text-slate-300 font-semibold">Nouvelle Question</li>
        </ol>
    </nav>

    <div class="max-w-2xl">
        <h1 class="text-2xl font-black text-slate-900 dark:text-white mb-2">Ajouter une Question</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Quiz : <span class="font-bold text-primary">{{ quiz.titre }}</span></p>

        <div class="glass-card rounded-2xl p-8">
            {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
                {% for field in form %}
                    {% if field.vars.name != '_token' %}
                    <div>
                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">{{ field.vars.label|default(field.vars.name|capitalize) }}</label>
                        {{ form_widget(field, {'attr': {'class': 'form-input'}}) }}
                        {% if field.vars.errors|length > 0 %}
                            <div class="mt-1.5">
                            {% for error in field.vars.errors %}
                                <p class="text-xs font-semibold text-red-500">{{ error.message }}</p>
                            {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    {% endif %}
                {% endfor %}

                <div class="flex items-center gap-3 pt-4">
                    <button type="submit" class="btn-primary text-sm !py-3 !px-6 inline-flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Ajouter la Question
                    </button>
                    <a href="{{ path('app_back_office_quiz_show', {'id': quiz.id}) }}" class="btn-secondary text-sm !py-3 !px-6">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
