<aside id="sidebar" class="fixed top-0 left-0 z-40 w-72 h-screen transition-transform -translate-x-full lg:translate-x-0">
    <div class="h-full px-6 py-6 overflow-y-auto bg-white border-r border-gray-200 shadow-xl">
        
        <!-- Logo -->
        <div class="flex items-center gap-3 mb-10 pb-6 border-b border-gray-200">
            <svg class="w-10 h-10" viewBox="0 0 40 40" fill="none">
                <path d="M10 30C10 30 15 25 20 25C25 25 30 30 30 30" stroke="#1E88E5" stroke-width="3" stroke-linecap="round"/>
                <path d="M10 15C10 15 15 10 20 10C25 10 30 15 30 15" stroke="#43A047" stroke-width="3" stroke-linecap="round"/>
                <circle cx="12" cy="20" r="2" fill="#FBC02D"/>
                <circle cx="28" cy="20" r="2" fill="#FBC02D"/>
            </svg>
            <div>
                <span class="text-2xl font-extrabold gradient-text">SkillPath</span>
                <p class="text-xs text-gray-500 font-medium">Gestion des Cours</p>
            </div>
        </div>
        
        <!-- Navigation -->
        {% set route = app.request.get('_route') %}
        <nav class="space-y-2">
            <a href="{{ path('app_admin_dashboard') }}" 
               class="flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all duration-300 {{ route == 'app_admin_dashboard' ? 'text-white bg-gradient-to-r from-brand-blue to-brand-blue-dark shadow-md font-semibold' : 'text-gray-700 hover:bg-gray-100' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                <span>Tableau de bord</span>
            </a>
            
            <a href="{{ path('admin_cours_list') }}" 
               class="flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all duration-300 {{ route starts with 'admin_cours' ? 'text-white bg-gradient-to-r from-brand-blue to-brand-blue-dark shadow-md font-semibold' : 'text-gray-700 hover:bg-gray-100' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
                <span>Gestion des cours</span>
            </a>
            
            <a href="{{ path('admin_module_list') }}" 
               class="flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all duration-300 {{ route starts with 'admin_module' ? 'text-white bg-gradient-to-r from-brand-blue to-brand-blue-dark shadow-md font-semibold' : 'text-gray-700 hover:bg-gray-100' }}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                </svg>
                <span>Modules</span>
            </a>
        </nav>
    </div>
</aside>
