{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs - BackOffice{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex flex-col">
    <!-- Navigation ou Header Dashboard -->
    <header class="bg-white shadow-sm border-b border-gray-200 py-4 px-8 flex justify-between items-center">
        <div class="flex items-center">
            <img src="{{ asset('images/logo.png') }}" alt="Logo" class="h-10 w-auto mr-3">
            <h1 class="text-2xl font-bold text-skill-blue">SkillPath <span class="text-gray-400 font-medium">| BackOffice</span></h1>
        </div>
        <div class="flex items-center space-x-4">
            <span class="text-sm text-gray-500">Admin: {{ app.user.username|default('Administrateur') }}</span>
            <a href="{{ path('app_logout') }}" class="text-xs font-bold text-red-500 hover:text-red-700 uppercase tracking-wider">Déconnexion</a>
        </div>
    </header>

    <main class="flex-1 p-8">
        <div class="max-w-6xl mx-auto">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-3xl font-extrabold text-gray-900">Utilisateurs</h2>
                    <p class="text-gray-500 mt-1">Gérez les membres de la plateforme SkillPath.</p>
                </div>
                <a href="{{ path('app_user_admin_create') }}" class="bg-skill-blue hover:bg-skill-blue/90 text-white font-bold py-2.5 px-5 rounded-xl shadow-lg shadow-skill-blue/20 transition-all flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                    Ajouter un utilisateur
                </a>
            </div>

            {% for message in app.flashes('success') %}
                <div class="bg-green-100 border border-green-200 text-green-700 px-4 py-3 rounded-xl mb-6 flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-green-500" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    {{ message }}
                </div>
            {% endfor %}

            <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-gray-50/50">
                        <tr>
                            <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100">ID</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100">Utilisateur</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100">Rôle</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100">Statut</th>
                            <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-sm">
                        {% for user in users %}
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="px-6 py-4 text-gray-500 font-medium">#{{ user.id }}</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center">
                                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-skill-blue/20 to-skill-green/20 flex items-center justify-center text-skill-blue font-bold mr-3 shadow-inner">
                                        {{ user.username|first|upper }}
                                    </div>
                                    <div>
                                        <div class="text-gray-900 font-bold">{{ user.username }}</div>
                                        <div class="text-gray-500 text-xs">{{ user.email }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                {% if user.role == 'admin' %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-skill-yellow/10 text-skill-yellow border border-skill-yellow/20">
                                        Administrateur
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-skill-blue/10 text-skill-blue border border-skill-blue/20">
                                        Étudiant
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4">
                                {% if user.status == 'active' %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-skill-green/10 text-skill-green border border-skill-green/20">
                                        <span class="w-1.5 h-1.5 rounded-full bg-skill-green mr-1.5 animate-pulse"></span>
                                        Actif
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-gray-100 text-gray-500 border border-gray-200">
                                        {{ user.status|capitalize }}
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-right space-x-2">
                                <a href="{{ path('app_user_show', {id: user.id}) }}" class="text-gray-400 hover:text-skill-blue transition-colors p-1.5 hover:bg-skill-blue/10 rounded-lg inline-block" title="Voir">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                                <a href="{{ path('app_user_edit', {id: user.id}) }}" class="text-gray-400 hover:text-skill-green transition-colors p-1.5 hover:bg-skill-green/10 rounded-lg inline-block" title="Modifier">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                                    </svg>
                                </a>
                                <form action="{{ path('app_user_delete', {id: user.id}) }}" method="POST" class="inline-block" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                    <button type="submit" class="text-gray-400 hover:text-red-500 transition-colors p-1.5 hover:bg-red-50 rounded-lg inline-block" title="Supprimer">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center">
                                <div class="text-gray-400 mb-2 font-medium">Aucun utilisateur trouvé</div>
                                <a href="{{ path('app_user_admin_create') }}" class="text-skill-blue hover:underline font-bold text-sm">Ajouter le premier utilisateur</a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}
