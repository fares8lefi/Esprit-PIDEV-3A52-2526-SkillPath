{% extends 'base.html.twig' %}

{% block title %}Profil Utilisateur - {{ user.username }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex flex-col">
    <!-- Header Dashboard -->
    <header class="bg-white shadow-sm border-b border-gray-200 py-4 px-8 flex justify-between items-center">
        <div class="flex items-center">
            <img src="{{ asset('images/logo.png') }}" alt="Logo" class="h-10 w-auto mr-3">
            <h1 class="text-2xl font-bold text-skill-blue">SkillPath <span class="text-gray-400 font-medium">| BackOffice</span></h1>
        </div>
        <a href="{{ path('app_user_index') }}" class="text-gray-500 hover:text-gray-700 font-bold text-sm flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
            </svg>
            Retour à la liste
        </a>
    </header>

    <main class="flex-1 p-8">
        <div class="max-w-3xl mx-auto">
            <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100 italic">
                <!-- Cover Area -->
                <div class="h-32 bg-gradient-to-r from-skill-blue via-skill-green to-skill-yellow/50"></div>
                
                <div class="px-10 pb-10">
                    <!-- Profile Header -->
                    <div class="flex flex-col md:flex-row items-center md:items-end -mt-16 mb-8 space-y-4 md:space-y-0 md:space-x-6 text-center md:text-left">
                        <div class="w-32 h-32 rounded-3xl bg-white p-1.5 shadow-2xl overflow-hidden border border-gray-100">
                             <div class="w-full h-full rounded-2xl bg-gradient-to-br from-skill-blue to-skill-green flex items-center justify-center text-white text-4xl font-bold">
                                {{ user.username|first|upper }}
                            </div>
                        </div>
                        <div class="flex-1 pb-2">
                            <h2 class="text-3xl font-extrabold text-gray-900 leading-tight">{{ user.username }}</h2>
                            <div class="flex items-center space-x-3 mt-1 justify-center md:justify-start">
                                <span class="text-gray-500 font-medium">{{ user.email }}</span>
                                <span class="w-1.5 h-1.5 rounded-full bg-gray-300"></span>
                                <span class="text-gray-400">ID: #{{ user.id }}</span>
                            </div>
                        </div>
                        <div class="flex space-x-3 pb-2">
                             <a href="{{ path('app_user_edit', {id: user.id}) }}" class="bg-skill-blue hover:bg-skill-blue/90 text-white font-bold py-2 px-6 rounded-xl shadow-lg shadow-skill-blue/20 transition-all flex items-center text-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                                </svg>
                                Modifier
                            </a>
                        </div>
                    </div>

                    <!-- Details Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-6 border-t border-gray-100">
                        <div>
                            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Informations Système</h3>
                            <div class="space-y-4">
                                <div class="flex justify-between items-center py-2 border-b border-gray-50">
                                    <span class="text-gray-500 text-sm">Rôle</span>
                                    <span class="font-bold text-gray-900">
                                        {{ user.role == 'admin' ? 'Administrateur' : 'Étudiant' }}
                                    </span>
                                </div>
                                <div class="flex justify-between items-center py-2 border-b border-gray-50">
                                    <span class="text-gray-500 text-sm">Statut du compte</span>
                                    <div class="flex items-center">
                                        {% if user.status == 'active' %}
                                            <span class="w-1.5 h-1.5 rounded-full bg-skill-green mr-2 animate-pulse"></span>
                                            <span class="font-bold text-skill-green text-sm uppercase">Actif</span>
                                        {% else %}
                                            <span class="font-bold text-gray-400 text-sm uppercase">{{ user.status }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex justify-between items-center py-2 border-b border-gray-50">
                                    <span class="text-gray-500 text-sm">État vérification</span>
                                    <span class="font-bold {{ user.isVerified ? 'text-skill-blue' : 'text-red-400' }} text-sm uppercase">
                                        {{ user.isVerified ? 'Vérifié' : 'Non vérifié' }}
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div>
                            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Activités & Cours</h3>
                            <div class="bg-gray-50 rounded-2xl p-6 text-center">
                                <div class="inline-flex items-center justify-center w-12 h-12 bg-skill-blue/10 text-skill-blue rounded-xl mb-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path d="M12 14l9-5-9-5-9 5 9 5z" />
                                        <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                                    </svg>
                                </div>
                                <div class="text-2xl font-black text-gray-900">{{ user.cours|length }}</div>
                                <div class="text-xs text-gray-500 font-bold uppercase mt-1 tracking-tighter">Cours inscrits</div>
                                <p class="text-xs text-gray-400 mt-4 leading-relaxed italic">
                                    Ce membre participe activement à la communauté SkillPath.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
