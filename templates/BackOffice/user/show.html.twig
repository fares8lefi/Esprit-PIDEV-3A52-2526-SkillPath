{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Profil de l'Utilisateur - {{ user.username }}{% endblock %}

{% block content %}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-fade-up">
    
    <!-- Left Column: Profile Card -->
    <div class="lg:col-span-1 space-y-6">
        <!-- Back Link -->
        <a href="{{ path('app_user_index') }}" class="inline-flex items-center gap-2 text-xs font-bold text-slate-400 hover:text-primary transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Annuaire des Membres
        </a>

        <!-- Main Info -->
        <div class="glass-card p-8 rounded-[2.5rem] relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-full blur-3xl"></div>
            
            <div class="relative z-10 flex flex-col items-center text-center">
                <div class="w-24 h-24 rounded-3xl flex items-center justify-center text-white text-3xl font-black shadow-2xl shadow-purple-500/20 mb-6
                    {% if user.role == 'admin' %}bg-gradient-to-br from-amber-500 to-orange-600{% else %}gradient-primary{% endif %}">
                    {{ user.username|first|upper }}
                </div>
                <h2 class="text-2xl font-black text-slate-900 dark:text-white leading-tight mb-1">{{ user.username }}</h2>
                <p class="text-slate-400 font-medium text-sm mb-6">{{ user.email }}</p>
                
                <div class="flex flex-wrap justify-center gap-2 mb-8">
                    {% if user.role == 'admin' %}
                        <span class="badge badge-amber px-4 py-1.5 uppercase tracking-widest text-[10px]">Administrateur</span>
                    {% else %}
                        <span class="badge badge-purple px-4 py-1.5 uppercase tracking-widest text-[10px]">Étudiant</span>
                    {% endif %}
                    
                    {% if user.status == 'active' %}
                        <span class="badge badge-green px-4 py-1.5 uppercase tracking-widest text-[10px]">Actif</span>
                    {% else %}
                        <span class="badge badge-gray px-4 py-1.5 uppercase tracking-widest text-[10px]">{{ user.status|capitalize }}</span>
                    {% endif %}
                </div>

                <div class="flex gap-4 w-full pt-8 border-t border-slate-100/50 dark:border-white/5">
                    <a href="{{ path('app_user_edit', {id: user.id}) }}" class="flex-1 btn-primary py-3 !rounded-2xl text-xs hover:scale-105 transition-transform text-center flex items-center justify-center">
                        Modifier
                    </a>
                    <form action="{{ path('app_user_delete', {id: user.id}) }}" method="POST" class="flex-1" onsubmit="return confirm('Voulez-vous vraiment supprimer ce compte ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button type="submit" class="w-full py-3 border-2 border-red-500/10 text-red-500 font-bold rounded-2xl text-xs hover:bg-red-500/5 transition-colors">
                            Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Stats & Data -->
    <div class="lg:col-span-2 space-y-6">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white">Aperçu du Compte</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Courses Stat -->
            <div class="glass-card p-8 rounded-[2.5rem] flex items-center gap-6 group hover:translate-y-[-4px] transition-all duration-300">
                <div class="w-16 h-16 rounded-3xl bg-primary/10 flex items-center justify-center text-primary group-hover:gradient-primary group-hover:text-white transition-all shadow-lg shadow-purple-500/5">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                </div>
                <div>
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-1">Cours Inscrits</p>
                    <h4 class="text-3xl font-black text-slate-900 dark:text-white">{{ user.courses|length }}</h4>
                </div>
            </div>

            <!-- Verification Stat -->
            <div class="glass-card p-8 rounded-[2.5rem] flex items-center gap-6 group hover:translate-y-[-4px] transition-all duration-300">
                <div class="w-16 h-16 rounded-3xl {% if user.isVerified %}bg-green-500/10 text-green-500{% else %}bg-red-500/10 text-red-500{% endif %} flex items-center justify-center transition-all">
                    {% if user.isVerified %}
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {% else %}
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    {% endif %}
                </div>
                <div>
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-1">Vérification</p>
                    <h4 class="text-2xl font-black text-slate-900 dark:text-white">{{ user.isVerified ? 'Vérifié' : 'Non Vérifié' }}</h4>
                </div>
            </div>
        </div>

        <!-- System Details Bento -->
        <div class="glass-card p-10 rounded-[2.5rem]">
            <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-8 pb-4 border-b border-slate-100/50 dark:border-white/5">Détails Techniques</h4>
            <div class="space-y-6">
                <div class="flex justify-between items-center">
                    <span class="text-sm font-bold text-slate-500">ID Utilisateur</span>
                    <span class="text-xs font-black font-mono text-slate-400">#{{ user.id }}</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-sm font-bold text-slate-500">Rôle</span>
                    <span class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-widest">{{ user.role }}</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-sm font-bold text-slate-500">Statut du Compte</span>
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full {% if user.status == 'active' %}bg-green-500 animate-pulse{% else %}bg-slate-300{% endif %}"></span>
                        <span class="text-xs font-black text-slate-900 dark:text-white uppercase tracking-widest">{{ user.status }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
