{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Brouillon Nouvel Architecte - Admin{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto space-y-8 animate-fade-up">
    {# Breadcrumbs #}
    <div class="flex items-center gap-4">
        <a href="{{ path('app_user_index') }}" class="w-10 h-10 rounded-xl glass flex items-center justify-center text-slate-400 hover:text-primary transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500">Annuaire des Membres</p>
            <h1 class="text-2xl font-black text-slate-900 dark:text-white">Initialiser Nouvel Architecte</h1>
        </div>
    </div>

    {# Form #}
    <div class="glass-card p-10 rounded-[2.5rem] border border-slate-200/50 dark:border-white/5 relative overflow-hidden shadow-2xl shadow-purple-500/5">
        <form action="{{ path('app_user_admin_create') }}" method="POST" class="space-y-8 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="group">
                    <label for="username" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Nom d'Utilisateur Orchestrateur</label>
                    <input type="text" id="username" name="username" required
                        class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm"
                        placeholder="ex. phares_lefi">
                </div>
                <div class="group">
                    <label for="email" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Email Officiel</label>
                    <input type="email" id="email" name="email" required
                        class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm"
                        placeholder="ex. contact@skillpath.tn">
                </div>

                <div class="md:col-span-2 group">
                    <label for="password" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Jeton d'Accès Temporaire (Mot de passe)</label>
                    <input type="password" id="password" name="password" required
                        class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm"
                        placeholder="••••••••">
                    <p class="text-[10px] text-slate-400 mt-2 italic">L'utilisateur doit mettre à jour ce jeton lors de son premier déploiement.</p>
                </div>

                <div class="group">
                    <label for="role" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Autorisation Attribuée (Rôle)</label>
                    <select id="role" name="role" class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm cursor-pointer appearance-none">
                        <option value="student">Compte Étudiant</option>
                        <option value="admin">Administrateur Plateforme</option>
                    </select>
                </div>
                
                <div class="group">
                    <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Statut Initial</label>
                    <div class="flex items-center space-x-4 py-3">
                        <span class="inline-flex items-center px-4 py-1.5 bg-green-500/10 text-green-500 rounded-xl text-[10px] font-black uppercase tracking-widest border border-green-500/20">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500 mr-2 animate-pulse"></span>
                            Actif par Défaut
                        </span>
                    </div>
                </div>
            </div>

            <div class="pt-8 flex items-center gap-4 border-t border-slate-100/50 dark:border-white/5">
                <button type="submit" class="btn-primary !py-4 !px-8 text-xs font-black uppercase tracking-[0.2em] flex items-center gap-3 !rounded-2xl shadow-lg shadow-purple-500/20 hover:scale-[1.02] active:scale-95 transition-all">
                    Enregistrer l'Orchestrateur
                </button>
                <a href="{{ path('app_user_index') }}" class="px-8 py-4 text-xs font-black uppercase tracking-[0.2em] text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors">Annuler</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
