{% extends 'base.html.twig' %}

{% block title %}Admin - Créer Utilisateur{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen bg-neutral-900 text-white p-6">
    <div class="w-full max-w-md bg-neutral-800 rounded-2xl shadow-2xl p-8 border border-neutral-700">
        <div class="flex items-center justify-center mb-6">
            <div class="p-3 bg-red-500/10 rounded-full border border-red-500/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
        </div>
        
        <h1 class="text-2xl font-bold mb-2 text-center text-white">Administration</h1>
        <p class="text-neutral-400 text-center mb-8 text-sm">Gestion de création d'utilisateurs</p>
        
        <form method="post" class="space-y-4">
            <div>
                <label for="username" class="block text-sm font-medium text-neutral-400 mb-1">Nom d'utilisateur</label>
                <input type="text" id="username" name="username" required 
                       class="w-full bg-neutral-700 border border-neutral-600 rounded-lg px-4 py-2 focus:ring-2 focus:ring-red-500 focus:outline-none transition-all">
            </div>
            
            <div>
                <label for="email" class="block text-sm font-medium text-neutral-400 mb-1">Email</label>
                <input type="email" id="email" name="email" required 
                       class="w-full bg-neutral-700 border border-neutral-600 rounded-lg px-4 py-2 focus:ring-2 focus:ring-red-500 focus:outline-none transition-all">
            </div>

            <div>
                <label for="password" class="block text-sm font-medium text-neutral-400 mb-1">Mot de passe</label>
                <input type="password" id="password" name="password" required 
                       class="w-full bg-neutral-700 border border-neutral-600 rounded-lg px-4 py-2 focus:ring-2 focus:ring-red-500 focus:outline-none transition-all">
            </div>

            <div>
                <label for="role" class="block text-sm font-medium text-neutral-400 mb-1">Rôle</label>
                <select id="role" name="role" required 
                        class="w-full bg-neutral-700 border border-neutral-600 rounded-lg px-4 py-2 focus:ring-2 focus:ring-red-500 focus:outline-none transition-all appearance-none cursor-pointer">
                    <option value="student">Student</option>
                    <option value="admin">Admin</option>
                </select>
            </div>

            <div class="pt-4">
                <button type="submit" 
                        class="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-3 rounded-lg transition-all transform hover:scale-[1.02] active:scale-95 shadow-lg shadow-red-900/20">
                    Créer l'utilisateur
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
