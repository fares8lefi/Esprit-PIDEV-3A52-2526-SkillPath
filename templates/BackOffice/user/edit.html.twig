{% extends 'base.html.twig' %}

{% block title %}Modifier Utilisateur - {{ user.username }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex flex-col">
    <!-- Header Dashboard -->
    <header class="bg-white shadow-sm border-b border-gray-200 py-4 px-8 flex justify-between items-center">
        <div class="flex items-center">
            <img src="{{ asset('images/logo.png') }}" alt="Logo" class="h-10 w-auto mr-3">
            <h1 class="text-2xl font-bold text-skill-blue">SkillPath <span class="text-gray-400 font-medium">| BackOffice</span></h1>
        </div>
        <a href="{{ path('app_user_index') }}" class="text-gray-500 hover:text-gray-700 font-bold text-sm flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
            </svg>
            Retour à la liste
        </a>
    </header>

    <main class="flex-1 p-8">
        <div class="max-w-2xl mx-auto">
            <div class="mb-8 flex justify-between items-end">
                <div>
                    <h2 class="text-3xl font-extrabold text-gray-900">Modifier l'utilisateur</h2>
                    <p class="text-gray-500 mt-1 italic">ID: #{{ user.id }} — {{ user.email }}</p>
                </div>
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-skill-blue to-skill-green flex items-center justify-center text-white text-2xl font-bold shadow-lg shadow-skill-blue/20">
                    {{ user.username|first|upper }}
                </div>
            </div>

            <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100 p-10">
                <form action="{{ path('app_user_edit', {id: user.id}) }}" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="username" class="block text-sm font-bold text-gray-700 mb-2">Nom d'utilisateur</label>
                            <input type="text" id="username" name="username" value="{{ user.username }}" required
                                class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:bg-white focus:border-skill-blue focus:outline-none transition-all placeholder-gray-400">
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-bold text-gray-700 mb-2">Adresse Email</label>
                            <input type="email" id="email" name="email" value="{{ user.email }}" required
                                class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:bg-white focus:border-skill-blue focus:outline-none transition-all placeholder-gray-400">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="role" class="block text-sm font-bold text-gray-700 mb-2">Rôle</label>
                            <select id="role" name="role" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:bg-white focus:border-skill-blue focus:outline-none transition-all appearance-none cursor-pointer">
                                <option value="student" {% if user.role == 'student' %}selected{% endif %}>Étudiant (Student)</option>
                                <option value="admin" {% if user.role == 'admin' %}selected{% endif %}>Administrateur (Admin)</option>
                            </select>
                        </div>
                        <div>
                            <label for="status" class="block text-sm font-bold text-gray-700 mb-2">Statut du compte</label>
                            <select id="status" name="status" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:bg-white focus:border-skill-blue focus:outline-none transition-all appearance-none cursor-pointer">
                                <option value="active" {% if user.status == 'active' %}selected{% endif %}>Actif</option>
                                <option value="pending" {% if user.status == 'pending' %}selected{% endif %}>En attente</option>
                                <option value="suspended" {% if user.status == 'suspended' %}selected{% endif %}>Suspendu</option>
                            </select>
                        </div>
                    </div>

                    <div class="pt-4 border-t border-gray-100">
                        <label for="password" class="block text-sm font-bold text-gray-700 mb-2">Changer le mot de passe (optionnel)</label>
                        <input type="password" id="password" name="password"
                            class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:bg-white focus:border-skill-blue focus:outline-none transition-all"
                            placeholder="Laisser vide pour ne pas changer">
                        <p class="text-xs text-gray-400 mt-2">N'entrez de valeur que si vous souhaitez réinitialiser son mot de passe.</p>
                    </div>

                    <div class="pt-6 flex space-x-4">
                        <button type="submit" class="flex-1 bg-skill-green hover:bg-skill-green/90 text-white font-bold py-4 rounded-2xl shadow-lg shadow-skill-green/30 transform transition-all active:scale-[0.98] hover:shadow-xl">
                            Enregistrer les modifications
                        </button>
                        <a href="{{ path('app_user_index') }}" class="px-8 py-4 bg-gray-100 text-gray-500 font-bold rounded-2xl hover:bg-gray-200 transition-colors">
                            Annuler
                        </a>
                    </div>
                </form>

                <div class="mt-8 pt-8 border-t border-red-100 flex justify-center">
                     <form action="{{ path('app_user_delete', {id: user.id}) }}" method="POST" onsubmit="return confirm('DÉFINITIF : Voulez-vous vraiment supprimer cet utilisateur ? Cette action est irréversible.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button type="submit" class="text-red-500 hover:text-red-700 font-bold text-sm tracking-wide flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                            SUPPRIMER LE COMPTE DÉFINITIVEMENT
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
