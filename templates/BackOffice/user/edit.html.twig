{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Modifier l'Utilisateur: {{ user.username }} - Admin{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto space-y-8 animate-fade-up">
    {# Breadcrumbs #}
    <div class="flex items-center gap-4">
        <a href="{{ path('app_user_index') }}" class="w-10 h-10 rounded-xl glass flex items-center justify-center text-slate-400 hover:text-primary transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500">Gestion des Utilisateurs</p>
            <h1 class="text-2xl font-black text-slate-900 dark:text-white">Modifier le Profil</h1>
        </div>
    </div>

    <div class="glass-card p-10 rounded-[2.5rem] border border-slate-200/50 dark:border-white/5 relative overflow-hidden shadow-2xl shadow-purple-500/5">
        <div class="flex justify-between items-start mb-10 pb-6 border-b border-slate-100/50 dark:border-white/5 relative z-10">
            <div>
                <h2 class="text-xl font-black text-slate-900 dark:text-white">Informations du Compte</h2>
                <p class="text-[10px] font-bold text-slate-400 mt-1 uppercase tracking-widest">ID: #{{ user.id }} — {{ user.email }}</p>
            </div>
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-white text-xl font-extrabold shadow-lg shadow-purple-500/20
                {% if user.role == 'admin' %}bg-gradient-to-br from-amber-500 to-orange-600{% else %}gradient-primary{% endif %}">
                {{ user.username|first|upper }}
            </div>
        </div>

        <form action="{{ path('app_user_edit', {id: user.id}) }}" method="POST" class="space-y-8 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="group">
                    <label for="username" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Nom d'Utilisateur</label>
                    <input type="text" id="username" name="username" value="{{ user.username }}" required
                        class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm">
                </div>
                <div class="group">
                    <label for="email" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Email</label>
                    <input type="email" id="email" name="email" value="{{ user.email }}" required
                        class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm">
                </div>

                <div class="group">
                    <label for="role" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Rôle</label>
                    <select id="role" name="role" class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm cursor-pointer appearance-none">
                        <option value="student" {% if user.role == 'student' %}selected{% endif %}>Étudiant</option>
                        <option value="admin" {% if user.role == 'admin' %}selected{% endif %}>Administrateur</option>
                    </select>
                </div>
                <div class="group">
                    <label for="status" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Statut</label>
                    <select id="status" name="status" class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm cursor-pointer appearance-none">
                        <option value="active" {% if user.status == 'active' %}selected{% endif %}>Actif</option>
                        <option value="pending" {% if user.status == 'pending' %}selected{% endif %}>En Attente</option>
                        <option value="suspended" {% if user.status == 'suspended' %}selected{% endif %}>Suspendu</option>
                    </select>
                </div>

                <div class="md:col-span-2 group pt-4 border-t border-slate-100/50 dark:border-white/5">
                    <label for="password" class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-primary transition-colors">Nouveau Mot de Passe (Optionnel)</label>
                    <input type="password" id="password" name="password"
                        class="form-input !rounded-2xl !bg-slate-50/50 dark:!bg-white/2 !border-slate-100 dark:!border-white/5 focus:!border-primary/30 transition-all font-medium text-sm"
                        placeholder="Laisser vide pour ne pas changer">
                </div>
            </div>

            <div class="pt-8 flex items-center gap-4 border-t border-slate-100/50 dark:border-white/5">
                <button type="submit" class="btn-primary !py-4 !px-8 text-xs font-black uppercase tracking-[0.2em] flex items-center gap-3 !rounded-2xl shadow-lg shadow-purple-500/20 hover:scale-[1.02] active:scale-95 transition-all">
                    Enregistrer les Modifications
                </button>
                <a href="{{ path('app_user_index') }}" class="px-8 py-4 text-xs font-black uppercase tracking-[0.2em] text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors">Annuler</a>
            </div>
        </form>

        <div class="mt-12 pt-10 border-t border-red-500/10 flex flex-col items-center">
             <form action="{{ path('app_user_delete', {id: user.id}) }}" method="POST" onsubmit="return confirm('Attention : Cette action est irréversible. Voulez-vous vraiment supprimer cet utilisateur ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                <button type="submit" class="px-6 py-3 rounded-xl border border-red-500/20 text-red-500 hover:bg-red-500/5 font-black text-[10px] tracking-[0.2em] uppercase transition-all flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    Supprimer le Compte
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
