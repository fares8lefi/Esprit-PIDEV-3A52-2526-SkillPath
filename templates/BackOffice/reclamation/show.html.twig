{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Gérer la Demande{% endblock %}

{% block content %}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-fade-up">
    
    <!-- Left Column: Details & Actions -->
    <div class="lg:col-span-1 space-y-6">
        <!-- Back Link -->
        <a href="{{ path('app_admin_reclamation_index') }}" class="inline-flex items-center gap-2 text-xs font-bold text-slate-400 hover:text-primary transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Retour à l'Index
        </a>

        <!-- Info Card -->
        <div class="glass-card p-7 rounded-2xl">
            <div class="flex items-center gap-4 mb-6">
                 <div class="w-14 h-14 rounded-xl gradient-primary flex items-center justify-center text-white text-xl font-bold shadow-lg shadow-purple-500/15">
                    {{ reclamation.user.username|first|upper }}
                </div>
                <div>
                    <h2 class="text-lg font-bold text-slate-900 dark:text-white">{{ reclamation.user.username }}</h2>
                    <p class="text-xs font-medium text-slate-400">{{ reclamation.user.email }}</p>
                </div>
            </div>

            <div class="space-y-5">
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-1.5">Sujet</span>
                    <p class="text-slate-900 dark:text-white font-semibold text-sm">{{ reclamation.sujet }}</p>
                </div>
                <div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400 block mb-1.5">Description</span>
                    <p class="text-slate-600 dark:text-slate-300 font-medium leading-relaxed text-sm mb-4">{{ reclamation.description }}</p>

                    {% if reclamation.pieceJointe %}
                        <div class="mt-4 p-4 bg-slate-100 dark:bg-white/5 rounded-2xl border border-slate-200 dark:border-white/10">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-3 flex items-center gap-2">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" /></svg>
                                Pièce jointe
                            </p>
                            {% if reclamation.pieceJointe matches '/\\.(jpg|jpeg|png)$/i' %}
                                <div class="relative group">
                                    <img src="{{ asset('uploads/reclamations/' ~ reclamation.pieceJointe) }}" alt="Pièce jointe" class="rounded-xl shadow-md border border-slate-200 dark:border-white/10 group-hover:scale-[1.02] transition-transform duration-300 cursor-zoom-in">
                                </div>
                            {% else %}
                                <a href="{{ asset('uploads/reclamations/' ~ reclamation.pieceJointe) }}" target="_blank" class="flex items-center gap-3 p-3 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-white/10 hover:border-primary transition-all group">
                                    <div class="w-9 h-9 rounded-lg bg-primary/8 text-primary flex items-center justify-center group-hover:gradient-primary group-hover:text-white transition-all">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-[10px] font-bold text-slate-900 dark:text-white truncate">Ouvrir le document</p>
                                    </div>
                                    <svg class="w-3 h-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Status Management -->
        <div class="glass-card p-7 rounded-2xl">
             <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Définir l'État</h3>
             {{ form_start(status_form) }}
                <div class="flex gap-2">
                    {{ form_widget(status_form.statut, {'attr': {'class': 'form-input flex-1 !py-2.5 text-sm'}}) }}
                    <button class="gradient-primary hover:shadow-lg hover:shadow-purple-500/20 text-white p-3 rounded-xl transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    </button>
                </div>
                {{ form_errors(status_form.statut) }}
            {{ form_end(status_form) }}

            <div class="mt-6 pt-6 border-t border-slate-100/50 dark:border-white/5">
                 <form method="post" action="{{ path('app_admin_reclamation_delete', {'id': reclamation.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce ticket ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
                    <button class="w-full py-2.5 rounded-xl border-2 border-red-100/50 dark:border-red-900/20 text-red-400 hover:bg-red-50 dark:hover:bg-red-500/5 font-bold text-xs transition-all uppercase tracking-wide">
                        Supprimer le Ticket
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Conversation -->
    <div class="lg:col-span-2 space-y-5">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Fil de Discussion</h2>

        <div class="space-y-4">
            {% for response in reclamation.reponses %}
                <div class="{% if 'ADMIN' in response.user.roles %}chat-admin{% else %}chat-user{% endif %} p-5">
                    <div class="flex justify-between items-start mb-2">
                        <div class="flex items-center gap-2">
                            <div class="w-7 h-7 rounded-lg {% if 'ADMIN' in response.user.roles %}bg-accent/15 text-accent{% else %}bg-primary/10 text-primary{% endif %} flex items-center justify-center text-[10px] font-bold">
                                {{ response.user.username|first|upper }}
                            </div>
                            <span class="text-xs font-bold {% if 'ADMIN' in response.user.roles %}text-accent{% else %}text-primary dark:text-primary-light{% endif %}">
                                {{ response.user.username }} {% if 'ADMIN' in response.user.roles %}<span class="text-[9px] opacity-60">(Support Plateforme)</span>{% endif %}
                            </span>
                        </div>
                    </div>
                    <p class="text-slate-700 dark:text-slate-300 font-medium whitespace-pre-line leading-relaxed text-sm pl-9">{{ response.message }}</p>
                </div>
            {% else %}
                    <div class="text-center py-8">
                        <div class="w-12 h-12 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center mx-auto mb-3">
                            <svg class="w-6 h-6 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        </div>
                        <p class="text-slate-400 font-medium text-sm">Aucune transmission enregistrée dans ce fil.</p>
                    </div>
            {% endfor %}

            <!-- Response Form -->
            <div class="glass-card p-7 rounded-2xl shadow-lg border-2 border-primary/8 dark:border-primary/15">
                <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-4">Envoyer une Réponse Officielle</h3>
                {{ form_start(response_form) }}
                    <div class="mb-4">
                        {{ form_widget(response_form.message, {'attr': {'class': 'form-input min-h-[100px] resize-none text-sm', 'placeholder': 'Rédigez votre transmission officielle...'}}) }}
                        {{ form_errors(response_form.message) }}
                    </div>
                    <div class="flex justify-end">
                        <button class="btn-primary !py-2.5 !px-6 text-sm flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                            Transmettre
                        </button>
                    </div>
                {{ form_end(response_form) }}
            </div>
        </div>
    </div>

</div>
{% endblock %}
