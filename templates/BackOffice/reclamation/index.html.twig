{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Demandes des Membres - Admin{% endblock %}

{% block content %}
<div class="space-y-6 animate-fade-up">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight">Demandes des <span class="gradient-text">Membres</span></h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm font-medium mt-1">Superviser et résoudre les demandes et retours des utilisateurs.</p>
        </div>
        <div class="flex items-center gap-3">
            <span class="badge badge-purple">{{ reclamations|length }} Total</span>
            <span class="badge badge-amber">{{ reclamations|filter(r => r.statut|lower == 'pending' or r.statut|lower == 'en attente')|length }} En Attente</span>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="flex flex-wrap gap-2 pb-2">
        {% set statuses = {
            'all': 'Tous',
            'Pending': 'En attente',
            'In Progress': 'En cours',
            'Resolved': 'Résolu',
            'Closed': 'Fermé'
        } %}
        
        {% for key, label in statuses %}
            <a href="{{ path('app_admin_reclamation_index', {status: key, search: search, sort: sort, direction: direction}) }}" 
               class="px-4 py-2 rounded-xl text-xs font-bold transition-all border {{ current_status == key or (current_status is empty and key == 'all') ? 'bg-primary text-white border-primary shadow-lg shadow-primary/20' : 'bg-white dark:bg-white/5 text-slate-500 border-slate-200 dark:border-white/10 hover:border-primary/50' }}">
                {{ label }}
                {% if key == 'all' %}
                    <span class="ml-1.5 opacity-60">{{ reclamations|length }}</span>
                {% endif %}
            </a>
        {% endfor %}
    </div>
    <!-- Actions Bar -->
    <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
        <form method="get" class="flex items-center gap-3 bg-white dark:bg-white/5 px-4 py-2 rounded-xl border border-slate-200 dark:border-white/10 w-full md:w-96 focus-within:ring-2 focus-within:ring-primary/20 transition-all group">
            <svg class="w-4 h-4 text-slate-400 group-focus-within:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" name="search" value="{{ search }}" placeholder="Rechercher par sujet ou email..." class="bg-transparent border-none focus:outline-none text-sm w-full text-slate-900 dark:text-white placeholder-slate-400 font-medium">
            <input type="hidden" name="status" value="{{ current_status }}">
            {% if search %}
                <a href="{{ path('app_admin_reclamation_index', {status: current_status}) }}" class="text-slate-400 hover:text-red-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </a>
            {% endif %}
        </form>

        <div class="flex gap-2">
            <a href="{{ path('app_admin_reclamation_index', {status: current_status, sort: 'statut', direction: direction == 'desc' ? 'asc' : 'desc', search: search}) }}" class="btn-secondary !py-2 !px-4 text-[10px] flex items-center gap-2">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/></svg>
                Trier par Statut
            </a>
        </div>
    </div>

    <!-- Table -->
    <div class="glass-card rounded-2xl overflow-hidden">
        <table class="w-full">
            <thead>
                <tr class="border-b border-slate-100/50 dark:border-white/5">
                    <th class="text-left py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-400">
                        <a href="{{ path('app_admin_reclamation_index', {sort: 'id', direction: sort == 'id' and direction == 'desc' ? 'asc' : 'desc', search: search, status: current_status}) }}" class="flex items-center gap-1 hover:text-primary">
                            ID
                            {% if sort == 'id' %}<svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ direction == 'desc' ? 'M19 9l-7 7-7-7' : 'M5 15l7-7 7 7' }}"/></svg>{% endif %}
                        </a>
                    </th>
                    <th class="text-left py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-400">Membre</th>
                    <th class="text-left py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-400">
                         <a href="{{ path('app_admin_reclamation_index', {sort: 'sujet', direction: sort == 'sujet' and direction == 'desc' ? 'asc' : 'desc', search: search, status: current_status}) }}" class="flex items-center gap-1 hover:text-primary">
                    <th class="text-left py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-400">Statut</th>
                    <th class="text-right py-4 px-6 text-[10px] font-bold uppercase tracking-widest text-slate-400">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for reclamation in reclamations %}
                <tr class="border-b border-slate-50/50 dark:border-white/3 hover:bg-primary/3 dark:hover:bg-primary/5 transition-colors group">
                    <td class="py-4 px-6">
                        <span class="text-xs font-bold text-slate-400">#{{ reclamation.id }}</span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-lg gradient-primary flex items-center justify-center text-white text-xs font-bold shadow-sm shadow-purple-500/10">
                                {{ reclamation.user ? reclamation.user.username|first|upper : '?' }}
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-900 dark:text-white group-hover:text-primary transition-colors">{{ reclamation.user ? reclamation.user.username : 'Anonyme' }}</p>
                                <p class="text-[11px] text-slate-400 font-medium">{{ reclamation.user ? reclamation.user.email : '' }}</p>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <p class="text-sm font-medium text-slate-700 dark:text-slate-300 max-w-xs truncate">{{ reclamation.sujet }}</p>
                    </td>
                    <td class="py-4 px-6">
                        {% if reclamation.statut|lower == 'pending' or reclamation.statut|lower == 'en attente' %}
                            <span class="badge badge-amber">En Attente</span>
                        {% elseif reclamation.statut|lower == 'resolved' or reclamation.statut|lower == 'résolu' %}
                            <span class="badge badge-green">Résolu</span>
                        {% else %}
                            <span class="badge badge-purple">{{ reclamation.statut|capitalize }}</span>
                        {% endif %}
                    </td>
                    <td class="py-4 px-6 text-right">
                        <a href="{{ path('app_admin_reclamation_show', {'id': reclamation.id}) }}" class="inline-flex items-center gap-1.5 text-xs font-bold text-primary dark:text-primary-light hover:underline transition-colors">
                            Gérer
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="py-16 text-center">
                        <div class="w-14 h-14 rounded-2xl bg-primary/8 flex items-center justify-center mx-auto mb-4">
                            <svg class="w-7 h-7 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                        </div>
                        <p class="text-slate-400 font-semibold text-sm">Aucune demande active trouvée.</p>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
