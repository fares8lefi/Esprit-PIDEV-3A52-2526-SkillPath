{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Gestion des Événements - SkillPath{% endblock %}

{% block content %}
<div class="space-y-8 animate-in fade-in duration-500">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight">Gestion des <span class="gradient-text">Événements</span></h1>
            <p class="text-slate-500 dark:text-slate-400 mt-2 font-medium">Gérez vos événements et planifications.</p>
        </div>
        <a href="{{ path('admin_event_new') }}" class="btn-primary flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Nouvel événement
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 px-6 py-4 rounded-2xl flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="font-medium">{{ message }}</span>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="bg-red-500/10 border border-red-500/20 text-red-600 dark:text-red-400 px-6 py-4 rounded-2xl flex items-center gap-3">
            <span class="font-medium">{{ message }}</span>
        </div>
    {% endfor %}

    <!-- Table -->
    <div class="glass-card rounded-[2rem] overflow-hidden border-none text-left">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50/50 dark:bg-white/5 border-b border-slate-100 dark:border-white/5">
                    <tr>
                        <th class="px-8 py-5 text-left text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Événement</th>
                        <th class="px-8 py-5 text-left text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Date</th>
                        <th class="px-8 py-5 text-left text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Horaire</th>
                        <th class="px-8 py-5 text-left text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Lieu</th>
                        <th class="px-8 py-5 text-right text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-white/5">
                    {% for event in events %}
                        <tr class="group hover:bg-slate-50/50 dark:hover:bg-white/2 transition-all">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4 text-left">
                                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex-shrink-0 flex items-center justify-center overflow-hidden">
                                        {% if event.image %}
                                            <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-full h-full object-cover">
                                        {% else %}
                                            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                        {% endif %}
                                    </div>
                                    <div class="text-left">
                                        <div class="text-sm font-bold text-slate-900 dark:text-white">{{ event.title }}</div>
                                        <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">ID: #{{ event.id }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <span class="badge badge-purple">
                                    {{ event.eventDate ? event.eventDate|date('d/m/Y') : 'N/A' }}
                                </span>
                            </td>
                            <td class="px-8 py-5">
                                <span class="text-sm font-medium text-slate-700 dark:text-slate-300">
                                    {{ event.startTime ? event.startTime|date('H:i') : '' }} - {{ event.endTime ? event.endTime|date('H:i') : '' }}
                                </span>
                            </td>
                            <td class="px-8 py-5">
                                <span class="badge badge-green">
                                    {{ event.location ? event.location.name : 'Non défini' }}
                                </span>
                            </td>
                            <td class="px-8 py-5">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <a href="{{ path('admin_event_show', {id: event.id}) }}" class="p-2 text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors" title="Détails">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    </a>
                                    <a href="{{ path('admin_event_edit', {id: event.id}) }}" class="p-2 text-slate-400 hover:text-emerald-500 transition-colors" title="Modifier">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    </a>
                                    <button onclick="openDeleteModal('{{ path('admin_event_delete', {id: event.id}) }}', '{{ csrf_token('delete' ~ event.id) }}')" class="p-2 text-slate-400 hover:text-red-500 transition-colors" title="Supprimer">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-8 py-20 text-center">
                                <div class="w-20 h-20 bg-slate-50 dark:bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
                                    <svg class="w-10 h-10 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                </div>
                                <h3 class="text-xl font-bold text-slate-900 dark:text-white">Aucun événement</h3>
                                <p class="text-slate-500 dark:text-slate-400 mt-2 mb-8">Commencez par créer votre premier événement.</p>
                                <a href="{{ path('admin_event_new') }}" class="btn-primary">Créer un événement</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Suppression -->
<div id="deleteModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
        <div class="glass-card max-w-md w-full p-8 rounded-[2.5rem] shadow-2xl relative animate-scale-in">
            <div class="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-red-500/20">
                <svg class="w-10 h-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <h3 class="text-2xl font-black text-slate-900 dark:text-white text-center mb-2 tracking-tight">Supprimer l'événement ?</h3>
            <p class="text-slate-500 dark:text-slate-400 text-center mb-8 font-medium">Cette action est irréversible.</p>
            
            <form id="deleteForm" method="POST">
                <input type="hidden" name="_token" id="deleteToken">
                <div class="grid grid-cols-2 gap-4">
                    <button type="button" onclick="closeDeleteModal()" class="btn-secondary">Annuler</button>
                    <button type="submit" class="w-full py-4 bg-red-500 text-white font-bold rounded-2xl shadow-lg shadow-red-500/20 hover:bg-red-600 transition-all">Supprimer</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    function openDeleteModal(url, token) {
        const modal = document.getElementById('deleteModal');
        const form = document.getElementById('deleteForm');
        const tokenInput = document.getElementById('deleteToken');
        
        form.action = url;
        tokenInput.value = token;
        
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeDeleteModal() {
        const modal = document.getElementById('deleteModal');
        modal.classList.add('hidden');
        document.body.style.overflow = '';
    }
</script>
{% endblock %}
