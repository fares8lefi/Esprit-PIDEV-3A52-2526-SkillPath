{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Modifier {{ event.title }} - SkillPath{% endblock %}

{% block content %}
<div class="space-y-8 animate-in fade-in duration-500">
    <div class="flex items-center gap-4 mb-2">
        <a href="{{ path('admin_event_list') }}" class="p-2 rounded-xl hover:bg-slate-100 dark:hover:bg-white/5 transition-all">
            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <h1 class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight">Modifier <span class="gradient-text">Événement</span></h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1 font-medium">{{ event.title }} — ID: #{{ event.id }}</p>
        </div>
    </div>

    <div class="glass-card rounded-[2rem] p-8">
        {{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data', 'novalidate': 'novalidate'}}) }}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Titre <span class="text-red-500">*</span></label>
                    {{ form_widget(form.title) }}
                    {{ form_errors(form.title) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Date <span class="text-red-500">*</span></label>
                    {{ form_widget(form.eventDate) }}
                    {{ form_errors(form.eventDate) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Lieu</label>
                    {{ form_widget(form.location) }}
                    {{ form_errors(form.location) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Heure de début <span class="text-red-500">*</span></label>
                    {{ form_widget(form.startTime) }}
                    {{ form_errors(form.startTime) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Heure de fin <span class="text-red-500">*</span></label>
                    {{ form_widget(form.endTime) }}
                    {{ form_errors(form.endTime) }}
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Description</label>
                    {{ form_widget(form.description, {'attr': {'id': 'event_description'}}) }}
                    {{ form_errors(form.description) }}

                    {# ── AI improve button ── #}
                    <button type="button" id="ai-improve-btn"
                            class="mt-3 inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold
                                   bg-gradient-to-r from-violet-600 to-indigo-600 text-white shadow-md
                                   hover:from-violet-700 hover:to-indigo-700 transition-all duration-200
                                   disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg id="ai-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        <span id="ai-btn-label">✨ Améliorer avec l'IA</span>
                    </button>
                    <span id="ai-error" class="hidden ml-3 text-xs text-red-500 font-medium"></span>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Image</label>
                    {{ form_widget(form.imageFile) }}
                    {{ form_errors(form.imageFile) }}
                    {% if event.image %}
                        <div class="mt-3 flex items-center gap-3">
                            <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-16 h-16 rounded-xl object-cover">
                            <span class="text-xs text-slate-400 font-medium">Image actuelle</span>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="flex gap-4 pt-6 border-t border-slate-200/50 dark:border-white/5">
                <a href="{{ path('admin_event_list') }}" class="flex-1 btn-secondary text-center">Annuler</a>
                <button type="submit" class="flex-1 btn-primary">
                    <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    Enregistrer les modifications
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const btn      = document.getElementById('ai-improve-btn');
    const label    = document.getElementById('ai-btn-label');
    const errSpan  = document.getElementById('ai-error');
    const textarea = document.getElementById('event_description');

    if (!btn || !textarea) return;

    btn.addEventListener('click', async function () {
        const text = textarea.value.trim();
        if (!text) {
            errSpan.textContent = 'Veuillez écrire une description avant de l\'améliorer.';
            errSpan.classList.remove('hidden');
            return;
        }

        btn.disabled      = true;
        label.textContent = '⏳ Amélioration en cours…';
        errSpan.classList.add('hidden');

        try {
            const response = await fetch('{{ path('admin_event_improve_description') }}', {
                method : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body   : JSON.stringify({ description: text }),
            });

            const data = await response.json();

            if (!response.ok || data.error) {
                throw new Error(data.error ?? 'Erreur inconnue.');
            }

            textarea.value = data.improved;
        } catch (err) {
            errSpan.textContent = '❌ ' + err.message;
            errSpan.classList.remove('hidden');
        } finally {
            btn.disabled      = false;
            label.textContent = '✨ Améliorer avec l\'IA';
        }
    });
});
</script>
{% endblock %}
