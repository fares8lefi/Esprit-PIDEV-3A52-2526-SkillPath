{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Nouvel Événement - SkillPath{% endblock %}

{% block content %}
<div class="space-y-8 animate-in fade-in duration-500">
    <div class="flex items-center gap-4 mb-2">
        <a href="{{ path('admin_event_list') }}" class="p-2 rounded-xl hover:bg-slate-100 dark:hover:bg-white/5 transition-all">
            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <h1 class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight">Nouvel <span class="gradient-text">Événement</span></h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1 font-medium">Créez un nouvel événement</p>
        </div>
    </div>

    <div class="glass-card rounded-[2rem] p-8">
        {{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Titre <span class="text-red-500">*</span></label>
                    {{ form_widget(form.title) }}
                    {{ form_errors(form.title) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Date <span class="text-red-500">*</span></label>
                    {{ form_widget(form.eventDate) }}
                    {{ form_errors(form.eventDate) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Lieu</label>
                    {{ form_widget(form.location) }}
                    {{ form_errors(form.location) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Heure de début <span class="text-red-500">*</span></label>
                    {{ form_widget(form.startTime) }}
                    {{ form_errors(form.startTime) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Heure de fin <span class="text-red-500">*</span></label>
                    {{ form_widget(form.endTime) }}
                    {{ form_errors(form.endTime) }}
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Description</label>
                    {{ form_widget(form.description) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Image</label>
                    {{ form_widget(form.imageFile) }}
                    {{ form_errors(form.imageFile) }}
                </div>
            </div>

            <div class="flex gap-4 pt-6 border-t border-slate-200/50 dark:border-white/5">
                <a href="{{ path('admin_event_list') }}" class="flex-1 btn-secondary text-center">Annuler</a>
                <button type="submit" class="flex-1 btn-primary">
                    <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Créer l'événement
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
