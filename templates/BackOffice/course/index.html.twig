{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Annuaire des Cours - Admin{% endblock %}

{% block content %}
<div class="space-y-8 animate-fade-up">
    {# Header #}
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white">Annuaire des Cours</h1>
            <p class="text-slate-500 font-medium mt-1">Total: <span class="text-primary font-bold">{{ courses.getTotalItemCount }}</span> programmes académiques actifs</p>
        </div>
        <a href="{{ path('admin_course_new') }}" class="btn-primary flex items-center gap-2 !py-3 !px-6">
            <svg class="w-5 h-5 child-path:stroke-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Lancer un Nouveau Cours
        </a>
    </div>

    {# Filters #}
    <div class="glass p-6 rounded-2xl border border-slate-200/50 dark:border-white/5 flex flex-col md:flex-row items-center gap-4">
        <form action="{{ path('admin_course_index') }}" method="get" class="flex-grow w-full md:w-auto relative group">
            <svg class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text" name="q" value="{{ app.request.query.get('q') }}" placeholder="Rechercher des cours..." 
                   class="w-full pl-12 pr-4 py-3 bg-slate-100/60 dark:bg-white/5 border-2 border-transparent rounded-xl focus:outline-none focus:border-primary/30 focus:bg-white dark:focus:bg-white/8 transition-all text-sm font-medium">
        </form>
        <div class="flex items-center gap-3 w-full md:w-auto">
             <button class="flex-grow md:flex-initial btn-secondary !py-3 !px-6 !text-sm !font-bold">Filtrer</button>
             <a href="{{ path('admin_course_index') }}" class="p-3 text-slate-400 hover:text-red-500 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
             </a>
        </div>
    </div>

    {# Table/Grid #}
    <div class="glass rounded-2xl border border-slate-200/50 dark:border-white/5 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-white/2 border-b border-slate-200/50 dark:border-white/5">
                        <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Info Cours</th>
                        <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Titre du Cours</th>
                        <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Niveau</th>
                        <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">Modules</th>
                        <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200/50 dark:divide-white/5">
                    {% for course in courses %}
                        <tr class="hover:bg-slate-50/50 dark:hover:bg-white/2 transition-colors group">
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="w-14 h-14 rounded-xl overflow-hidden bg-slate-100 dark:bg-white/5 border border-slate-200/50 dark:border-white/10 flex-shrink-0">
                                        {% if course.image %}
                                            <img src="{{ asset('uploads/modules/' ~ course.image) }}" class="w-full h-full object-cover">
                                        {% else %}
                                            <div class="w-full h-full gradient-primary opacity-20 flex items-center justify-center">
                                                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="min-w-0">
                                        <p class="font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors truncate">{{ course.title }}</p>
                                        <p class="text-xs text-slate-400 mt-0.5 line-clamp-1 italic italic">{{ course.description }}</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <p class="font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors truncate">{{ course.title }}</p>
                            </td>
                            <td class="px-6 py-5 text-center">
                                <span class="badge badge-cyan !text-[10px]">{{ course.level }}</span>
                            </td>
                            <td class="px-6 py-5 text-center">
                                <span class="px-3 py-1 rounded-lg bg-primary/10 text-primary text-xs font-bold">{{ course.modules|length }} Unités</span>
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex items-center justify-end gap-2 text-slate-400">
                                    <a href="{{ path('admin_course_show', {id: course.id}) }}" class="p-2 hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="Voir">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                    </a>
                                    <a href="{{ path('admin_course_edit', {id: course.id}) }}" class="p-2 hover:text-amber-500 hover:bg-amber-500/10 rounded-lg transition-all" title="Modifier">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    </a>
                                    <form method="post" action="{{ path('admin_course_delete', {'id': course.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce cours ?');" style="display: inline-block;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
                                        <button class="p-2 hover:text-red-500 hover:bg-red-500/10 rounded-lg transition-all" title="Supprimer">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-slate-500 italic">Aucun cours trouvé. Commencez par en créer un !</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        
        {# Pagination #}
        <div class="px-6 py-4 bg-slate-50/50 dark:bg-white/2 border-t border-slate-200/50 dark:border-white/5">
            {{ knp_pagination_render(courses) }}
        </div>
    </div>
</div>
{% endblock %}
