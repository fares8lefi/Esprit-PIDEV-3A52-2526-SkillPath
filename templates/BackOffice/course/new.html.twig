{% extends 'BackOffice/layout.html.twig' %}

{% block title %}{{ course.id ? 'Edit Course' : 'Create Course' }} - Admin{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto space-y-8 animate-fade-up">
    {# Breadcrumbs/Back #}
    <div class="flex items-center gap-4">
        <a href="{{ path('admin_course_index') }}" class="w-10 h-10 rounded-xl glass flex items-center justify-center text-slate-400 hover:text-primary transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500">Back to List</p>
            <h1 class="text-2xl font-black text-slate-900 dark:text-white">{{ course.id ? 'Refine Course Details' : 'Architect New Course' }}</h1>
        </div>
    </div>

    {# Form #}
    <div class="glass p-10 rounded-3xl border border-slate-200/50 dark:border-white/5 relative overflow-hidden">
        {# Decoration #}
        <div class="absolute -top-32 -right-32 w-64 h-64 bg-primary/5 blur-[100px] rounded-full"></div>

        {{ form_start(form, {'attr': {'class': 'space-y-8 relative z-10'}}) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="md:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Title</label>
                    {{ form_widget(form.title) }}
                    {{ form_errors(form.title) }}
                </div>
                
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Category</label>
                    {{ form_widget(form.category) }}
                    {{ form_errors(form.category) }}
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Architectural Level</label>
                    {{ form_widget(form.level) }}
                    {{ form_errors(form.level) }}
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Comprehensive Description</label>
                    {{ form_widget(form.description) }}
                    {{ form_errors(form.description) }}
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Estimated Duration (Min)</label>
                    {{ form_widget(form.duration) }}
                    {{ form_errors(form.duration) }}
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Course Investment (DT)</label>
                    {{ form_widget(form.price) }}
                    {{ form_errors(form.price) }}
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Visual ID (Banner)</label>
                    <div class="mt-2 p-8 border-2 border-dashed border-slate-200 dark:border-white/10 rounded-2xl bg-slate-50 md:flex flex-col items-center justify-center text-center group hover:border-primary/50 transition-all dark:bg-white/2 cursor-pointer">
                        {{ form_widget(form.imageFile, {'attr': {'class': 'hidden'}}) }}
                        <div onclick="document.getElementById('{{ form.imageFile.vars.id }}').click()" class="flex flex-col items-center">
                            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary mb-4 group-hover:scale-110 transition-transform">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            </div>
                            <p class="text-sm font-bold">Drop image here or click to browse</p>
                            <p class="text-xs text-slate-400 mt-1 uppercase tracking-widest">JPG, PNG or WEBP up to 3MB</p>
                        </div>
                    </div>
                    {{ form_errors(form.imageFile) }}
                </div>
            </div>

            <div class="flex items-center justify-end gap-4 pt-8 border-t border-slate-200/50 dark:border-white/5">
                <a href="{{ path('admin_course_index') }}" class="btn-secondary !text-sm !py-3 !px-6">Cancel</a>
                <button type="submit" class="btn-primary !text-sm !py-3 !px-8">
                    {{ course.id ? 'Optimize Course' : 'Finalize Creation' }}
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
