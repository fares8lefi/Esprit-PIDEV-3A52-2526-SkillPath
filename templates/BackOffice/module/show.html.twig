{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Module Explorer: {{ module.title }} - Admin{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto space-y-8 animate-fade-up">
    {# Header #}
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-6">
            <a href="{{ path('admin_module_index') }}" class="w-12 h-12 rounded-2xl glass flex items-center justify-center text-slate-400 hover:text-primary transition-all border border-slate-200 dark:border-white/10">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </a>
            
            {% if module.image %}
                <div class="w-16 h-16 rounded-2xl border border-slate-200 dark:border-white/10 overflow-hidden shadow-sm">
                    <img src="{{ asset('uploads/modules/' ~ module.image) }}" class="w-full h-full object-cover">
                </div>
            {% endif %}

            <h1 class="text-3xl font-black text-slate-900 dark:text-white leading-tight">{{ module.title }}</h1>
        </div>
        <div class="flex gap-3">
             <a href="{{ path('admin_module_edit', {id: module.id}) }}" class="btn-secondary !py-2.5 !px-5 !text-xs">Adjust Unit</a>
             <a href="{{ path('admin_module_edit', {id: module.id}) }}" class="btn-secondary !py-2.5 !px-5 !text-xs">Ajuster l'Unité</a>
             {% if module.course is defined and module.course is not null %}
                 <a href="{{ path('admin_course_show', {id: module.course.id}) }}" class="btn-primary !py-2.5 !px-5 !text-xs">Voir le Contexte du Cours</a>
             {% else %}
                 <span class="btn-secondary !py-2.5 !px-5 !text-xs opacity-50 cursor-not-allowed">Cours Manquant</span>
             {% endif %}
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
            {# Content #}
            <div class="glass p-10 rounded-3xl border border-slate-200/50 dark:border-white/5">
                <div class="flex items-center gap-4 mb-8">
                     <span class="badge {{ module.type == 'video' ? 'badge-purple' : 'badge-cyan' }}">{{ module.type|upper }}</span>
                     <span class="text-xs font-bold text-slate-400 uppercase tracking-widest italic italic">Architecturé le {{ module.createdAt|date('d M Y') }}</span>
                </div>

                <div class="prose dark:prose-invert max-w-none text-slate-600 dark:text-slate-400 leading-relaxed min-h-[400px]">
                     <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Contenu d'Apprentissage</h3>
                    <div class="p-6 rounded-2xl bg-slate-50 dark:bg-white/2 border border-slate-200/50 dark:border-white/5 font-mono text-sm">
                        {{ module.content|nl2br }}
                    </div>

                    <h3 class="text-xl font-bold text-slate-900 dark:text-white mt-12 mb-6">Description de l'Unité</h3>
                    <div class="whitespace-pre-line">
                        {{ module.description }}
                    </div>
                </div>
            </div>
        </div>

        {# Meta #}
        <div class="space-y-6">
            <div class="glass p-8 rounded-3xl border border-slate-200/50 dark:border-white/5">
                <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-6">Affiliation</p>
                <div class="p-6 rounded-2xl bg-primary/5 border border-primary/10">
                    <p class="text-[10px] font-bold text-primary uppercase tracking-widest mb-2">Member of Course</p>
                <p class="text-[10px] font-bold text-primary uppercase tracking-widest mb-2">Member of Course</p>
                {% if module.course is defined and module.course is not null %}
                    <p class="font-bold text-slate-900 dark:text-white mb-4">{{ module.course.title }}</p>
                    <a href="{{ path('admin_course_show', {id: module.course.id}) }}" class="text-xs font-bold text-primary hover:underline">View Roadmap →</a>
                {% else %}
                    <p class="font-bold text-slate-400 italic mb-4">Non Assigné (Cours Supprimé)</p>
                {% endif %}
                </div>
            </div>

            <div class="glass p-8 rounded-3xl border border-slate-200/50 dark:border-white/5">
                <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-6">Paramètres</p>
                <div class="space-y-4">
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-slate-400 font-medium">Démarrage Auto</span>
                        <span class="text-success font-black text-[10px] uppercase tracking-widest">Actif</span>
                    </div>
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-slate-400 font-medium">Certification</span>
                        <span class="text-primary font-black text-[10px] uppercase tracking-widest">Activé</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
