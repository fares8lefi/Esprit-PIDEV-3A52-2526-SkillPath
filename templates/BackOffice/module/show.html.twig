{% extends 'base.html.twig' %}

{% block title %}Détails Module - SkillPath{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
        .gradient-text {
            background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
{% endblock %}

{% block body %}

<div class="min-h-screen bg-gray-50">
    <div class="max-w-5xl mx-auto p-6">

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-extrabold gradient-text">{{ module.name }}</h1>
                <p class="text-sm text-gray-600">Détails du module</p>
            </div>

            <div class="flex gap-2">
                <a href="{{ path('admin_module_edit', {id: module.id}) }}" class="px-5 py-2.5 bg-skillpath-green text-white rounded-xl font-semibold hover:bg-skillpath-green-dark transition-all">
                    Modifier
                </a>
                <a href="{{ path('admin_module_list') }}" class="px-5 py-2.5 border border-gray-300 rounded-xl font-semibold text-gray-700 hover:bg-gray-100 transition-all">
                    Retour
                </a>
            </div>
        </div>

            <div class="p-6 grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="md:col-span-2 space-y-6">
                    <div class="flex items-center gap-3">
                        <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold bg-brand-blue/10 text-brand-blue uppercase tracking-wider">
                            Formation : {{ module.cours.titre|default('N/A') }}
                        </span>
                        
                        <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold bg-gray-100 text-gray-600 uppercase tracking-wider">
                            Type : {{ module.type|default('Autre')|upper }}
                        </span>
                    </div>

                    <div>
                        <h2 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
                            <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/>
                            </svg>
                            Description
                        </h2>
                        <div class="text-gray-700 leading-relaxed bg-gray-50 rounded-2xl p-6 border border-gray-100">
                            {{ module.description ? module.description|nl2br : 'Aucune description fournie.' }}
                        </div>
                    </div>

                    <div>
                        <h2 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
                            <svg class="w-5 h-5 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                            Contenu du module
                        </h2>
                        <div class="bg-gray-900 text-gray-300 rounded-2xl p-6 font-mono text-sm overflow-x-auto shadow-inner">
                            {{ module.contenu ? module.contenu : '— Aucun contenu disponible —' }}
                        </div>
                    </div>
                </div>

                <div class="md:col-span-1 border-l border-gray-100 pl-8 space-y-6">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-500 uppercase mb-4">Informations Système</h3>
                        <div class="space-y-4">
                            <div class="flex flex-col">
                                <span class="text-xs text-gray-400">Date de création</span>
                                <span class="text-sm font-medium text-gray-900">{{ module.dateCreation|date('d/m/Y H:i') }}</span>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-xs text-gray-400">ID Unique</span>
                                <span class="text-sm font-mono text-gray-600">MOD-{{ module.id|format('%04d') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        <!-- Delete card -->
        <div class="mt-6 bg-white border border-gray-200 rounded-2xl shadow-sm p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Zone dangereuse</h3>
            <p class="text-sm text-gray-600 mb-4">Supprimer le module définitivement.</p>

            <form method="post" action="{{ path('admin_module_delete', {id: module.id}) }}"
                  onsubmit="return confirm('Supprimer ce module ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_module' ~ module.id) }}">
                <button class="px-6 py-3 bg-red-600 text-white rounded-xl font-semibold hover:bg-red-700 transition-all">
                    Supprimer
                </button>
            </form>
        </div>

    </div>
</div>

{% endblock %}
