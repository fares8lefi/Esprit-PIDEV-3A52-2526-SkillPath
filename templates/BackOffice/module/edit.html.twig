{% extends 'base.html.twig' %}

{% block title %}Modifier Module - SkillPath{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .gradient-text {
            background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gray-50 flex">
        <!-- Sidebar -->
        {% include 'BackOffice/_sidebar.html.twig' %}

        <!-- Main Content -->
        <div class="lg:ml-72 flex-1">
            <div class="p-8">
                
                <!-- Breadcrumb -->
                <nav class="mb-6">
                    <ol class="flex items-center space-x-2 text-sm">
                        <li>
                            <a href="{{ path('admin_module_list') }}" class="text-gray-500 hover:text-gray-700">
                                Tableau de bord
                            </a>
                        </li>
                        <li class="text-gray-400">/</li>
                        <li>
                            <a href="{{ path('admin_module_list') }}" class="text-gray-500 hover:text-gray-700">
                                Modules
                            </a>
                        </li>
                        <li class="text-gray-400">/</li>
                        <li class="text-gray-900 font-medium">Modifier</li>
                    </ol>
                </nav>

                <div class="max-w-5xl mx-auto">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h1 class="text-2xl font-extrabold gradient-text">Modifier le module</h1>
                            <p class="text-sm text-gray-600">Met à jour les informations du module.</p>
                        </div>
                    </div>

                    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6">
                        {% include 'BackOffice/module/_form.html.twig' with {form: form, module: module, button_label: 'Mettre à jour'} %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
