{% extends 'base.html.twig' %}

{% block title %}Gestion des modules{% endblock %}

{% block body %}

<div style="width:90%; margin:auto; margin-top:40px;">

    <h1 style="margin-bottom:20px;">📦 Gestion des modules</h1>

    <a href="{{ path('module_new') }}"
       style="
           background:#4CAF50;
           color:white;
           padding:10px 15px;
           text-decoration:none;
           border-radius:5px;
           font-weight:bold;
       ">
        ➕ Ajouter un module
    </a>

    <div style="margin-top:20px; background:white; padding:20px; border-radius:8px;">
        <table width="100%" style="border-collapse: collapse;">
            <thead>
                <tr style="background:#f4f4f4; text-align:left;">
                    <th style="padding:10px;">ID</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Date</th>
                    <th>Level</th>
                    <th>Image</th>
                    <th width="150">Actions</th>
                </tr>
            </thead>

            <tbody>
            {% for m in modules %}
                <tr style="border-top:1px solid #ddd;">
                    <td style="padding:10px;">{{ m.id }}</td>
                    <td>{{ m.name }}</td>
                    <td>{{ m.description }}</td>
                    <td>{{ m.dateCreation ? m.dateCreation|date('Y-m-d') : '' }}</td>
                    <td>{{ m.level }}</td>
                    <td>{{ m.image }}</td>
                    <td>
                        <a href="{{ path('module_edit', {'id': m.id}) }}"
                           style="color:orange; text-decoration:none;">
                           ✏️
                        </a>
                        |
                        <a href="{{ path('module_delete', {'id': m.id}) }}"
                           onclick="return confirm('Supprimer ?')"
                           style="color:red; text-decoration:none;">
                           🗑️
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" style="text-align:center; padding:20px;">
                        Aucun module trouvé
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>

{% endblock %}
