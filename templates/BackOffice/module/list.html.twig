{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Gestion des Modules - SkillPath{% endblock %}

{% block content %}
<div class="space-y-8 animate-in fade-in duration-500">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-extrabold text-white tracking-tight">Gestion des <span class="vibrant-text">Modules</span></h1>
            <p class="text-neutral-500 mt-2 font-medium">Configurez les parcours d'apprentissage et les thématiques.</p>
        </div>
        <a href="{{ path('module_new') }}" class="px-6 py-3 vibrant-gradient rounded-2xl text-sm font-bold text-white shadow-lg shadow-skill-blue/25 flex items-center gap-2 transform hover:scale-105 active:scale-95 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter un module
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="bg-green-500/10 border border-green-500/20 text-green-400 px-6 py-4 rounded-2xl flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="font-medium">{{ message }}</span>
        </div>
    {% endfor %}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for m in modules %}
            <div class="glass-card rounded-[2.5rem] p-8 group relative overflow-hidden">
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-6">
                        <div class="w-16 h-16 rounded-2xl bg-neutral-800/50 border border-neutral-700/50 flex items-center justify-center group-hover:border-skillpath-blue/30 transition-all">
                            {% if m.image %}
                                <img src="{{ asset('uploads/' ~ m.image) }}" alt="{{ m.name }}" class="w-12 h-12 object-cover rounded-xl">
                            {% else %}
                                <div class="w-12 h-12 rounded-xl vibrant-gradient flex items-center justify-center text-xl font-black text-white shadow-inner">
                                    {{ m.name|first|upper }}
                                </div>
                            {% endif %}
                        </div>
                        <span class="px-3 py-1 rounded-xl text-[10px] font-black uppercase tracking-wider bg-skillpath-blue/10 text-skillpath-blue border border-skillpath-blue/20">
                            Niveau {{ m.level }}
                        </span>
                    </div>

                    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-skillpath-blue transition-colors">{{ m.name }}</h3>
                    <p class="text-neutral-500 text-sm line-clamp-3 mb-6">{{ m.description }}</p>

                    <div class="flex items-center justify-between pt-6 border-t border-neutral-800/50">
                        <div class="text-xs text-neutral-600 font-bold uppercase tracking-widest">
                            {{ m.dateCreation ? m.dateCreation|date('d/m/Y') : 'Récemment' }}
                        </div>
                        <div class="flex gap-2">
                            <a href="{{ path('module_edit', {'id': m.id}) }}" class="p-2.5 bg-neutral-800/50 text-neutral-400 hover:text-skillpath-green hover:bg-skillpath-green/10 rounded-xl transition-all border border-neutral-700/50" title="Modifier">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                                </svg>
                            </a>
                            <a href="{{ path('module_delete', {'id': m.id}) }}" onclick="return confirm('Voulez-vous supprimer ce module ?')" class="p-2.5 bg-neutral-800/50 text-neutral-400 hover:text-red-500 hover:bg-red-500/10 rounded-xl transition-all border border-neutral-700/50" title="Supprimer">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
                <!-- Card background glow -->
                <div class="absolute -right-12 -bottom-12 w-32 h-32 bg-skillpath-blue/5 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-700"></div>
            </div>
        {% else %}
            <div class="col-span-full py-20 text-center glass-card rounded-[2.5rem]">
                <div class="w-20 h-20 bg-neutral-800/50 rounded-full flex items-center justify-center mx-auto mb-6 border border-neutral-700/50">
                    <svg class="w-10 h-10 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                </div>
                <h3 class="text-xl font-bold text-white">Aucun module</h3>
                <p class="text-neutral-500 mt-2 mb-8">Commencez par créer votre premier module d'apprentissage.</p>
                <a href="{{ path('module_new') }}" class="px-8 py-3 vibrant-gradient rounded-2xl text-sm font-bold text-white shadow-lg shadow-skillpath-blue/25 transition-all">
                    Créer un module
                </a>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
