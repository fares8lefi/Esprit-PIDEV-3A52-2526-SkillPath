{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Brouillon Nouvelle Unité - Admin{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto space-y-8 animate-fade-up">
    {# Breadcrumbs #}
    <div class="flex items-center gap-4">
        <a href="{{ path('admin_module_index') }}" class="w-10 h-10 rounded-xl glass flex items-center justify-center text-slate-400 hover:text-primary transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500">Retour au Curriculum</p>
            <h1 class="text-2xl font-black text-slate-900 dark:text-white">Architecturer un Nouveau Module</h1>
        </div>
    </div>

    {# Form #}
    <div class="glass p-10 rounded-3xl border border-slate-200/50 dark:border-white/5 relative overflow-hidden">
        {{ form_start(form, {'attr': {'class': 'space-y-8 relative z-10'}}) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="md:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Titre de l'Unité</label>
                    {{ form_widget(form.title) }}
                    {{ form_errors(form.title) }}
                </div>
                
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Cours Cible</label>
                    {{ form_widget(form.course) }}
                    {{ form_errors(form.course) }}
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Format du Contenu</label>
                    {{ form_widget(form.type) }}
                    {{ form_errors(form.type) }}
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Description du Module (Synopsis)</label>
                    {{ form_widget(form.description) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="md:col-span-1">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Logo / Illustration</label>
                    {{ form_widget(form.imageFile) }}
                    {{ form_errors(form.imageFile) }}
                    {% if module.image is defined and module.image %}
                        <div class="mt-2 flex items-center gap-2">
                            <span class="text-[10px] text-slate-400">Actuel:</span>
                            <img src="{{ asset('uploads/modules/' ~ module.image) }}" class="w-8 h-8 rounded border border-white/10 object-cover">
                        </div>
                    {% endif %}
                </div>

                <div class="md:col-span-1">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Document de Cours (PDF/Word)</label>
                    {{ form_widget(form.documentFile) }}
                    {{ form_errors(form.documentFile) }}
                    {% if module.document is defined and module.document %}
                        <div class="mt-2 flex items-center gap-2">
                            <span class="text-[10px] text-slate-400">Actuel:</span>
                            <span class="text-[10px] font-mono text-primary truncate max-w-[100px]">{{ module.document }}</span>
                        </div>
                    {% endif %}
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Contenu Principal / Ressources</label>
                    {{ form_widget(form.content) }}
                    {{ form_errors(form.content) }}
                    <p class="text-[10px] text-slate-400 mt-2 italic">Supporte le Markdown, texte enrichi, ou URLs de ressources. Si c'est une vidéo, mettez l'URL ici.</p>
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Niveau de difficulté</label>
                    {{ form_widget(form.level) }}
                    {{ form_errors(form.level) }}
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Planification (Schedule at)</label>
                    {{ form_widget(form.scheduledAt) }}
                    {{ form_errors(form.scheduledAt) }}
                    <p class="text-[10px] text-slate-400 mt-2 italic">Date et heure à laquelle le module sera visible.</p>
                </div>
            </div>

            <div class="flex items-center justify-end gap-4 pt-8 border-t border-slate-200/50 dark:border-white/5">
                <a href="{{ path('admin_module_index') }}" class="btn-secondary !text-sm !py-3 !px-6">Abandonner</a>
                <button type="submit" class="btn-primary !text-sm !py-3 !px-8">Finaliser l'Unité</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
