{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Nouveau Module - SkillPath{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto animate-in fade-in slide-in-from-bottom-8 duration-700">
    <div class="mb-10 flex items-center gap-6">
        <a href="{{ path('admin_module_list') }}" class="w-14 h-14 rounded-2xl glass border border-slate-200/50 dark:border-white/5 flex items-center justify-center text-slate-400 hover:text-primary hover:border-primary/30 transition-all group">
            <svg class="w-6 h-6 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white tracking-tight">Nouveau <span class="gradient-text">Module</span></h1>
            <p class="text-slate-500 dark:text-slate-500 font-medium">Créez un nouveau chapitre interactif pour vos apprenants.</p>
        </div>
    </div>

    <div class="glass-card rounded-[2.5rem] border-none overflow-hidden relative p-10">
        <div class="absolute top-0 left-0 w-full h-1 gradient-primary opacity-50"></div>
        
        {% include 'BackOffice/module/_form.html.twig' with {'button_label': 'Créer le module'} %}
    </div>
</div>
{% endblock %}
