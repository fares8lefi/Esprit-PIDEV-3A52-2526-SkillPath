{{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
        {{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
        {{ form_widget(form.name) }}
        {{ form_errors(form.name) }}
    </div>

    <div>
        {{ form_label(form.level, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
        {{ form_widget(form.level) }}
        {{ form_errors(form.level) }}
    </div>
</div>

<div>
    {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
    {{ form_widget(form.description) }}
    {{ form_errors(form.description) }}
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
    <div>
        {{ form_label(form.imageFile, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
        {{ form_widget(form.imageFile) }}
        {{ form_errors(form.imageFile) }}
        <p class="text-xs text-gray-500 mt-2">Formats acceptés : JPG / PNG / WEBP (max 3MB)</p>
    </div>

    {% if module.image %}
        <div class="bg-gray-50 border border-gray-200 rounded-2xl p-4">
            <p class="text-sm font-semibold text-gray-800 mb-3">Image actuelle</p>
            <img src="{{ asset('uploads/modules/' ~ module.image) }}" class="w-full h-40 object-cover rounded-xl border border-gray-200" alt="">
        </div>
    {% endif %}
</div>

<div class="flex items-center gap-3 pt-2">
    <button class="px-6 py-3 bg-gradient-to-r from-skillpath-blue to-skillpath-blue-dark text-white rounded-xl font-semibold hover:shadow-lg transition-all">
        {{ button_label|default('Enregistrer') }}
    </button>

    <a href="{{ path('admin_module_list') }}" class="px-6 py-3 border-2 border-gray-300 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 transition-all">
        Annuler
    </a>
</div>

{{ form_end(form) }}
