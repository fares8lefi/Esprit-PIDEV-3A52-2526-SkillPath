{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Admin Dashboard - SkillPath{% endblock %}

{% block content %}
    <div class="space-y-8">
        <!-- Welcome -->
        <section class="flex flex-col md:flex-row md:items-center justify-between gap-6 animate-fade-up">
            <div>
                <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Tableau de <span class="gradient-text">Bord</span></h1>
                <p class="text-slate-500 dark:text-slate-400 mt-1 font-medium text-sm">Bienvenue, {{ app.user.username }}. Voici l'état actuel de votre plateforme.</p>
            </div>
            <div class="flex gap-3">
                <a href="{{ path('app_admin_reclamation_index') }}" class="btn-secondary !py-2.5 !px-5 text-sm flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                    Réclamations
                </a>
                <a href="{{ path('app_user_admin_create') }}" class="btn-primary !py-2.5 !px-5 text-sm flex items-center gap-2 !rounded-xl">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                    Nouvel Utilisateur
                </a>
            </div>
        </section>

        <!-- Stats Bento Grid -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 animate-fade-up delay-100">
            <!-- Users -->
            <div class="glass-card p-6 rounded-2xl">
                <div class="flex justify-between items-start mb-5">
                    <div class="w-11 h-11 bg-primary/8 dark:bg-primary/15 text-primary dark:text-primary-light rounded-xl flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    </div>
                    <span class="badge badge-purple">Global</span>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest">Utilisateurs</p>
                <h3 class="text-3xl font-black text-slate-900 dark:text-white mt-1">{{ userCount }}</h3>
                <div class="progress-bar mt-4"><div class="progress-bar-fill" style="width: 65%"></div></div>
            </div>

            <!-- Urgent Reclamations -->
            <div class="glass-card p-6 rounded-2xl relative overflow-hidden group border-2 border-red-500/20">
                <div class="flex justify-between items-start mb-5">
                    <div class="w-11 h-11 bg-red-100 dark:bg-red-500/15 text-red-500 rounded-xl flex items-center justify-center animate-pulse">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    </div>
                    {% if urgentCount > 0 %}
                        <span class="badge badge-red animate-bounce">Alerte</span>
                    {% else %}
                        <span class="badge badge-green">Calme</span>
                    {% endif %}
                </div>
                <p class="text-red-500/60 dark:text-red-400/60 text-[10px] font-bold uppercase tracking-widest">Urgences IA</p>
                <h3 class="text-3xl font-black text-slate-900 dark:text-white mt-1">{{ urgentCount }}</h3>
                <div class="mt-4">
                    <a href="{{ path('app_admin_reclamation_index', {'status': 'Urgent'}) }}" class="text-[10px] font-bold text-red-500 hover:underline uppercase tracking-wider">Voir les alertes →</a>
                </div>
            </div>

            <!-- Courses -->
            <div class="glass-card p-6 rounded-2xl">
                <div class="flex justify-between items-start mb-5">
                    <div class="w-11 h-11 bg-accent/10 text-accent rounded-xl flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <span class="badge badge-cyan">Contenu</span>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest">Cours</p>
                <h3 class="text-3xl font-black text-slate-900 dark:text-white mt-1">{{ coursCount }}</h3>
                <div class="progress-bar mt-4"><div class="progress-bar-fill" style="width: 80%"></div></div>
            </div>

            <!-- Total Reclamations -->
            <div class="glass-card p-6 rounded-2xl">
                <div class="flex justify-between items-start mb-5">
                    <div class="w-11 h-11 bg-amber-100 dark:bg-amber-500/15 text-amber-500 rounded-xl flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                    </div>
                    <span class="badge badge-amber">{{ reclamationCount }} Total</span>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest">Support Clients</p>
                <h3 class="text-3xl font-black text-slate-900 dark:text-white mt-1">{{ reclamationCount }}</h3>
                <div class="mt-4">
                    <a href="{{ path('app_admin_reclamation_index') }}" class="text-[10px] font-bold text-amber-600 hover:underline uppercase tracking-wider">Tickets en cours →</a>
                </div>
            </div>
        </section>

        <!-- Bottom Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-fade-up delay-200">
            <!-- Recent Users -->
            <div class="lg:col-span-2 glass-card rounded-2xl p-7 overflow-hidden">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white">Derniers Utilisateurs</h3>
                        <p class="text-slate-500 dark:text-slate-400 text-xs mt-0.5 font-medium">Les membres récemment inscrits.</p>
                    </div>
                    <a href="{{ path('app_user_index') }}" class="text-primary dark:text-primary-light hover:underline font-bold text-xs transition-colors">Voir tout →</a>
                </div>

                <div class="space-y-4">
                    {% for user in recentUsers %}
                    <div class="flex items-center gap-4 group cursor-pointer">
                        <div class="w-11 h-11 rounded-xl gradient-primary flex items-center justify-center text-xs font-bold text-white shadow-md shadow-purple-500/10 group-hover:scale-105 transition-transform">
                            {{ user.username|first|upper }}
                        </div>
                        <div class="flex-1 flex justify-between items-center border-b border-slate-100/50 dark:border-white/5 pb-4 group-last:border-0">
                            <div>
                                <p class="text-sm font-bold text-slate-900 dark:text-white group-hover:text-primary dark:group-hover:text-primary-light transition-colors">{{ user.username }}</p>
                                <p class="text-xs text-slate-400 font-medium">{{ user.email }}</p>
                            </div>
                            <div class="text-right">
                                <span class="badge badge-purple text-[9px]">ID: #{{ user.id }}</span>
                                <p class="text-[10px] text-slate-400 mt-1 font-medium">
                                    {{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : 'Ancien Membre' }}
                                </p>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <p class="text-slate-400 text-center py-10 font-medium text-sm">Aucun utilisateur récent.</p>
                    {% endfor %}
                </div>
            </div>

            <!-- Info Column -->
            <div class="space-y-6">
                <!-- CTA Card -->
                <div class="gradient-primary rounded-2xl p-7 relative overflow-hidden shadow-xl shadow-purple-500/15 group">
                    <div class="relative z-10">
                        <h3 class="text-xl font-black text-white leading-tight">Gérez vos <br>modules</h3>
                        <p class="text-white/70 mt-2 text-sm font-medium">Accédez à l'édition rapide des contenus pédagogiques.</p>
                        <a href="{{ path('module_list') }}" class="mt-5 block w-full py-3 bg-white text-primary text-center font-bold rounded-xl hover:bg-slate-50 transition-all active:scale-95 shadow-lg text-sm">Accéder aux modules</a>
                    </div>
                    <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/5 rounded-full blur-3xl group-hover:scale-125 transition-transform duration-700"></div>
                </div>

                <!-- System Status -->
                <div class="glass-card rounded-2xl p-7">
                    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-5">Résumé Système</h3>
                    <div class="space-y-3">
                        <div class="flex items-center justify-between p-3.5 bg-slate-50/50 dark:bg-white/3 rounded-xl">
                            <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Serveur</span>
                            <span class="flex items-center gap-1.5 text-mint text-[10px] font-bold">
                                <span class="w-1.5 h-1.5 bg-mint rounded-full animate-pulse"></span>
                                OPÉRATIONNEL
                            </span>
                        </div>
                        <div class="flex items-center justify-between p-3.5 bg-slate-50/50 dark:bg-white/3 rounded-xl">
                            <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Base de données</span>
                            <span class="text-slate-900 dark:text-white text-[10px] font-bold">MariaDB 10.4</span>
                        </div>
                        <div class="flex items-center justify-between p-3.5 bg-slate-50/50 dark:bg-white/3 rounded-xl">
                            <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Storage</span>
                            <span class="text-slate-900 dark:text-white text-[10px] font-bold">74%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
