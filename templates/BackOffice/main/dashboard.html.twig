{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Tableau de Bord Admin - SkillPath{% endblock %}

{% block stylesheets %}
<style>
    @media print {
        aside, header, nav, [data-html2canvas-ignore], .btn-primary, .btn-secondary, button {
            display: none !important;
        }
        main {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            background: white !important;
        }
        #dashboard-content {
            padding: 10px !important;
            margin: 0 !important;
        }
        .glass-card {
            border: 1px solid #eee !important;
            box-shadow: none !important;
            break-inside: avoid;
            background: white !important;
            color: black !important;
        }
        .dark .glass-card {
            background: white !important;
            color: black !important;
        }
        canvas {
            max-width: 100% !important;
            height: auto !important;
        }
    }
</style>
{% endblock %}

{% block content %}
    <div id="dashboard-content" class="space-y-8 animate-fade-up">
        <!-- Welcome -->
        <section class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Tableau de Bord <span class="gradient-text">Admin</span></h1>
                <p class="text-slate-500 dark:text-slate-400 mt-1 font-medium text-sm">Bon retour, {{ app.user.username }}. Voici l'aperçu analytique de SkillPath.</p>
            </div>
            <div class="flex gap-3" data-html2canvas-ignore>
                <a href="{{ path('app_admin_reclamation_index') }}" class="btn-secondary !py-2.5 !px-5 text-sm flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                    Réclamations
                </a>
                <button onclick="exportToPDF(event)" class="btn-secondary !py-2.5 !px-5 text-sm flex items-center gap-2 group">
                    <svg class="w-4 h-4 text-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                    PDF
                </button>
                <button onclick="exportToExcel(event)" class="btn-secondary !py-2.5 !px-5 text-sm flex items-center gap-2 group">
                    <svg class="w-4 h-4 text-mint" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Excel
                </button>
                <a href="{{ path('app_user_admin_create') }}" class="btn-primary !py-2.5 !px-5 text-sm flex items-center gap-2 !rounded-xl">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                    Nouvel Architecte
                </a>
            </div>
        </section>

        <!-- Stats Bento Grid -->
        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-5">
            <!-- Users -->
            <div class="glass-card p-5 rounded-2xl border-b-4 border-primary hover-lift group">
                <div class="flex justify-between items-start mb-3">
                    <div class="w-10 h-10 bg-primary/10 text-primary rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    </div>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-black uppercase tracking-widest">Utilisateurs</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white mt-1">{{ userCount }}</h3>
            </div>

            <!-- Urgent Reclamations -->
            <div class="glass-card p-5 rounded-2xl border-b-4 border-red-500 hover-lift group relative overflow-hidden">
                {% if urgentCount > 0 %}
                <div class="absolute inset-0 bg-red-500/5 animate-pulse"></div>
                {% endif %}
                <div class="flex justify-between items-start mb-3 relative z-10">
                    <div class="w-10 h-10 bg-red-100 dark:bg-red-500/15 text-red-500 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    </div>
                    {% if urgentCount > 0 %}
                        <span class="badge badge-red animate-bounce">Alerte</span>
                    {% endif %}
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-black uppercase tracking-widest relative z-10">Urgences IA</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white mt-1 relative z-10">{{ urgentCount }}</h3>
            </div>

            <!-- Courses -->
            <div class="glass-card p-5 rounded-2xl border-b-4 border-secondary hover-lift group">
                <div class="flex justify-between items-start mb-3">
                    <div class="w-10 h-10 bg-secondary/10 text-secondary rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-black uppercase tracking-widest">Cours</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white mt-1">{{ courseCount }}</h3>
            </div>

            <!-- Modules -->
            <div class="glass-card p-5 rounded-2xl border-b-4 border-accent hover-lift group">
                <div class="flex justify-between items-start mb-3">
                    <div class="w-10 h-10 bg-accent/10 text-accent rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    </div>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-black uppercase tracking-widest">Modules</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white mt-1">{{ moduleCount }}</h3>
            </div>

            <!-- Reclamations -->
            <div class="glass-card p-5 rounded-2xl border-b-4 border-coral hover-lift group">
                <div class="flex justify-between items-start mb-3">
                    <div class="w-10 h-10 bg-coral/10 text-coral rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    </div>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-black uppercase tracking-widest">Réclamations</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white mt-1">{{ reclamationCount }}</h3>
            </div>

            <!-- Results -->
            <div class="glass-card p-5 rounded-2xl border-b-4 border-mint hover-lift group">
                <div class="flex justify-between items-start mb-3">
                    <div class="w-10 h-10 bg-mint/10 text-mint rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                </div>
                <p class="text-slate-500 dark:text-slate-400 text-[10px] font-black uppercase tracking-widest">Résultats</p>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white mt-1">{{ resultatCount }}</h3>
            </div>
        </section>

        <!-- Charts Section -->
        <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Registrations Chart -->
            <div class="glass-card p-6 rounded-2xl">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Croissance des Utilisateurs</h3>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">7 derniers jours</span>
                </div>
                <div class="h-[300px] w-full">
                    <canvas id="registrationChart"></canvas>
                </div>
            </div>

            <!-- Categories & Roles Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="glass-card p-6 rounded-2xl">
                    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-4 text-center">Répartition des Rôles</h3>
                    <div class="h-[200px] flex items-center justify-center">
                        <canvas id="rolesChart"></canvas>
                    </div>
                </div>
                <div class="glass-card p-6 rounded-2xl">
                    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-4 text-center">Réclamations</h3>
                    <div class="h-[200px] flex items-center justify-center">
                        <canvas id="reclamationChart"></canvas>
                    </div>
                </div>
                <div class="glass-card p-6 rounded-2xl md:col-span-2">
                    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-4">Cours par Catégorie</h3>
                    <div class="h-[200px]">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <!-- Bottom Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Recent Users -->
            <div class="lg:col-span-2 glass-card rounded-2xl p-7 overflow-hidden">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white">Recrues Récentes</h3>
                        <p class="text-slate-500 dark:text-slate-400 text-xs mt-0.5 font-medium">Les 5 derniers membres inscrits.</p>
                    </div>
                    <a href="{{ path('app_user_index') }}" class="text-primary dark:text-primary-light hover:underline font-bold text-xs transition-colors">Tout Voir →</a>
                </div>

                <div class="space-y-3">
                    {% for user in recentUsers %}
                    <div class="flex items-center gap-4 p-3 rounded-2xl hover:bg-slate-50 dark:hover:bg-white/5 transition-all group">
                        <div class="w-12 h-12 rounded-2xl gradient-primary flex items-center justify-center text-sm font-black text-white shadow-lg shadow-purple-500/10 group-hover:scale-110 transition-transform">
                            {{ user.username|first|upper }}
                        </div>
                        <div class="flex-1 flex flex-col sm:flex-row sm:items-center justify-between gap-2">
                            <div>
                                <p class="text-[0.9rem] font-black text-slate-900 dark:text-white">{{ user.username }}</p>
                                <p class="text-[0.7rem] text-slate-500 dark:text-slate-400 font-medium">{{ user.email }}</p>
                            </div>
                            <div class="flex items-center gap-3 sm:text-right">
                                <div class="hidden xs:block">
                                    <span class="badge {{ user.roles[0] == 'ROLE_ADMIN' ? 'badge-purple' : 'badge-cyan' }}">
                                        {{ user.roles[0]|replace({'ROLE_': ''})|upper }}
                                    </span>
                                </div>
                                <p class="text-[0.7rem] text-slate-400 font-semibold tabular-nums">
                                    {{ user.createdAt ? user.createdAt|date('d/m/Y') : 'N/A' }}
                                </p>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <div class="flex flex-col items-center justify-center py-12 text-center">
                        <div class="w-16 h-16 bg-slate-100 dark:bg-white/5 rounded-2xl flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        </div>
                        <p class="text-slate-500 dark:text-slate-400 font-bold text-sm">Aucun utilisateur trouvé.</p>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Quick Access -->
            <div class="space-y-6">
                <div class="gradient-primary rounded-2xl p-7 relative overflow-hidden shadow-xl shadow-purple-500/15 group">
                    <div class="relative z-10">
                        <h3 class="text-xl font-black text-white leading-tight">Gestion des <br>Cours</h3>
                        <p class="text-white/70 mt-2 text-sm font-medium">Contrôlez les contenus pédagogiques.</p>
                        <a href="{{ path('admin_course_index') }}" class="mt-5 block w-full py-3 bg-white text-primary text-center font-bold rounded-xl hover:scale-[1.02] transition-all shadow-lg text-sm">Accéder aux Cours</a>
                    </div>
                </div>

                <div class="glass-card rounded-2xl p-7">
                    <h3 class="text-base font-bold text-slate-900 dark:text-white mb-5">Raccourcis</h3>
                    <div class="grid grid-cols-2 gap-3">
                        <a href="{{ path('app_admin_reclamation_index') }}" class="p-3 bg-slate-50 dark:bg-white/5 rounded-xl text-center group">
                            <p class="text-[10px] font-bold text-slate-500 group-hover:text-primary">Soutien</p>
                        </a>
                        <a href="{{ path('app_reclamation_index') }}" class="p-3 bg-slate-50 dark:bg-white/5 rounded-xl text-center group">
                            <p class="text-[10px] font-bold text-slate-500 group-hover:text-secondary">Ma Vue</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart.js, jsPDF, jsPDF-AutoTable and SheetJS CDNs -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.2/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script>
        // PDF Export Function
        function exportToPDF(event) {
            const btn = event.currentTarget;
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path></svg>';
            btn.disabled = true;

            setTimeout(function() {
                try {
                    var jsPDF = window.jspdf.jsPDF;
                    var doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });
                    var pageW = doc.internal.pageSize.getWidth();
                    var pageH = doc.internal.pageSize.getHeight();
                    var margin = 15;
                    var y = margin;

                    doc.setFillColor(124, 58, 237);
                    doc.rect(0, 0, pageW, 28, 'F');
                    doc.setTextColor(255, 255, 255);
                    doc.setFontSize(20);
                    doc.setFont('helvetica', 'bold');
                    doc.text('SkillPath — Rapport Dashboard', margin, 18);
                    y = 36;

                    doc.autoTable({
                        startY: y,
                        margin: { left: margin, right: margin },
                        head: [['Indicateur', 'Valeur']],
                        body: [
                            ['Utilisateurs', '{{ userCount }}'],
                            ['Urgences IA', '{{ urgentCount }}'],
                            ['Cours', '{{ courseCount }}'],
                            ['Modules', '{{ moduleCount }}'],
                            ['Réclamations', '{{ reclamationCount }}'],
                            ['Résultats', '{{ resultatCount }}']
                        ],
                        theme: 'grid'
                    });

                    doc.save('SkillPath_Report.pdf');
                } catch (err) {
                    console.error(err);
                } finally {
                    btn.innerHTML = originalHTML;
                    btn.disabled = false;
                }
            }, 300);
        }

        // Excel Export Function
        function exportToExcel(event) {
            const btn = event.currentTarget;
            const originalHTML = btn.innerHTML;
            btn.innerHTML = '...';
            
            try {
                const stats = [
                    ["Indicateur", "Valeur"],
                    ["Utilisateurs", "{{ userCount }}"],
                    ["Urgences", "{{ urgentCount }}"],
                    ["Cours", "{{ courseCount }}"],
                    ["Modules", "{{ moduleCount }}"],
                    ["Réclamations", "{{ reclamationCount }}"]
                ];

                const wb = XLSX.utils.book_new();
                const ws = XLSX.utils.aoa_to_sheet(stats);
                XLSX.utils.book_append_sheet(wb, ws, "Stats");
                XLSX.writeFile(wb, "SkillPath_Export.xlsx");
            } finally {
                btn.innerHTML = originalHTML;
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const isDark = document.documentElement.classList.contains('dark');
            const textColor = isDark ? '#94A3B8' : '#64748B';
            const gridColor = isDark ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)';

            const colors = {
                primary: '#7C3AED',
                secondary: '#F59E0B',
                accent: '#06B6D4',
                coral: '#FB7185',
                mint: '#34D399',
                slate: '#64748B'
            };

            Chart.defaults.color = textColor;

            // 1. Registration Chart
            const regCtx = document.getElementById('registrationChart')?.getContext('2d');
            if (regCtx) {
                new Chart(regCtx, {
                    type: 'line',
                    data: {
                        labels: {{ registrationLabels|default([])|json_encode|raw }},
                        datasets: [{
                            label: 'Nouveaux Utilisateurs',
                            data: {{ registrationValues|default([])|json_encode|raw }},
                            borderColor: colors.primary,
                            tension: 0.4,
                            fill: true,
                            backgroundColor: 'rgba(124, 58, 237, 0.1)'
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }

            // 2. Roles Chart
            const rolesCtx = document.getElementById('rolesChart')?.getContext('2d');
            if (rolesCtx) {
                new Chart(rolesCtx, {
                    type: 'doughnut',
                    data: {
                        labels: {{ rolesLabels|default([])|json_encode|raw }},
                        datasets: [{
                            data: {{ rolesValues|default([])|json_encode|raw }},
                            backgroundColor: [colors.primary, colors.slate]
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }

            // 3. Reclamation Chart
            const recCtx = document.getElementById('reclamationChart')?.getContext('2d');
            if (recCtx) {
                new Chart(recCtx, {
                    type: 'pie',
                    data: {
                        labels: {{ reclamationLabels|default([])|json_encode|raw }},
                        datasets: [{
                            data: {{ reclamationValues|default([])|json_encode|raw }},
                            backgroundColor: [colors.coral, colors.primary, colors.mint, colors.secondary]
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }

            // 4. Category Chart
            const catCtx = document.getElementById('categoryChart')?.getContext('2d');
            if (catCtx) {
                new Chart(catCtx, {
                    type: 'bar',
                    data: {
                        labels: {{ categoriesLabels|default([])|json_encode|raw }},
                        datasets: [{
                            data: {{ categoriesValues|default([])|json_encode|raw }},
                            backgroundColor: colors.accent,
                            borderRadius: 10
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
                });
            }
        });
    </script>
{% endblock %}
