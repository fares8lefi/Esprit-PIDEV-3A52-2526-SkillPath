{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Tableau de Bord Admin - SkillPath{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .progress-bar {
        height: 4px;
        background: rgba(124,58,237,0.08);
        border-radius: 9999px;
        overflow: hidden;
    }
    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #7C3AED, #06B6D4);
        border-radius: 9999px;
        transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .stat-card {
        transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .stat-card:hover {
        transform: translateY(-4px);
    }
</style>
{% endblock %}

{% block content %}
<div class="space-y-8 animate-fade-up">

    {# ── Welcome Banner ── #}
    <section class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">
                Tableau de Bord <span class="gradient-text">Admin</span>
            </h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1 font-medium text-sm">
                Bon retour, <span class="font-bold text-slate-700 dark:text-slate-200">{{ app.user.username }}</span>. Voici l'aperçu de votre plateforme.
            </p>
        </div>
        <div class="flex gap-3">
            <a href="{{ path('app_admin_reclamation_index') }}" class="btn-secondary !py-2.5 !px-5 text-sm flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                Support
                {% if pendingCount > 0 %}
                    <span class="bg-red-500 text-white text-[9px] font-black rounded-full w-4 h-4 flex items-center justify-center">{{ pendingCount }}</span>
                {% endif %}
            </a>
            <a href="{{ path('app_user_admin_create') }}" class="btn-primary !py-2.5 !px-5 text-sm flex items-center gap-2 !rounded-xl">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                Nouvel Utilisateur
            </a>
        </div>
    </section>

    {# ── KPI Stats Grid ── #}
    <section class="grid grid-cols-2 lg:grid-cols-4 gap-5">

        {# Users #}
        <div class="stat-card glass-card p-6 rounded-2xl">
            <div class="flex justify-between items-start mb-5">
                <div class="w-11 h-11 bg-primary/8 dark:bg-primary/15 text-primary dark:text-primary-light rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                </div>
                <span class="badge badge-purple">Membres</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest">Utilisateurs Actifs</p>
            <h3 class="text-4xl font-black text-slate-900 dark:text-white mt-1">{{ userCount }}</h3>
            <div class="progress-bar mt-4"><div class="progress-bar-fill" style="width: 72%"></div></div>
        </div>

        {# Courses #}
        <div class="stat-card glass-card p-6 rounded-2xl">
            <div class="flex justify-between items-start mb-5">
                <div class="w-11 h-11 bg-accent/10 text-accent rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                </div>
                <span class="badge badge-cyan">Contenu</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest">Cours Disponibles</p>
            <h3 class="text-4xl font-black text-slate-900 dark:text-white mt-1">{{ courseCount }}</h3>
            <div class="progress-bar mt-4"><div class="progress-bar-fill" style="width: 60%"></div></div>
        </div>

        {# Modules #}
        <div class="stat-card glass-card p-6 rounded-2xl">
            <div class="flex justify-between items-start mb-5">
                <div class="w-11 h-11 bg-secondary/10 text-secondary rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                </div>
                <span class="badge badge-amber">Modules</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest">Unités d'Apprentissage</p>
            <h3 class="text-4xl font-black text-slate-900 dark:text-white mt-1">{{ moduleCount }}</h3>
            <div class="progress-bar mt-4"><div class="progress-bar-fill" style="width: 45%"></div></div>
        </div>

        {# Reclamations #}
        <div class="stat-card glass-card p-6 rounded-2xl">
            <div class="flex justify-between items-start mb-5">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center
                    {% if pendingCount > 0 %}bg-red-50 dark:bg-red-500/10 text-red-400{% else %}bg-mint/10 text-mint{% endif %}">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                </div>
                {% if pendingCount > 0 %}
                    <span class="badge badge-red">{{ pendingCount }} En attente</span>
                {% else %}
                    <span class="badge badge-green">Tout traité</span>
                {% endif %}
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest">Tickets Support</p>
            <h3 class="text-4xl font-black text-slate-900 dark:text-white mt-1">{{ reclamationCount }}</h3>
            <div class="progress-bar mt-4">
                <div class="progress-bar-fill" style="width: {{ reclamationCount > 0 ? ((resolvedCount / reclamationCount) * 100)|round : 0 }}%; background: linear-gradient(90deg, #10B981, #34D399)"></div>
            </div>
        </div>

    </section>

    {# ── Main Content Grid ── #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Recent Users Table #}
        <div class="lg:col-span-2 glass-card rounded-2xl overflow-hidden">
            <div class="flex justify-between items-center px-7 py-5 border-b border-slate-100/50 dark:border-white/5">
                <div>
                    <h3 class="text-base font-bold text-slate-900 dark:text-white">Recrues Récentes</h3>
                    <p class="text-slate-500 dark:text-slate-400 text-xs mt-0.5 font-medium">Nouveaux membres inscrits sur SkillPath.</p>
                </div>
                <a href="{{ path('app_user_index') }}" class="text-primary dark:text-primary-light hover:underline font-bold text-xs transition-colors">Voir tout →</a>
            </div>
            <div class="divide-y divide-slate-100/50 dark:divide-white/5">
                {% for user in recentUsers %}
                <div class="flex items-center gap-4 px-7 py-4 hover:bg-primary/3 dark:hover:bg-primary/5 transition-colors group">
                    <div class="w-10 h-10 rounded-xl gradient-primary flex items-center justify-center text-xs font-bold text-white shadow-md shadow-purple-500/10 flex-shrink-0 group-hover:scale-105 transition-transform">
                        {{ user.username|first|upper }}
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-slate-900 dark:text-white group-hover:text-primary dark:group-hover:text-primary-light transition-colors truncate">{{ user.username }}</p>
                        <p class="text-xs text-slate-400 font-medium truncate">{{ user.email }}</p>
                    </div>
                    <div class="text-right flex-shrink-0">
                        <span class="badge {% if user.role == 'admin' %}badge-purple{% else %}badge-cyan{% endif %} text-[9px]">
                            {{ user.role|upper }}
                        </span>
                        <p class="text-[10px] text-slate-400 mt-1 font-medium">
                            {{ user.createdAt ? user.createdAt|date('d M, H:i') : '—' }}
                        </p>
                    </div>
                </div>
                {% else %}
                <div class="px-7 py-16 text-center">
                    <p class="text-slate-400 font-medium text-sm">Aucun utilisateur enregistré.</p>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Right Column #}
        <div class="space-y-6">

            {# CTA Module Card #}
            <div class="gradient-primary rounded-2xl p-7 relative overflow-hidden shadow-xl shadow-purple-500/15 group">
                <div class="relative z-10">
                    <div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </div>
                    <h3 class="text-xl font-black text-white leading-tight">Programme<br>Maître</h3>
                    <p class="text-white/70 mt-2 text-sm font-medium">Gérez les unités d'apprentissage de la plateforme.</p>
                    <a href="{{ path('admin_module_index') }}" class="mt-5 block w-full py-3 bg-white text-primary text-center font-bold rounded-xl hover:bg-slate-50 transition-all active:scale-95 shadow-lg text-sm">
                        Gérer les Modules
                    </a>
                </div>
                <div class="absolute -right-10 -bottom-10 w-48 h-48 bg-white/5 rounded-full blur-3xl group-hover:scale-125 transition-transform duration-700"></div>
            </div>

            {# Recent Reclamations #}
            <div class="glass-card rounded-2xl overflow-hidden">
                <div class="flex justify-between items-center px-6 py-4 border-b border-slate-100/50 dark:border-white/5">
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white">Tickets Récents</h3>
                    <a href="{{ path('app_admin_reclamation_index') }}" class="text-primary dark:text-primary-light hover:underline font-bold text-xs">Gérer →</a>
                </div>
                <div class="divide-y divide-slate-100/50 dark:divide-white/5">
                    {% for reclamation in recentReclamations %}
                    <a href="{{ path('app_admin_reclamation_show', {'id': reclamation.id}) }}" class="flex items-start gap-3 px-6 py-4 hover:bg-primary/3 dark:hover:bg-primary/5 transition-colors group block">
                        <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5
                            {% if reclamation.statut|lower in ['pending', 'en attente'] %}bg-amber-50 dark:bg-amber-500/10 text-amber-500
                            {% elseif reclamation.statut|lower in ['resolved', 'résolu'] %}bg-green-50 dark:bg-green-500/10 text-green-500
                            {% else %}bg-primary/8 text-primary{% endif %}">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors truncate">{{ reclamation.sujet }}</p>
                            <p class="text-[10px] text-slate-400 font-medium truncate">{{ reclamation.user ? reclamation.user.username : 'Anonyme' }}</p>
                        </div>
                        <span class="text-[9px] font-black px-2 py-1 rounded-full flex-shrink-0
                            {% if reclamation.statut|lower in ['pending', 'en attente'] %}bg-amber-50 dark:bg-amber-500/10 text-amber-600
                            {% elseif reclamation.statut|lower in ['resolved', 'résolu'] %}bg-green-50 dark:bg-green-500/10 text-green-600
                            {% else %}bg-primary/8 text-primary{% endif %}">
                            {{ reclamation.statut }}
                        </span>
                    </a>
                    {% else %}
                    <div class="px-6 py-8 text-center">
                        <p class="text-slate-400 text-xs font-medium">Aucun ticket pour le moment.</p>
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# System Status #}
            <div class="glass-card rounded-2xl p-6">
                <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-4">Intégrité du Système</h3>
                <div class="space-y-3">
                    <div class="flex items-center justify-between p-3 bg-slate-50/50 dark:bg-white/3 rounded-xl">
                        <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Infrastructure</span>
                        <span class="flex items-center gap-1.5 text-mint text-[10px] font-bold">
                            <span class="w-1.5 h-1.5 bg-mint rounded-full animate-pulse"></span>
                            OPTIMISÉ
                        </span>
                    </div>
                    <div class="flex items-center justify-between p-3 bg-slate-50/50 dark:bg-white/3 rounded-xl">
                        <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Moteur</span>
                        <span class="text-slate-900 dark:text-white text-[10px] font-bold">SkillPath v2.1</span>
                    </div>
                    <div class="flex items-center justify-between p-3 bg-slate-50/50 dark:bg-white/3 rounded-xl">
                        <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Tickets résolus</span>
                        <span class="text-slate-900 dark:text-white text-[10px] font-bold">
                            {{ resolvedCount }} / {{ reclamationCount }}
                        </span>
                    </div>
                    <div class="flex items-center justify-between p-3 bg-slate-50/50 dark:bg-white/3 rounded-xl">
                        <span class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Date</span>
                        <span class="text-slate-900 dark:text-white text-[10px] font-bold">{{ "now"|date('d/m/Y') }}</span>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>
{% endblock %}
