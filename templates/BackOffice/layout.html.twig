{% extends 'base.html.twig' %}

{% block stylesheets %}
<style>
    /* Global Form Styles for Dark Mode */
    .dark input, .dark select, .dark textarea {
        background-color: rgba(255,255,255,0.04);
        color: #F1F5F9;
        border-color: rgba(255,255,255,0.06);
    }
    .dark input:focus, .dark select:focus, .dark textarea:focus {
        border-color: #7C3AED;
        background-color: rgba(124,58,237,0.06);
    }
</style>
{% endblock %}

{% block body %}
<div class="flex min-h-screen mesh-light dark:mesh-dark overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-72 glass border-r border-slate-200/50 dark:border-white/5 flex flex-col z-20 sticky top-0 h-screen">
        <!-- Logo -->
        <div class="p-8">
            <div class="flex items-center gap-3 group cursor-pointer">
                <div class="w-10 h-10 gradient-primary rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/20 group-hover:scale-110 transition-transform">
                    <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-6 h-6 invert brightness-0">
                </div>
                <span class="text-xl font-black tracking-tight text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-4 py-2 space-y-1">
            <p class="px-4 mb-3 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400/80 dark:text-slate-500">Navigation</p>

            <a href="{{ path('app_admin_dashboard') }}" class="sidebar-item {% if app.request.get('_route') == 'app_admin_dashboard' %}sidebar-active{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100/60 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-[0.85rem]">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                Tableau de Bord
            </a>
            <a href="{{ path('app_user_index') }}" class="sidebar-item {% if 'app_user' in app.request.get('_route') %}sidebar-active{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100/60 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-[0.85rem]">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                Annuaire des Utilisateurs
            </a>
            <a href="{{ path('admin_module_index') }}" class="sidebar-item {% if 'admin_module' in app.request.get('_route') %}sidebar-active{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100/60 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-[0.85rem]">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                Unités d'Apprentissage
            </a>
            <a href="{{ path('admin_course_index') }}" class="sidebar-item {% if 'admin_course' in app.request.get('_route') %}sidebar-active{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100/60 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-[0.85rem]">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                Système de Cours
            </a>
            <a href="{{ path('app_back_office_quiz_index') }}" class="sidebar-item {% if 'quiz' in app.request.get('_route') %}sidebar-active{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100/60 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-[0.85rem]">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                Centre d'Évaluation
            </a>
            <a href="{{ path('app_back_office_resultat_index') }}" class="sidebar-item {% if 'resultat' in app.request.get('_route') %}sidebar-active{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100/60 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-[0.85rem]">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                Journaux de Performance
            </a>
            <a href="{{ path('app_admin_reclamation_index') }}" class="sidebar-item {% if 'app_admin_reclamation' in app.request.get('_route') %}sidebar-active{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100/60 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-[0.85rem]">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                Demandes des Membres
            </a>

            <div class="pt-6 pb-3 px-4">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400/80 dark:text-slate-500">Infrastructure</p>
            </div>
            <a href="#" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-[0.85rem] text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100/60 dark:hover:bg-white/5">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Paramètres Généraux
            </a>
        </nav>

        <!-- Logout -->
        <div class="p-4 border-t border-slate-200/50 dark:border-white/5">
            <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl font-bold text-sm text-red-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-all group">
                <svg class="w-[18px] h-[18px] group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                Déconnexion
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
        <!-- Top Header -->
        <header class="h-[72px] glass border-b border-slate-200/30 dark:border-white/5 flex items-center justify-between px-8 sticky top-0 z-10">
            <!-- Search -->
            <div class="flex items-center gap-3 bg-slate-100/60 dark:bg-white/5 px-4 py-2.5 rounded-xl w-80 focus-within:ring-2 focus-within:ring-primary/20 focus-within:bg-white dark:focus-within:bg-white/8 transition-all group">
                <svg class="w-4 h-4 text-slate-400 dark:text-slate-500 group-focus-within:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="text" placeholder="Recherche Globale..." class="bg-transparent border-none focus:outline-none text-sm w-full text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600 font-medium">
            </div>

            <div class="flex items-center gap-5">
                <!-- Notifications -->
                <button class="relative p-2.5 text-slate-400 dark:text-slate-500 hover:text-primary dark:hover:text-primary-light rounded-xl hover:bg-primary/5 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-coral rounded-full ring-2 ring-white dark:ring-[#0B0F1A]"></span>
                </button>
                
                <div class="h-6 w-px bg-slate-200/50 dark:bg-white/5"></div>

                <!-- User -->
                <div class="flex items-center gap-3 group cursor-pointer">
                    <div class="text-right">
                        <p class="text-xs font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">{{ app.user.username|default('Platform Admin') }}</p>
                        <p class="text-[10px] text-slate-400 dark:text-slate-500 font-semibold uppercase tracking-wider">Administrateur</p>
                    </div>
                    <div class="w-10 h-10 rounded-xl gradient-primary flex items-center justify-center text-white font-black text-sm shadow-lg shadow-purple-500/20 group-hover:scale-105 group-hover:shadow-purple-500/30 transition-all">
                        {{ app.user.username|default('A')|first|upper }}
                    </div>
                </div>
            </div>
        </header>

        <div class="p-8 animate-fade-up">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
{% endblock %}
