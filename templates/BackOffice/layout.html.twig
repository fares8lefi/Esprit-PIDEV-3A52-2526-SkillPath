{% extends 'base.html.twig' %}

{% block stylesheets %}
<style>
    .glass {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }
    .dark .glass {
        background: rgba(23, 23, 23, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .glass-card {
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(0, 0, 0, 0.05);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .dark .glass-card {
        background: rgba(38, 38, 38, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .glass-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px -10px rgba(0,0,0,0.1);
    }
    .dark .glass-card:hover {
        background: rgba(38, 38, 38, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .vibrant-gradient {
        background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
    }
    .vibrant-text {
        background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .sidebar-item {
        transition: all 0.2s;
    }
    .sidebar-active {
        background: rgba(30, 136, 229, 0.1);
        border-right: 3px solid #1E88E5;
        color: #1E88E5;
    }
    
    /* Global Form Styles for Dark Mode */
    .dark input, .dark select, .dark textarea {
        background-color: rgba(23, 23, 23, 0.5);
        color: #f8fafc; /* slate-50 */
        border-color: rgba(255, 255, 255, 0.1);
    }
    .dark input::placeholder, .dark textarea::placeholder {
        color: #94a3b8; /* slate-400 */
    }
    .dark input:focus, .dark select:focus, .dark textarea:focus {
        border-color: #1E88E5;
        background-color: rgba(30, 136, 229, 0.05);
    }
    
    /* Autofill Fix */
    input:-webkit-autofill,
    input:-webkit-autofill:hover, 
    input:-webkit-autofill:focus, 
    input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px white inset !important;
        -webkit-text-fill-color: #0f172a !important;
    }
    .dark input:-webkit-autofill,
    .dark input:-webkit-autofill:hover, 
    .dark input:-webkit-autofill:focus, 
    .dark input:-webkit-autofill:active{
        -webkit-box-shadow: 0 0 0 30px #020617 inset !important;
        -webkit-text-fill-color: white !important;
    }
</style>
{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-200 overflow-hidden transition-colors duration-300">
    <!-- Sidebar -->
    <aside class="w-72 glass border-r border-slate-200 dark:border-slate-800/5 flex flex-col z-20 sticky top-0 h-screen">
        <div class="p-8">
            <div class="flex items-center gap-3">
                <img src="{{ asset('images/logo.png') }}" alt="Logo" class="h-10 w-auto">
                <span class="text-2xl font-black tracking-tight text-slate-900 dark:text-white">SkillPath</span>
            </div>
        </div>

        <nav class="flex-1 px-4 py-4 space-y-2">
            <a href="{{ path('app_admin_dashboard') }}" class="sidebar-item {% if app.request.get('_route') == 'app_admin_dashboard' %}sidebar-active text-skillpath-blue{% else %}text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Dashboard
            </a>
            <a href="{{ path('app_user_index') }}" class="sidebar-item {% if 'app_user' in app.request.get('_route') %}sidebar-active text-skillpath-blue{% else %}text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                Utilisateurs
            </a>
            <a href="{{ path('module_list') }}" class="sidebar-item {% if 'module' in app.request.get('_route') %}sidebar-active text-skillpath-blue{% else %}text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                Modules
            </a>
            <a href="{{ path('admin_cours_list') }}" class="sidebar-item {% if 'cours' in app.request.get('_route') %}sidebar-active text-skillpath-blue{% else %}text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5{% endif %} flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                Cours
            </a>
            
            <div class="pt-8 pb-4 px-4">
                <span class="text-xs font-black uppercase tracking-widest text-slate-400 dark:text-neutral-500">Système</span>
            </div>
            <a href="#" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl font-medium text-slate-500 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Paramètres
            </a>
        </nav>

        <div class="p-4 border-t border-slate-200 dark:border-neutral-800/50">
            <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl font-black text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 transition-all group uppercase text-xs tracking-widest">
                <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                Déconnexion
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
        <!-- Top Header -->
        <header class="h-20 glass border-b border-slate-200 dark:border-neutral-800/50 flex items-center justify-between px-8 sticky top-0 z-10">
            <div class="flex items-center gap-4 bg-slate-100 dark:bg-neutral-900/50 border border-slate-200 dark:border-neutral-800 px-4 py-2 rounded-2xl w-96 focus-within:border-skillpath-blue/50 focus-within:ring-1 focus-within:ring-skillpath-blue/20 transition-all group">
                <svg class="w-5 h-5 text-slate-400 dark:text-neutral-500 group-focus-within:text-skillpath-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="text" placeholder="Rechercher..." class="bg-transparent border-none focus:outline-none text-sm w-full text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-neutral-600 font-medium">
            </div>

            <div class="flex items-center gap-6">
                <button class="relative p-2 text-slate-400 dark:text-neutral-400 hover:text-slate-900 dark:hover:text-white transition-all hover:scale-110">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-skillpath-blue rounded-full border-2 border-slate-50 dark:border-[#0A0A0A]"></span>
                </button>
                <div class="h-8 w-[1px] bg-slate-200 dark:bg-neutral-800"></div>
                <div class="flex items-center gap-3 group cursor-pointer">
                    <div class="text-right">
                        <p class="text-xs font-black text-slate-900 dark:text-white group-hover:text-skillpath-blue transition-colors">{{ app.user.username|default('Admin') }}</p>
                        <p class="text-[10px] text-slate-400 dark:text-neutral-500 uppercase tracking-widest font-black">Administrateur</p>
                    </div>
                    <div class="w-10 h-10 rounded-xl vibrant-gradient flex items-center justify-center text-white font-black text-lg shadow-lg shadow-blue-500/20 group-hover:scale-105 transition-transform">
                        {{ app.user.username|default('A')|first|upper }}
                    </div>
                </div>
            </div>
        </header>

        <div class="p-8">
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
{% endblock %}
