{% extends 'BackOffice/layout.html.twig' %}

{% block title %}{{ location.name }} - SkillPath{% endblock %}

{% block content %}
<div class="space-y-8 animate-in fade-in duration-500">
    <div class="flex items-center gap-4 mb-2">
        <a href="{{ path('admin_location_list') }}" class="p-2 rounded-xl hover:bg-slate-100 dark:hover:bg-white/5 transition-all">
            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <h1 class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight">{{ location.name }}</h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1 font-medium">ID: #{{ location.id }}</p>
        </div>
    </div>

    <div class="glass-card rounded-[2rem] p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Bâtiment -->
            <div>
                <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Bâtiment</h3>
                <p class="font-bold text-slate-900 dark:text-white">{{ location.building|default('Non spécifié') }}</p>
            </div>

            <!-- Salle -->
            <div>
                <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Numéro de salle</h3>
                <span class="badge badge-purple">{{ location.roomNumber }}</span>
            </div>

            <!-- Capacité -->
            <div>
                <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Capacité maximale</h3>
                <span class="badge badge-amber">{{ location.maxCapacity }} places</span>
            </div>

            <!-- Événements associés -->
            <div>
                <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Événements</h3>
                <span class="badge badge-green">{{ location.events|length }} événement{{ location.events|length > 1 ? 's' : '' }}</span>
            </div>
        </div>

        <!-- Image -->
        {% if location.image %}
        <div class="mt-8 pt-6 border-t border-slate-200/50 dark:border-white/5">
            <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-3">Image</h3>
            <img src="{{ asset('uploads/locations/' ~ location.image) }}" class="max-w-md h-auto rounded-2xl shadow-sm" alt="{{ location.name }}">
        </div>
        {% endif %}

        <!-- Liste des événements -->
        {% if location.events|length > 0 %}
        <div class="mt-8 pt-6 border-t border-slate-200/50 dark:border-white/5">
            <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-4">Événements dans ce lieu</h3>
            <div class="space-y-3">
                {% for event in location.events %}
                    <div class="flex items-center justify-between p-4 bg-slate-50/50 dark:bg-white/5 rounded-xl">
                        <div class="flex items-center gap-4">
                            <span class="w-8 h-8 flex items-center justify-center bg-primary/10 text-primary rounded-lg font-bold text-xs">{{ loop.index }}</span>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white text-sm">{{ event.title }}</h4>
                                <p class="text-xs text-slate-400">{{ event.eventDate ? event.eventDate|date('d/m/Y') : '' }}</p>
                            </div>
                        </div>
                        <a href="{{ path('admin_event_show', {id: event.id}) }}" class="p-2 text-slate-400 hover:text-primary transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Actions -->
        <div class="flex gap-4 pt-8 mt-8 border-t border-slate-200/50 dark:border-white/5">
            <a href="{{ path('admin_location_list') }}" class="btn-secondary">
                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Retour
            </a>
            <a href="{{ path('admin_location_edit', {id: location.id}) }}" class="btn-primary">
                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Modifier
            </a>
        </div>
    </div>
</div>
{% endblock %}
