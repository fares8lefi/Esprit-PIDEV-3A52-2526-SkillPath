{% extends 'base.html.twig' %}

{% block title %}{{ cours.titre }} - SkillPath{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
        }
        
        .gradient-text {
            background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'skillpath-blue': '#1E88E5',
                        'skillpath-blue-dark': '#1565C0',
                        'skillpath-green': '#43A047',
                        'skillpath-green-dark': '#2E7D32',
                    }
                }
            }
        }
    </script>
{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gray-50 py-8">
        <div class="container mx-auto px-4">
            
            <!-- Breadcrumb -->
            <nav class="mb-6">
                <ol class="flex items-center space-x-2 text-sm">
                    <li>
                        <a href="{{ path('admin_cours_list') }}" class="text-gray-500 hover:text-gray-700">
                            Tableau de bord
                        </a>
                    </li>
                    <li class="text-gray-400">/</li>
                    <li>
                        <a href="{{ path('admin_cours_list') }}" class="text-gray-500 hover:text-gray-700">
                            Gestion des cours
                        </a>
                    </li>
                    <li class="text-gray-400">/</li>
                    <li class="text-gray-900 font-medium">Détails</li>
                </ol>
            </nav>
            
            <div class="max-w-4xl mx-auto">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                    
                    <!-- Header -->
                    <div class="bg-gradient-to-r from-skillpath-blue to-skillpath-blue-dark px-8 py-6">
                        <div class="flex items-center justify-between">
                            <h1 class="text-2xl font-bold text-white">{{ cours.titre }}</h1>
                            <span class="px-4 py-2 bg-white bg-opacity-20 text-white rounded-lg text-sm font-medium">
                                ID: #{{ cours.id }}
                            </span>
                        </div>
                    </div>

                    <div class="p-8 space-y-6">
                        
                        <!-- Informations principales -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-2">Type</h3>
                                {% set typeConfig = {
                                    'video': { icon: '📹', color: 'bg-blue-100 text-blue-700', label: 'Vidéo' },
                                    'texte': { icon: '📝', color: 'bg-green-100 text-green-700', label: 'Texte' },
                                    'quiz': { icon: '🎓', color: 'bg-purple-100 text-purple-700', label: 'Quiz' },
                                    'exercice': { icon: '💻', color: 'bg-yellow-100 text-yellow-700', label: 'Exercice' },
                                    'document': { icon: '📄', color: 'bg-gray-100 text-gray-700', label: 'Document' }
                                } %}
                                
                                {% set type = typeConfig[cours.type] ?? { icon: '📄', color: 'bg-gray-100 text-gray-700', label: cours.type } %}
                                
                                <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium {{ type.color }}">
                                    <span>{{ type.icon }}</span>
                                    <span>{{ type.label }}</span>
                                </span>
                            </div>

                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-2">Module</h3>
                                <p class="text-gray-900 font-medium">{{ cours.module.name }}</p>
                            </div>

                            <div>
                                <h3 class="text-sm font-semibold text-gray-600 mb-2">Créé le</h3>
                                <p class="text-gray-900">{{ cours.createdAt|date('d/m/Y à H:i') }}</p>
                            </div>
                        </div>

                        {% if cours.updatedAt %}
                            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                                <div class="flex items-center gap-2">
                                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    <span class="text-sm text-blue-800">
                                        Dernière modification le {{ cours.updatedAt|date('d/m/Y à H:i') }}
                                    </span>
                                </div>
                            </div>
                        {% endif %}

                        <!-- Contenu -->
                        <div class="border-t border-gray-200 pt-6">
                            <h3 class="text-sm font-semibold text-gray-600 mb-3">Contenu</h3>
                            <div class="bg-gray-50 rounded-lg p-6">
                                <p class="text-gray-900 whitespace-pre-wrap">{{ cours.contenu }}</p>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex gap-4 pt-6 border-t border-gray-200">
                            <a href="{{ path('admin_cours_list') }}" class="px-6 py-3 border-2 border-gray-300 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 transition-all">
                                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                                </svg>
                                Retour à la liste
                            </a>
                            <a href="{{ path('admin_cours_edit', {id: cours.id}) }}" class="px-6 py-3 bg-gradient-to-r from-skillpath-green to-skillpath-green-dark text-white rounded-xl font-semibold hover:shadow-lg transition-all">
                                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                                Modifier
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}