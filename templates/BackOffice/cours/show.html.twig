{% extends 'base.html.twig' %}

{% block title %}{{ cours.titre }} - SkillPath{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .gradient-text {
            background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gray-50 flex">
        <!-- Sidebar -->
        {% include 'BackOffice/_sidebar.html.twig' %}

        <!-- Main Content -->
        <div class="lg:ml-72 flex-1">
            <div class="p-8">
                
                <!-- Breadcrumb -->
                <nav class="mb-6">
                    <ol class="flex items-center space-x-2 text-sm">
                        <li>
                            <a href="{{ path('admin_cours_list') }}" class="text-gray-500 hover:text-gray-700">
                                Tableau de bord
                            </a>
                        </li>
                        <li class="text-gray-400">/</li>
                        <li>
                            <a href="{{ path('admin_cours_list') }}" class="text-gray-500 hover:text-gray-700">
                                Gestion des cours
                            </a>
                        </li>
                        <li class="text-gray-400">/</li>
                        <li class="text-gray-900 font-medium">Détails</li>
                    </ol>
                </nav>
                
                <div class="max-w-4xl mx-auto">
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                        
                        <!-- Header -->
                        <div class="bg-gradient-to-r from-brand-blue to-brand-blue-dark px-8 py-6">
                            <div class="flex items-center justify-between">
                                <h1 class="text-2xl font-bold text-white">{{ cours.titre }}</h1>
                                <span class="px-4 py-2 bg-white bg-opacity-20 text-white rounded-lg text-sm font-medium">
                                    ID: #{{ cours.id }}
                                </span>
                            </div>
                        </div>

                        <div class="p-8 space-y-6">
                            
                            <!-- Informations principales -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <h3 class="text-sm font-semibold text-gray-600 mb-2">Niveau</h3>
                                    <span class="px-4 py-2 bg-blue-100 text-blue-700 rounded-lg text-sm font-medium">
                                        {{ cours.level }}
                                    </span>
                                </div>

                                <div>
                                    <h3 class="text-sm font-semibold text-gray-600 mb-2">Catégorie</h3>
                                    <span class="px-4 py-2 bg-purple-100 text-purple-700 rounded-lg text-sm font-medium">
                                        {{ cours.categorie|default('N/A') }}
                                    </span>
                                </div>

                                <div>
                                    <h3 class="text-sm font-semibold text-gray-600 mb-2">Créé le</h3>
                                    <p class="text-gray-900">{{ cours.createdAt|date('d/m/Y à H:i') }}</p>
                                </div>
                            </div>

                            <!-- Description -->
                            <div class="border-t border-gray-100 pt-6">
                                <h3 class="text-sm font-semibold text-gray-600 mb-3">Description</h3>
                                <div class="bg-gray-50 rounded-xl p-6 text-gray-700 leading-relaxed">
                                    {{ cours.description ? cours.description|nl2br : 'Aucune description.' }}
                                </div>
                            </div>

                            <!-- Image -->
                            {% if cours.image %}
                            <div class="border-t border-gray-100 pt-6">
                                <h3 class="text-sm font-semibold text-gray-600 mb-3">Image de la formation</h3>
                                <img src="{{ asset('uploads/modules/' ~ cours.image) }}" class="max-w-md h-auto rounded-2xl shadow-sm border border-gray-200" alt="{{ cours.titre }}">
                            </div>
                            {% endif %}

                            <!-- Modules -->
                            <div class="border-t border-gray-100 pt-6">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-lg font-bold text-gray-900">Chapitres / Modules ({{ cours.modules|length }})</h3>
                                    <a href="{{ path('admin_module_new') }}" class="text-sm text-brand-blue font-semibold hover:underline">
                                        + Ajouter un module
                                    </a>
                                </div>
                                
                                {% if cours.modules is empty %}
                                    <div class="p-4 bg-gray-50 border border-dashed border-gray-300 rounded-xl text-center text-gray-500 italic">
                                        Aucun module associé pour le moment.
                                    </div>
                                {% else %}
                                    <div class="space-y-3">
                                        {% for module in cours.modules %}
                                            <div class="flex items-center justify-between p-4 bg-white border border-gray-200 rounded-xl hover:shadow-md transition-all">
                                                <div class="flex items-center gap-4">
                                                    <span class="w-8 h-8 flex items-center justify-center bg-gray-100 text-gray-600 rounded-lg font-bold text-xs">{{ loop.index }}</span>
                                                    <div>
                                                        <h4 class="font-bold text-gray-900">{{ module.name }}</h4>
                                                        <p class="text-xs text-gray-500 uppercase">{{ module.type }}</p>
                                                    </div>
                                                </div>
                                                <a href="{{ path('admin_module_show', {id: module.id}) }}" class="p-2 text-gray-400 hover:text-brand-blue transition-all">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                                    </svg>
                                                </a>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>

                            <!-- Actions -->
                            <div class="flex gap-4 pt-6 border-t border-gray-200">
                                <a href="{{ path('admin_cours_list') }}" class="px-6 py-3 border-2 border-gray-300 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 transition-all text-center">
                                    <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                                    </svg>
                                    Retour à la liste
                                </a>
                                <a href="{{ path('admin_cours_edit', {id: cours.id}) }}" class="px-6 py-3 bg-gradient-to-r from-brand-green to-brand-green-dark text-white rounded-xl font-semibold hover:shadow-lg transition-all text-center">
                                    <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                    Modifier
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}