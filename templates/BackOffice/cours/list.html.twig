{% extends 'base.html.twig' %}

{% block title %}Gestion des cours{% endblock %}

{% block body %}

<div class="p-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-gray-800">
            📚 Gestion des cours
        </h1>

        <a href="{{ path('cours_new') }}"
           class="px-5 py-3 bg-green-600 text-white rounded-lg shadow hover:bg-green-700 transition">
            ➕ Ajouter un cours
        </a>
    </div>

    <!-- Table -->
    <div class="bg-white shadow rounded-xl overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-100 border-b">
                <tr>
                    <th class="p-4 text-left">ID</th>
                    <th class="p-4 text-left">Titre</th>
                    <th class="p-4 text-left">Contenu</th>
                    <th class="p-4 text-left">Type</th>
                    <th class="p-4 text-right">Actions</th>
                </tr>
            </thead>

            <tbody>
            {% for c in cours %}
                <tr class="border-b hover:bg-gray-50">
                    <td class="p-4 font-bold text-blue-600">
                        #{{ c.id }}
                    </td>

                    <td class="p-4">
                        {{ c.titre }}
                    </td>

                    <td class="p-4">
                        {{ c.contenu }}
                    </td>

                    <td class="p-4">
                        {{ c.type }}
                    </td>

                    <td class="p-4 text-right space-x-3">
                        <!-- Edit -->
                        <a href="{{ path('cours_edit', {'id': c.id}) }}"
                           class="text-blue-600 hover:underline">
                           ✏ Modifier
                        </a>

                        <!-- Delete -->
                        <a href="{{ path('cours_delete', {'id': c.id}) }}"
                           class="text-red-600 hover:underline"
                           onclick="return confirm('Supprimer ce cours ?')">
                           🗑 Supprimer
                        </a>
                    </td>
                </tr>

            {% else %}
                <tr>
                    <td colspan="5" class="p-6 text-center text-gray-500">
                        Aucun cours disponible
                    </td>
                </tr>
            {% endfor %}
            </tbody>

        </table>
    </div>

</div>

{% endblock %}
