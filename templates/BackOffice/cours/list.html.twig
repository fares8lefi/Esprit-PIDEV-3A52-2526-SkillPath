{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Gestion du Contenu des Cours - SkillPath{% endblock %}

{% block content %}
<div class="space-y-8 animate-in fade-in duration-500">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-extrabold text-white tracking-tight">Gestion des <span class="vibrant-text">Cours</span></h1>
            <p class="text-neutral-500 mt-2 font-medium">Gérez le contenu pédagogique et les supports de cours.</p>
        </div>
        <a href="{{ path('admin_cours_new') }}" class="px-6 py-3 vibrant-gradient rounded-2xl text-sm font-bold text-white shadow-lg shadow-skill-blue/25 flex items-center gap-2 transform hover:scale-105 active:scale-95 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Nouveau contenu
        </a>
    </div>

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="bg-green-500/10 border border-green-500/20 text-green-400 px-6 py-4 rounded-2xl flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="font-medium">{{ message }}</span>
        </div>
    {% endfor %}

    <!-- Filters -->
    <div class="glass-card p-6 rounded-3xl border border-neutral-800/50">
        <form method="get" action="{{ path('admin_cours_list') }}" class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="md:col-span-2">
                <label class="block text-xs font-black text-neutral-500 uppercase tracking-widest mb-3">Rechercher</label>
                <div class="relative group">
                    <input type="text" name="search" value="{{ app.request.get('search') }}" placeholder="Titre, contenu..." class="w-full bg-neutral-900/50 border border-neutral-800 text-white rounded-xl py-3 pl-12 pr-4 focus:outline-none focus:border-skillpath-blue/50 focus:ring-1 focus:ring-skillpath-blue/20 transition-all group-hover:border-neutral-700">
                    <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-neutral-500 group-focus-within:text-skillpath-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
            </div>
            
            <div>
                <label class="block text-xs font-black text-neutral-500 uppercase tracking-widest mb-3">Module</label>
                <select name="module" class="w-full bg-neutral-900/50 border border-neutral-800 text-white rounded-xl py-3 px-4 focus:outline-none focus:border-skillpath-blue/50 transition-all appearance-none cursor-pointer">
                    <option value="">Tous les modules</option>
                    {% for module in modules %}
                        <option value="{{ module.id }}" {% if app.request.get('module') == module.id %}selected{% endif %}>{{ module.name }}</option>
                    {% endfor %}
                </select>
            </div>
            
            <div>
                <label class="block text-xs font-black text-neutral-500 uppercase tracking-widest mb-3">Type</label>
                <select name="type" class="w-full bg-neutral-900/50 border border-neutral-800 text-white rounded-xl py-3 px-4 focus:outline-none focus:border-skillpath-blue/50 transition-all appearance-none cursor-pointer">
                    <option value="">Tous les types</option>
                    <option value="video" {% if app.request.get('type') == 'video' %}selected{% endif %}>📹 Vidéo</option>
                    <option value="texte" {% if app.request.get('type') == 'texte' %}selected{% endif %}>📝 Texte</option>
                    <option value="quiz" {% if app.request.get('type') == 'quiz' %}selected{% endif %}>🎓 Quiz</option>
                    <option value="exercice" {% if app.request.get('type') == 'exercice' %}selected{% endif %}>💻 Exercice</option>
                    <option value="document" {% if app.request.get('type') == 'document' %}selected{% endif %}>📄 Document</option>
                </select>
            </div>
            <button type="submit" class="hidden">Filtrer</button>
        </form>
    </div>

    <!-- cours Table -->
    <div class="glass-card rounded-[2.5rem] overflow-hidden border border-neutral-800/50">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-neutral-800/50">
                        <th class="px-8 py-6 text-xs font-black text-neutral-500 uppercase tracking-widest">Contenu</th>
                        <th class="px-8 py-6 text-xs font-black text-neutral-500 uppercase tracking-widest">Type</th>
                        <th class="px-8 py-6 text-xs font-black text-neutral-500 uppercase tracking-widest">Module</th>
                        <th class="px-8 py-6 text-xs font-black text-neutral-500 uppercase tracking-widest text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-neutral-800/30">
                    {% for item in cours %}
                    <tr class="hover:bg-white/[0.02] transition-colors group">
                        <td class="px-8 py-6">
                            <div class="text-white font-bold group-hover:text-skillpath-blue transition-colors">{{ item.titre }}</div>
                            <div class="text-neutral-500 text-xs mt-1 max-w-md truncate">{{ item.contenu }}</div>
                        </td>
                        <td class="px-8 py-6">
                            {% set typeConfig = {
                                'video': { icon: '📹', color: 'bg-blue-500/10 text-blue-400 border-blue-500/20', label: 'Vidéo' },
                                'texte': { icon: '📝', color: 'bg-green-500/10 text-green-400 border-green-500/20', label: 'Texte' },
                                'quiz': { icon: '🎓', color: 'bg-purple-500/10 text-purple-400 border-purple-500/20', label: 'Quiz' },
                                'exercice': { icon: '💻', color: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20', label: 'Exercice' },
                                'document': { icon: '📄', color: 'bg-neutral-500/10 text-neutral-400 border-neutral-500/20', label: 'Document' }
                            } %}
                            {% set type = typeConfig[item.type] ?? { icon: '📄', color: 'bg-neutral-500/10 text-neutral-400', label: item.type } %}
                            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-xl text-[10px] font-black uppercase tracking-wider border {{ type.color }}">
                                {{ type.icon }} {{ type.label }}
                            </span>
                        </td>
                        <td class="px-8 py-6">
                            <span class="text-sm font-medium text-neutral-400">
                                {{ item.module.name|default('N/A') }}
                            </span>
                        </td>
                        <td class="px-8 py-6 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('admin_cours_show', {id: item.id}) }}" class="p-2.5 bg-neutral-800/50 text-neutral-400 hover:text-white hover:bg-neutral-800 rounded-xl transition-all border border-neutral-700/50" title="Voir">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                                <a href="{{ path('admin_cours_edit', {id: item.id}) }}" class="p-2.5 bg-neutral-800/50 text-neutral-400 hover:text-skillpath-green hover:bg-skillpath-green/10 rounded-xl transition-all border border-neutral-700/50" title="Modifier">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                                    </svg>
                                </a>
                                <button onclick="deletecours({{ item.id }}, '{{ csrf_token('delete' ~ item.id) }}')" class="p-2.5 bg-neutral-800/50 text-neutral-400 hover:text-red-500 hover:bg-red-500/10 rounded-xl transition-all border border-neutral-700/50" title="Supprimer">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="px-8 py-20 text-center">
                            <div class="w-20 h-20 bg-neutral-800/50 rounded-full flex items-center justify-center mx-auto mb-6 border border-neutral-700/50">
                                <svg class="w-10 h-10 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            </div>
                            <h3 class="text-xl font-bold text-white">Aucun contenu pédagogique</h3>
                            <p class="text-neutral-500 mt-2 mb-8">Déterminez les leçons et les supports de cours ici.</p>
                            <a href="{{ path('admin_cours_new') }}" class="px-8 py-3 vibrant-gradient rounded-2xl text-sm font-bold text-white shadow-lg shadow-skillpath-blue/25 transition-all">
                                Ajouter un contenu
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        
        <!-- Pagination logic could go here if needed, following same style -->
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="glass-card rounded-[2.5rem] shadow-2xl max-w-md w-full border border-neutral-800 animate-in zoom-in duration-300">
        <div class="p-10 text-center">
            <div class="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-red-500/20 text-red-500">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">Confirmer la suppression</h3>
            <p class="text-neutral-500 mb-10">Cette action est irréversible. Voulez-vous vraiment supprimer ce contenu ?</p>
            
            <form id="deleteForm" method="post" action="">
                <input type="hidden" name="_token" id="deleteToken" value="">
                <div class="flex gap-4">
                    <button type="button" onclick="closeDeleteModal()" class="flex-1 px-6 py-4 bg-neutral-800 text-white rounded-2xl font-bold hover:bg-neutral-700 transition-all border border-white/5">
                        Annuler
                    </button>
                    <button type="submit" class="flex-1 px-6 py-4 bg-red-600 text-white rounded-2xl font-bold hover:bg-red-700 transition-all shadow-lg shadow-red-600/20">
                        Supprimer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    function deletecours(id, csrfToken) {
        const deleteForm = document.getElementById('deleteForm');
        deleteForm.action = "/admin/cours/" + id;
        document.getElementById('deleteToken').value = csrfToken;
        document.getElementById('deleteModal').classList.remove('hidden');
    }
    
    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.add('hidden');
    }

    // Auto-submit filters on change
    document.querySelectorAll('select[name="module"], select[name="type"]').forEach(select => {
        select.addEventListener('change', function() {
            this.closest('form').submit();
        });
    });
    
    // Search with debounce
    let searchTimeout;
    const searchInput = document.querySelector('input[name="search"]');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                this.closest('form').submit();
            }, 500);
        });
    }
</script>
{% endblock %}
