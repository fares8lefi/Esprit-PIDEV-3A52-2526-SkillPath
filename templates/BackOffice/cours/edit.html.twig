{% extends 'base.html.twig' %}

{% block title %}Modifier {{ cours.titre }} - SkillPath{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
        }
        
        .gradient-text {
            background: linear-gradient(135deg, #1E88E5 0%, #43A047 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'skillpath-blue': '#1E88E5',
                        'skillpath-blue-dark': '#1565C0',
                        'skillpath-green': '#43A047',
                        'skillpath-green-dark': '#2E7D32',
                    }
                }
            }
        }
    </script>
{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gray-50 py-8">
        <div class="container mx-auto px-4">
            
            <!-- Breadcrumb -->
            <nav class="mb-6">
                <ol class="flex items-center space-x-2 text-sm">
                    <li>
                        <a href="{{ path('admin_cours_list') }}" class="text-gray-500 hover:text-gray-700">
                            Tableau de bord
                        </a>
                    </li>
                    <li class="text-gray-400">/</li>
                    <li>
                        <a href="{{ path('admin_cours_list') }}" class="text-gray-500 hover:text-gray-700">
                            Gestion des cours
                        </a>
                    </li>
                    <li class="text-gray-400">/</li>
                    <li class="text-gray-900 font-medium">Modifier</li>
                </ol>
            </nav>
            
            <div class="max-w-3xl mx-auto">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
                    
                    <!-- Header -->
                    <div class="mb-8 pb-6 border-b border-gray-200">
                        <div class="flex items-center justify-between">
                            <div>
                                <h1 class="text-3xl font-bold gradient-text">Modifier le contenu</h1>
                                <p class="text-gray-600 mt-2">{{ cours.titre }}</p>
                            </div>
                            <span class="px-4 py-2 bg-blue-100 text-blue-700 rounded-lg text-sm font-medium">
                                ID: #{{ cours.id }}
                            </span>
                        </div>
                    </div>

                    <!-- Informations supplémentaires -->
                    <div class="mb-6 p-4 bg-gray-50 rounded-lg">
                        <div class="grid grid-cols-2 gap-4 text-sm">
                            <div>
                                <span class="text-gray-600">Créé le:</span>
                                <span class="font-medium ml-2">{{ cours.createdAt|date('d/m/Y à H:i') }}</span>
                            </div>
                            {% if cours.updatedAt %}
                                <div>
                                    <span class="text-gray-600">Modifié le:</span>
                                    <span class="font-medium ml-2">{{ cours.updatedAt|date('d/m/Y à H:i') }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
                        
                        <!-- Titre -->
                        <div>
                            {{ form_label(form.titre, null, {
                                'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'},
                                'label_html': true,
                                'label': 'Titre <span class="text-red-500">*</span>'
                            }) }}
                            {{ form_widget(form.titre) }}
                            <div class="mt-1">
                                {{ form_errors(form.titre) }}
                            </div>
                        </div>

                        <!-- Type -->
                        <div>
                            {{ form_label(form.type, null, {
                                'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'},
                                'label_html': true,
                                'label': 'Type de contenu <span class="text-red-500">*</span>'
                            }) }}
                            {{ form_widget(form.type) }}
                            <div class="mt-1">
                                {{ form_errors(form.type) }}
                            </div>
                        </div>

                        <!-- Module -->
                        <div>
                            {{ form_label(form.module, null, {
                                'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'},
                                'label_html': true,
                                'label': 'Module <span class="text-red-500">*</span>'
                            }) }}
                            {{ form_widget(form.module) }}
                            <div class="mt-1">
                                {{ form_errors(form.module) }}
                            </div>
                        </div>

                        <!-- Contenu -->
                        <div>
                            {{ form_label(form.contenu, null, {
                                'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'},
                                'label_html': true,
                                'label': 'Contenu <span class="text-red-500">*</span>'
                            }) }}
                            {{ form_widget(form.contenu) }}
                            <p class="mt-2 text-xs text-gray-500">
                                <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                Pour les vidéos, insérer l'URL. Pour les documents, insérer le chemin du fichier.
                            </p>
                            <div class="mt-1">
                                {{ form_errors(form.contenu) }}
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex gap-4 pt-6 border-t border-gray-200">
                            <a href="{{ path('admin_cours_list') }}" class="flex-1 px-6 py-3 border-2 border-gray-300 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 transition-all text-center">
                                Annuler
                            </a>
                            <button type="submit" class="flex-1 px-6 py-3 bg-gradient-to-r from-skillpath-green to-skillpath-green-dark text-white rounded-xl font-semibold hover:shadow-lg transition-all">
                                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                                Enregistrer les modifications
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <style>
        /* Style pour les erreurs de formulaire */
        .form-error-message {
            color: #dc2626;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        
        .form-error-icon {
            color: #dc2626;
        }
        
        /* Style pour les champs en erreur */
        .is-invalid {
            border-color: #dc2626 !important;
        }
    </style>
{% endblock %}