{% extends 'base.html.twig' %}

{% block title %}New Quiz{% endblock %}

{% block body %}
    <div class="container mx-auto p-4">
        <h1 class="text-2xl font-bold mb-4">Create new Quiz</h1>

        {{ form_start(form, {'attr': {'class': 'max-w-lg'}}) }}
            <div class="mb-4">
                {{ form_label(form.titre, null, {'label_attr': {'class': 'block text-white text-sm font-bold mb-2'}}) }}
                {{ form_widget(form.titre, {'attr': {'class': 'shadow appearance-none border border-gray-600 rounded w-full py-2 px-3 text-white bg-gray-800 leading-tight focus:outline-none focus:shadow-outline'}}) }}
                {{ form_errors(form.titre) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.description, null, {'label_attr': {'class': 'block text-white text-sm font-bold mb-2'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'shadow appearance-none border border-gray-600 rounded w-full py-2 px-3 text-white bg-gray-800 leading-tight focus:outline-none focus:shadow-outline'}}) }}
                {{ form_errors(form.description) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.duree, null, {'label_attr': {'class': 'block text-white text-sm font-bold mb-2'}}) }}
                {{ form_widget(form.duree, {'attr': {'class': 'shadow appearance-none border border-gray-600 rounded w-full py-2 px-3 text-white bg-gray-800 leading-tight focus:outline-none focus:shadow-outline'}}) }}
                {{ form_errors(form.duree) }}
            </div>
            <div class="mb-4">
                {{ form_label(form.noteMax, null, {'label_attr': {'class': 'block text-white text-sm font-bold mb-2'}}) }}
                {{ form_widget(form.noteMax, {'attr': {'class': 'shadow appearance-none border border-gray-600 rounded w-full py-2 px-3 text-white bg-gray-800 leading-tight focus:outline-none focus:shadow-outline'}}) }}
                {{ form_errors(form.noteMax) }}
            </div>

            <button class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">Save</button>
            <a href="{{ path('app_back_office_quiz_index') }}" class="inline-block align-baseline font-bold text-sm text-blue-500 hover:text-blue-800 ml-4">Back to list</a>
        {{ form_end(form) }}
    </div>
{% endblock %}
