{% extends 'BackOffice/layout.html.twig' %}

{% block title %}Assessment: {{ quiz.titre }} - SkillPath{% endblock %}

{% block content %}
    <!-- Breadcrumb -->
    <nav class="mb-6">
        <ol class="flex items-center gap-2 text-sm font-medium">
            <li><a href="{{ path('app_back_office_quiz_index') }}" class="text-slate-400 dark:text-slate-500 hover:text-primary transition-colors">Centre d'Évaluation</a></li>
            <li class="text-slate-300 dark:text-slate-600">/</li>
            <li class="text-slate-700 dark:text-slate-300">{{ quiz.titre }}</li>
        </ol>
    </nav>

    <!-- Quiz Details Card -->
    <div class="glass-card rounded-2xl overflow-hidden mb-8 border border-white/5">
        <!-- Header -->
        <div class="gradient-primary px-8 py-7">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-2xl font-black text-white tracking-tight">{{ quiz.titre }}</h1>
                    <p class="text-white/70 text-sm mt-1 font-medium">{{ quiz.description }}</p>
                </div>
                <span class="px-4 py-2 bg-white/15 backdrop-blur-md text-white rounded-xl text-[10px] font-black uppercase tracking-widest border border-white/10">ID: #{{ quiz.id }}</span>
            </div>
        </div>

        <!-- Details Grid -->
        <div class="p-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
                <div class="text-center p-5 rounded-2xl bg-slate-50/50 dark:bg-white/[0.03] border border-slate-100 dark:border-white/5">
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Cours Cible</p>
                    {% if quiz.course is defined and quiz.course is not null %}
                        <p class="text-sm font-bold text-slate-900 dark:text-white">{{ quiz.course.title }}</p>
                    {% else %}
                        <p class="text-sm font-bold text-slate-400 italic">Non Assigné (Cours Supprimé)</p>
                    {% endif %}
                </div>
                <div class="text-center p-5 rounded-2xl bg-slate-50/50 dark:bg-white/[0.03] border border-slate-100 dark:border-white/5">
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Temps Alloué</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white">{{ quiz.duree }}<span class="text-xs font-bold text-slate-400 ml-1 uppercase">Min</span></p>
                </div>
                <div class="text-center p-5 rounded-2xl bg-slate-50/50 dark:bg-white/[0.03] border border-slate-100 dark:border-white/5">
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Rendement Max</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white">{{ quiz.noteMax }}<span class="text-xs font-bold text-slate-400 ml-1 uppercase">Pts</span></p>
                </div>
                <div class="text-center p-5 rounded-2xl bg-slate-50/50 dark:bg-white/[0.03] border border-slate-100 dark:border-white/5">
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Vecteurs</p>
                    <p class="text-2xl font-black text-slate-900 dark:text-white">{{ quiz.questions|length }}</p>
                </div>
                <div class="text-center p-5 rounded-2xl bg-slate-50/50 dark:bg-white/[0.03] border border-slate-100 dark:border-white/5">
                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2">Déploiement</p>
                    <p class="text-sm font-bold text-slate-900 dark:text-white">{{ quiz.dateCreation ? quiz.dateCreation|date('d M Y') : 'Hérité' }}</p>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-3 pt-6 border-t border-slate-200/60 dark:border-white/5">
                <a href="{{ path('app_back_office_quiz_index') }}" class="btn-secondary !py-2.5 !px-5 text-sm inline-flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                    Centrer
                </a>
                <a href="{{ path('app_back_office_quiz_edit', {'id': quiz.id}) }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-bold text-sm bg-amber-500/10 text-amber-600 dark:text-amber-400 hover:bg-amber-500/20 transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    Modifier
                </a>
                <form method="post" action="{{ path('app_back_office_quiz_delete', {'id': quiz.id}) }}" onsubmit="return confirm('Confirmer le démantèlement de cet actif d\'évaluation ? Cette action impactera toutes les données de performance liées.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                    <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-bold text-sm bg-red-500/10 text-red-500 dark:text-red-400 hover:bg-red-500/20 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Démanteler
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Questions Section -->
    <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-black text-slate-900 dark:text-white">Vecteurs d'Évaluation <span class="text-slate-400 font-medium ml-2">({{ quiz.questions|length }})</span></h2>
        <a href="{{ path('app_back_office_question_new', {'id_quiz': quiz.id}) }}" class="btn-primary inline-flex items-center gap-2 text-sm !py-2.5 !px-6 !rounded-xl">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Ajouter un Vecteur
        </a>
    </div>

    <div class="space-y-4">
        {% for question in quiz.questions %}
            <div class="glass-card rounded-2xl p-7 border border-white/5 hover:border-primary/20 transition-all group">
                <div class="flex items-start justify-between mb-6">
                    <div class="flex items-start gap-5 flex-1">
                        <span class="w-12 h-12 rounded-2xl gradient-primary flex items-center justify-center text-white text-base font-black flex-shrink-0 shadow-lg shadow-purple-500/20 group-hover:scale-105 transition-transform">{{ loop.index }}</span>
                        <div class="flex-1">
                            <h3 class="font-bold text-base text-slate-900 dark:text-white mb-2 leading-snug">{{ question.enonce }}</h3>
                            <div class="flex items-center gap-3">
                                <span class="badge badge-amber uppercase tracking-widest !text-[9px] font-black">{{ question.points }} Points de Rendement</span>
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Source Vecteur: Admin Local</span>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 flex-shrink-0">
                        <a href="{{ path('app_back_office_question_edit', {'id': question.id}) }}" class="p-2.5 rounded-xl text-slate-400 hover:text-amber-500 hover:bg-amber-500/10 transition-all border border-transparent hover:border-amber-500/20" title="Modifier">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        </a>
                        <form method="post" action="{{ path('app_back_office_question_delete', {'id': question.id}) }}" onsubmit="return confirm('Purger ce vecteur cible ?');" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ question.id) }}">
                            <button type="submit" class="p-2.5 rounded-xl text-slate-400 hover:text-red-500 hover:bg-red-500/10 transition-all border border-transparent hover:border-red-500/20" title="Démanteler">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Choices Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 ml-16">
                    {% set choices = {'A': question.choixA, 'B': question.choixB, 'C': question.choixC, 'D': question.choixD} %}
                    {% for letter, text in choices %}
                        {% if text %}
                        <div class="flex items-center gap-4 p-4 rounded-2xl {{ question.bonneReponse == letter ? 'bg-mint/5 border border-mint/20' : 'bg-slate-50/50 dark:bg-white/[0.03] border border-slate-100 dark:border-white/5' }}">
                            <span class="w-8 h-8 rounded-xl {{ question.bonneReponse == letter ? 'bg-mint text-white' : 'bg-slate-200/60 dark:bg-white/10 text-slate-500 dark:text-slate-400' }} flex items-center justify-center text-xs font-black flex-shrink-0 shadow-sm">{{ letter }}</span>
                            <span class="text-sm font-medium {{ question.bonneReponse == letter ? 'text-mint dark:text-mint-light font-bold' : 'text-slate-600 dark:text-slate-400' }}">{{ text }}</span>
                            {% if question.bonneReponse == letter %}
                                <div class="ml-auto w-5 h-5 rounded-full bg-mint flex items-center justify-center border border-white/20">
                                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                </div>
                            {% endif %}
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% else %}
            <div class="glass-card rounded-3xl p-16 text-center border border-dashed border-slate-200 dark:border-white/10">
                <div class="flex flex-col items-center gap-4">
                    <div class="w-20 h-20 rounded-3xl bg-slate-50 dark:bg-white/5 flex items-center justify-center text-slate-200 dark:text-slate-700">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                        <p class="text-base font-bold text-slate-400 dark:text-slate-500">Aucun vecteur identifié pour cette évaluation.</p>
                        <p class="text-sm text-slate-500 dark:text-slate-600 mt-1">Statut opérationnel: En attente d'injection de vecteur.</p>
                    </div>
                    <a href="{{ path('app_back_office_question_new', {'id_quiz': quiz.id}) }}" class="mt-4 text-sm font-black text-primary hover:text-primary-dark transition-colors uppercase tracking-widest">Construire une Source de Vecteur →</a>
                </div>
            </div>
        {% endfor %}
    </div>

    <!-- Results Section -->
    {% if quiz.resultats|length > 0 %}
    <div class="mt-16">
        <h2 class="text-xl font-black text-slate-900 dark:text-white mb-8">Journaux de Performance <span class="text-slate-400 font-medium ml-2">({{ quiz.resultats|length }})</span></h2>
        <div class="glass-card rounded-2xl overflow-hidden border border-white/5">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="bg-slate-50/50 dark:bg-white/2 border-b border-slate-100 dark:border-white/5">
                            <th class="text-left px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">ID Membre</th>
                            <th class="text-left px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Score de Rendement</th>
                            <th class="text-left px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Statut</th>
                            <th class="text-left px-8 py-5 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500">Timestamp du Log</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-white/5">
                    {% for resultat in quiz.resultats %}
                        {% set pct = resultat.noteMax > 0 ? (resultat.score / resultat.noteMax * 100)|round : 0 %}
                        <tr class="hover:bg-slate-50/30 dark:hover:bg-white/[0.01] transition-colors">
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-3">
                                    {% if resultat.etudiant is defined and resultat.etudiant is not null %}
                                        <div class="w-8 h-8 rounded-lg gradient-primary flex items-center justify-center text-white text-[10px] font-black">{{ resultat.etudiant.username|first|upper }}</div>
                                        <span class="font-bold text-sm text-slate-900 dark:text-white">{{ resultat.etudiant.username }}</span>
                                    {% else %}
                                        <div class="w-8 h-8 rounded-lg bg-slate-300 flex items-center justify-center text-white text-[10px] font-black">?</div>
                                        <span class="font-bold text-sm text-slate-400 italic">Unknown (User Deleted)</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-2">
                                    <span class="font-black text-sm text-slate-900 dark:text-white">{{ resultat.score }}</span>
                                    <span class="text-slate-400 text-xs font-bold">/ {{ resultat.noteMax }}</span>
                                    <div class="ml-2 px-2 py-0.5 rounded-md bg-slate-100 dark:bg-white/5 text-[10px] font-black text-slate-500">{{ pct }}%</div>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                {% if pct >= 50 %}
                                    <span class="badge badge-green !text-[9px] font-black uppercase tracking-widest">Validé</span>
                                {% else %}
                                    <span class="badge badge-red !text-[9px] font-black uppercase tracking-widest">Échoué</span>
                                {% endif %}
                            </td>
                            <td class="px-8 py-5 text-xs text-slate-400 font-medium">
                                {{ resultat.datePassage|date('d M, H:i') }}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {% endif %}
{% endblock %}
