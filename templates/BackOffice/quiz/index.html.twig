{% extends 'base.html.twig' %}

{% block title %}Quiz Index{% endblock %}

{% block body %}
    <div class="container mx-auto p-4">
        <h1 class="text-2xl font-bold mb-4">Quiz List</h1>

        <a href="{{ path('app_back_office_quiz_new') }}" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded mb-4 inline-block">Create new</a>

        <div class="overflow-x-auto relative shadow-md sm:rounded-lg">
            <table class="w-full text-sm text-left text-gray-400">
                <thead class="text-xs text-gray-400 uppercase bg-gray-900">
                    <tr>
                        <th scope="col" class="py-3 px-6">Id</th>
                        <th scope="col" class="py-3 px-6">Titre</th>
                        <th scope="col" class="py-3 px-6">Description</th>
                        <th scope="col" class="py-3 px-6">Duree</th>
                        <th scope="col" class="py-3 px-6">Note Max</th>
                        <th scope="col" class="py-3 px-6">Date Creation</th>
                        <th scope="col" class="py-3 px-6">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for quiz in quizzes %}
                    <tr class="bg-gray-800 border-b border-gray-700 hover:bg-gray-700">
                        <td class="py-4 px-6 text-white">{{ quiz.id }}</td>
                        <td class="py-4 px-6 text-white">{{ quiz.titre }}</td>
                        <td class="py-4 px-6 text-gray-300">{{ quiz.description }}</td>
                        <td class="py-4 px-6 text-gray-300">{{ quiz.duree }} min</td>
                        <td class="py-4 px-6 text-gray-300">{{ quiz.noteMax }}</td>
                        <td class="py-4 px-6 text-gray-300">{{ quiz.dateCreation ? quiz.dateCreation|date('Y-m-d H:i:s') : '' }}</td>
                        <td class="py-4 px-6">
                            <a href="{{ path('app_back_office_quiz_show', {'id': quiz.id}) }}" class="font-medium text-blue-400 hover:underline">Show</a>
                            <a href="{{ path('app_back_office_quiz_edit', {'id': quiz.id}) }}" class="font-medium text-blue-400 hover:underline ml-2">Edit</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="py-4 px-6 text-center text-gray-400">No records found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
