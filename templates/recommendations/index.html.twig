{% extends 'base.html.twig' %}

{% block title %}SkillPath - Recommandations Personnalisées{% endblock %}

{% block body %}
<div class="relative min-h-screen mesh-light dark:mesh-dark overflow-hidden">
    <!-- Premium Header -->
    <nav class="glass sticky top-0 z-[100] px-6 lg:px-12 py-4 shadow-sm backdrop-blur-md">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="{{ path('app_home') }}" class="flex items-center gap-3 group transition-transform hover:scale-105">
                <div class="w-10 h-10 gradient-primary rounded-xl flex items-center justify-center shadow-lg shadow-purple-500/20">
                    <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-6 h-6 invert brightness-0">
                </div>
                <span class="text-2xl font-black tracking-tight text-slate-900 dark:text-white">Skill<span class="gradient-text">Path</span></span>
            </a>

            <div class="flex items-center gap-6">
                <a href="{{ path('app_event_index') }}" class="text-xs font-black uppercase tracking-widest text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Événements</a>
                <a href="{{ path('front_course_index') }}" class="text-xs font-black uppercase tracking-widest text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Catalogue</a>
                <a href="{{ path('app_home') }}" class="text-xs font-black uppercase tracking-widest text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-primary-light transition-colors">Accueil</a>
                
                {% if app.user %}
                    <!-- Notifications -->
                    <div class="relative">
                        <button onclick="fetchNotifications()" class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-white/5 flex items-center justify-center text-slate-400 hover:text-primary transition-all relative">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                            <span id="notification-count" class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-black rounded-full flex items-center justify-center border-2 border-white dark:border-slate-900 hidden">0</span>
                        </button>

                        <!-- Dropdown -->
                        <div id="notification-dropdown" class="absolute right-0 mt-3 w-80 glass dark:bg-slate-900/90 rounded-2xl shadow-2xl border border-white/10 overflow-hidden hidden z-[110] animate-scale-in">
                            <div class="p-4 border-b border-slate-50 dark:border-white/5 bg-slate-50/50 dark:bg-white/5">
                                <h3 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">Notifications</h3>
                            </div>
                            <div id="notification-list" class="max-h-96 overflow-y-auto custom-scrollbar">
                                <!-- Dynamic content -->
                            </div>
                        </div>
                    </div>
                {% endif %}

                <div class="h-8 w-[1px] bg-slate-200 dark:bg-slate-800"></div>
                {% if app.user %}
                    <a href="{{ path('app_logout') }}" class="text-xs font-black uppercase tracking-widest text-red-500 hover:text-red-600 transition-colors">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_user_login') }}" class="text-xs font-black uppercase tracking-widest text-primary hover:text-primary-light transition-colors">Connexion</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <!-- Header / Hero pour recommendations -->
    <section class="max-w-7xl mx-auto px-6 lg:px-12 pt-20 pb-16">
        <div class="text-center animate-fade-up">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/8 dark:bg-primary/15 border border-primary/15 dark:border-primary/20 mb-8">
                <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                <span class="text-[11px] font-bold text-primary dark:text-primary-light uppercase tracking-widest">SkillPath IA</span>
            </div>
            <h1 class="text-4xl lg:text-6xl font-[900] text-slate-900 dark:text-white mb-6 tracking-tight">
                Recommandé pour <span class="gradient-text">Vous</span>
            </h1>
            <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto font-medium leading-relaxed">
                Notre intelligence artificielle a analysé votre profil, votre niveau et vos objectifs pour vous proposer le parcours d'apprentissage idéal.
            </p>
            
            <!-- Budget Filter Form -->
            <form method="GET" action="{{ path('app_recommendations') }}" class="mt-8 flex items-center justify-center gap-4 max-w-sm mx-auto">
                <input type="number" name="budget" value="{{ budget }}" placeholder="Votre Budget Max (DT)" class="form-input !bg-white/5 !border-slate-200 dark:!border-white/10 focus:!border-primary !text-slate-900 dark:!text-white w-full h-12 px-4 rounded-xl transition-all" step="0.01">
                <button type="submit" class="btn-primary !h-12 !px-6 rounded-xl flex items-center gap-2 shadow-lg shadow-primary/20">
                    Filtrer
                </button>
            </form>
        </div>
    </section>

    <!-- Results Section -->
    <section class="max-w-7xl mx-auto px-6 lg:px-12 pb-28">
        <div class="flex justify-end items-center mb-8">
            <span class="text-xs font-black text-slate-400 uppercase tracking-widest">{{ recommendations|length }} Cours Trouvés</span>
        </div>

        {% if recommendations is empty %}
            <div class="py-24 text-center glass rounded-[2.5rem] border-2 border-dashed border-slate-200/50 dark:border-white/10">
                <div class="w-16 h-16 mx-auto bg-slate-100 dark:bg-white/5 rounded-2xl flex items-center justify-center mb-6">
                    <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3 class="text-2xl font-black text-slate-900 dark:text-white mb-4">Aucune recommandation trouvée</h3>
                <p class="text-slate-500 font-medium mb-8">Essayez d'ajuster votre budget ou de compléter votre profil pour aider notre IA.</p>
                <a href="{{ path('app_home') }}" class="btn-secondary !px-8 !py-4">Retour à l'accueil</a>
            </div>
        {% else %}
            <div class="space-y-8 animate-fade-up delay-100">
                {% for item in recommendations %}
                    {% set course = item.course %}
                    <div class="group relative bg-white dark:bg-[#121622] rounded-[2.5rem] border border-slate-200/50 dark:border-white/5 overflow-hidden hover:border-primary/30 transition-all duration-500 flex flex-col md:flex-row shadow-xl shadow-slate-200/20 dark:shadow-none items-stretch">
                        
                        {# Course Image #}
                        <div class="w-full md:w-72 h-48 md:h-auto relative overflow-hidden shrink-0">
                            {% if course.image %}
                                <img src="{{ asset('uploads/modules/' ~ course.image) }}" alt="{{ course.title }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                            {% else %}
                                <div class="w-full h-full gradient-primary opacity-20 flex items-center justify-center text-white text-4xl font-black">
                                    {{ course.title|first }}
                                </div>
                            {% endif %}
                        </div>

                        {# Course Info #}
                        <div class="flex-grow p-8 flex flex-col justify-between">
                            <div>
                                <div class="flex flex-wrap items-center gap-2 mb-4">
                                    <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-slate-200 dark:border-white/10 text-slate-600 dark:text-slate-300">{{ course.category|default('General') }}</span>
                                    {% for reason in item.reasons %}
                                        <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-primary/30 bg-primary/10 text-primary flex items-center gap-1 shadow-sm shadow-primary/10">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                            {{ reason }}
                                        </span>
                                    {% endfor %}
                                    <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-slate-200 dark:border-white/10 text-slate-500 ml-auto">{{ course.level }}</span>
                                </div>

                                <h2 class="text-2xl font-black mb-3 text-slate-900 dark:text-white group-hover:text-primary transition-colors">
                                    <a href="{{ path('front_course_show', {id: course.id}) }}">{{ course.title }}</a>
                                </h2>
                                <p class="text-slate-500 dark:text-slate-400 text-sm line-clamp-3 mb-6 font-medium">{{ course.description }}</p>

                                <div class="flex items-center gap-8 text-[10px] font-black uppercase tracking-widest text-slate-400">
                                    <div class="flex items-center gap-2">
                                        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                                        <span>{{ course.modules|length }} Chapitres</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <svg class="w-3.5 h-3.5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        <span>{{ course.duration|default('120') }} min</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-primary ml-auto">
                                        <span class="text-sm font-black">{{ course.price|default('0.00') }} DT</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-8 flex items-center justify-between border-t border-slate-100 dark:border-white/5 pt-6">
                                <div class="flex items-center gap-2 text-slate-500">
                                    <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                    <span class="text-xs font-bold">{{ course.rating|default('N/A') }} / 5</span>
                                </div>
                                <form action="{{ path('front_course_enroll', {id: course.id}) }}" method="POST">
                                    <button type="submit" class="btn-primary !px-6 !py-3 !text-xs flex items-center gap-2 shadow-lg shadow-primary/20 group-hover:scale-105 transition-transform">
                                        S'inscrire
                                        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}
