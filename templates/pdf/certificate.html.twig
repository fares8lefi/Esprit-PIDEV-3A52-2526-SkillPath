<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Certificat - {{ course.title }}</title>
    <style>
        body { font-family: 'Helvetica', Arial, sans-serif; text-align: center; color: #333; margin: 0; padding: 20px; }
        .certificate-container { border: 15px solid #1E88E5; padding: 50px; position: relative; border-radius: 10px; background-color: #fff; }
        .bg-pattern { position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.05; background-image: repeating-linear-gradient(45deg, #1E88E5 0, #1E88E5 1px, transparent 1px, transparent 50%; background-size: 20px 20px; z-index: -1; }
        .header { margin-bottom: 40px; }
        .logo { font-size: 32px; font-weight: bold; color: #1E88E5; letter-spacing: 2px; text-transform: uppercase; }
        .title { font-size: 48px; color: #1F2937; margin: 30px 0; text-transform: uppercase; letter-spacing: 5px; }
        .subtitle { font-size: 20px; color: #6B7280; font-style: italic; margin-bottom: 30px; }
        .student-name { font-size: 42px; font-weight: bold; color: #1E88E5; margin: 20px 0; text-decoration: underline; }
        .course-info { font-size: 22px; color: #374151; margin: 30px 0; line-height: 1.5; }
        .course-title { font-weight: bold; font-size: 26px; display: block; margin-top: 10px; color: #111827; }
        .footer { margin-top: 60px; display: table; width: 100%; }
        .footer-left { display: table-cell; text-align: left; vertical-align: bottom; width: 50%; }
        .footer-right { display: table-cell; text-align: right; vertical-align: bottom; width: 50%; }
        .signature { border-top: 2px solid #9CA3AF; width: 250px; display: inline-block; padding-top: 10px; font-size: 16px; color: #4B5563; }
        .seal { width: 120px; height: 120px; border-radius: 50%; border: 4px solid #F59E0B; margin: 0 auto; line-height: 120px; color: #F59E0B; font-weight: bold; font-size: 14px; position: absolute; bottom: 50px; left: 50%; transform: translateX(-50%); box-shadow: 0 0 10px rgba(245, 158, 11, 0.3); }
        .cert-info { font-size: 12px; color: #9CA3AF; text-align: left; margin-top: 50px; }
    </style>
</head>
<body>
    <div class="certificate-container">
        <div class="bg-pattern"></div>
        <div class="header">
            <div class="logo">SkillPath</div>
        </div>

        <h1 class="title">Certificat de Réussite</h1>
        <p class="subtitle">Ce document certifie formelnellement que</p>
        
        <div class="student-name">{{ user.username }}</div>
        
        <div class="course-info">
            a terminé avec succès tous les modules et évaluations du cours intitulé :
            <span class="course-title">{{ course.title }}</span>
        </div>

        <div class="footer">
            <div class="footer-left">
                <div class="signature">
                    <strong>Directeur des Études</strong><br>
                    SkillPath Academy
                </div>
            </div>
            <div class="footer-right">
                <div class="signature" style="text-align: center;">
                    <strong>Fait le :</strong> {{ date }}<br>
                </div>
            </div>
        </div>

        <div class="seal">CERTIFIÉ</div>

        <div class="cert-info">
            ID Certificat: {{ certificate.certCode }}<br>
            Vérifiable sur: www.skillpath.com/verify/{{ certificate.certCode }}
        </div>
    </div>
</body>
</html>
