includes:
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - bin/
        - config/
        - public/
        - src/
        - tests/
    excludePaths:
        - src/Kernel.php
    reportUnmatchedIgnoredErrors: false
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
